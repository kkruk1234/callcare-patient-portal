@app.get("/", response_class=HTMLResponse)
async def home() -> str:
    rows = []
    for p in _packet_files():
        try:
            d = _load_json(p)
        except Exception:
            continue

        pid = _safe_str(d.get("packet_id") or p.stem)
        created = _safe_str(d.get("created_at"))
        meta = _load_meta(pid)
        patient_ctx = _patient_context_for_packet(pid, d, meta)

        status = _safe_str(meta.get("status") or "active")
        prescription = _safe_str(meta.get("prescription_status") or "under review")
        note_sent = _safe_str(meta.get("note_sent") or "to be mailed")
        patient_name = _safe_str(patient_ctx.get("patient_name")) or "Unknown patient"
        chart_number = _safe_str(patient_ctx.get("chart_number")) or "Not linked"

        rows.append(
            f"<tr>"
            f"<td><a href='/packet/{_html_escape(pid)}'>{_html_escape(patient_name)}</a></td>"
            f"<td>{_html_escape(chart_number)}</td>"
            f"<td>{_html_escape(created)}</td>"
            f"<td>{_html_escape(status)}</td>"
            f"<td>{_html_escape(prescription)}</td>"
            f"<td>{_html_escape(note_sent)}</td>"
            f"</tr>"
        )

    body = "".join(rows) or "<tr><td colspan='6'>No routed review packets yet.</td></tr>"

    return f"""
    <html>
      <head>
        <title>CallCare Physician Portal</title>
        <style>
          body {{ font-family: Arial, sans-serif; margin: 24px; }}
          table {{ border-collapse: collapse; width: 100%; }}
          th, td {{ border: 1px solid #ccc; padding: 8px; text-align: left; vertical-align: top; }}
          th {{ background: #f5f5f5; }}
          a {{ text-decoration: none; color: #0a58ca; }}
        </style>
      </head>
      <body>
        <h1>CallCare Physician Portal</h1>
        <p>Routed review packets from telephone encounters.</p>
        <table>
          <thead>
            <tr>
              <th>Patient</th>
              <th>Chart #</th>
              <th>Created</th>
              <th>Status</th>
              <th>Prescription</th>
              <th>Note Sent</th>
            </tr>
          </thead>
          <tbody>
            {body}
          </tbody>
        </table>
      </body>
    </html>
    """


@app.get("/packet/{packet_id}", response_class=HTMLResponse)
async def packet_detail(packet_id: str) -> str:
    path = _packet_path(packet_id)
    if not path.exists():
        raise HTTPException(status_code=404, detail="Packet not found")

    d = _load_json(path)
    meta = _load_meta(packet_id)
    patient_ctx = _patient_context_for_packet(packet_id, d, meta)

    if _safe_str(meta.get("status")) == "active":
        meta["status"] = "under review"
        _save_meta(packet_id, meta)

    note_text = _safe_str(d.get("note_text"))
    evidence = d.get("evidence", []) or []
    first_line_med = _extract_first_line_medication(note_text)

    ev_html = ""
    for i, ev in enumerate(evidence, 1):
        title = _html_escape(ev.get("title"))
        source = _html_escape(ev.get("source"))
        url = _html_escape(ev.get("url"))
        accessed = _html_escape(ev.get("accessed"))
        ev_html += (
            f"<h4>Evidence {i}</h4>"
            f"<p><strong>Title:</strong> {title}<br>"
            f"<strong>Source:</strong> {source}<br>"
            f"<strong>Accessed:</strong> {accessed}<br>"
            f"<strong>URL:</strong> <a href='{url}' target='_blank'>{url}</a></p>"
        )

    if not ev_html:
        ev_html = "<p>No evidence attached.</p>"

    status = _html_escape(meta.get("status"))
    prescription_status = _html_escape(meta.get("prescription_status"))
    note_sent = _html_escape(meta.get("note_sent"))

    patient_name = _safe_str(patient_ctx.get("patient_name")) or "Unknown patient"
    chart_number = _safe_str(patient_ctx.get("chart_number")) or "Not linked"
    dob = _safe_str(patient_ctx.get("date_of_birth"))
    sex_at_birth = _safe_str(patient_ctx.get("sex_at_birth"))
    chief_complaint = _safe_str(patient_ctx.get("chief_complaint"))
    phone_number = _safe_str(patient_ctx.get("phone_number"))
    email = _safe_str(patient_ctx.get("email"))

    conditions_html = _render_list_items(
        patient_ctx.get("conditions") or [],
        ["condition_name", "status"],
        "No past medical history on file.",
    )
    allergies_html = _render_list_items(
        patient_ctx.get("allergies") or [],
        ["allergen", "reaction", "severity"],
        "No allergy data on file.",
    )
    social_html = _render_list_items(
        patient_ctx.get("social_history") or [],
        ["domain", "value_text"],
        "No social history on file.",
    )
    pharmacy_html = _render_pharmacy(patient_ctx.get("preferred_pharmacy") or {})

    return f"""
    <html>
      <head>
        <title>Packet {_html_escape(packet_id)}</title>
        <style>
          body {{ font-family: Arial, sans-serif; margin: 24px; }}
          pre {{ white-space: pre-wrap; border: 1px solid #ccc; padding: 12px; background: #fafafa; }}
          textarea {{ width: 100%; min-height: 420px; font-family: monospace; font-size: 14px; }}
          a {{ text-decoration: none; color: #0a58ca; }}
          .meta {{ margin-bottom: 18px; }}
          .buttons form {{ display: inline-block; margin-right: 10px; margin-bottom: 10px; }}
          button {{ padding: 8px 12px; }}
          .section {{ margin-top: 22px; }}
        </style>
      </head>
      <body>
        <p><a href="/">← Back to inbox</a></p>
        <h1>{_html_escape(patient_name)}</h1>

        <div class="meta">
          <p><strong>Chart #:</strong> {_html_escape(chart_number)}</p>
          <p><strong>Date of Birth:</strong> {_html_escape(dob)}</p>
          <p><strong>Sex at Birth:</strong> {_html_escape(sex_at_birth)}</p>
          <p><strong>Phone:</strong> {_html_escape(phone_number)}</p>
          <p><strong>Email:</strong> {_html_escape(email)}</p>
          <p><strong>Chief Complaint:</strong> {_html_escape(chief_complaint)}</p>
          <p><strong>Created:</strong> {_html_escape(d.get('created_at'))}</p>
          <p><strong>Session ID:</strong> {_html_escape(d.get('session_id'))}</p>
          <p><strong>Call SID:</strong> {_html_escape(meta.get('call_sid'))}</p>
          <p><strong>Pathway:</strong> {_html_escape(d.get('pathway_id'))}</p>
          <p><strong>Status:</strong> {status}</p>
          <p><strong>Prescription:</strong> {prescription_status}</p>
          <p><strong>Note Sent:</strong> {note_sent}</p>
          <p><strong>First-line prescription:</strong> {_html_escape(first_line_med or "Not found in note")}</p>
        </div>

        <div class="section">
