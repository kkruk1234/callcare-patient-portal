@app.get("/packet/{packet_id}/full-text", response_class=HTMLResponse)
async def full_text(packet_id: str) -> str:
    packet_path = _packet_path(packet_id)
    if not packet_path.exists():
        raise HTTPException(status_code=404, detail="Packet not found")

    call_log = _load_call_transcript_for_packet(packet_id)
    transcript = call_log.get("transcript", []) if isinstance(call_log, dict) else []

    summary = ""
    if transcript:
        for turn in reversed(transcript):
            if _safe_str(turn.get("role")).lower() == "assistant":
                summary = _safe_str(turn.get("text"))
                break

    transcript_for_display = list(transcript)
    if summary and transcript_for_display:
        last_turn = transcript_for_display[-1]
        if _safe_str(last_turn.get("role")).lower() == "assistant" and _safe_str(last_turn.get("text")) == summary:
            transcript_for_display = transcript_for_display[:-1]

    transcript_html = ""
    for turn in transcript_for_display:
        role = _html_escape(turn.get("role"))
        text = _html_escape(turn.get("text"))
        transcript_html += f"<p><strong>{role}:</strong> {text}</p>"

    if not transcript_html:
        transcript_html = "<p>No call transcript available for this packet.</p>"

    return f"""
    <html>
      <head>
        <title>Full Text {_html_escape(packet_id)}</title>
        <style>
          body {{ font-family: Arial, sans-serif; margin: 24px; }}
          a {{ text-decoration: none; color: #0a58ca; }}
        </style>
      </head>
      <body>
        <p><a href="/packet/{_html_escape(packet_id)}">← Back to packet</a></p>
        <h1>Full Text for Packet {_html_escape(packet_id)}</h1>

        <h2>Call Transcript</h2>
        {transcript_html}

        <h2>Spoken Summary to Patient</h2>
        <p>{_html_escape(summary or "No patient summary available.")}</p>
      </body>
    </html>
    """


@app.post("/packet/{packet_id}/update")
async def update_note(packet_id: str, note_text: str = Form(...)) -> RedirectResponse:
    path = _packet_path(packet_id)
    if not path.exists():
        raise HTTPException(status_code=404, detail="Packet not found")

    d = _load_json(path)
    d["note_text"] = _safe_str(note_text)
    _save_json(path, d)

    meta = _load_meta(packet_id)
    if _safe_str(meta.get("status")) == "active":
        meta["status"] = "under review"
        _save_meta(packet_id, meta)

    return RedirectResponse(url=f"/packet/{packet_id}", status_code=303)


@app.post("/packet/{packet_id}/sign")
async def sign_note(packet_id: str) -> RedirectResponse:
    path = _packet_path(packet_id)
    if not path.exists():
        raise HTTPException(status_code=404, detail="Packet not found")

    meta = _load_meta(packet_id)
    meta["status"] = "completed"
    _save_meta(packet_id, meta)

    return RedirectResponse(url=f"/packet/{packet_id}", status_code=303)


@app.post("/packet/{packet_id}/prescribe")
async def send_prescription(packet_id: str) -> RedirectResponse:
    path = _packet_path(packet_id)
    if not path.exists():
        raise HTTPException(status_code=404, detail="Packet not found")

    meta = _load_meta(packet_id)
    meta["prescription_status"] = "sent"
    _save_meta(packet_id, meta)

    return RedirectResponse(url=f"/packet/{packet_id}", status_code=303)


@app.post("/packet/{packet_id}/note-sent/{mode}")
async def note_sent(packet_id: str, mode: str) -> RedirectResponse:
    path = _packet_path(packet_id)
    if not path.exists():
        raise HTTPException(status_code=404, detail="Packet not found")

    normalized = _safe_str(mode).lower()
    if normalized not in {"emailed", "to-be-mailed", "to_be_mailed", "to be mailed"}:
        raise HTTPException(status_code=400, detail="Invalid note-sent mode")

    final_mode = "emailed" if normalized == "emailed" else "to be mailed"

    meta = _load_meta(packet_id)
    meta["note_sent"] = final_mode
    _save_meta(packet_id, meta)

    return RedirectResponse(url=f"/packet/{packet_id}", status_code=303)
