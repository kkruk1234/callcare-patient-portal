    print("\n--- CLINICAL NOTE (SOAP) ---")
    soap = getattr(note, "soap", "") or ""
    soap = _clean_soap(soap, state)
    soap = _strip_snippets_block(soap)
    # CallCare: pregnancy dedupe (anchor)
    # Remove standalone extra pregnancy sentences without changing spacing.
    # If Subjective already mentions pregnancy, drop any leftover standalone 'She is ... pregnant.'
    if re.search(r"(?im)^S:\n.*\bpregnan", soap):
        pass
    # CallCare: SOAP spacing fix v3 (ensure blank line BETWEEN sections)
    # 1) Put headers on their own lines if they appear inline
    soap = soap.replace(' S:', '\nS:')
    soap = soap.replace(' O:', '\nO:')
    soap = soap.replace(' A:', '\nA:')
    soap = soap.replace(' P:', '\nP:')
    # 2) Normalize header line to: HEADER + newline
    soap = re.sub(r'(?m)^S:\s*', 'S:\n', soap)
    soap = re.sub(r'(?m)^O:\s*', 'O:\n', soap)
    soap = re.sub(r'(?m)^A:\s*', 'A:\n', soap)
    soap = re.sub(r'(?m)^P:\s*', 'P:\n', soap)
    # 3) Ensure exactly ONE blank line before each new header (except the first S:)
    soap = re.sub(r'(?m)\n(?=O:\n)', '\n\n', soap)
    soap = re.sub(r'(?m)\n(?=A:\n)', '\n\n', soap)
    soap = re.sub(r'(?m)\n(?=P:\n)', '\n\n', soap)
    # 4) Collapse any accidental 3+ newlines
    soap = re.sub(r'\n{3,}', '\n\n', soap)
    age_val = getattr(state, 'age', None)
    if age_val is None:
        sx = getattr(state, 'symptoms', None) or {}
        if isinstance(sx, dict):
