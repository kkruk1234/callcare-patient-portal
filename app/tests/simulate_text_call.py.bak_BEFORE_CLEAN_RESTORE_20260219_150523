def _pick_handler(sm):
    for name in ("process_answer", "process", "process_input", "handle_answer", "advance_state"):
        fn = getattr(sm, name, None)
        if callable(fn):
            return fn, name
    raise RuntimeError(
        "No input handler found in app/clinical/state_machine.py. "
        "Expected one of: process_answer, process, process_input, handle_answer, advance_state."
    )


def _pick_prompt(sm):
    for name in ("next_prompt", "get_prompt", "prompt"):
        fn = getattr(sm, name, None)
        if callable(fn):
            return fn, name
    raise RuntimeError(
        "No prompt function found in app/clinical/state_machine.py. "
        "Expected next_prompt() (recommended) or get_prompt()/prompt()."
    )


def _try_natural_question(raw: str, state: CallState) -> str:
    """
    Try to naturalize the question via LLM (if llm_dialogue exists).
    Fall back to raw prompt on any error (rate limits, missing key, etc).
    """
    try:
        llm = importlib.import_module("app.clinical.llm_dialogue")
        make_natural_question = getattr(llm, "make_natural_question")
        return make_natural_question(raw, state=state)
    except Exception:
        return raw


def _extract_evidence(note, state: CallState):
    """
    Evidence can exist in multiple places depending on the build:
    - note.evidence (preferred)
    - state.decision.evidence (common older behavior)
    - state.evidence / state.evidence_used (fallback)
    """
    ev = getattr(note, "evidence", None)
    if ev:
        return list(ev)

    decision = getattr(state, "decision", None)
    if decision is not None:
        dev = getattr(decision, "evidence", None)
        if dev:
            return list(dev)

    for attr in ("evidence", "evidence_used"):
        sev = getattr(state, attr, None)
        if sev:
            return list(sev)

    return []


# CallCare: evidence printing helpers (citations-only, min-3 for urinary)
def _cc_cc_lower(state):
    cc = ""
    try:
        sx = getattr(state, "symptoms", None) or {}
        if isinstance(sx, dict):
            cc = sx.get("chief_complaint") or sx.get("chief") or ""
    except Exception:
        pass
    try:
        if not cc:
            cc = (getattr(state, "chief_complaint", "") or "")
    except Exception:
        pass
    return str(cc).lower()

def _cc_is_urinary(state):
    cc = _cc_cc_lower(state)
    keys = ("dysuria","burning when i pee","burns when i pee","painful urination",
            "uti","cystitis","urinary tract","urinary","urine","pee","peeing","bladder","urethra")
    return any(k in cc for k in keys)

def _cc_should_drop(state, url, title):
    cc = _cc_cc_lower(state)
    urinary = _cc_is_urinary(state)
    if not urinary:
        return False
    allow_stones = ("stone" in cc) or ("stones" in cc) or ("renal colic" in cc) or ("colicky" in cc)
    allow_incont = ("incontinence" in cc) or ("leak" in cc) or ("leaking" in cc)
    blob = (str(url or "") + " " + str(title or "")).lower()
    if "burn-evaluation" in blob or "burn evaluation" in blob or "burns-and-scalds" in blob or "/burns" in blob:
        return True
    if "oedema" in blob or "edema" in blob or "swollen ankles" in blob:
        return True
    if ("urinaryincontinence" in blob or "urinary incontinence" in blob) and not allow_incont:
        return True
    if ("bladder-stones" in blob or "bladder stones" in blob) and not allow_stones:
        return True
    return False

def _cc_norm_item(e):
    if isinstance(e, dict):
        title = (e.get("title") or "").strip()
        source = (e.get("source") or "").strip()
        url = (e.get("url") or "").strip()
    else:
        title = (getattr(e, "title", "") or "").strip()
        source = (getattr(e, "source", "") or "").strip()
        url = (getattr(e, "url", "") or "").strip()
    url_to_print = url
    if (not url_to_print) and (source.startswith("http://") or source.startswith("https://")):
        url_to_print = source
    return (title or source or "Source"), url_to_print

def _print_evidence(evidence_items, state=None, note_text=None):
    # No gating. No filtering. Print whatever is present.
    # evidence_items may be None, list[dict], or list[obj] with attributes.
    if not evidence_items:
        print("\n--- EVIDENCE USED ---")
        print("(none)")
        return

    def _get(e, *keys):
        # supports dict or object attributes
        if isinstance(e, dict):
            for k in keys:
                v = e.get(k)
                if v:
                    return v
            return ""
        for k in keys:
            v = getattr(e, k, None)
            if v:
                return v
        return ""

    print("\n--- EVIDENCE USED ---")
    for e in evidence_items:
        title = (_get(e, "title", "name") or "").replace("\n", " ").strip()
        url = (_get(e, "url", "source_url", "link", "href") or "").strip()
        accessed = (_get(e, "accessed_at", "accessed", "retrieved_at", "fetched_at") or "").strip()

        # Always print at least the title
        if title and url and accessed:
            print(f"- {title}. Accessed {accessed}. {url}")
        elif title and url:
            print(f"- {title}. {url}")
        elif title:
            print(f"- {title}")
        else:
            # last resort: show something rather than dropping it
            s = str(e).replace("\n", " ").strip()
            print(f"- {s[:200]}")

    # normalize + filter + dedupe
    seen = set()
    final = []
    for e in evidence_items:
        label, url = _cc_norm_item(e)
        if not url or url in seen:
            continue
        if state is not None and _cc_should_drop(state, url, label):
            continue
        seen.add(url)
        final.append((label, url))

    # --- CallCare: evidence sorting (deterministic, relevance-first) ---
    def _cc_tokens_for_sort(state):
        toks = []
        try:
            pid = str(getattr(state, "pathway_id", "") or "").lower().replace("_", " ")
            if pid:
                toks.append(pid)
                for t in re.split(r"[^a-z0-9]+", pid):
                    if len(t) >= 4:
                        toks.append(t)
        except Exception:
            pass
        try:
            cc = _cc_cc_lower(state)
            if cc:
                toks.append(cc)
                words = [w for w in re.split(r"[^a-z0-9]+", cc) if len(w) >= 4]
                toks += words
                for i in range(len(words)-1):
                    toks.append(words[i] + " " + words[i+1])
        except Exception:
            pass
        # de-dupe preserve order
        seen2 = set()
        out2 = []
        for t in toks:
            t = (t or "").strip()
            if t and t not in seen2:
                seen2.add(t)
                out2.append(t)
        return out2[:18]

    def _cc_evidence_score(title, url, state):
        t = (title or "").lower()
        u = (url or "").lower()
        blob = t + " " + u

        score = 0

        # Strong relevance: pathway/CC token matches
        toks = _cc_tokens_for_sort(state) if state is not None else []
        if toks:
            if any(tok in blob for tok in toks[:3]):   # phrase-level first
                score += 50
            if any(tok in blob for tok in toks[3:]):
                score += 10

        # Prefer condition/guideline pages
        if "nhs.uk/conditions/" in u:
            score += 10
        if "guideline" in blob or "ckS" in blob.lower() or "nice" in blob:
            score += 6

        # Penalize drift magnets
        if "medlineplus.gov/genetics/" in u:
            score -= 30
        if "syndrome" in t or "congenital" in t:
            score -= 12
        # Adult patient: penalize "in children"
        try:
            age = getattr(state, "age", None)
            is_adult = isinstance(age, (int,float)) and age >= 18
        except Exception:
            is_adult = False
        if is_adult and ("in children" in t or "children" in t or "pediatric" in t or "paediatric" in t):
            score -= 20

        # Mild penalty for generic hubs
        if any(x in t for x in ["disorders", "injuries", "bones, joints and muscles"]):
            score -= 3

        return score

    try:
        if state is not None and final:
            final.sort(key=lambda tu: (_cc_evidence_score(tu[0], tu[1], state), tu[1]), reverse=True)
    except Exception:
        pass

    # --- CALLCARE_EVIDENCE_MIN3_ALL_V1 ---
    # Top-up to 3 citations for ALL complaints (not just urinary), and protect pathway-relevant source.
    def _cc_pid_tokens(state):
        try:
            pid = str(getattr(state, "pathway_id", "") or "").strip().lower()
        except Exception:
            pid = ""
        pid_phrase = pid.replace("_", " ").replace("-", " ").strip()
        toks = []
        if pid:
            toks.append(pid)
        if pid_phrase and pid_phrase != pid:
            toks.append(pid_phrase)
        return [t for t in toks if t]

    def _cc_is_protected(label, url, state):
        blob = (str(label or "") + " " + str(url or "")).lower()
        for t in _cc_pid_tokens(state):
            if t and t in blob:
                return True
        return False

    # If we accidentally dropped a pathway-relevant item earlier, try to re-add it from original evidence_items.
    try:
        if state is not None:
            protected = [x for x in final if _cc_is_protected(x[0], x[1], state)]
            if not protected and evidence_items:
                for e in evidence_items:
                    label, url = _cc_norm_item(e)
                    if not url:
                        continue
                    if _cc_is_protected(label, url, state) and url not in seen:
                        seen.add(url)
                        final.append((label, url))
                        break
    except Exception:
        pass

    # Universal top-up to >=3
    if state is not None and len(final) == 0:
        try:
            from app.rag.retrieve import retrieve
            cc = _cc_cc_lower(state)
            pid = str(getattr(state, "pathway_id", "") or "").strip().replace("_", " ")
            q = (cc + " " + pid + " guideline").strip()
            for h in retrieve(q, k=160):
                if not isinstance(h, dict):
                    continue
                t = (h.get("title") or "").strip() or "Source"
                u = (h.get("url") or h.get("source") or "").strip()
                if not u or u in seen:
                    continue
                # Keep urinary drop logic only for urinary complaints
                if _cc_is_urinary(state) and _cc_should_drop(state, u, t):
                    continue
                seen.add(u)
                final.append((t, u))
                if len(final) >= 3:
                    break
        except Exception:
            pass

    # As a last resort (still <3), don't hide everything—print what we have.
    # --- END CALLCARE_EVIDENCE_MIN3_ALL_V1 ---

    accessed = date.today().isoformat()
    for title, url in final[:5]:
        # CALLCARE_SIM_EVID_TITLE_GATE
        def _cc_norm(s: str) -> str:
            s = (s or "").lower()
            s = re.sub(r"\s+", " ", s).strip()
            return s
        
        def _cc_split_terms(dx: str):
            dx = (dx or "").strip()
            if not dx:
                return []
            inside = re.findall(r"\(([^)]+)\)", dx)
            outside = re.sub(r"\([^)]*\)", " ", dx)
            parts = [outside] + inside
            terms = []
            for p in parts:
                for t in re.split(r"[;/,]|\bor\b|\band\b", p, flags=re.IGNORECASE):
                    t = t.strip()
                    if len(t) >= 4:
                        terms.append(t)
            out = []
            seen = set()
            for t in terms:
                tn = _cc_norm(t)
                if tn and tn not in seen:
                    seen.add(tn)
                    out.append(t)
            return out
        
        # Working diagnosis string (prefer NoteDraft.working_diagnosis)
        _wd = ""
        try:
            _wd = str(getattr(note_draft, "working_diagnosis", "") or getattr(note_draft, "diagnosis", "") or "").strip()
        except Exception:
            _wd = ""
        _terms = _cc_split_terms(_wd)
        if _terms:
            _tn = _cc_norm(title)
            if not any(_cc_norm(t) in _tn for t in _terms):
                continue
        if _cc_evidence_title_ok(title, state):
            if _cc_evidence_title_ok(title, note_text):
                if _cc_title_ok(title):
                    if _cc_title_ok(title):
                        print(f"- {title}. Accessed {accessed}. {url}")


def _print_note(note, state: CallState):



    # CALLCARE_SIM_EVID_GATE_V5 cache note text for evidence gating


    note_text = ''


