            if v is not None:
                m = re.match(r'^(\d{1,3})', str(v).strip())
                if m:
                    age_val = int(m.group(1))
    if age_val is not None and str(age_val).strip() != '':
        parts = soap.splitlines()
        for idx, ln in enumerate(parts):
            if ln.strip().startswith('S:') and 'Age' not in ln and 'age' not in ln:
                # DISABLED: do not append inline age to S: line
