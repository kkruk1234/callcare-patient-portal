def _cc_norm(s: str) -> str:
    s = (s or "").lower()
    s = re.sub(r"\s+", " ", s).strip()
    return s

def _cc_split_terms(dx: str):
    dx = (dx or "").strip()
    if not dx:
        return []
    inside = re.findall(r"\(([^)]+)\)", dx)
    outside = re.sub(r"\([^)]*\)", " ", dx)
    parts = [outside] + inside
    terms = []
    for p in parts:
        for t in re.split(r"[;/,]|\bor\b|\band\b", p, flags=re.IGNORECASE):
            t = t.strip()
            if len(t) >= 4:
                terms.append(t)
    out, seen = [], set()
    for t in terms:
        tn = _cc_norm(t)
        if tn and tn not in seen:
            seen.add(tn)
            out.append(t)
    return out

def _cc_terms_from_note_text(note_text: str):
    txt = note_text or ""
    m = re.search(r"([A-Za-z][A-Za-z\s\-](6, 80)\([A-Za-z][A-Za-z\s\-](3, 80)\))", txt)
    if m:
        return _cc_split_terms(m.group(1))
    m2 = re.search(r"(Diagnosis|Assessment)\s*:\s*([^\n\r](6, 140))", txt, flags=re.IGNORECASE)
    if m2:
        return _cc_split_terms(m2.group(2))
    return []

def _cc_evidence_title_ok(title: str, note_text: str) -> bool:
    terms = _cc_terms_from_note_text(note_text)
    if not terms:
        return True
    tn = _cc_norm(title)
    return any(_cc_norm(t) in tn for t in terms)



