            d = _cc_dump(state) or {}
            sx = d.get("symptoms")
            sx_keys = sorted(list(sx.keys())) if isinstance(sx, dict) else None
            pw = None
            if isinstance(sx, dict):
                pw = sx.get("_pathway") or sx.get("pathway") or sx.get("route") or sx.get("routing")
        
            snap = {
                "ts": time.time(),
                "state_keys": sorted(list(d.keys())),
                "pathway_id": d.get("pathway_id"),
                "pathway_label": d.get("pathway_label"),
                "working_diagnosis": d.get("working_diagnosis"),
                "decision": d.get("decision"),
                "symptoms_type": str(type(sx)),
                "symptoms_keys": sx_keys,
                "_pathway_obj": pw,
            }
        
            Path("logs").mkdir(exist_ok=True)
            with open("logs/state_before_buildnote.jsonl","a",encoding="utf-8") as f:
                f.write(json.dumps(snap, default=str) + "\n")
        except Exception:
            pass

        note = build_note(state)

        # Finalize first so evidence-from-manifest is attached to the note
        packet = finalize(state.session_id, note, state)
        _print_note(packet.note, state)
        _print_patient_summary(note)

        try:
            rq = importlib.import_module("app.clinical.review_queue")
            enqueue_for_review = getattr(rq, "enqueue_for_review")
            enqueue_for_review(state, note)
            print("\n(Queued for async physician review.)")
        except Exception as e:
            print("\n(Warn) Review queue failed:", str(e))

    except Exception as e:
        print("\n(Warn) Could not build note:", str(e))
        traceback.print_exc()  # DEBUG: show full error context

    print("\n--- END SIMULATION ---\n")


if __name__ == "__main__":
    run()
