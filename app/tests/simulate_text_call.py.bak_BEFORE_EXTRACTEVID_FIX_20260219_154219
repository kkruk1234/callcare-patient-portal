def _cc_get_note_text(note_draft):
    # Try common fields that might store the full note
    if note_draft is None:
        return ""
    if isinstance(note_draft, dict):
        for k in ["note_text", "note", "text", "narrative", "soap_note"]:
            v = note_draft.get(k)
            if isinstance(v, str) and v.strip():
                return v
        return ""
    for attr in ["note_text", "note", "text", "narrative", "soap_note"]:
        v = getattr(note_draft, attr, None)
        if isinstance(v, str) and v.strip():
            return v
    return ""

def _cc_terms_from_working_dx(note_draft):

    # Allow passing CallState as the context object too
    # Try state.working_diagnosis / state.pathway_label / state.pathway_id if present.
    # 1) direct working_diagnosis/diagnosis
    wd = ""
    if note_draft is not None:
        if isinstance(note_draft, dict):
            wd = str(note_draft.get("working_diagnosis") or note_draft.get("diagnosis") or "").strip()
        else:
            wd = str(getattr(note_draft, "working_diagnosis", "") or getattr(note_draft, "diagnosis", "") or "").strip()
    if wd:
        return _cc_split_terms(wd)

    # state-like fallback
    try:
        wd2 = str(getattr(note_draft, 'working_diagnosis', '') or getattr(note_draft, 'diagnosis', '') or '').strip()
        if wd2:
            return _cc_split_terms(wd2)
    except Exception:
        pass
    try:
        wd3 = str(getattr(note_draft, 'working_diagnosis', '') or getattr(note_draft, 'pathway_label', '') or getattr(note_draft, 'pathway_id', '') or '').strip()
        if wd3:
            return _cc_split_terms(wd3)
    except Exception:
        pass
    # 2) parse from note text as fallback
    txt = _cc_get_note_text(note_draft)
    if not txt:
        return []

    # Look for a phrase like "lateral epicondylitis (tennis elbow)" anywhere
    m = re.search(r"([A-Za-z][A-Za-z\s\-]{6,80}\([A-Za-z][A-Za-z\s\-]{3,80}\))", txt)
    if m:
        return _cc_split_terms(m.group(1))

    # Or "Assessment: <dx>"
    m2 = re.search(r"Assessment\s*:\s*([^\n\r]{6,120})", txt, flags=re.IGNORECASE)
    if m2:
        return _cc_split_terms(m2.group(1))

    return []

def _cc_evidence_title_ok(title: str, note_draft) -> bool:
    terms = _cc_terms_from_working_dx(note_draft)
    if not terms:
        # conservative: if we can't determine dx terms, do NOT filter (avoid hiding everything)
        return True
    tn = _cc_norm(title)
    return any(_cc_norm(t) in tn for t in terms)

