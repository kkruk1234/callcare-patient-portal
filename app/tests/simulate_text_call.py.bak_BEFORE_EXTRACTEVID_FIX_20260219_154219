def _cc_is_urinary(state):
    cc = _cc_cc_lower(state)
    keys = ("dysuria","burning when i pee","burns when i pee","painful urination",
            "uti","cystitis","urinary tract","urinary","urine","pee","peeing","bladder","urethra")
    return any(k in cc for k in keys)

def _cc_should_drop(state, url, title):
    cc = _cc_cc_lower(state)
    urinary = _cc_is_urinary(state)
    if not urinary:
        return False
    allow_stones = ("stone" in cc) or ("stones" in cc) or ("renal colic" in cc) or ("colicky" in cc)
    allow_incont = ("incontinence" in cc) or ("leak" in cc) or ("leaking" in cc)
    blob = (str(url or "") + " " + str(title or "")).lower()
    if "burn-evaluation" in blob or "burn evaluation" in blob or "burns-and-scalds" in blob or "/burns" in blob:
        return True
    if "oedema" in blob or "edema" in blob or "swollen ankles" in blob:
        return True
    if ("urinaryincontinence" in blob or "urinary incontinence" in blob) and not allow_incont:
        return True
    if ("bladder-stones" in blob or "bladder stones" in blob) and not allow_stones:
        return True
    return False

