def _print_evidence(evidence_items, state=None, note_text=None):
    print()
    print('--- EVIDENCE USED ---')
    if not evidence_items:
        print('(none)')
        return

    def _get(e, *keys):
        if isinstance(e, dict):
            for k in keys:
                v = e.get(k)
                if v:
                    return v
            return ''
        for k in keys:
            v = getattr(e, k, None)
            if v:
                return v
        return ''

    seen = set()
    printed = 0
    for e in evidence_items:
        title = str(_get(e, 'title', 'name') or '').replace('\n', ' ').strip()
        url = str(_get(e, 'url', 'source_url', 'link', 'href') or '').strip()
        accessed = str(_get(e, 'accessed_at', 'accessed', 'retrieved_at', 'fetched_at') or '').strip()

        if not title:
            continue

        key = (title.lower(), url.lower())
        if key in seen:
            continue
        seen.add(key)

        if url and accessed:
            print(f'- {title}. Accessed {accessed}. {url}')
        elif url:
            print(f'- {title}. {url}')
        else:
            print(f'- {title}')

        printed += 1
        if printed >= 10:
            break

