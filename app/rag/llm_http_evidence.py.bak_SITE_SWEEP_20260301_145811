from __future__ import annotations

import re
from typing import Any, Dict, List, Optional
from urllib.parse import urlparse

try:
    from openai import OpenAI
except Exception:
    OpenAI = None  # type: ignore

try:
    from app.core.models import EvidenceRef
except Exception:
    EvidenceRef = None  # type: ignore


# -----------------------------
# Domain Filtering
# -----------------------------

def _allow_hosts() -> List[str]:
    return [
        "cdc.gov","nih.gov","nlm.nih.gov","medlineplus.gov",
        "pubmed.ncbi.nlm.nih.gov","pmc.ncbi.nlm.nih.gov",
        "aafp.org","nice.org.uk","nhs.uk","who.int",
        "mayoclinic.org","clevelandclinic.org",
        "merckmanuals.com","bmj.com","bestpractice.bmj.com"
    ]


def _is_allowed(url: str) -> bool:
    u = str(url or "").lower()
    if not (u.startswith("http://") or u.startswith("https://")):
        return False
    if any(x in u for x in ["droracle.ai","reddit.com","quora.com","facebook.com","tiktok.com"]):
        return False
    return any(h in u for h in _allow_hosts())


def _publisher(url: str) -> str:
    try:
        h = urlparse(url).netloc.lower().replace("www.","")
        parts = h.split(".")
        if len(parts) >= 2:
            return parts[-2].upper()
        return h
    except Exception:
        return "Source"


# -----------------------------
# URL Extraction
# -----------------------------

def _urls_from_annotations(resp: Dict[str, Any]) -> List[str]:
    urls = []
    outs = resp.get("output") or []
    for item in outs:
        if not isinstance(item, dict):
            continue
        if item.get("type") != "message":
            continue
        content = item.get("content") or []
        for c in content:
            anns = c.get("annotations") or []
            for a in anns:
                if isinstance(a, dict) and a.get("type") == "url_citation":
                    if a.get("url"):
                        urls.append(a["url"])
    return urls


def _urls_from_any_text(resp: Dict[str, Any]) -> List[str]:
    urls = []
    def walk(x):
        if isinstance(x, str):
            for m in re.findall(r"https?://[^\s\)\]\}<>\"']+", x):
                urls.append(m)
        elif isinstance(x, list):
            for v in x:
                walk(v)
        elif isinstance(x, dict):
            for v in x.values():
                walk(v)
    walk(resp)
    return urls


def _dedupe(urls: List[str]) -> List[str]:
    seen = set()
    out = []
    for u in urls:
        u = str(u).strip()
        if not u or u in seen:
            continue
        seen.add(u)
        out.append(u)
    return out


# -----------------------------
# Main Function
# -----------------------------

def llm_http_evidence(
    *,
    chief_complaint: str,
    queries: Optional[List[str]] = None,
    diagnosis_hint: Optional[str] = None,
    context: Optional[str] = None,
    assessment_text: Optional[str] = None,
    min_urls: int = 4,
    max_urls: int = 6,
    timeout_s: int = 12,
    max_queries: int = 2,
    debug: bool = False,
    **_ignored,
) -> List[EvidenceRef]:

    if OpenAI is None:
        raise RuntimeError("openai SDK not available")

    anchor = assessment_text or diagnosis_hint or context or chief_complaint
    anchor = str(anchor or "").strip()

    if not anchor:
        return []

    client = OpenAI()

    qlist = queries or [
        f"{anchor} outpatient management guideline",
        f"{anchor} medication dosing contraindications"
    ]

    qlist = qlist[:max(1, max_queries)]

    all_urls: List[str] = []

    for q in qlist:
        try:
            resp = client.responses.create(
                model="gpt-4.1-mini",
                input=[{
                    "role":"user",
                    "content":[{"type":"input_text","text":q}]
                }],
                tools=[{"type":"web_search_preview"}],
                tool_choice={"type":"web_search_preview"},
                temperature=0.0,
                timeout=timeout_s,
            )
            d = resp.model_dump()
        except Exception:
            continue

        urls = _urls_from_annotations(d)
        if not urls:
            urls = _urls_from_any_text(d)

        all_urls.extend(urls)

    all_urls = _dedupe(all_urls)
    all_urls = [u for u in all_urls if _is_allowed(u)]
    all_urls = all_urls[:max_urls]

    out: List[EvidenceRef] = []

    for u in all_urls:
        title = u
        if EvidenceRef is not None:
            out.append(EvidenceRef(title=title, source=u, snippet=""))
        else:
            out.append({"title":title,"source":u,"snippet":""})  # fallback

    if debug:
        print("EVID_URLS:", all_urls)

    return out
