MAX_URLS = 8

TRUSTED_DOMAINS_DEFAULT = [
    "nhs.uk",
    "nice.org.uk",
    "aafp.org",
    "cdc.gov",
    "nih.gov",
    "medlineplus.gov",
    "dailymed.nlm.nih.gov",
