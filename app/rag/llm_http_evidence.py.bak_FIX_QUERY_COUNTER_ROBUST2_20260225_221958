    "clevelandclinic.org",
    "my.clevelandclinic.org",
]

ALLOWED_EXACT_HOSTS = [
    'www.nhs.uk',
]

def _is_allowed(url: str) -> bool:
    try:
        host = (urlparse(url).netloc or "").lower()
        if not host:
            return False
        # strip port
        if ":" in host:
            host = host.split(":", 1)[0]
        for eh in ALLOWED_EXACT_HOSTS:
            eh = (eh or '').lower().strip()
            if eh and host == eh:
                return True
        for suf in ALLOWED_HOST_SUFFIXES:
            suf = (suf or "").lower().strip()
            if not suf:
                continue
            if host == suf or host.endswith("." + suf):
                return True
        return False
    except Exception:
        return False

def _is_blocked(url: str) -> bool:
    host = (urlparse(url).netloc or "").lower()
    for bad in BLOCK_HOST_SUBSTRINGS:
        if bad in host:
            return True
    return False


def _rank_urls(urls: List[str], *, keywords: List[str] = None) -> List[str]:
    # Relevance-first ranking across allowed sources.
    # No US/UK weighting. Relevance wins.
    kws = [str(k or "").strip().lower() for k in (keywords or []) if str(k or "").strip()]
    kws = [k for k in kws if len(k) >= 3]
    kws = kws[:12]

    def _tokens_from_url(u: str) -> List[str]:
        try:
            p = urlparse(u)
            blob = " ".join([p.netloc or "", p.path or ""]).lower()
        except Exception:
            blob = (u or "").lower()
        blob = re.sub(r"[^a-z0-9]+", " ", blob)
        toks = [t for t in blob.split() if t]
        return toks

    def score(u: str) -> Tuple[int, int, int]:
        toks = _tokens_from_url(u)
        tokset = set(toks)

        overlap = 0
        for k in kws:
            kparts = [x for x in re.split(r"[^a-z0-9]+", k) if x]
            if not kparts:
                continue
            if any(x in tokset for x in kparts):
                overlap += 1

        # Small nudges for clinically useful pages (still subordinate to overlap)
        helpful = 0
        for t in ("guideline", "management", "treatment", "prescribing", "antibiotic", "dosing", "dose", "therapy", "self-care", "red-flags", "warnings"):
            if t in tokset:
                helpful += 1

        # Prefer shorter URLs a bit (usually cleaner canonical pages)
        return (overlap, helpful, -len(u or ""))

    return sorted(list(urls or []), key=score, reverse=True)

def _publisher_from_url(url: str) -> str:
    host = (urlparse(url).netloc or "").lower()
    for key, label in PUBLISHER_BY_HOST:
        if key in host:
            return label
    return host or "Source"


_TITLE_RE = re.compile(r"<\s*title[^>]*>(.*?)<\s*/\s*title\s*>", re.IGNORECASE | re.DOTALL)

def _fetch_title(url: str, timeout_s: int) -> str:
    socket.setdefaulttimeout(timeout_s)
    headers = {
        "User-Agent": "CallCareEvidenceBot/1.0",
        "Accept": "text/html,application/xhtml+xml",
    }

    try:
        req = Request(url, headers=headers)
        with urlopen(req, timeout=timeout_s) as resp:
            ctype = (resp.headers.get("Content-Type") or "").lower()
            raw = resp.read(150_000)
    except Exception:
        return _fallback_title_from_url(url)

    if "html" not in ctype and b"<html" not in raw[:5000].lower():
        return _fallback_title_from_url(url)

    try:
        text = raw.decode("utf-8", errors="ignore")
    except Exception:
        return _fallback_title_from_url(url)

    m = _TITLE_RE.search(text)
    if not m:
        return _fallback_title_from_url(url)

    title = unescape(m.group(1))
    title = re.sub(r"\s+", " ", title).strip()
    title = title.strip(" -|•\u2013\u2014")
    return title or _fallback_title_from_url(url)

def _fallback_title_from_url(url: str) -> str:
    host = (urlparse(url).netloc or "").lower()
    path = (urlparse(url).path or "").strip("/")
    if not path:
        return host or "Reference"
    seg = path.split("/")[-1]
    seg = seg.replace("-", " ").replace("_", " ").strip()
    return (seg[:80] if seg else host) or "Reference"


def _clean_sentence(s: str) -> str:
    s = (s or "").strip()
    s = re.sub(r"\s+", " ", s)
    s = s.strip(" .")
    return s or "Reference"
