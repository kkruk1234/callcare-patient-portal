def llm_http_evidence(
    *,
    chief_complaint: str,
    diagnosis_hint: Optional[str] = None,
    context: Optional[str] = None,
    assessment_text: Optional[str] = None,
    min_urls: int = 4,
    max_urls: int = 6,
    timeout_s: int = 12,
    max_queries: int = 2,
    title_fetch_n: int = 10,
    debug: bool = False,
    max_per_publisher: int = 2,
    trace_fn: Optional[callable] = None,
    **_ignored,
) -> List[EvidenceRef]:
    if OpenAI is None:
        raise RuntimeError("openai SDK not available; cannot run web_search evidence retrieval")

    cc = (chief_complaint or "").strip()
    if not cc:
        raise ValueError("chief_complaint is required")

    # Clinical anchor priority (generic): assessment_text > diagnosis_hint/context > complaint.
    anchor = (assessment_text or "").strip() or (diagnosis_hint or "").strip() or (context or "").strip() or cc
    anchor = _shorten(anchor, 200)

    keywords = _extract_keywords(anchor)

    # If we have a richer anchor (assessment/differential), require more matches to reduce drift.
    min_matches = 3 if (assessment_text and len(keywords) >= 6) else 2

    client = OpenAI(timeout=60)

    candidate_urls: List[str] = []
    seen = set()

    _cc_q_used = 0  # speed cap (queries)
    for q in _build_queries(anchor=anchor):

        urls = _openai_web_search_urls(client=client, query=q, debug=debug)
        for u in urls:
            nu = _normalize_url(u)
            if not nu:
                continue
            if _is_blocked(nu):
                continue
            if not _is_allowed(nu):
                continue
            if nu in seen:
                continue
            seen.add(nu)
            candidate_urls.append(nu)
        _cc_q_used += 1
        if _cc_q_used >= max_queries:
            break

        if len(candidate_urls) >= 60:
            break

    if len(candidate_urls) < min_urls:
        for q in _build_fallback_queries(anchor=anchor):
            urls = _openai_web_search_urls(client=client, query=q, debug=debug)
            for u in urls:
                nu = _normalize_url(u)
                if not nu or _is_blocked(nu) or (not _is_allowed(nu)) or nu in seen:
                    continue
                seen.add(nu)
                candidate_urls.append(nu)
            if len(candidate_urls) >= 60:
                break

    ranked_urls = _rank_urls(candidate_urls, keywords=keywords)

    today = date.today().isoformat()

    candidates: List[dict] = []
    for i_url, url in enumerate(ranked_urls):
        if i_url < int(title_fetch_n):
            title = _fetch_title(url, timeout_s=timeout_s) or _fallback_title_from_url(url)
        else:
            title = _fallback_title_from_url(url)
        pub = _publisher_from_url(url)
        candidates.append({"title": title, "source": pub, "url": url, "accessed": today, "snippet": ""})
        if len(candidates) >= 30:
            break

    filtered: List[dict] = []
    for r in candidates:
        if _keyword_relevant(keywords=keywords, title=str(r.get("title") or ""), url=str(r.get("url") or r.get("source") or ""), min_matches=min_matches):
            filtered.append(r)

    
    # Diversity-first selection:
    # 1) Take at most 1 per publisher until we reach min_urls.
    # 2) If still short, relax diversity (up to max_per_publisher) to reach max_urls.
    final: List[dict] = []
    counts: Dict[str, int] = {}

    # Pass 1: strict diversity (1 per publisher)
    for r in filtered:
        pub = str(r.get("source") or "").strip() or "Source"
        key = pub
        if counts.get(key, 0) >= 1:
            continue
        counts[key] = counts.get(key, 0) + 1
        final.append(r)
        if len(final) >= min_urls or len(final) >= max_urls:
            break

    # Pass 2: relax diversity if needed (up to max_per_publisher)
    if len(final) < min_urls:
        for r in filtered:
            if r in final:
                continue
            pub = str(r.get("source") or "").strip() or "Source"
            key = pub
            if counts.get(key, 0) >= max_per_publisher:
                continue
            counts[key] = counts.get(key, 0) + 1
            final.append(r)
            if len(final) >= min_urls or len(final) >= max_urls:
                break

    # HARD FLOOR: if still below min_urls, backfill from candidates (still allowlisted)
    if len(final) < min_urls:
        seen_urls = set(str(x.get("url") or "").strip() for x in final if isinstance(x, dict))
        for r in candidates:
            if len(final) >= min_urls:
                break
            u = str(r.get("url") or "").strip()
            if not u or u in seen_urls:
                continue
            seen_urls.add(u)
            final.append(r)

    return final


def format_evidence_lines(evs: Sequence[EvidenceRef]) -> List[str]:
    lines: List[str] = []
    for e in evs:
        title = _clean_sentence(e.get('title') if isinstance(e, dict) else e.title)
        publisher = _clean_sentence((e.get('publisher') if isinstance(e, dict) else getattr(e, 'publisher', '')) or (e.get('source') if isinstance(e, dict) else getattr(e, 'source', '')))
        url = ((e.get('url') if isinstance(e, dict) else getattr(e, 'url', None)) or (e.get('source') if isinstance(e, dict) else getattr(e, 'source', '')) or '').strip()
        accessed = ((e.get('accessed') if isinstance(e, dict) else getattr(e, 'accessed', '')) or '').strip()
        lines.append(f"{title}. {publisher}. {url}. Accessed {accessed}.")
    return lines


def _openai_web_search_urls(*, client: Any, query: str, debug: bool) -> List[str]:
    resp = client.responses.create(
        model="gpt-4o-mini",
        input=query,
        tools=[{"type": "web_search_preview"}],
        tool_choice={"type": "web_search_preview"},
        include=["web_search_call.action.sources"],
    )

    output = getattr(resp, "output", None) or []
    urls: List[str] = []

    for item in output:
        itype = getattr(item, "type", None) or (item.get("type") if isinstance(item, dict) else None)
        if itype != "web_search_call":
            continue

        action = _get(item, "action", default={})
        sources = _get(action, "sources", default=[]) or []

        for s in sources:
            u = _get(s, "url", default=None)
            if u:
                urls.append(str(u))

        if debug:
            try:
                slen = len(sources)
            except Exception:
                slen = -1
            print(f"[DEBUG web_search] query={query!r} action.sources_len={slen} urls_extracted={len(urls)}")

    return _dedupe_keep_order(urls)


def _get(obj: Any, key: str, default: Any = None) -> Any:
    if obj is None:
        return default
    if isinstance(obj, dict):
        return obj.get(key, default)
    return getattr(obj, key, default)


def _dedupe_keep_order(items: Iterable[str]) -> List[str]:
    out: List[str] = []
    seen = set()
    for x in items:
        if x in seen:
            continue
        seen.add(x)
        out.append(x)
    return out


def _build_queries(*, anchor: str) -> List[str]:
    """
    Generic query templates ONLY.
    No condition/anatomy hardcoding.
    """
    a = anchor.strip()
    return [
        f"{a} treatment",
        f"{a} red flags",
        f"{a} pain relief dosing",
        f"{a} analgesics dosing acetaminophen ibuprofen",
        f"{a} patient information",
        f"{a} guideline",
        f"{a} NHS",
        f"{a} MedlinePlus",
        f"{a} Merck Manual",
        f"{a} NICE",
    ]


def _build_fallback_queries(*, anchor: str) -> List[str]:
    a = anchor.strip()
    return [
        f"{a} when to see a doctor",
        f"{a} self care advice",
        f"{a} return precautions",
    ]


def _shorten(s: str, max_chars: int) -> str:
    s = re.sub(r"\s+", " ", (s or "").strip())
    return s[:max_chars]


_STOPWORDS = {
    "a","an","the","and","or","but","if","then","than","so","to","of","in","on","at","for","with","without",
    "is","are","was","were","be","been","being","it","this","that","these","those","as","by","from",
    "i","me","my","we","our","you","your","they","their","he","she","his","her",
    "left","right","side","sided","today","yesterday","week","weeks","day","days",
    "painful","hurts","hurt","ache","aches","area","localized","likely","due","minor","without","trauma",
    "absence","systemic","symptoms","neurological","deficits","reduces","concern","more","serious","pathology",
    "working","diagnosis","differential","mechanical","musculoskeletal","injury",
}

def _extract_keywords(text: str) -> List[str]:
    t = (text or "").lower()
    parts = re.split(r"[^a-z0-9]+", t)
    toks: List[str] = []
    for p in parts:
        p = p.strip()
        if not p:
            continue
        if p in _STOPWORDS:
            continue
        if len(p) < 3:
            continue
        toks.append(p)

    out: List[str] = []
    seen = set()
    for x in toks:
        if x in seen:
            continue
        seen.add(x)
        out.append(x)
        if len(out) >= 12:
            break
    return out


def _keyword_relevant(*, keywords: List[str], title: str, url: str, min_matches: int) -> bool:
    if not keywords or len(keywords) < min_matches:
        return True
    hay = f"{title} {url}".lower()
    hits = 0
    for kw in keywords:
        if kw and (kw in hay):
            hits += 1
        if hits >= min_matches:
            return True
    return False


def _normalize_url(url: str) -> Optional[str]:
    url = (url or "").strip()
    if not url:
        return None
    url = url.strip("()[]{}<>'\" \t\r\n")

    try:
        p = urlparse(url)
    except Exception:
        return None

    if p.scheme not in ("http", "https"):
        return None
    if not p.netloc:
        return None

    q = [(k, v) for (k, v) in parse_qsl(p.query, keep_blank_values=True) if not k.lower().startswith("utm_")]
    p = p._replace(query=urlencode(q, doseq=True))
    p = p._replace(fragment="")

    return urlunparse(p)



