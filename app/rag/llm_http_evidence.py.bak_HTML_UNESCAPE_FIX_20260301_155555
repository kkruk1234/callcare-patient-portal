import urllib.request
import ssl

def _fetch_title_snippet(url: str, *, timeout_s: int = 3, max_bytes: int = 200_000) -> Dict[str, str]:
    """
    Best-effort: fetch <title> and a short plaintext snippet.
    - No bs4 dependency (regex + simple tag stripping).
    - For PDFs, title falls back to filename.
    """
    u = str(url or "").strip()
    if not u:
        return {"title": "", "snippet": ""}
    low = u.lower()
    if low.endswith(".pdf") or ".pdf" in low:
        tail = u.split("/")[-1].split("?")[0]
        tail = tail.replace("-", " ").replace("_", " ")
        return {"title": tail[:160], "snippet": ""}

    ctx = ssl.create_default_context()
    ctx.check_hostname = False
    ctx.verify_mode = ssl.CERT_NONE

    req = urllib.request.Request(
        u,
        headers={
            "User-Agent": "Mozilla/5.0 (CallCareEvidenceBot/1.0)",
            "Accept": "text/html,application/xhtml+xml",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout_s, context=ctx) as r:
            raw = r.read(max_bytes)
    except Exception:
        return {"title": "", "snippet": ""}

    try:
        html = raw.decode("utf-8", errors="replace")
    except Exception:
        try:
            html = raw.decode("latin-1", errors="replace")
        except Exception:
            return {"title": "", "snippet": ""}

    # title
    title = ""
    m = re.search(r"(?is)<title[^>]*>(.*?)</title>", html)
    if m:
        title = html.unescape(re.sub(r"\s+", " ", m.group(1)).strip())
    if not title:
        title = _strip_tracking(u)

    # snippet: strip tags, collapse whitespace, take first 600 chars
    text = re.sub(r"(?is)<(script|style).*?>.*?</\1>", " ", html)
    text = re.sub(r"(?is)<[^>]+>", " ", text)
    text = re.sub(r"\s+", " ", text).strip()
    snippet = text[:600]
    return {"title": title[:160], "snippet": snippet}



