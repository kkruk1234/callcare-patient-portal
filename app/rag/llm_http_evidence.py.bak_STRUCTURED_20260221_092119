import os
import json
import time
import re
from urllib.parse import urlparse

# Authoritative allowlist (including subdomains)
ALLOWLIST_DOMAINS = {
    "cdc.gov",
    "nih.gov",
    "ncbi.nlm.nih.gov",
    "medlineplus.gov",
    "who.int",
    "nice.org.uk",
    "nhs.uk",
    "aafp.org",
    "idsociety.org",
    "acog.org",
    "acep.org",
    "aaos.org",
    "ginasthma.org",
    "goldcopd.org",
    "escardio.org",
    "heart.org",
    "diabetes.org",
    "merckmanuals.com",
}

DEFAULT_MODEL = os.getenv("CALLCARE_LLM_EVIDENCE_MODEL", "gpt-4o-mini")

# Generic “bad page” signals (not dx-specific)
BAD_TITLE_SIGNALS = [
    "page not found",
    "not found",
    "error",
    "access denied",
    "forbidden",
    "unauthorized",
    "oops",
    "we can’t find",
    "we can't find",
]

STOPWORDS = {
    "the","a","an","and","or","of","to","in","on","for","with","without","is","are",
    "this","that","it","as","by","from","at","be","been","was","were","can","may",
    "your","you","patient","patients","adult","adults","child","children","man","woman",
}

def _domain_allowed(url: str) -> bool:
    try:
        host = urlparse(url).netloc.lower()
        host = host.split(":")[0]
        if host.startswith("www."):
            host = host[4:]
        for d in ALLOWLIST_DOMAINS:
            if host == d or host.endswith("." + d):
                return True
        return False
    except Exception:
        return False

def _norm(s: str) -> str:
    return re.sub(r"\s+", " ", (s or "").strip()).lower()

def _tokenize_query(q: str) -> list[str]:
    q = _norm(q)
    # keep simple words and numbers
    toks = re.findall(r"[a-z0-9]+", q)
    toks = [t for t in toks if t and t not in STOPWORDS and len(t) >= 3]
    # keep up to 8 tokens to avoid over-filtering
    return toks[:8]

def _relevance_ok(url: str, title: str, snippet: str, query: str) -> bool:
    toks = _tokenize_query(query)
    if not toks:
        return True  # if query is empty, don't block
    hay = " ".join([_norm(url), _norm(title), _norm(snippet)])
    # Require at least 1 token match (generic, scalable)
    return any(t in hay for t in toks)

def _extract_title_and_snippet(html: str) -> tuple[str, str]:
    title = ""
    snippet = ""
    try:
        m = re.search(r"<title[^>]*>(.*?)</title>", html, flags=re.I | re.S)
        if m:
            title = re.sub(r"\s+", " ", re.sub(r"<.*?>", "", m.group(1))).strip()
    except Exception:
        title = ""
    try:
        m = re.search(
            r'<meta[^>]+name=["\']description["\'][^>]+content=["\']([^"\']+)["\']',
            html,
            flags=re.I | re.S,
        )
        if m:
            snippet = re.sub(r"\s+", " ", m.group(1)).strip()
    except Exception:
        snippet = ""
    return title, snippet

def _http_get_validate(url: str, timeout: float = 5.0) -> dict:
    """
    Returns dict:
      { ok: bool, status: int|None, title: str, snippet: str, reason: str }
    Never raises.
    """
    try:
        import requests
        r = requests.get(
            url,
            timeout=timeout,
            allow_redirects=True,
            headers={"User-Agent": "CallCare/1.0"},
        )
        status = getattr(r, "status_code", None)
        text = (r.text or "")
        title, snippet = _extract_title_and_snippet(text[:200000])

        tnorm = _norm(title)
        bad_title = any(sig in tnorm for sig in BAD_TITLE_SIGNALS)

        if status is None:
            return {"ok": False, "status": None, "title": title, "snippet": snippet, "reason": "no_status"}
        if status >= 400:
            return {"ok": False, "status": status, "title": title, "snippet": snippet, "reason": f"http_{status}"}
        if bad_title:
            return {"ok": False, "status": status, "title": title, "snippet": snippet, "reason": "bad_title"}
        # ok-ish even if title missing (some sites), but we still return what we have
        return {"ok": True, "status": status, "title": title, "snippet": snippet, "reason": "ok"}
    except Exception as e:
        return {"ok": False, "status": None, "title": "", "snippet": "", "reason": f"exception:{type(e).__name__}"}

def _openai_chat_json(prompt: str, model: str) -> dict:
    key = os.environ.get("OPENAI_API_KEY")
    if not key:
        raise RuntimeError("OPENAI_API_KEY not set")

    import requests
    payload = {
        "model": model,
        "messages": [
            {"role": "system", "content": "Return ONLY valid JSON. No prose. No markdown."},
            {"role": "user", "content": prompt},
        ],
        "temperature": 0.2,
    }
    t0 = time.time()
    resp = requests.post(
        "https://api.openai.com/v1/chat/completions",
        headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json"},
        json=payload,
        timeout=20,
    )
    dt = time.time() - t0
    if resp.status_code >= 400:
        raise RuntimeError(f"OpenAI HTTP {resp.status_code}: {resp.text[:300]}")
    data = resp.json()
    content = data["choices"][0]["message"]["content"]
    try:
        obj = json.loads(content)
    except Exception as e:
        raise RuntimeError(f"LLM returned non-JSON: {content[:200]}") from e
    obj["_latency_s"] = dt
    return obj

def _make_evidence_ref(EvidenceRef, title: str, url: str, snippet: str):
    # Try common schema variants (resilient)
    candidates = [
        {"title": title, "source": url, "snippet": snippet},
        {"title": title, "url": url, "snippet": snippet},
        {"title": title, "source": url},
        {"title": title, "url": url},
        {"source": url, "snippet": snippet},
        {"url": url, "snippet": snippet},
        {"source": url},
        {"url": url},
    ]
    last = None
    for d in candidates:
        try:
            return EvidenceRef(**d)
        except Exception as e:
            last = e
            continue
    raise last or RuntimeError("Could not construct EvidenceRef")

def _prompt_initial_urls(dx: str, cc: str, min_urls: int, max_urls: int) -> str:
    return f"""
Return JSON exactly:
{{ "urls": ["https://...","https://..."] }}

Rules:
- Return {min_urls} to {max_urls} URLs.
- ONLY choose sources from these domains (including subdomains): {sorted(ALLOWLIST_DOMAINS)}
- Choose stable, public pages that are likely to load directly in a browser (avoid internal search results pages).
- Prefer outpatient evaluation + treatment pages; when meds are used, prefer pages that include medication/dosing.
- No duplicates.

Input:
- Chief complaint: {cc}
- Working diagnosis hint: {dx}
""".strip()

def _prompt_repair_urls(dx: str, cc: str, min_urls: int, max_urls: int, bad: list[dict], keep: list[str]) -> str:
    # Ask to replace only the bad ones; keep good ones.
    bad_lines = []
    for b in bad[:12]:
        bad_lines.append(f"- {b.get('url')}  ({b.get('reason')})")
    bad_text = "\n".join(bad_lines) if bad_lines else "(none)"

    keep_text = "\n".join([f"- {u}" for u in keep]) if keep else "(none)"

    return f"""
Return JSON exactly:
{{ "urls": ["https://...","https://..."] }}

You must return {min_urls} to {max_urls} total URLs.

KEEP these URLs unchanged:
{keep_text}

REPLACE these URLs because they failed to load or were error pages:
{bad_text}

Rules:
- ONLY use these domains (including subdomains): {sorted(ALLOWLIST_DOMAINS)}
- Each URL must be a real public page (not a site search results page).
- Avoid 404 / “Page Not Found” / “Error” pages.
- Must be relevant to the condition (match the chief complaint/diagnosis).
- No duplicates.

Input:
- Chief complaint: {cc}
- Working diagnosis hint: {dx}
""".strip()

def llm_http_evidence(
    *,
    diagnosis_hint: str,
    chief_complaint: str,
    max_urls: int = 6,
    min_urls: int = 4,
    trace_fn=None,
    max_rounds: int = 2,
):
    """
    LLM chooses candidate URLs on allowlist; we validate via HTTP and generic relevance;
    we request replacements for failures up to max_rounds.
    No FAISS. No auto-acquire. No dx-specific cheat rules.
    """
    if trace_fn:
        trace_fn("llm_http_evidence_start", dx=diagnosis_hint, cc=chief_complaint, model=DEFAULT_MODEL)

    from app.core.models import EvidenceRef  # keep import local

    dx = (diagnosis_hint or "").strip()
    cc = (chief_complaint or "").strip()
    query = dx or cc

    good_urls: list[str] = []
    bad_info: list[dict] = []
    last_llm_urls = []

    for round_idx in range(max_rounds):
        if round_idx == 0:
            prompt = _prompt_initial_urls(dx, cc, min_urls, max_urls)
        else:
            prompt = _prompt_repair_urls(dx, cc, min_urls, max_urls, bad_info, good_urls)

        obj = _openai_chat_json(prompt, DEFAULT_MODEL)
        urls = obj.get("urls") or []
        last_llm_urls = urls if isinstance(urls, list) else []

        # allowlist + dedupe (relative to both good and bad sets)
        seen = set(good_urls) | {b.get("url") for b in bad_info if b.get("url")}
        candidates = []
        if isinstance(urls, list):
            for u in urls:
                if not isinstance(u, str):
                    continue
                u = u.strip()
                if not (u.startswith("http://") or u.startswith("https://")):
                    continue
                if not _domain_allowed(u):
                    continue
                if u in seen:
                    continue
                seen.add(u)
                candidates.append(u)
                if len(good_urls) + len(candidates) >= max_urls:
                    break

        if trace_fn:
            trace_fn(
                "llm_http_evidence_urls",
                round=round_idx + 1,
                llm_urls=len(last_llm_urls) if isinstance(last_llm_urls, list) else -1,
                candidate_urls=len(candidates),
                kept_good=len(good_urls),
                latency_s=obj.get("_latency_s"),
            )

        # validate candidates
        new_bad = []
        for u in candidates:
            v = _http_get_validate(u, timeout=5.0)
            if not v["ok"]:
                new_bad.append({"url": u, "reason": v["reason"], "status": v.get("status"), "title": v.get("title", "")[:120]})
                continue

            title = v.get("title") or u
            snippet = v.get("snippet") or "Authoritative clinical reference (see source)."

            # relevance gating (generic)
            if not _relevance_ok(u, title, snippet, query):
                new_bad.append({"url": u, "reason": "low_relevance", "status": v.get("status"), "title": title[:120]})
                continue

            good_urls.append(u)

        # update bad info for next repair prompt
        bad_info = (bad_info + new_bad)[:20]

        if len(good_urls) >= min_urls:
            break

    # Build EvidenceRefs for the good URLs (fetch again for title/snippet; cheap)
    refs = []
    for u in good_urls[:max_urls]:
        v = _http_get_validate(u, timeout=5.0)
        title = (v.get("title") or u).strip()
        snippet = (v.get("snippet") or "Authoritative clinical reference (see source).").strip()
        try:
            refs.append(_make_evidence_ref(EvidenceRef, title=title, url=u, snippet=snippet))
        except Exception as e:
            if trace_fn:
                trace_fn("llm_http_evidence_ref_error", url=u, err_type=type(e).__name__, err=str(e))

    if trace_fn:
        trace_fn(
            "llm_http_evidence_done",
            refs=len(refs),
            good_urls=len(good_urls),
            bad_urls=len(bad_info),
            last_bad=bad_info[:5],
        )

    return refs
