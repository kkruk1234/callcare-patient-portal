import os
import json
import time
import re
from urllib.parse import urlparse

ALLOWLIST_DOMAINS = {
    "nih.gov",
    "ncbi.nlm.nih.gov",
    "medlineplus.gov",
    "nice.org.uk",
    "nhs.uk",
    "who.int",
    "merckmanuals.com",
    "idsociety.org",
    "acog.org",
    "acep.org",
    "aaos.org",
    "aafp.org",
}

DEFAULT_MODEL = os.getenv("CALLCARE_LLM_EVIDENCE_MODEL", "gpt-4o-mini")

BAD_TITLE_SIGNALS = [
    "page not found",
    "not found",
    "error",
    "access denied",
    "forbidden",
    "unauthorized",
    "oops",
    "we can’t find",
    "we can't find",
]

STOPWORDS = {
    "the","a","an","and","or","of","to","in","on","for","with","without","is","are",
    "this","that","it","as","by","from","at","be","been","was","were","can","may",
    "your","you","patient","patients","adult","adults","child","children",
}


def _normalize_url(u: str) -> str:
    try:
        u = (u or "").strip()
        # Normalize www + trailing slashes for dedupe
        u = u.replace("://www.", "://")
        if u.endswith("/"):
            u = u[:-1]
        return u
    except Exception:
        return (u or "").strip()

def _domain_allowed(url: str) -> bool:
    try:
        host = urlparse(url).netloc.lower().split(":")[0]
        if host.startswith("www."):
            host = host[4:]
        for d in ALLOWLIST_DOMAINS:
            if host == d or host.endswith("." + d):
                return True
        return False
    except Exception:
        return False

def _norm(s: str) -> str:
    return re.sub(r"\s+", " ", (s or "").strip()).lower()

def _tokenize_query(q: str) -> list[str]:
    q = _norm(q)
    toks = re.findall(r"[a-z0-9]+", q)
    toks = [t for t in toks if t and t not in STOPWORDS and len(t) >= 3]
    return toks[:10]

def _relevance_ok(url: str, title: str, snippet: str, query: str) -> bool:
    toks = _tokenize_query(query)
    if not toks:
        return True
    hay = " ".join([_norm(url), _norm(title), _norm(snippet)])
    return any(t in hay for t in toks)

def _extract_title_and_snippet(html: str) -> tuple[str, str]:
    title = ""
    snippet = ""
    try:
        m = re.search(r"<title[^>]*>(.*?)</title>", html, flags=re.I | re.S)
        if m:
            title = re.sub(r"\s+", " ", re.sub(r"<.*?>", "", m.group(1))).strip()
    except Exception:
        title = ""
    try:
        m = re.search(
            r'<meta[^>]+name=["\']description["\'][^>]+content=["\']([^"\']+)["\']',
            html,
            flags=re.I | re.S,
        )
        if m:
            snippet = re.sub(r"\s+", " ", m.group(1)).strip()
    except Exception:
        snippet = ""
    return title, snippet

def _http_get_validate(url: str, timeout: float = 6.0) -> dict:
    try:
        import requests
        r = requests.get(url, timeout=timeout, allow_redirects=True, headers={"User-Agent": "CallCare/1.0"})
        status = getattr(r, "status_code", None)
        text = (r.text or "")
        title, snippet = _extract_title_and_snippet(text[:200000])

        tnorm = _norm(title)
        if status is None:
            return {"ok": False, "status": None, "title": title, "snippet": snippet, "reason": "no_status"}
        if status >= 400:
            return {"ok": False, "status": status, "title": title, "snippet": snippet, "reason": f"http_{status}"}
        if any(sig in tnorm for sig in BAD_TITLE_SIGNALS):
            return {"ok": False, "status": status, "title": title, "snippet": snippet, "reason": "bad_title"}

        return {"ok": True, "status": status, "title": title, "snippet": snippet, "reason": "ok"}
    except Exception as e:
        return {"ok": False, "status": None, "title": "", "snippet": "", "reason": f"exception:{type(e).__name__}"}

def _openai_chat_json(prompt: str, model: str) -> dict:
    key = os.environ.get("OPENAI_API_KEY")
    if not key:
        raise RuntimeError("OPENAI_API_KEY not set")

    import requests
    payload = {
        "model": model,
        "messages": [
            {"role": "system", "content": "Return ONLY valid JSON. No prose. No markdown."},
            {"role": "user", "content": prompt},
        ],
        "temperature": 0.2,
    }
    t0 = time.time()
    resp = requests.post(
        "https://api.openai.com/v1/chat/completions",
        headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json"},
        json=payload,
        timeout=20,
    )
    dt = time.time() - t0
    if resp.status_code >= 400:
        raise RuntimeError(f"OpenAI HTTP {resp.status_code}: {resp.text[:300]}")
    data = resp.json()
    content = data["choices"][0]["message"]["content"]
    obj = json.loads(content)
    obj["_latency_s"] = dt
    return obj

def _make_evidence_ref(EvidenceRef, title: str, url: str, snippet: str):
    candidates = [
        {"title": title, "source": url, "snippet": snippet},
        {"title": title, "url": url, "snippet": snippet},
        {"title": title, "source": url},
        {"title": title, "url": url},
        {"source": url, "snippet": snippet},
        {"url": url, "snippet": snippet},
        {"source": url},
        {"url": url},
    ]
    last = None
    for d in candidates:
        try:
            return EvidenceRef(**d)
        except Exception as e:
            last = e
    raise last or RuntimeError("Could not construct EvidenceRef")

def _construct_url(item: dict) -> str:
    kind = (item.get("kind") or "").strip().lower()
    if kind == "url":
        return str(item.get("url") or "").strip()

    if kind == "nhs_condition":
        slug = str(item.get("slug") or "").strip().strip("/")
        return f"https://www.nhs.uk/conditions/{slug}/" if slug else ""

    if kind == "nice_guidance":
        gid = str(item.get("id") or "").strip().lower().replace(" ", "")
        return f"https://www.nice.org.uk/guidance/{gid}" if gid else ""

    if kind == "medlineplus_topic":
        # prefer canonical “backpain.html” style; if model supplies hyphenated, we’ll also try de-hyphenation later
        slug = str(item.get("slug") or "").strip().strip("/")
        if not slug:
            return ""
        if slug.endswith(".html"):
            return f"https://medlineplus.gov/{slug}"
        return f"https://medlineplus.gov/{slug}.html"

    return ""

def _prompt_items(dx: str, cc: str, min_urls: int, max_urls: int, bad: list[dict], keep: list[str]) -> str:
    bad_lines = [f"- {b.get('url')} ({b.get('reason')})" for b in bad[:12]]
    keep_lines = [f"- {u}" for u in keep]
    return f"""
Return JSON exactly:
{{
  "items": [
    {{"kind":"nhs_condition","slug":"..."}},
    {{"kind":"medlineplus_topic","slug":"..."}},
    {{"kind":"nice_guidance","id":"NG59"}},
    {{"kind":"url","url":"https://..."}}
  ]
}}

You must return enough candidates so that after validation we can reach at least {min_urls} sources (ideally {max_urls}).

KEEP these URLs unchanged:
{chr(10).join(keep_lines) if keep_lines else "(none)"}

REPLACE anything that failed:
{chr(10).join(bad_lines) if bad_lines else "(none)"}

Rules:
- Prefer structured items (nhs_condition / medlineplus_topic / nice_guidance) to avoid broken URLs.
- If using kind="url", it MUST be from these domains (including subdomains): {sorted(ALLOWLIST_DOMAINS)}
- Avoid internal site search results pages.
- Avoid 404 / “Page Not Found” / “Error” pages.
- Must be relevant to: {cc} (dx hint: {dx})
- No duplicates.
""".strip()

def _medlineplus_variants(url: str) -> list[str]:
    # If MedlinePlus topic URL 404s and contains hyphens, try de-hyphenated slug.
    try:
        if "medlineplus.gov/" not in url:
            return []
        path = urlparse(url).path.strip("/")
        if not path.endswith(".html"):
            return []
        slug = path[:-5]
        if "-" in slug:
            return [f"https://medlineplus.gov/{slug.replace('-', '')}.html"]
    except Exception:
        pass
    return []

def _ncbi_topup(query: str, needed: int, trace_fn=None) -> list[str]:
    """
    Deterministic fallback: use NCBI E-utilities to find relevant reviews with free full text.
    Returns PubMed URLs (and prefers PMC when available).
    """
    if needed <= 0:
        return []
    try:
        import requests

        term = query.strip()
        if not term:
            term = "back pain"

        # Review + humans + english + last 10 years + free full text
        # (This is generic and scalable; not dx-specific.)
        q = f'({term}) AND review[pt] AND humans[mesh] AND english[lang] AND "last 10 years"[pdat] AND free full text[sb]'
        esearch = requests.get(
            "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi",
            params={"db": "pubmed", "retmode": "json", "retmax": max(needed * 3, 10), "term": q},
            timeout=10,
        )
        ids = (esearch.json().get("esearchresult", {}).get("idlist") or [])[: max(needed * 2, 10)]
        if trace_fn:
            trace_fn("ncbi_topup_esearch", query=term, found=len(ids))
        if not ids:
            return []

        esummary = requests.get(
            "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esummary.fcgi",
            params={"db": "pubmed", "retmode": "json", "id": ",".join(ids)},
            timeout=10,
        )
        summ = esummary.json().get("result", {}) or {}
        urls = []
        for pid in ids:
            if pid not in summ:
                continue
            urls.append(f"https://pubmed.ncbi.nlm.nih.gov/{pid}/")
            if len(urls) >= needed:
                break
        if trace_fn:
            trace_fn("ncbi_topup_done", added=len(urls))
        return urls
    except Exception as e:
        if trace_fn:
            trace_fn("ncbi_topup_error", err_type=type(e).__name__, err=str(e))
        return []

def _llm_relevance_filter(context: str, candidates: list[dict], model: str, trace_fn=None) -> list[dict]:
    """
    candidates: [{url,title,snippet}]
    Returns subset to KEEP based on relevance to context (Assessment).
    One LLM call per batch (keeps latency reasonable).
    """
    try:
        # If no context, do not filter (avoid breaking non-SOAP flows)
        ctx = (context or "").strip()
        if not ctx:
            return candidates

        payload = []
        for c in candidates[:10]:  # cap batch size
            payload.append({
                "url": c.get("url",""),
                "title": (c.get("title") or "")[:180],
                "snippet": (c.get("snippet") or "")[:300],
            })

        prompt = f"""
Return JSON only:
{{
  "keep": [
    {{"url":"https://...","keep":true}},
    ...
  ]
}}

Task:
You are filtering medical references for a telephone triage note.
KEEP only sources that are clinically relevant to the patient's working assessment below.
DROP sources that are about a different condition, different syndrome, or clearly mismatched context.

Working assessment context (from note A:):
{ctx}

Candidates:
{json.dumps(payload, ensure_ascii=False)}

Rules:
- Prefer sources relevant to the specific clinical picture in the context.
- If a source is about a different syndrome (e.g., radicular pain/sciatica) but the context is localized non-radicular pain, DROP it.
- If unclear, DROP (safety: better fewer than wrong-topic).
""".strip()

        obj = _openai_chat_json(prompt, model)
        keep_list = obj.get("keep") or []
        keep_urls = set()
        if isinstance(keep_list, list):
            for row in keep_list:
                if not isinstance(row, dict):
                    continue
                if row.get("keep") is True and isinstance(row.get("url"), str):
                    keep_urls.add(_normalize_url(row["url"]))

        kept = [c for c in candidates if _normalize_url(c.get("url","")) in keep_urls]

        if trace_fn:
            trace_fn("llm_relevance_filter", in_n=len(candidates), out_n=len(kept))
        return kept
    except Exception as e:
        if trace_fn:
            trace_fn("llm_relevance_filter_error", err_type=type(e).__name__, err=str(e))
        # Fail-open: if filter fails, don't drop everything
        return candidates


def llm_http_evidence(
    *,
    diagnosis_hint: str,
    chief_complaint: str,
    max_urls: int = 6,
    min_urls: int = 4,          # YOU want 4 minimum
    trace_fn=None,
    max_rounds: int = 4,
):
    if trace_fn:
        trace_fn("llm_http_evidence_start", dx=diagnosis_hint, cc=chief_complaint, model=DEFAULT_MODEL)

    from app.core.models import EvidenceRef

    dx = (diagnosis_hint or "").strip()
    cc = (chief_complaint or "").strip()
    query = dx or cc

    good_urls: list[str] = []
    bad_info: list[dict] = []

    for round_idx in range(max_rounds):
        prompt = _prompt_items(dx, cc, min_urls, max_urls, bad_info, good_urls)
        obj = _openai_chat_json(prompt, DEFAULT_MODEL)
        items = obj.get("items") or []
        if not isinstance(items, list):
            items = []

        seen = set(good_urls) | {b.get("url") for b in bad_info if b.get("url")}
        candidates = []
        for it in items:
            if not isinstance(it, dict):
                continue
            u = _construct_url(it)
            if not u or not (u.startswith("http://") or u.startswith("https://")):
                continue
            if not _domain_allowed(u):
                continue
            if u in seen:
                continue
            seen.add(u)
            candidates.append(u)
            if len(good_urls) + len(candidates) >= max_urls:
                break

        if trace_fn:
            trace_fn("llm_http_evidence_urls", round=round_idx + 1, candidate_urls=len(candidates), kept_good=len(good_urls), latency_s=obj.get("_latency_s"))

        new_bad = []
        for u in candidates:
            v = _http_get_validate(u, timeout=6.0)
            if not v["ok"]:
                # try medlineplus de-hyphenation once (generic)
                tried = False
                for alt in _medlineplus_variants(u):
                    tried = True
                    v2 = _http_get_validate(alt, timeout=6.0)
                    if v2["ok"]:
                        u = alt
                        v = v2
                        break
                if not v["ok"]:
                    new_bad.append({"url": u, "reason": v["reason"], "status": v.get("status"), "title": (v.get("title") or "")[:120], "tried_alt": tried})
                    continue

            title = v.get("title") or u
            snippet = v.get("snippet") or "Authoritative clinical reference (see source)."

            if not _relevance_ok(u, title, snippet, query):
                new_bad.append({"url": u, "reason": "low_relevance", "status": v.get("status"), "title": title[:120]})
                continue

            good_urls.append(_normalize_url(u))

        bad_info = (bad_info + new_bad)[:25]
        if len(good_urls) >= min_urls:
            break

    # Enforce minimum: PubMed/PMC top-up (authoritative, deterministic) if still short
    if len(good_urls) < min_urls:
        need = min_urls - len(good_urls)
        top = _ncbi_topup(query=query, needed=need, trace_fn=trace_fn)
        for u in top:
            if _normalize_url(u) not in set(map(_normalize_url, good_urls)) and _domain_allowed(u):
                good_urls.append(_normalize_url(u))
            if len(good_urls) >= min_urls:
                break

    # Build EvidenceRefs
    refs = []
    for u in good_urls[:max_urls]:
        v = _http_get_validate(u, timeout=6.0)
        title = (v.get("title") or u).strip()
        snippet = (v.get("snippet") or "Authoritative clinical reference (see source).").strip()
        try:
            refs.append(_make_evidence_ref(EvidenceRef, title=title, url=u, snippet=snippet))
        except Exception as e:
            if trace_fn:
                trace_fn("llm_http_evidence_ref_error", url=u, err_type=type(e).__name__, err=str(e))

    if trace_fn:
        trace_fn("llm_http_evidence_done", refs=len(refs), good_urls=len(good_urls), bad_urls=len(bad_info), last_bad=bad_info[:5])

    return refs
