MAX_URLS = 8

TRUSTED_DOMAINS_DEFAULT = [
    "nhs.uk",
    "nice.org.uk",
    "aafp.org",
    "cdc.gov",
    "nih.gov",
    "medlineplus.gov",
    "dailymed.nlm.nih.gov",
    "fda.gov",
    "who.int",
    "ncbi.nlm.nih.gov",
    "pubmed.ncbi.nlm.nih.gov",
]

LIB_ROOT = Path("data") / "sources" / "library"
PACKS_ROOT = Path("data") / "packs"
LOG_PATH = Path("logs") / "auto_acquire_attempts.json"


@dataclass
class AcquireResult:
    ok: bool
    reason: str
    query: str
    pack: Optional[str]
    urls: List[str]
    titles: Dict[str, str]
    elapsed_sec: float


def _now() -> float:
    return time.time()


def _stable_hash(s: str) -> str:
    return hashlib.sha256(s.encode("utf-8")).hexdigest()[:16]


def _ensure_dir(p: Path) -> None:
    p.mkdir(parents=True, exist_ok=True)


def _read_json(p: Path) -> Any:
    return json.loads(p.read_text(encoding="utf-8"))


def _write_json(p: Path, obj: Any) -> None:
    _ensure_dir(p.parent)
    p.write_text(json.dumps(obj, indent=2, ensure_ascii=False), encoding="utf-8")


def _append_log(item: Dict[str, Any]) -> None:
    _ensure_dir(LOG_PATH.parent)
    data: List[Any] = []
    if LOG_PATH.exists():
        try:
            existing = _read_json(LOG_PATH)
            if isinstance(existing, list):
                data = existing
            elif isinstance(existing, dict):
                data = list(existing.values())
        except Exception:
            data = []
    data.append(item)
    _write_json(LOG_PATH, data)


def _domain_allowed(url: str, allowed_domains: Sequence[str]) -> bool:
    u = (url or "").lower()
    return any(d.lower().strip() in u for d in allowed_domains if d)


def _norm(s: str) -> str:
    s = (s or "").lower()
    s = re.sub(r"\s+", " ", s).strip()
    return s


def _title_contains_any(title: str, terms: Sequence[str]) -> bool:
    t = _norm(title)
    for term in terms:
        tn = _norm(term)
        if tn and tn in t:
            return True
    return False


def _fetch_page_title(url: str, *, timeout_sec: float = 4.0, max_bytes: int = 200_000) -> str:
    """
    Fast, bounded title fetch. We only need <title>…</title>.
    """
    headers = {
        "User-Agent": "CallCareEvidenceBot/1.0 (+https://example.invalid)",
        "Accept": "text/html,application/xhtml+xml",
    }
    try:
        r = requests.get(url, headers=headers, timeout=timeout_sec, stream=True, allow_redirects=True)
        r.raise_for_status()
        buf = b""
        for chunk in r.iter_content(chunk_size=8192):
            if not chunk:
                break
            buf += chunk
            if len(buf) >= max_bytes:
                break
        text = buf.decode("utf-8", errors="ignore")
        m = re.search(r"<title[^>]*>(.*?)</title>", text, flags=re.IGNORECASE | re.DOTALL)
        if not m:
            return ""
        title = re.sub(r"\s+", " ", m.group(1)).strip()
        # Strip common suffix junk
        title = re.sub(r"\s*-\s*NHS\s*$", " - NHS", title)
        return title
    except Exception:
        return ""


def _fix_library_titles(titles_by_url: Dict[str, str]) -> None:
    """
    Ensure source.json.title reflects the fetched page title.
    This is critical because your Evidence Used gating is title-based.
    """
    if not titles_by_url or not LIB_ROOT.exists():
        return

    for src_json in LIB_ROOT.rglob("source.json"):
        try:
            src = _read_json(src_json)
            if not isinstance(src, dict):
                continue
            u = (src.get("url") or src.get("source_url") or "").strip()
            if not u or u not in titles_by_url:
                continue

            new_title = (titles_by_url.get(u) or "").strip()
            if not new_title:
                continue

            old_title = (src.get("title") or "").strip()
            # Fix missing/garbage titles commonly seen ("content.txt")
            if (not old_title) or (old_title.lower() in {"content.txt", "content", "untitled"}):
                src["title"] = new_title
                _write_json(src_json, src)
        except Exception:
            continue


def _openai_web_search_urls(query: str, *, max_urls: int) -> List[str]:
    """
    OpenAI-only web search.

    Uses the Responses API with tools=[{"type":"web_search"}] to fetch live results.
    Returns a deduplicated list of http(s) URLs (length <= max_urls).

    Always logs to logs/web_search_debug.jsonl so failures never silently become "0 urls".
    """
    import os, re, time, json
    from pathlib import Path

    Path("logs").mkdir(exist_ok=True)
    log_path = Path("logs/web_search_debug.jsonl")

    def _log(obj):
        try:
            obj = dict(obj or {})
            obj["ts"] = time.time()
            with log_path.open("a", encoding="utf-8") as f:
                f.write(json.dumps(obj, ensure_ascii=False, default=str) + "\n")
        except Exception:
            pass

    api_key = os.environ.get("OPENAI_API_KEY")
    if not api_key:
        _log({"ok": False, "stage": "no_api_key", "query": query})
        return []

    # Defensive: ensure positive max_urls
    try:
        n = int(max_urls)
    except Exception:
        n = 8
    if n <= 0:
        n = 8

    try:
        from openai import OpenAI
        client = OpenAI(api_key=api_key)

        resp = client.responses.create(
            model="gpt-4.1-mini",
            input=[{"role": "user", "content": query}],
            tools=[{"type": "web_search"}],
            tool_choice="auto",
        )

        txt = (getattr(resp, "output_text", "") or "").strip()

        # Extract URLs from the model output text
        found = re.findall(r"https?://[^\s\)\]\}<>\"']+", txt)
        # Strip common tracking param added by tool
        cleaned = []
        for u in found:
            u = u.strip()
            if not u:
                continue
            u = re.sub(r"[?&]utm_source=openai\b", "", u)
            # clean dangling ? or &
            u = re.sub(r"[?&]$", "", u)
            cleaned.append(u)

        # Dedup while preserving order
        out = []
        seen = set()
        for u in cleaned:
            if not (u.startswith("http://") or u.startswith("https://")):
                continue
            if u in seen:
                continue
            seen.add(u)
            out.append(u)
            if len(out) >= n:
                break

        _log({"ok": True, "stage": "web_search", "query": query, "urls": len(out), "head": out[:5]})
        return out

    except Exception as e:
        _log({"ok": False, "stage": "exception", "query": query, "error": repr(e)})
        return []

def acquire_ingest_reindex(
    *,
    query: str,
    allowed_domains: Optional[Sequence[str]] = None,
    max_urls: int = 4,
    force: bool = False,
    required_title_terms: Optional[Sequence[str]] = None,
    time_budget_sec: float = 12.0,
) -> Dict[str, Any]:
    """
    Title-aware acquisition:
    - Search for candidate URLs
    - Fetch page titles quickly
    - KEEP ONLY URLs whose TITLE contains ANY required_title_terms (OR logic)
    - Ingest kept URLs
    - Fix stored library titles for those URLs
    Returns a dict compatible with your existing log structure.
    """
    t0 = _now()
    allowed = list(allowed_domains) if allowed_domains else list(TRUSTED_DOMAINS_DEFAULT)
    terms = [t for t in (required_title_terms or []) if isinstance(t, str) and t.strip()]
    max_urls = max(1, min(int(max_urls), MAX_URLS))

    pack_path: Optional[str] = None
    raw_urls: List[str] = []
    allowed_urls: List[str] = []
    titles_by_url: Dict[str, str] = {}

    try:
        if _now() - t0 > time_budget_sec:
            raise TimeoutError("time budget exceeded before search")

        raw_urls = _openai_web_search_urls(query, max_urls=max_urls * 10)
        raw_urls = list(dict.fromkeys([u for u in raw_urls if isinstance(u, str) and u.strip()]))

        # domain filter
        cand = [u for u in raw_urls if _domain_allowed(u, allowed)]

        # title gate (OR logic) if terms provided
        kept: List[str] = []
        for u in cand:
            if _now() - t0 > time_budget_sec:
                break
            title = _fetch_page_title(u, timeout_sec=4.0)
            if title:
                titles_by_url[u] = title
            if terms:
                if title and _title_contains_any(title, terms):
                    kept.append(u)
            else:
                # If no title terms provided, keep first N trusted results
                kept.append(u)
            if len(kept) >= max_urls:
                break

        allowed_urls = kept[:max_urls]

        h = _stable_hash(query + "|" + "|".join(terms))
        pack = {
            "id": f"auto_{h}",
            "created_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            "query": query,
            "required_title_terms": terms,
            "urls": allowed_urls,
            "titles_by_url": titles_by_url,
            "allowed_domains": allowed,
        }
        pack_path = str(PACKS_ROOT / f"auto_{h}.json")
        _write_json(Path(pack_path), pack)

        if allowed_urls:
            # Ingest
            try:
                from app.rag.ingest_urls import ingest_pack  # type: ignore
                ingest_pack(pack_path)  # type: ignore
            except Exception:
                from app.rag.ingest_urls import ingest_urls  # type: ignore
                ingest_urls(pack_path)  # type: ignore

            # Fix stored titles after ingest
            _fix_library_titles({u: titles_by_url.get(u, "") for u in allowed_urls})

        elapsed = _now() - t0
        out = {
            "ok": True,
            "reason": "ok",
            "ts": _now(),
            "query": query,
            "pack": pack_path,
            "urls": allowed_urls,
            "titles_by_url": {u: titles_by_url.get(u, "") for u in allowed_urls},
            "elapsed_sec": round(elapsed, 3),
        }
        _append_log(out)
        return out

    except Exception as e:
        elapsed = _now() - t0
        out = {
            "ok": False,
            "reason": f"{type(e).__name__}: {e}",
            "ts": _now(),
            "query": query,
            "pack": pack_path,
            "urls": allowed_urls,
            "titles_by_url": {u: titles_by_url.get(u, "") for u in allowed_urls},
            "elapsed_sec": round(elapsed, 3),
        }
        _append_log(out)
        return out
