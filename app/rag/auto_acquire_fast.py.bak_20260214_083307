from __future__ import annotations

import hashlib
import json
import os
import time
from dataclasses import dataclass
from typing import Any, Dict, List, Optional, Sequence, Tuple


TRUSTED_DOMAINS_DEFAULT = [
    "nhs.uk",
    "nice.org.uk",
    "aafp.org",
    "cdc.gov",
    "nih.gov",
    "medlineplus.gov",
    "dailymed.nlm.nih.gov",
    "fda.gov",
    "who.int",
    "ncbi.nlm.nih.gov",
    "pubmed.ncbi.nlm.nih.gov",
]


@dataclass
class AcquireResult:
    ok: bool
    query: str
    urls_found: int
    urls_allowed: int
    urls_ingested: int
    pack_path: Optional[str]
    elapsed_sec: float
    error: Optional[str]
    ingested_docs: List[Dict[str, Any]]  # doc handles suitable for EvidenceRef creation


def _now() -> float:
    return time.time()


def _stable_hash(s: str) -> str:
    return hashlib.sha256(s.encode("utf-8")).hexdigest()[:16]


def _ensure_dir(path: str) -> None:
    os.makedirs(path, exist_ok=True)


def _write_json(path: str, obj: Any) -> None:
    _ensure_dir(os.path.dirname(path))
    with open(path, "w", encoding="utf-8") as f:
        json.dump(obj, f, indent=2, ensure_ascii=False)


def _append_log(path: str, item: Dict[str, Any]) -> None:
    _ensure_dir(os.path.dirname(path))
    try:
        if os.path.exists(path):
            with open(path, "r", encoding="utf-8") as f:
                data = json.load(f)
                if not isinstance(data, list):
                    data = []
        else:
            data = []
    except Exception:
        data = []
    data.append(item)
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)


def _domain_allowed(url: str, allowed_domains: Sequence[str]) -> bool:
    u = (url or "").lower()
    for d in allowed_domains:
        d = d.lower().strip()
        if d and d in u:
            return True
    return False


def _openai_web_search_urls(query: str, *, max_urls: int) -> List[str]:
    """
    This function intentionally calls into whatever OpenAI web-search wrapper you already have
    in your codebase (llm_note_writer or rag tools). If not present, it fails cleanly.

    The key here is: return plain result URLs, deterministically truncated.
    """
    # Try to reuse an existing helper if your project already has one.
    # We keep this import inside so missing imports don't crash the simulator unless auto-acquire is invoked.
    try:
        from app.rag.auto_acquire import _openai_web_search_urls as existing  # type: ignore
        urls = existing(query=query, max_urls=max_urls)  # type: ignore
        return list(urls)[:max_urls]
    except Exception:
        # No existing search helper available.
        return []


def acquire_ingest_attach(
    *,
    query: str,
    allowed_domains: Optional[Sequence[str]] = None,
    max_urls: int = 4,
    time_budget_sec: float = 8.0,
) -> AcquireResult:
    """
    Time-bounded: web search -> domain filter -> create pack -> ingest -> return ingested doc handles
    WITHOUT rebuilding FAISS in-call.

    If anything fails, return ok=False with error and whatever partial results we have.
    """
    t0 = _now()
    allowed = list(allowed_domains) if allowed_domains else list(TRUSTED_DOMAINS_DEFAULT)

    pack_path = None
    ingested_docs: List[Dict[str, Any]] = []
    try:
        # 1) search (bounded)
        if _now() - t0 > time_budget_sec:
            raise TimeoutError("time budget exceeded before search")

        raw_urls = _openai_web_search_urls(query, max_urls=max_urls * 3)
        raw_urls = [u for u in raw_urls if isinstance(u, str) and u.strip()]
        raw_urls = list(dict.fromkeys(raw_urls))  # dedupe preserve order

        allowed_urls = [u for u in raw_urls if _domain_allowed(u, allowed)]
        allowed_urls = allowed_urls[:max_urls]

        # 2) pack
        h = _stable_hash(query)
        pack = {
            "id": f"auto_{h}",
            "created_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            "query": query,
            "urls": allowed_urls,
            "allowed_domains": allowed,
        }
        pack_path = os.path.join("data", "packs", f"auto_{h}.json")
        _write_json(pack_path, pack)

        # 3) ingest (bounded)
        if _now() - t0 > time_budget_sec:
            raise TimeoutError("time budget exceeded before ingest")

        try:
            from app.rag.ingest_urls import ingest_pack  # type: ignore
        except Exception:
            from app.rag.ingest_urls import ingest_urls as ingest_pack  # type: ignore

        # Ingest API varies across iterations; tolerate both styles.
        try:
            ingest_result = ingest_pack(pack_path)  # type: ignore
        except TypeError:
            ingest_result = ingest_pack(pack)  # type: ignore

        # 4) Extract ingested doc handles for immediate attachment
        # We accept multiple possible formats.
        if isinstance(ingest_result, dict):
            docs = ingest_result.get("docs") or ingest_result.get("documents") or ingest_result.get("items") or []
            if isinstance(docs, list):
                ingested_docs = [d for d in docs if isinstance(d, dict)]
        elif isinstance(ingest_result, list):
            ingested_docs = [d for d in ingest_result if isinstance(d, dict)]

        elapsed = _now() - t0
        _append_log(
            os.path.join("logs", "auto_acquire_attempts.json"),
            {
                "ok": True,
                "query": query,
                "urls_found": len(raw_urls),
                "urls_allowed": len(allowed_urls),
                "urls_ingested": len(ingested_docs),
                "pack_path": pack_path,
                "elapsed_sec": round(elapsed, 3),
            },
        )
        return AcquireResult(
            ok=True,
            query=query,
            urls_found=len(raw_urls),
            urls_allowed=len(allowed_urls),
            urls_ingested=len(ingested_docs),
            pack_path=pack_path,
            elapsed_sec=elapsed,
            error=None,
            ingested_docs=ingested_docs,
        )
    except Exception as e:
        elapsed = _now() - t0
        _append_log(
            os.path.join("logs", "auto_acquire_attempts.json"),
            {
                "ok": False,
                "query": query,
                "pack_path": pack_path,
                "elapsed_sec": round(elapsed, 3),
                "error": f"{type(e).__name__}: {e}",
            },
        )
        return AcquireResult(
            ok=False,
            query=query,
            urls_found=0,
            urls_allowed=0,
            urls_ingested=len(ingested_docs),
            pack_path=pack_path,
            elapsed_sec=elapsed,
            error=f"{type(e).__name__}: {e}",
            ingested_docs=ingested_docs,
        )
