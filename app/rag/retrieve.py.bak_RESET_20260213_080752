import json
import os
import re
from pathlib import Path
from typing import Dict, List, Optional, Tuple

import faiss
import numpy as np

from app.clinical.embeddings import get_embedder  # EMBED_HARDEN_PATCH_V1


# Resolve project root reliably (…/callcare/)
BASE_DIR = Path(__file__).resolve().parents[2]

# Your actual index location
INDEX_DIR = BASE_DIR / "data" / "index"
FAISS_PATH = INDEX_DIR / "faiss.index"
DOCS_PATH = INDEX_DIR / "docs.json"

_model = None
_index = None
_DOCS = None


def _ensure_loaded():
    global _model, _index, _DOCS
    if _model is None:
        _model = get_embedder()
    if _index is None:
        if not FAISS_PATH.exists():
            raise FileNotFoundError(f"FAISS index not found: {FAISS_PATH}")
        _index = faiss.read_index(str(FAISS_PATH))
    if _DOCS is None:
        if not DOCS_PATH.exists():
            raise FileNotFoundError(f"Docs file not found: {DOCS_PATH}")
        with open(DOCS_PATH, "r", encoding="utf-8") as f:
            _DOCS = json.load(f)


def _debug_enabled() -> bool:
    return os.environ.get("RAG_DEBUG", "").strip() in ("1", "true", "TRUE", "yes", "YES")


_WORD_RE = re.compile(r"[a-z0-9]+")


def _tokenize(text: str) -> List[str]:
    text = (text or "").lower()
    return _WORD_RE.findall(text)


def _relevance_score(query_tokens: List[str], doc: Dict, diagnosis_hint: Optional[str]) -> float:
    """
    Deterministic lightweight relevance scoring.
    We keep FAISS score as primary signal, but we penalize obvious off-topic chunks.
    - lexical overlap: how many query tokens appear in title/text
    - diagnosis hint: bonus if diagnosis/pathway slug appears in source/title/text/url
    """
    title = (doc.get("title") or "").lower()
    text = (doc.get("text") or "").lower()
    src = (doc.get("source") or "").lower()
    url = (doc.get("url") or "").lower()

    hay = " ".join([title, src, url, text[:2000]])  # cap for speed
    if not query_tokens:
        overlap = 0.0
    else:
        hits = 0
        for t in query_tokens:
            if len(t) <= 2:
                continue
            if t in hay:
                hits += 1
        overlap = hits / max(1, len([t for t in query_tokens if len(t) > 2]))

    hint_bonus = 0.0
    if diagnosis_hint:
        h = diagnosis_hint.lower().strip()
        if h and (h in src or h in title or h in url or h in text[:3000].lower()):
            hint_bonus = 0.35  # strong boost if explicitly mentioned

    # Final relevance uses overlap + hint; keep bounded [0, 1.5]
    return min(1.5, overlap + hint_bonus)


def _dedupe_key(d: Dict) -> Tuple[str, str, str]:
    # Prefer URL, else source, else first 200 chars of text
    url = (d.get("url") or "").strip()
    src = (d.get("source") or "").strip()
    txt = (d.get("text") or "").strip()[:200]
    return (url, src, txt)


def retrieve(query: str, k: int = 5, *, diagnosis_hint: Optional[str] = None, fetch_k: int = 40):
    """
    Return list[dict]: {score, source, title, url, text}

    Improvements vs prior:
    - fetch_k wider net from FAISS, then filter + dedupe
    - deterministic relevance scoring to reduce off-topic results
    - optional diagnosis_hint (pathway_id/slug) to bias toward matching sources
    - optional debug output via env var RAG_DEBUG=1
    """
    _ensure_loaded()

    if query is None:
        query = ""
    query = str(query).strip()
    if not query:
        return []

    # Encode + search
    qv = _model.encode([query]).astype("float32")
    faiss.normalize_L2(qv)

    fetch_k = max(int(fetch_k), int(k), 10)
    scores, ids = _index.search(qv, int(fetch_k))

    # Build candidates
    candidates: List[Dict] = []
    for score, idx in zip(scores[0], ids[0]):
        try:
            d = _DOCS[int(idx)]
        except Exception:
            continue

        candidates.append(
            {
                "score": float(score),
                "source": d.get("source", "") or "",
                "title": d.get("title", "") or "Guideline excerpt",
                "url": d.get("url", "") or "",
                "text": d.get("text", "") or "",
            }
        )

    # Dedupe
    seen = set()
    deduped: List[Dict] = []
    for d in candidates:
        key = _dedupe_key(d)
        if key in seen:
            continue
        seen.add(key)
        deduped.append(d)

    # Relevance filter / rerank
    q_tokens = _tokenize(query)
    scored: List[Tuple[float, Dict]] = []
    for d in deduped:
        rel = _relevance_score(q_tokens, d, diagnosis_hint)
        # Combine: keep FAISS score as base, but add relevance weight.
        # FAISS cosine scores are typically in [0,1]; we add up to ~0.75.
        combined = d["score"] + (0.75 * rel)
        scored.append((combined, d))

    scored.sort(key=lambda x: x[0], reverse=True)

    # Drop obviously irrelevant results when we have enough alternatives.
    # If overlap is ~0, rel score will be ~0. We'll enforce a weak floor.
    filtered: List[Dict] = []
    for combined, d in scored:
        rel = _relevance_score(q_tokens, d, diagnosis_hint)
        # Keep if it has at least some overlap OR if diagnosis hint matched OR if we still have too few.
        if rel >= 0.12 or (diagnosis_hint and rel >= 0.30):
            filtered.append(d)
        if len(filtered) >= int(k):
            break

    # If filtering got too strict, fall back to top-k scored (better than empty)
    if len(filtered) < int(min(k, 3)):
        filtered = [d for _, d in scored[: int(k)]]

    if _debug_enabled():
        print("\n=== RAG_DEBUG retrieve() ===")
        print(f"query: {query!r}")
        print(f"diagnosis_hint: {diagnosis_hint!r}")
        print(f"requested k: {k}  fetch_k: {fetch_k}")
        print(f"candidates: {len(candidates)}  deduped: {len(deduped)}  returned: {len(filtered)}")
        for i, d in enumerate(filtered[: min(len(filtered), 10)], start=1):
            snippet = (d.get("text") or "").replace("\n", " ").strip()[:180]
            print(f"{i:02d}. score={d['score']:.4f}  title={d.get('title','')[:80]!r}")
            print(f"    source={d.get('source','')[:120]!r}")
            print(f"    url={d.get('url','')[:120]!r}")
            print(f"    snippet={snippet!r}")
        print("=== END RAG_DEBUG ===\n")

    return filtered
