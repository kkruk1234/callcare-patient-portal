def llm_http_evidence(
    *,
    chief_complaint: str,
    diagnosis_hint: Optional[str] = None,
    context: Optional[str] = None,
    assessment_text: Optional[str] = None,
    min_urls: int = 3,
    max_urls: int = 6,
    max_per_source: int = 2,
    debug: bool = False,
    # speed controls
    max_queries: int = 3,
    title_fetch_n: int = 8,
    title_timeout_s: int = 4,
    trace_fn: Optional[callable] = None,
    model: str = "gpt-4o-mini",
    **_ignored: Any,
) -> List[EvidenceRef]:
    if OpenAI is None:
        raise RuntimeError("openai SDK not available; cannot run web_search evidence retrieval")

    cc = (chief_complaint or "").strip()
    if not cc:
        raise ValueError("chief_complaint is required")

    anchor = (assessment_text or "").strip() or (diagnosis_hint or "").strip() or (context or "").strip() or cc
    anchor = _shorten(anchor, 220)

    keywords = _extract_keywords(anchor)
    min_matches = 2

    client = OpenAI(timeout=60)
    today = date.today().isoformat()

    def _trace(event: str, **data: Any) -> None:
        if trace_fn is None:
            return
        try:
            trace_fn(event, **data)
        except Exception:
            pass

    _trace("llm_http_evidence_start", cc=cc, dx=(diagnosis_hint or ""), anchor=anchor, max_queries=max_queries)

    candidate_urls: List[str] = []
    seen = set()

    queries = _build_queries(anchor=anchor)
    queries = queries[: max(1, int(max_queries))]

    for q in queries:
        urls = _openai_web_search_urls(
            client=client,
            query=q,
            model=model,
            debug=debug,
            trace_fn=trace_fn,
        )
        for h in hits:
            u = h.get('url','')
            t0 = h.get('title','')
            nu = _normalize_url(u)
            if not nu:
                continue
            if not _is_allowed(nu):
                continue
            if nu in seen:
                continue
            seen.add(nu)
            candidate_urls.append(nu)
    ranked = candidate_urls[:]
    candidates: List[EvidenceRef] = []
    for idx, url in enumerate(ranked):
        if idx < max(0, int(title_fetch_n)):
            title = t0 or _fallback_title_from_url(url)
        else:
            title = _fallback_title_from_url(url)

        source = _source_from_url(url)
        snippet = f"{url} | Accessed {today}"

        candidates.append(EvidenceRef(title=_clean(title), source=_clean(source), snippet=snippet))
        if len(candidates) >= 20:
            break

    # Relevance filter
    filtered: List[EvidenceRef] = []
    for r in candidates:
        if _keyword_relevant(keywords, r.title, r.snippet, min_matches=min_matches):
            filtered.append(r)

    # Do NOT allow relevance filtering to zero-out all allowlisted candidates
    if not filtered:
        filtered = candidates[:]

    # Diversity cap by source
    final: List[EvidenceRef] = []
    counts: Dict[str, int] = {}
    for r in filtered:
        src = (r.source or "Source").strip()
        counts[src] = counts.get(src, 0)
        if counts[src] >= max_per_source:
            continue
        counts[src] += 1
        final.append(r)
        if len(final) >= max_urls:
            break

    # If still short, relax diversity but keep relevance
    if len(final) < min_urls:
        for r in filtered:
            if r in final:
                continue
            final.append(r)
            if len(final) >= max_urls:
                break

    _trace("llm_http_evidence_done", refs=len(final), candidates=len(candidates), filtered=len(filtered))
    return final


def format_evidence_lines(evs: Sequence[EvidenceRef]) -> List[str]:
    lines: List[str] = []
    for e in evs:
        title = _clean(getattr(e, "title", ""))
        source = _clean(getattr(e, "source", ""))
        snip = (getattr(e, "snippet", "") or "").strip()
        if snip:
            lines.append(f"{title}. {source}. {snip}.")
        else:
            lines.append(f"{title}. {source}.")
    return lines


def _openai_web_search_urls(*, client: Any, query: str, debug: bool, trace_fn: Optional[callable]) -> List[Dict[str, str]]:
    """
    Return list of {title,url,host}. Uses web_search-provided titles (FAST).
    Forces tool use.
    """
    resp = client.responses.create(
        model="gpt-4o-mini",
        input=query,
        tools=[{"type": "web_search"}],
        tool_choice={"type": "web_search"},
        max_tool_calls=1,
        include=["web_search_call.action.sources", "web_search_call.results"],
    )

    out = getattr(resp, "output", None) or []
    items: List[Dict[str, str]] = []
    sources_len = 0
    results_len = 0

    def add(title, url):
        if not url:
            return
        nu = _normalize_url(str(url))
        if not nu:
            return
        if not _is_allowed(nu):
            return
        try:
            from urllib.parse import urlparse
            host = (urlparse(nu).netloc or "").lower()
        except Exception:
            host = ""
        t = (str(title or "")).strip()
        if not t:
            t = _fallback_title_from_url(nu)
        items.append({"title": t, "url": nu, "host": host})

    for item in out:
        itype = getattr(item, "type", None) or (item.get("type") if isinstance(item, dict) else None)
        if itype != "web_search_call":
            continue

        action = _get(item, "action", default={})
        sources = _get(action, "sources", default=[]) or []
        sources_len += _safe_len(sources)

        for s in sources:
            add(_get(s, "title", default=None), _get(s, "url", default=None))

        results = _get(item, "results", default=[]) or []
        results_len += _safe_len(results)

        for r in results:
            add(_get(r, "title", default=None), _get(r, "url", default=None) or _get(r, "link", default=None))

    if debug:
        try:
            print(f"[DEBUG web_search] sources_len={sources_len} results_len={results_len} items={len(items)} query={query!r}")
        except Exception:
            pass

    if trace_fn is not None:
        try:
            trace_fn("web_search_done", q=query, sources=sources_len, results=results_len, items=len(items))
        except Exception:
            pass

    # Deduplicate by URL keep order
    out2 = []
    seen = set()
    for it in items:
        u = it.get("url","")
        if u in seen:
            continue
        seen.add(u)
        out2.append(it)
    return out2
def _dedupe_keep_order(items: Iterable[str]) -> List[str]:
    out: List[str] = []
    seen = set()
    for x in items:
        if x in seen:
            continue
        seen.add(x)
        out.append(x)
    return out


def _build_queries(*, anchor: str) -> List[str]:
    a = anchor.strip()

    group1 = " OR ".join(["site:nice.org.uk", "site:nhs.uk", "site:cdc.gov", "site:who.int", "site:aafp.org"])
    group2 = " OR ".join(["site:idsociety.org", "site:acog.org", "site:aap.org", "site:cochranelibrary.com", "site:cochrane.org"])
    group3 = " OR ".join(["site:pubmed.ncbi.nlm.nih.gov", "site:pmc.ncbi.nlm.nih.gov", "site:ncbi.nlm.nih.gov"])

    return [
        f"({group1}) {a} outpatient management red flags",
        f"({group2}) {a} guideline recommendation",
        f"({group3}) {a} dosing acetaminophen ibuprofen adult",
    ]


def _shorten(s: str, max_chars: int) -> str:
    s = re.sub(r"\s+", " ", (s or "").strip())
    return s[:max_chars]


_STOPWORDS = {
    "a","an","the","and","or","but","if","then","to","of","in","on","at","for","with","without",
    "is","are","was","were","be","been","being","it","this","that","these","those","as","by","from",
    "i","me","my","we","our","you","your","they","their","he","she","his","her",
    "left","right","today","yesterday","week","weeks","day","days",
    "pain","hurts","hurt","ache","aches","area","localized","likely","due","minor","without","trauma",
}

def _extract_keywords(text: str) -> List[str]:
    t = (text or "").lower()
    parts = re.split(r"[^a-z0-9]+", t)
    toks: List[str] = []
    for p in parts:
        p = p.strip()
        if not p or p in _STOPWORDS or len(p) < 3:
            continue
        toks.append(p)
    out: List[str] = []
    seen = set()
    for x in toks:
        if x in seen:
            continue
        seen.add(x)
        out.append(x)
        if len(out) >= 12:
            break
    return out


def _keyword_relevant(keywords: List[str], title: str, snippet: str, min_matches: int) -> bool:
    if not keywords:
        return True
    hay = f"{title} {snippet}".lower()
    hits = 0
    for kw in keywords:
        if kw and kw in hay:
            hits += 1
            if hits >= min_matches:
                return True
    return False


def _normalize_url(url: str) -> Optional[str]:
    url = (url or "").strip().strip("()[]{}<>'\" \t\r\n")
    if not url:
        return None
    try:
        p = urlparse(url)
    except Exception:
        return None
    if p.scheme not in ("http", "https") or not p.netloc:
        return None
    q = [(k, v) for (k, v) in parse_qsl(p.query, keep_blank_values=True) if not k.lower().startswith("utm_")]
    p = p._replace(query=urlencode(q, doseq=True), fragment="")
    return urlunparse(p)


def _host(url: str) -> str:
    return (urlparse(url).netloc or "").lower()


def _is_blocked(url: str) -> bool:
    host = _host(url)
    for bad in BLOCK_HOST_SUBSTRINGS:
        if bad in host:
            return True
    return False


def _is_allowed(url: str) -> bool:
    host = _host(url)
    if host.endswith(".gov"):
        return True
    for good in ALLOW_HOST_SUBSTRINGS:
        if good in host:
            return True
    return False


def _rank_urls(urls: List[str]) -> List[str]:
    def score(u: str) -> Tuple[int, int]:
        host = _host(u)
        pref = 0
        for good in PREFERRED_HOST_SUBSTRINGS:
            if good in host:
                pref = 1
                break
        # prefer shorter URLs after pref match
        return (pref, -len(u))
    return sorted(urls, key=score, reverse=True)


def _source_from_url(url: str) -> str:
    host = _host(url)
    for key, label in SOURCE_BY_HOST:
        if key in host:
            return label
    return host or "Source"


_TITLE_RE = re.compile(r"<\s*title[^>]*>(.*?)<\s*/\s*title\s*>", re.IGNORECASE | re.DOTALL)

def _fetch_title(url: str, timeout_s: int) -> str:
    headers = {"User-Agent": "CallCareEvidenceBot/1.0", "Accept": "text/html,application/xhtml+xml"}
    try:
        req = Request(url, headers=headers)
        with urlopen(req, timeout=timeout_s) as resp:
            ctype = (resp.headers.get("Content-Type") or "").lower()
            raw = resp.read(60_000)
    except Exception:
        return _fallback_title_from_url(url)

    if "html" not in ctype and b"<html" not in raw[:5000].lower():
        return _fallback_title_from_url(url)

    try:
        text = raw.decode("utf-8", errors="ignore")
    except Exception:
        return _fallback_title_from_url(url)

    m = _TITLE_RE.search(text)
    if not m:
        return _fallback_title_from_url(url)

    title = unescape(m.group(1) or "")
    title = re.sub(r"\s+", " ", title).strip().strip(" -|•\u2013\u2014")
    return title or _fallback_title_from_url(url)


def _fallback_title_from_url(url: str) -> str:
    try:
        p = urlparse(url)
        path = (p.path or "").strip("/")
        if not path:
            return p.netloc or "Source"
        last = path.split("/")[-1]
        last = re.sub(r"\.(html|htm|php|aspx)$", "", last, flags=re.IGNORECASE)
        last = last.replace("-", " ").replace("_", " ").strip()
        return last or (p.netloc or "Source")
    except Exception:
        return "Source"


def _clean(s: str) -> str:
    s = (s or "").strip()
    return re.sub(r"\s+", " ", s)
