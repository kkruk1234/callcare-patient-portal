import hashlib
import json
import os
import re
import subprocess
import time
from dataclasses import dataclass
from pathlib import Path
from typing import Iterable, List, Optional
from urllib.parse import quote_plus, unquote, urlparse

import requests


# Project root (.../callcare)
BASE_DIR = Path(__file__).resolve().parents[2]
PACK_DIR = BASE_DIR / "data" / "packs"
LOG_DIR = BASE_DIR / "logs"
PACK_DIR.mkdir(parents=True, exist_ok=True)
LOG_DIR.mkdir(parents=True, exist_ok=True)

USER_AGENT = os.environ.get("CALLCARE_EVIDENCE_UA", "CallCareEvidenceBot/0.2 (+auto-acquire)")
TIMEOUT = float(os.environ.get("CALLCARE_ACQUIRE_TIMEOUT_SECS", "20"))
MAX_URLS = int(os.environ.get("CALLCARE_ACQUIRE_MAX_URLS", "3"))
SLEEP_SECS = float(os.environ.get("CALLCARE_ACQUIRE_SLEEP_SECS", "0.3"))

DEFAULT_ALLOWED_DOMAINS = [
    "nhs.uk",
    "nice.org.uk",
    "aafp.org",
    "cdc.gov",
    "nih.gov",
    "medlineplus.gov",
    "mayoclinic.org",
    "dailymed.nlm.nih.gov",
    "fda.gov",
]


@dataclass
class AcquireResult:
    urls: List[str]
    pack_path: Optional[str]
    ingested: bool
    reason: str


def _normalize_domain(netloc: str) -> str:
    netloc = (netloc or "").strip().lower()
    if netloc.startswith("www."):
        netloc = netloc[4:]
    return netloc


def _is_allowed(url: str, allowed_domains: Iterable[str]) -> bool:
    try:
        d = _normalize_domain(urlparse(url).netloc)
        if not d:
            return False
        for ad in allowed_domains:
            ad = _normalize_domain(ad)
            if d == ad or d.endswith("." + ad):
                return True
        return False
    except Exception:
        return False


def _dedupe_keep_order(urls: List[str]) -> List[str]:
    seen = set()
    out: List[str] = []
    for u in urls:
        u2 = (u or "").strip()
        if not u2 or u2 in seen:
            continue
        seen.add(u2)
        out.append(u2)
    return out


def _duckduckgo_html_search(query: str, *, max_results: int = 25) -> List[str]:
    """
    Lightweight search (no API key) using DuckDuckGo HTML endpoint.
    Returns a list of URLs (unfiltered).
    """
    q = (query or "").strip()
    if not q:
        return []

    url = "https://duckduckgo.com/html/?q=" + quote_plus(q)
    headers = {"User-Agent": USER_AGENT}
    r = requests.get(url, headers=headers, timeout=TIMEOUT)
    r.raise_for_status()
    html = r.text or ""

    # Extract links. DDG often wraps outbound links as /l/?uddg=<encoded>
    hrefs = re.findall(r'href="([^"]+)"', html)
    urls: List[str] = []
    for h in hrefs:
        if h.startswith("/l/?uddg=") or h.startswith("https://duckduckgo.com/l/?uddg=") or h.startswith("http://duckduckgo.com/l/?uddg="):
            m = re.search(r"uddg=([^&]+)", h)
            if m:
                try:
                    urls.append(unquote(m.group(1)))
                except Exception:
                    pass
            m = re.search(r"uddg=([^&]+)", h)
            if m:
                try:
                    urls.append(unquote(m.group(1)))
                except Exception:
                    pass
        elif h.startswith("http://") or h.startswith("https://"):
            urls.append(h)

    # Cleanup
    urls = [u.split("#")[0] for u in urls]
    urls = _dedupe_keep_order(urls)
    return urls[:max_results]


def _make_pack_id(query: str) -> str:
    h = hashlib.sha256((query or "").encode("utf-8")).hexdigest()[:12]
    return f"auto_{h}"


def _write_pack(pack_id: str, description: str, urls: List[str]) -> Path:
    pack = {"pack_id": pack_id, "description": description, "sources": [{"url": u} for u in urls]}
    path = PACK_DIR / f"{pack_id}.json"
    path.write_text(json.dumps(pack, indent=2), encoding="utf-8")
    return path


def _attempts_path() -> Path:
    return LOG_DIR / "auto_acquire_attempts.json"


def _already_attempted(pack_id: str) -> bool:
    fp = _attempts_path()
    if not fp.exists():
        return False
    try:
        data = json.loads(fp.read_text(encoding="utf-8")) or {}
        return bool(data.get(pack_id))
    except Exception:
        return False


def _mark_attempted(pack_id: str, info: dict) -> None:
    fp = _attempts_path()
    data = {}
    if fp.exists():
        try:
            data = json.loads(fp.read_text(encoding="utf-8")) or {}
        except Exception:
            data = {}
    data[pack_id] = info
    fp.write_text(json.dumps(data, indent=2), encoding="utf-8")


def _run(cmd: List[str]) -> (bool, str):
    try:
        r = subprocess.run(cmd, capture_output=True, text=True)
        out = ((r.stdout or "") + "\n" + (r.stderr or "")).strip()
        return (r.returncode == 0), out
    except Exception as e:
        return False, f"subprocess error: {e}"


def acquire_ingest_reindex(
    *,
    query: str,
    allowed_domains: Optional[List[str]] = None,
    max_urls: int = MAX_URLS,
    force: bool = False,
) -> AcquireResult:
    """
    Search -> whitelist-filter -> write JSON pack -> ingest_urls -> build_index -> reset retrieve cache.
    """
    q = (query or "").strip()
    if not q:
        return AcquireResult(urls=[], pack_path=None, ingested=False, reason="empty query")

    allowed = allowed_domains or list(DEFAULT_ALLOWED_DOMAINS)
    pack_id = _make_pack_id(q)

    if (not force) and _already_attempted(pack_id):
        return AcquireResult(urls=[], pack_path=None, ingested=False, reason=f"already attempted: {pack_id}")

    # 1) Search web
    try:
        raw_urls = _duckduckgo_html_search(q, max_results=30)
    except Exception as e:
        _mark_attempted(pack_id, {"query": q, "ok": False, "reason": f"search failed: {e}", "ts": time.time()})
        return AcquireResult(urls=[], pack_path=None, ingested=False, reason=f"search failed: {e}")

    # 2) Filter to allowed domains
    filtered = [u for u in raw_urls if _is_allowed(u, allowed)]
    filtered = _dedupe_keep_order(filtered)[: int(max_urls)]

    if not filtered:
        _mark_attempted(pack_id, {"query": q, "ok": False, "reason": "no allowed urls found", "ts": time.time()})
        return AcquireResult(urls=[], pack_path=None, ingested=False, reason="no allowed urls found")

    time.sleep(SLEEP_SECS)

    # 3) Write pack JSON
    pack_path = _write_pack(pack_id, f"Auto-acquired evidence for: {q}", filtered)

    # 4) Ingest
    ok1, out1 = _run(["python3", "-m", "app.rag.ingest_urls", "--pack", str(pack_path)])
    if not ok1:
        _mark_attempted(
            pack_id,
            {"query": q, "ok": False, "reason": "ingest failed", "ts": time.time(), "pack": str(pack_path), "urls": filtered, "out": out1[-2000:]},
        )
        return AcquireResult(urls=filtered, pack_path=str(pack_path), ingested=False, reason=f"ingest failed: {out1[-300:]}")

    # 5) Reindex
    ok2, out2 = _run(["python3", "-m", "app.rag.build_index"])
    if not ok2:
        _mark_attempted(
            pack_id,
            {"query": q, "ok": False, "reason": "index failed", "ts": time.time(), "pack": str(pack_path), "urls": filtered, "out": out2[-2000:]},
        )
        return AcquireResult(urls=filtered, pack_path=str(pack_path), ingested=True, reason=f"index failed: {out2[-300:]}")

    # 6) IMPORTANT: reload retrieve() cache so *this* run can see new index/docs.
    try:
        from app.rag.retrieve import reset_index_cache  # added by you
        reset_index_cache()
    except Exception:
        pass

    _mark_attempted(pack_id, {"query": q, "ok": True, "reason": "ok", "ts": time.time(), "pack": str(pack_path), "urls": filtered})
    return AcquireResult(urls=filtered, pack_path=str(pack_path), ingested=True, reason="ok")
