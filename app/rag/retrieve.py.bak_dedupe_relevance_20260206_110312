import json
import os
import numpy as np
import faiss

from app.clinical.embeddings import get_embedder  # EMBED_HARDEN_PATCH_V1



# --- CallCare disambiguation filters ---
def _looks_urinary(query: str) -> bool:
    q = (query or "").lower()
    urinary_terms = [
        "dysuria", "urine", "urinary", "pee", "peeing", "urination", "void", "voiding",
        "cystitis", "uti", "bladder", "urethra", "urethral"
    ]
    return any(t in q for t in urinary_terms)

def _drop_skin_burn_sense_if_urinary(query: str, results: list[dict]) -> list[dict]:
    """
    If the query is about urinary burning (e.g., 'burns when I pee'), remove results
    that are clearly about skin burns/scalds (word-sense mismatch).
    """
    if not results:
        # CallCare: word-sense disambiguation (e.g., urinary 'burning' ≠ skin burns)
        results = _drop_skin_burn_sense_if_urinary(query, results)

        return results
    if not _looks_urinary(query):
        return results

    out = []
    for r in results:
        title = str(r.get("title") or "").lower()
        url = str(r.get("url") or r.get("source") or "").lower()
        # very specific: only drop obvious burn/scald pages
        if ("burns-and-scalds" in url) or ("burns and scalds" in title) or (title.strip() == "burns and scalds"):
            continue
        out.append(r)
    return out
# --- End CallCare disambiguation filters ---

OUT_DIR = "data/index"

_model = get_embedder()  # EMBED_HARDEN_PATCH_V1
_index = faiss.read_index(os.path.join(OUT_DIR, "faiss.index"))

with open(os.path.join(OUT_DIR, "docs.json"), "r", encoding="utf-8") as f:
    _DOCS = json.load(f)


def retrieve(query: str, k: int = 5):
    if query is None:
        query = ""
    query = str(query).strip()
    if not query:
        return []

    q = _model.encode([query]).astype("float32")
    faiss.normalize_L2(q)
    scores, ids = _index.search(q, k)

    results = []
    for score, idx in zip(scores[0], ids[0]):
        try:
            d = _DOCS[int(idx)]
        except Exception:
            continue

        results.append(
            {
                "score": float(score),
                "source": d.get("source", ""),
                "title": d.get("title", "") or "Guideline excerpt",
                "url": d.get("url", "") or "",
                "text": d.get("text", "") or "",
            }
        )
    return results
