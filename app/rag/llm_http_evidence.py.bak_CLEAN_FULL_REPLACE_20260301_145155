def _now_iso_date() -> str:
    try:
        from datetime import date
        return date.today().isoformat()
    except Exception:
        return ""


def _shorten(s: str, n: int) -> str:
    s = str(s or "")
    s = re.sub(r"\s+", " ", s).strip()
    if len(s) <= n:
        return s
    return s[: n - 1].rstrip() + "…"


def _host(url: str) -> str:
    try:
        p = urlparse(url)
        return (p.netloc or "").lower().replace("www.", "").strip()
    except Exception:
        return ""


def _publisher_from_url(url: str) -> str:
    h = _host(url)
    if not h:
        return "Source"
    # compact publisher label
    parts = [p for p in h.split(".") if p]
    if len(parts) >= 2:
        core = parts[-2].upper()
        if core == "NHS":
            return "NHS"
        if core == "CDC":
            return "CDC"
        if core == "NIH":
            return "NIH"
        if core == "NICE":
            return "NICE"
        if core == "AAFP":
            return "AAFP"
        if core == "BMJ":
            return "BMJ"
        if core == "WHO":
            return "WHO"
        return parts[-2]
    return h


def _domains_allowlist() -> List[str]:
