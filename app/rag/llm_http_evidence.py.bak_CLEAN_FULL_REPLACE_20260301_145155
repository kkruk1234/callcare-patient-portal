# _CC_URLCITATION_EXTRACT_V1
def _cc_allow_hosts():
    # Authoritative-ish defaults. Adjust as you like.
    return (
        "cdc.gov","nih.gov","nlm.nih.gov","medlineplus.gov","pubmed.ncbi.nlm.nih.gov","pmc.ncbi.nlm.nih.gov",
        "aafp.org","ama-assn.org","acog.org","aap.org","idsociety.org","nice.org.uk","nhs.uk","who.int",
        "mayoclinic.org","clevelandclinic.org","merckmanuals.com",
        "bmj.com","bestpractice.bmj.com",
        "uptodate.com","dynamed.com",  # optional (may be paywalled)
    )

def _cc_is_allowed_url(u: str) -> bool:
    u = str(u or "").strip().lower()
    if not (u.startswith("http://") or u.startswith("https://")):
        return False
    # hard-deny obvious junk/aggregators
    deny = ("droracle.ai", "quora.com", "facebook.com", "tiktok.com", "pinterest.", "reddit.com")
    if any(d in u for d in deny):
        return False
    return any(h in u for h in _cc_allow_hosts())

def _cc_dedupe_keep_order(urls):
    out, seen = [], set()
    for u in urls or []:
        u = str(u or "").strip()
        if not u:
            continue
        if u in seen:
            continue
        seen.add(u)
        out.append(u)
    return out

def _cc_urls_from_message_annotations(resp_dump) -> list:
    """
    Extract URLs from Responses API message annotations:
      output[].type == "message"
        content[].annotations[].type == "url_citation"
    """
    urls = []
    try:
        outs = (resp_dump or {}).get("output") or []
        for it in outs:
            if not isinstance(it, dict) or it.get("type") != "message":
                continue
            content = it.get("content") or []
            for c in content:
                if not isinstance(c, dict):
                    continue
                anns = c.get("annotations") or []
                for a in anns:
                    if not isinstance(a, dict):
                        continue
                    if a.get("type") == "url_citation" and a.get("url"):
                        urls.append(str(a.get("url")))
    except Exception:
        return []
    return urls

def _cc_urls_from_any_text(resp_dump) -> list:
    """
    Last resort: regex scan any strings in dump for http(s) URLs.
    """
    urls = []
    def walk(x):
        if x is None:
            return
        if isinstance(x, str):
            for m in re.findall(r"https?://[^\s\)\]\}<>\"']+", x):
                urls.append(m)
            return
        if isinstance(x, list):
            for v in x:
                walk(v)
            return
        if isinstance(x, dict):
            for v in x.values():
                walk(v)
    try:
        walk(resp_dump)
    except Exception:
        return []
    return urls
