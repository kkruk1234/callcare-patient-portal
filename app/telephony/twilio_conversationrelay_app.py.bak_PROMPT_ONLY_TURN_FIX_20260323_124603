STATIC_DIR = Path("app") / "telephony" / "static"
STATIC_DIR.mkdir(parents=True, exist_ok=True)

_PENDING_FINALIZE_TASKS: Dict[str, asyncio.Task] = {}
_PENDING_NEXT_QUESTION_TASKS: Dict[str, asyncio.Task] = {}
_COMPLETING_CALLS: set[str] = set()
_COMPLETION_TASKS: Dict[str, asyncio.Task] = {}

_LAST_PROMPT_EVENT_TS: Dict[str, float] = {}
_PROMPT_EVENT_SEQ: Dict[str, int] = {}
_LAST_CALLER_ACTIVITY_TS: Dict[str, float] = {}

_TURN_STATE: Dict[str, Dict[str, Any]] = {}
_PREV_TURN_SNAPSHOT: Dict[str, Dict[str, Any]] = {}

ANSWER_SILENCE_SECONDS = 0.90
NEXT_QUESTION_DELAY_SECONDS = 0.20
POST_QUESTION_CONTINUATION_SECONDS = 1.00


def _env(name: str, default: str = "") -> str:
    return os.getenv(name, default).strip()


def _bool_env(name: str, default: bool = False) -> bool:
    val = _env(name, "")
    if not val:
        return default
    return val.lower() in {"1", "true", "yes", "on"}


def _safe_text(value: Any) -> str:
    return str(value or "").strip()


def _now_mono() -> float:
    return time.monotonic()


def _public_wss_url() -> str:
    url = _env("CALLCARE_TWILIO_WSS_URL")
    if not url:
        raise RuntimeError("CALLCARE_TWILIO_WSS_URL is not set")
    if not url.startswith("wss://"):
        raise RuntimeError("CALLCARE_TWILIO_WSS_URL must start with wss://")
    return url


def _conversationrelay_language() -> str:
    return _env("CALLCARE_TWILIO_LANGUAGE", "en-US")


def _conversationrelay_voice() -> str:
    return _env("CALLCARE_TWILIO_VOICE", "en-US-Wavenet-D")


def _conversationrelay_tts_provider() -> str:
    return _env("CALLCARE_TWILIO_TTS_PROVIDER", "Google")


def _hold_audio_url() -> str:
    return _env("CALLCARE_TWILIO_HOLD_AUDIO_URL", "")


def _build_twiml() -> str:
    url = xml_escape(_public_wss_url(), {'"': "&quot;"})
    language = xml_escape(_conversationrelay_language(), {'"': "&quot;"})
    tts_provider = xml_escape(_conversationrelay_tts_provider(), {'"': "&quot;"})
    voice = xml_escape(_conversationrelay_voice(), {'"': "&quot;"})

    return (
        '<?xml version="1.0" encoding="UTF-8"?>'
        "<Response>"
        "<Connect>"
        f'<ConversationRelay '
        f'url="{url}" '
        f'language="{language}" '
        f'ttsProvider="{tts_provider}" '
        f'voice="{voice}" '
        f'reportInputDuringAgentSpeech="any" '
        f'debug="speaker-events">'
        '<Parameter name="app" value="callcare" />'
        '<Parameter name="channel" value="voice" />'
        "</ConversationRelay>"
        "</Connect>"
        "</Response>"
    )


def _validate_ws_signature_if_enabled(websocket: WebSocket) -> bool:
    if not _bool_env("TWILIO_VALIDATE_SIGNATURE", False):
        return True

    auth_token = _env("TWILIO_AUTH_TOKEN")
    if not auth_token:
        log.warning("TWILIO_VALIDATE_SIGNATURE=1 but TWILIO_AUTH_TOKEN is empty")
        return False

    try:
        from twilio.request_validator import RequestValidator
    except Exception:
        log.warning("twilio package not installed; cannot validate X-Twilio-Signature")
        return False

    sig = websocket.headers.get("x-twilio-signature", "")
    if not sig:
        log.warning("Missing X-Twilio-Signature header on WebSocket handshake")
        return False

    url = str(websocket.url)
    try:
        validator = RequestValidator(auth_token)
        ok = validator.validate(url, {}, sig)
        if not ok:
            log.warning("Twilio WebSocket signature validation failed for %s", url)
        return ok
    except Exception as e:
        log.exception("Twilio WebSocket signature validation error: %s", e)
        return False


def _speech_wait_seconds(text: str, minimum: float = 1.0) -> float:
    words = len((text or "").split())
    seconds = 0.42 * words + 0.8
    return seconds if seconds > minimum else minimum


def _ensure_age_disclaimer(text: str) -> str:
    t = str(text or "")
    low = t.lower()
    disclaimer = (
        "The next few questions may feel repetitive, but they are important "
        "for medication safety and treatment decisions. "
    )
    if (("how old are you" in low) or ("what is your age" in low)) and disclaimer.strip().lower() not in low:
        return disclaimer + t
    return t


def _get_turn_state(call_sid: str) -> Dict[str, Any]:
    state = _TURN_STATE.get(call_sid)
    if state is None:
        state = {
            "current_question": "",
            "current_answer_parts": [],
            "client_speaking": False,
            "agent_speaking": False,
            "question_started_at": 0.0,
            "agent_speaking_until": 0.0,
        }
        _TURN_STATE[call_sid] = state
    return state


def _clear_turn_state(call_sid: str) -> None:
    _TURN_STATE.pop(call_sid, None)


def _set_agent_speaking(call_sid: str, text: str) -> None:
    turn_state = _get_turn_state(call_sid)
    turn_state["agent_speaking"] = True
    turn_state["agent_speaking_until"] = _now_mono() + _speech_wait_seconds(text, minimum=1.0)


def _clear_agent_speaking(call_sid: str) -> None:
    turn_state = _get_turn_state(call_sid)
    turn_state["agent_speaking"] = False
    turn_state["agent_speaking_until"] = 0.0


def _is_agent_speaking(call_sid: str) -> bool:
    turn_state = _get_turn_state(call_sid)
    if bool(turn_state.get("agent_speaking")):
        return True
    until = float(turn_state.get("agent_speaking_until", 0.0) or 0.0)
    return _now_mono() < until


def _mark_caller_activity(call_sid: str) -> None:
    _LAST_CALLER_ACTIVITY_TS[call_sid] = _now_mono()


def _caller_quiet_long_enough(call_sid: str) -> bool:
    last_ts = float(_LAST_CALLER_ACTIVITY_TS.get(call_sid, 0.0) or 0.0)
    if last_ts <= 0:
        return True
    return (_now_mono() - last_ts) >= ANSWER_SILENCE_SECONDS


def _cancel_pending_finalize_task(call_sid: str) -> None:
    task = _PENDING_FINALIZE_TASKS.pop(call_sid, None)
    if task is not None and not task.done():
        task.cancel()


def _cancel_pending_next_question_task(call_sid: str) -> None:
    task = _PENDING_NEXT_QUESTION_TASKS.pop(call_sid, None)
    if task is not None and not task.done():
        task.cancel()


def _snapshot_bridge_session(call_sid: str) -> Optional[Dict[str, Any]]:
    session = bridge.get_session(call_sid)
    if session is None:
        return None
    try:
        return {
            "state": copy.deepcopy(session.state),
            "transcript": copy.deepcopy(session.transcript),
            "last_prompt_text": str(getattr(session, "last_prompt_text", "") or ""),
            "safety_disclaimer_spoken": bool(getattr(session, "safety_disclaimer_spoken", False)),
        }
    except Exception:
        log.exception("Failed snapshotting session for callSid=%s", call_sid)
        return None


def _restore_bridge_session(call_sid: str, snapshot: Dict[str, Any]) -> bool:
    session = bridge.get_session(call_sid)
    if session is None:
        return False
    try:
        session.state = copy.deepcopy(snapshot["state"])
        session.transcript = copy.deepcopy(snapshot["transcript"])
        session.last_prompt_text = str(snapshot.get("last_prompt_text") or "")
        session.safety_disclaimer_spoken = bool(snapshot.get("safety_disclaimer_spoken", False))
        session.partial_user_buffer = []
        return True
    except Exception:
        log.exception("Failed restoring bridge session for callSid=%s", call_sid)
        return False


def _set_prev_turn_snapshot(call_sid: str, snapshot: Dict[str, Any], answer_text: str, question_text: str) -> None:
    _PREV_TURN_SNAPSHOT[call_sid] = {
        "snapshot": snapshot,
        "answer_text": _safe_text(answer_text),
        "question_text": _safe_text(question_text),
        "expires_at": _now_mono() + 15.0,
    }


def _clear_prev_turn_snapshot(call_sid: str) -> None:
    _PREV_TURN_SNAPSHOT.pop(call_sid, None)


def _cleanup_prev_turn_snapshot(call_sid: str) -> None:
    snap = _PREV_TURN_SNAPSHOT.get(call_sid)
    if not snap:
        return
    expires_at = float(snap.get("expires_at") or 0.0)
    if expires_at and _now_mono() > expires_at:
        _PREV_TURN_SNAPSHOT.pop(call_sid, None)


def _try_restore_previous_turn(call_sid: str, incoming_text: str) -> bool:
    _cleanup_prev_turn_snapshot(call_sid)
    snap = _PREV_TURN_SNAPSHOT.get(call_sid)
    if not snap:
        return False

    snapshot = snap.get("snapshot")
    answer_text = _safe_text(snap.get("answer_text"))
    question_text = _safe_text(snap.get("question_text"))

    if not snapshot or not answer_text:
        _PREV_TURN_SNAPSHOT.pop(call_sid, None)
        return False

    ok = _restore_bridge_session(call_sid, snapshot)
    if not ok:
        _PREV_TURN_SNAPSHOT.pop(call_sid, None)
        return False

    turn_state = _get_turn_state(call_sid)
    turn_state["current_question"] = question_text
    turn_state["current_answer_parts"] = [answer_text]
    turn_state["client_speaking"] = True
    turn_state["agent_speaking"] = False
    turn_state["agent_speaking_until"] = 0.0

    log.info(
        "Restored previous turn: callSid=%s question=%r answer=%r incoming=%r",
        call_sid,
        question_text,
        answer_text,
        incoming_text,
    )

    _PREV_TURN_SNAPSHOT.pop(call_sid, None)
    return True


async def _send_text(
    ws: WebSocket,
    call_sid: str,
    text: str,
    *,
    interruptible: bool = True,
    preemptible: bool = True,
) -> None:
    cleaned = _ensure_age_disclaimer(str(text or ""))
    cleaned = cleaned.replace("9-1-1", "emergency services immediately")
    cleaned = cleaned.replace("911", "emergency services immediately")
    cleaned = cleaned.replace("yes/no", "yes or no")
    cleaned = cleaned.replace("yes / no", "yes or no")
    cleaned = cleaned.replace("yes/no/unknown", "yes or no or unknown")

    token = cleaned
    if _conversationrelay_tts_provider() == "Google":
        cleaned = cleaned.replace("emergency services immediately", '<say-as interpret-as="digits">911</say-as>')
        token = f"<speak><break time=\"180ms\"/>{cleaned}</speak>"
    else:
        cleaned = cleaned.replace("emergency services immediately", "9 1 1")

    _set_agent_speaking(call_sid, cleaned)

    payload = {
        "type": "text",
        "token": token,
        "last": True,
        "interruptible": bool(interruptible),
        "preemptible": bool(preemptible),
    }
    await ws.send_text(json.dumps(payload))


async def _send_play(ws: WebSocket, source: str, loop: int = 999) -> None:
    if not source:
        return
    payload = {
        "type": "play",
        "source": source,
        "loop": loop,
        "preemptible": True,
        "interruptible": False,
    }
    await ws.send_text(json.dumps(payload))


async def _send_end(ws: WebSocket, reason_code: str = "callcare-complete", reason: str = "CallCare call complete") -> None:
    payload = {
        "type": "end",
        "handoffData": json.dumps(
            {
                "reasonCode": reason_code,
                "reason": reason,
            }
        ),
    }
    await ws.send_text(json.dumps(payload))


async def _try_start_hold_music(ws: WebSocket) -> None:
    hold_url = _hold_audio_url()
    if not hold_url:
        log.info("No CALLCARE_TWILIO_HOLD_AUDIO_URL set; skipping hold music")
        return
    try:
        log.info("Starting hold music from %s", hold_url)
        await _send_play(ws, hold_url, loop=999)
    except Exception:
        log.exception("Hold music failed to start")


async def _deliver_next_question(websocket: WebSocket, call_sid: str, question_text: str) -> None:
    try:
        await asyncio.sleep(NEXT_QUESTION_DELAY_SECONDS)

        if call_sid in _COMPLETING_CALLS:
            return

        turn_state = _get_turn_state(call_sid)
        turn_state["current_question"] = question_text
        turn_state["current_answer_parts"] = []
        turn_state["question_started_at"] = _now_mono()

        await _send_text(websocket, call_sid, question_text, interruptible=True, preemptible=True)
        await asyncio.sleep(0.15)

    except asyncio.CancelledError:
        raise
    except Exception:
        log.exception("Failed delivering next question for callSid=%s", call_sid)
    finally:
        current = _PENDING_NEXT_QUESTION_TASKS.get(call_sid)
        if current is not None and current.done():
            _PENDING_NEXT_QUESTION_TASKS.pop(call_sid, None)


async def _run_completion_flow(websocket: WebSocket, call_sid: str) -> None:
    try:
        log.info("Starting bridge.complete_session for callSid=%s", call_sid)

        summary = await asyncio.wait_for(
            asyncio.to_thread(bridge.complete_session, call_sid),
            timeout=120.0,
        )

        log.info("Completed bridge.complete_session for callSid=%s", call_sid)

        await asyncio.sleep(0.10)
        summary_text = f"Thank you for holding. {summary}"
        await _send_text(websocket, call_sid, summary_text, interruptible=False, preemptible=False)

        await asyncio.sleep(0.35)

        goodbye_text = "Thank you, goodbye."
        await _send_text(websocket, call_sid, goodbye_text, interruptible=False, preemptible=False)
        await asyncio.sleep(1.2)

        await _send_end(websocket, reason_code="callcare-complete", reason="CallCare intake complete")
        bridge.end_session(call_sid)

    except asyncio.TimeoutError:
        log.exception("bridge.complete_session timed out for callSid=%s", call_sid)
        fallback = (
            "Your intake is complete, but I need more time to finish processing your chart. "
            "A physician will review your information. Thank you, goodbye."
        )
        try:
            await _send_text(websocket, call_sid, fallback, interruptible=False, preemptible=False)
            await asyncio.sleep(0.35)
            await _send_text(websocket, call_sid, "Thank you, goodbye.", interruptible=False, preemptible=False)
            await asyncio.sleep(1.2)
            await _send_end(websocket, reason_code="callcare-timeout", reason="CallCare processing timeout")
        except Exception:
            pass
        bridge.end_session(call_sid)

    except Exception:
        log.exception("Completion flow failed for callSid=%s", call_sid)
        try:
            err_text = "I'm sorry, something went wrong while processing your call. Please call back if you still need help."
            await _send_text(websocket, call_sid, err_text, interruptible=False, preemptible=False)
            await asyncio.sleep(0.35)
            await _send_text(websocket, call_sid, "Thank you, goodbye.", interruptible=False, preemptible=False)
            await asyncio.sleep(1.2)
            await _send_end(websocket, reason_code="callcare-error", reason="CallCare processing error")
        except Exception:
            pass
        bridge.end_session(call_sid)

    finally:
        _COMPLETING_CALLS.discard(call_sid)
        _COMPLETION_TASKS.pop(call_sid, None)
        _cancel_pending_finalize_task(call_sid)
        _cancel_pending_next_question_task(call_sid)
        _clear_prev_turn_snapshot(call_sid)
        _clear_turn_state(call_sid)
        _LAST_CALLER_ACTIVITY_TS.pop(call_sid, None)


async def _start_completion_now(websocket: WebSocket, call_sid: str) -> None:
    if call_sid in _COMPLETING_CALLS:
        return

    _COMPLETING_CALLS.add(call_sid)
    _cancel_pending_finalize_task(call_sid)
    _cancel_pending_next_question_task(call_sid)
    _clear_prev_turn_snapshot(call_sid)

    processing_text = "Thank you for your responses. This may take up to a minute to process. Please stay on the line."
    log.info("Starting processing speech for callSid=%s", call_sid)
    await _send_text(websocket, call_sid, processing_text, interruptible=False, preemptible=False)
    log.info("Finished processing speech for callSid=%s", call_sid)

    await _try_start_hold_music(ws=websocket)

    log.info("Scheduling completion task for callSid=%s", call_sid)
    task = asyncio.create_task(_run_completion_flow(websocket, call_sid))
    _COMPLETION_TASKS[call_sid] = task


async def _finalize_current_answer_after_silence(websocket: WebSocket, call_sid: str) -> None:
    try:
        await asyncio.sleep(ANSWER_SILENCE_SECONDS)

        if call_sid in _COMPLETING_CALLS:
            return

        turn_state = _get_turn_state(call_sid)

        if turn_state.get("client_speaking", False):
            return

        if not _caller_quiet_long_enough(call_sid):
            return

        answer_text = " ".join(
            [_safe_text(x) for x in turn_state.get("current_answer_parts", []) if _safe_text(x)]
        ).strip()

        log.info("ConversationRelay prompt debounced final: callSid=%s text=%r", call_sid, answer_text)

        if not answer_text:
            session = bridge.get_session(call_sid)
            reprompt = ""
            if session is not None:
                reprompt = _safe_text(getattr(session, "last_prompt_text", ""))
            if reprompt:
                await _send_text(websocket, call_sid, reprompt, interruptible=True, preemptible=True)
            return

        current_question = _safe_text(turn_state.get("current_question"))
        snapshot = _snapshot_bridge_session(call_sid)

        result = bridge.handle_prompt_text(call_sid, answer_text)

        if result.done:
            log.info("Bridge returned done=True for callSid=%s", call_sid)
            await _start_completion_now(websocket, call_sid)
            return

        if snapshot is not None:
            _set_prev_turn_snapshot(
                call_sid=call_sid,
                snapshot=snapshot,
                answer_text=answer_text,
                question_text=current_question,
            )

        _cancel_pending_next_question_task(call_sid)
        task = asyncio.create_task(_deliver_next_question(websocket, call_sid, result.say))
        _PENDING_NEXT_QUESTION_TASKS[call_sid] = task

    except asyncio.CancelledError:
        raise
    except Exception:
        log.exception("Failed finalizing current answer for callSid=%s", call_sid)
    finally:
        current = _PENDING_FINALIZE_TASKS.get(call_sid)
        if current is not None and current.done():
            _PENDING_FINALIZE_TASKS.pop(call_sid, None)


