@app.api_route("/twilio/voice", methods=["GET", "POST"])
async def twilio_voice(request: Request) -> PlainTextResponse:
    if request.method == "POST":
        form = await request.form()
        from_number = str(form.get("From", "") or "")
        to_number = str(form.get("To", "") or "")
    else:
        from_number = str(request.query_params.get("From", "") or "")
        to_number = str(request.query_params.get("To", "") or "")

    stream_url = _stream_wss_url()

    xml = (
        '<?xml version="1.0" encoding="UTF-8"?>'
        "<Response>"
        "<Connect>"
        f'<Stream url="{_xml_escape(stream_url)}">'
        f'<Parameter name="from_number" value="{_xml_escape(from_number)}" />'
        f'<Parameter name="to_number" value="{_xml_escape(to_number)}" />'
        "</Stream>"
        "</Connect>"
        "</Response>"
    )
    return PlainTextResponse(content=xml, media_type="application/xml")


@app.websocket("/twilio/media-stream")
async def twilio_media_stream(ws: WebSocket) -> None:
    await ws.accept()
    session: Optional[MediaSession] = None

    try:
        while True:
            msg = await ws.receive_text()
            payload = json.loads(msg)
            event = payload.get("event")

            if event == "connected":
                _log("websocket connected")
                continue

            if event == "start":
                start = payload.get("start", {}) or {}
                custom = start.get("customParameters", {}) or {}

                call_sid = str(start.get("callSid") or "")
                stream_sid = str(start.get("streamSid") or payload.get("streamSid") or "")
                from_number = str(custom.get("from_number") or "")
                to_number = str(custom.get("to_number") or "")

                session = MediaSession(
                    call_sid=call_sid,
                    stream_sid=stream_sid,
                    from_number=from_number,
                    to_number=to_number,
                    ws=ws,
                )
                SESSIONS[call_sid] = session

                await _start_deepgram_stream(session)

                _, opening = bridge.start_session(call_sid, from_number=from_number, to_number=to_number)
                opening = _clean(f"{OPENING_HELLO} {opening}")
                session.expected_prompt = opening.replace(f"{OPENING_HELLO} ", "", 1) if opening.startswith(f"{OPENING_HELLO} ") else opening
                _log(f"{call_sid} BOT OPENING: {opening}")

                session.ignore_audio_until = time.time() + 1.2
                asyncio.create_task(_speak_text(session, opening, phase="question", allow_barge_in=False))
                continue

            if session is None:
                continue

            if event == "media":
                if session.ended:
                    continue

                now = time.time()
                media = payload.get("media", {}) or {}
                b64 = media.get("payload")
                if not b64:
                    continue

                chunk = base64.b64decode(b64)
                rms = _rms_mulaw(chunk)

                if now < session.ignore_audio_until:
                    continue

                if session.hold_playing or session.finishing or session.current_phase in {"processing", "summary", "goodbye", "hold"}:
                    continue

                if session.bot_speaking:
                    if not session.allow_barge_in:
                        continue
                    if now < session.barge_in_enabled_at:
                        continue
                    if rms < CALLCARE_RMS_THRESHOLD:
                        continue

                    if not session.pending_barge_mulaw:
                        session.pending_barge_started_at = now

                    session.pending_barge_mulaw.extend(chunk)

                    voiced_ms = int((now - session.pending_barge_started_at) * 1000) if session.pending_barge_started_at else 0
                    if voiced_ms >= CALLCARE_BARGE_IN_MIN_MS:
                        _log(f"{session.call_sid} barge-in detected")
                        await _send_clear(session)

                        if session.dg_ws:
                            with suppress(Exception):
                                await session.dg_ws.send(chunk)
                        session.pending_barge_mulaw.clear()
                        session.pending_barge_started_at = 0.0
                    continue

                if session.dg_ws:
                    with suppress(Exception):
                        await session.dg_ws.send(chunk)
                continue

            if event == "mark":
                mark = payload.get("mark", {}) or {}
                name = str(mark.get("name") or "")
                evt = session.mark_waiters.get(name)
                if evt:
                    evt.set()
                continue

            if event == "stop":
                _log(f"{session.call_sid} stop received")
                session.ended = True
                break

    except WebSocketDisconnect:
        _log("websocket disconnected")
    except Exception as e:
        msg = str(e)
        if "WebSocket is not connected" in msg or "Unexpected ASGI message" in msg:
            _log("websocket disconnected")
        else:
            _log(f"websocket error: {e}")
    finally:
        if session is not None:
            session.ended = True
            await _close_deepgram_stream(session)
            SESSIONS.pop(session.call_sid, None)
            with suppress(Exception):
                bridge.end_session(session.call_sid)
