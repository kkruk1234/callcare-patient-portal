def _parse_flag_list(val: str) -> list:
    """
    Parse a YAML-ish list on one line, like:
      urgent_today: ["code1","code2"]
    Returns list of codes.
    """
    val = (val or "").strip()
    if "[" in val and "]" in val:
        inside = val.split("[", 1)[1].rsplit("]", 1)[0]
        parts = [p.strip().strip('"').strip("'") for p in inside.split(",") if p.strip()]
        return [p for p in parts if p]
    return []


def _load_questions_for(pathway_id: str) -> list:
    """
    Load questions from YAML minimally (prompt + id + store_as + type),
    plus optional yes/no flag logic:

      if_yes:
        add_flags:
          urgent_today: ["fever_possible_infection"]

    Parsed into:
      question["if_yes_add_flags"] = {"urgent_today": ["fever_possible_infection"]}
    """
    fp = PATHWAYS_DIR / f"{pathway_id}.yaml"
    if not fp.exists():
        return []

    lines = fp.read_text(encoding="utf-8", errors="ignore").splitlines()

    questions = []
    in_questions = False
    current = None

    in_if = None  # "yes" or "no" or None
    in_add_flags = False

    for line in lines:
        if line.strip().startswith("questions:"):
            in_questions = True
            continue
        if not in_questions:
            continue

        if line.strip().startswith("- id:"):
            if current:
                questions.append(current)
            current = {
                "id": line.split(":", 1)[1].strip(),
                "prompt": "",
                "store_as": "",
                "type": "text",
                "if_yes_add_flags": {},
                "if_no_add_flags": {},
            }
            in_if = None
            in_add_flags = False
            continue

        if current is None:
            continue

        s = line.strip()

        if s.startswith("prompt:"):
            val = s.split(":", 1)[1].strip()
            val = val.strip('"').strip("'")
            current["prompt"] = val
            continue

        if s.startswith("store_as:"):
            current["store_as"] = s.split(":", 1)[1].strip()
            continue

        if s.startswith("type:"):
            current["type"] = s.split(":", 1)[1].strip()
            continue

        if s.startswith("if_yes:"):
            in_if = "yes"
            in_add_flags = False
            continue

        if s.startswith("if_no:"):
            in_if = "no"
            in_add_flags = False
            continue

        if s.startswith("add_flags:"):
            if in_if in ("yes", "no"):
                in_add_flags = True
            continue

        if in_add_flags and in_if in ("yes", "no") and ":" in s:
            bucket, rest = s.split(":", 1)
            bucket = bucket.strip()
            codes = _parse_flag_list(rest)
            if codes:
                key = "if_yes_add_flags" if in_if == "yes" else "if_no_add_flags"
                current.setdefault(key, {})
                current[key].setdefault(bucket, [])
                for c in codes:
                    if c not in current[key][bucket]:
                        current[key][bucket].append(c)

    if current:
        questions.append(current)

    return questions


def _next_prompt_orig(state: CallState) -> str:
    state.symptoms.setdefault("_answers", {})
    state.symptoms.setdefault("_pathway", {})
    _ensure_flags(state)

    if state.stage == "PATHWAY_Q" and state.symptoms.get("_reprompt"):
        return state.symptoms["_reprompt"]

    if state.stage == "CONSENT":
        return (
            "I'm an automated medical assistant. "
            "If this is an emergency, hang up and call 911. "
            "Do you consent to continue? (yes/no)"
        )

    if state.stage == "CHIEF":
        return "What's your main concern?"

    if state.stage == "AGE_BAND":
        return "How old are you? Please say your age in years (for example: 37)."

    if state.stage == "ALLERGIES":
        return "Do you have any medication allergies? If yes, list them. If no, say no."

    if state.stage == "WEIGHT":
        return "For dosing safety, what is the child's weight? You can say pounds or kilograms (for example: 28 pounds)."

    if state.stage == "PATHWAY_Q":
        pathway_id = state.symptoms.get("_pathway", {}).get("id") or "cough_uri"
        questions = _load_questions_for(pathway_id)
        idx = int(state.symptoms.get("_q_idx", 0))

        if idx >= len(questions):
            disp, reasons = _derive_disposition(state)
            state.symptoms["_disposition"] = disp
            state.symptoms["_disposition_reasons"] = reasons
            state.stage = "DECIDE"
            return ""

        q = questions[idx]
        return q.get("prompt") or "Please tell me more."

    if state.stage == "DECIDE":
        return ""

    return "I'm sorry — I got lost. Let's start over. What's your main concern?"


def _process_answer_orig(state: CallState, text: str) -> None:
    state.symptoms.setdefault("_answers", {})
    state.symptoms.setdefault("_pathway", {})
    _ensure_flags(state)

    t = _norm(text)

    if state.stage == "CONSENT":
        yn = _yesno(t)
        if yn is True:
            state.stage = "CHIEF"
        else:
            state.stage = "DECIDE"
        return

    if state.stage == "CHIEF":
        state.chief_complaint = text.strip()
        state.symptoms["_pathway"] = _pick_pathway(state.chief_complaint)
        state.symptoms["_q_idx"] = 0
        state.stage = "AGE_BAND"
        return

    if state.stage == "AGE_BAND":
        age_years = _parse_age_years(text)
        state.age_years = age_years
        state.age_band = _age_band_from_years(age_years) if age_years is not None else "unknown"
        state.stage = "PATHWAY_Q"
        return

    if state.stage == "PATHWAY_Q":
        pathway_id = state.symptoms.get("_pathway", {}).get("id") or "cough_uri"
        questions = _load_questions_for(pathway_id)
        idx = int(state.symptoms.get("_q_idx", 0))

        if idx >= len(questions):
            disp, reasons = _derive_disposition(state)
            state.symptoms["_disposition"] = disp
            state.symptoms["_disposition_reasons"] = reasons
            state.stage = "DECIDE"
            return

        q = questions[idx]
        qid = q.get("id") or f"q{idx}"
        store_as = q.get("store_as") or qid
        qtype = q.get("type") or "text"

        if qtype == "yesno":
            yn = _yesno(t)
            if yn is None:
                state.symptoms["_reprompt"] = f"Please answer yes or no. {q.get('prompt','')}"
                return

            state.symptoms["_answers"][qid] = "yes" if yn else "no"
            state.symptoms[store_as] = yn

            flag_map = q.get("if_yes_add_flags", {}) if yn else q.get("if_no_add_flags", {})
            if isinstance(flag_map, dict):
                for bucket, codes in flag_map.items():
                    if isinstance(codes, list):
                        for code in codes:
                            _add_flag(state, str(bucket), str(code))

        else:
            state.symptoms["_answers"][qid] = text.strip()
            state.symptoms[store_as] = text.strip()

        state.symptoms["_q_idx"] = idx + 1
        state.symptoms.pop("_reprompt", None)

        if state.symptoms["_q_idx"] >= len(questions):
            disp, reasons = _derive_disposition(state)
            state.symptoms["_disposition"] = disp
            state.symptoms["_disposition_reasons"] = reasons
            state.stage = "DECIDE"

        return

    state.stage = "CONSENT"



