def _norm(s: str) -> str:
    return (s or "").strip().lower()


def _yesno(s: str) -> Optional[bool]:
    s = _norm(s)
    if s in ["y", "yes", "yeah", "yep", "sure", "ok", "okay"]:
        return True
    if s in ["n", "no", "nope"]:
        return False
    return None


def _parse_age_years(s: str):
    """
    Parse age from common spoken forms:
    - "37" -> 37
    - "6 months" -> 0.5
    - "18 months" -> 1.5
    - "2 years" -> 2
    Returns float years or None.
    """
    t = _norm(s)
    if not t:
        return None
    # Extract number
    m = re.search(r"(\d+(\.\d+)?)", t)
    if not m:
        return None
    num = float(m.group(1))
    # Unit handling
    if "month" in t:
        return round(num / 12.0, 3)
    if "year" in t or "yr" in t:
        return num
    # If no unit, assume years
    return num


def _age_band_from_years(age_years: float) -> str:
    if age_years is None:
        return "unknown"
    if age_years < 3:
        return "0-2"
    if age_years < 13:
        return "3-12"
    if age_years < 18:
        return "13-17"
    if age_years < 65:
        return "18-64"
    return "65+"

def _ensure_flags(state: CallState) -> None:
    """
    Ensure flags buckets exist. Stored in state.symptoms so we do not have to change CallState model.
    """
    state.symptoms.setdefault(
        "_flags",
        {"ed_now": [], "urgent_today": [], "routine": [], "cannot_rule_out": []},
    )


def _add_flag(state: CallState, bucket: str, code: str) -> None:
    _ensure_flags(state)
    bucket = (bucket or "").strip()
    code = (code or "").strip()
    if not bucket or not code:
        return
    if bucket not in state.symptoms["_flags"]:
        return
    if code not in state.symptoms["_flags"][bucket]:
        state.symptoms["_flags"][bucket].append(code)


def _derive_disposition(state: CallState) -> Tuple[str, list]:
    """
    Deterministic disposition based on flags.
    Priority: ed_now > urgent_today > routine (default)
    """
    _ensure_flags(state)
    flags = state.symptoms["_flags"]
    if flags.get("ed_now"):
        return "ed_now", list(flags["ed_now"])
    if flags.get("urgent_today"):
        return "urgent_today", list(flags["urgent_today"])
    return "routine", list(flags.get("routine", []))


def _load_pathways() -> Dict[str, dict]:
    out: Dict[str, dict] = {}
    if PATHWAYS_DIR.exists():
        for fp in PATHWAYS_DIR.glob("*.yaml"):
            txt = fp.read_text(encoding="utf-8", errors="ignore")
            out[fp.stem] = {"_raw": txt}
    return out


def _extract_keywords(yaml_text: str) -> Tuple[str, list]:
    """
    Extract pathway id and keywords from our simple YAML shape.
    We rely on the structure you created (match:any_keywords).
    """
    pid = ""
    keywords = []
    for line in yaml_text.splitlines():
        line_stripped = line.strip()
        if line_stripped.startswith("id:"):
            pid = line_stripped.split(":", 1)[1].strip()
        if "any_keywords:" in line_stripped:
            if "[" in line_stripped and "]" in line_stripped:
                inside = line_stripped.split("[", 1)[1].rsplit("]", 1)[0]
                parts = [p.strip().strip('"').strip("'") for p in inside.split(",") if p.strip()]
                keywords.extend(parts)
    return pid, [k.lower() for k in keywords if k]


