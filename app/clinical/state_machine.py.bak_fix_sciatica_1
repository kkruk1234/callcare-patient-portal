import re

def _parse_age_years_wrapper(s: str):
    t = (s or "").strip().lower()
    if not t:
        return None
    m = re.search(r"(\d+(\.\d+)?)", t)
    if not m:
        return None
    num = float(m.group(1))
    if "month" in t:
        return round(num / 12.0, 3)
    if "year" in t or "yr" in t:
        return num
    return num

def _age_band_from_years_wrapper(age_years: float) -> str:
    if age_years is None:
        return "unknown"
    if age_years < 3:
        return "0-2"
    if age_years < 13:
        return "3-12"
    if age_years < 18:
        return "13-17"
    if age_years < 65:
        return "18-64"
    return "65+"

def next_prompt(state: CallState) -> str:
    """
    Wrapper around _next_prompt_orig:
    - prompts actual age (not bands)
    - prompts allergies and pediatric weight stages
    - auto-skips redundant pathway age question when age_years known
    """
    # Our added stages
    if state.stage == "AGE_BAND":
        return "How old are you? Please say your age in years (for example: 37)."

    if state.stage == "ALLERGIES":
        return "Do you have any medication allergies? If yes, list them. If no, say no."

    if state.stage == "WEIGHT":
        return "For dosing safety, what is the child's weight? You can say pounds or kilograms (for example: 28 pounds)."

    # Let the original state machine produce its prompt
    prompt = _next_prompt_orig(state)

    # Auto-skip pathway question like "How old is the child?" if we already have age_years
    if state.stage == "PATHWAY_Q" and getattr(state, "age_years", None) is not None:
        pl = (prompt or "").strip().lower()
        if "how old is the child" in pl or pl.startswith("how old is the child"):
            # Mark something in answers, advance q index, and ask again
            state.symptoms.setdefault("_answers", {})
            state.symptoms.setdefault("_q_idx", 0)
            idx = int(state.symptoms.get("_q_idx", 0))
            state.symptoms["_answers"]["pathway_child_age"] = str(state.age_years)
            state.symptoms["_q_idx"] = idx + 1
            # Get next prompt from original
            return _next_prompt_orig(state)

    return prompt

def process_answer(state: CallState, text: str) -> None:
    """
    Wrapper around _process_answer_orig:
    - AGE_BAND now captures numeric age_years and then routes to ALLERGIES
    - ALLERGIES stores drug allergies; routes to WEIGHT if pediatric, else PATHWAY_Q
    - WEIGHT stores weight then routes to PATHWAY_Q
    Everything else delegates to the original process handler.
    """
    # AGE_BAND: capture actual age, then go to ALLERGIES
    if state.stage == "AGE_BAND":
        age_years = _parse_age_years_wrapper(text)
        try:
            state.age_years = age_years
        except Exception:
            # If model doesn't have age_years yet, store in symptoms as fallback
            state.symptoms["age_years"] = age_years
        state.age_band = _age_band_from_years_wrapper(age_years) if age_years is not None else "unknown"
        state.stage = "ALLERGIES"
        return

    # ALLERGIES: store then route
    if state.stage == "ALLERGIES":
        state.symptoms["drug_allergies"] = (text or "").strip()
        ay = getattr(state, "age_years", None)
        if ay is None:
            ay = state.symptoms.get("age_years", None)
        if ay is not None and ay < 18:
            state.stage = "WEIGHT"
        else:
            state.stage = "PATHWAY_Q"
        return

    # WEIGHT: store then route to pathway questions
    if state.stage == "WEIGHT":
        state.symptoms["weight"] = (text or "").strip()
        state.stage = "PATHWAY_Q"
        return

    # Delegate everything else to original handler
    _process_answer_orig(state, text)

