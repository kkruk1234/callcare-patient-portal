# Web evidence ONLY (no YAML/manifest/library/reindex/title-gates)
# ----------------------------

def _dedupe_by_url_or_title(items: List[Dict[str, Any]], max_total: int) -> List[Dict[str, Any]]:
    out: List[Dict[str, Any]] = []
    seen = set()
    for e in items or []:
        if not isinstance(e, dict):
            continue
        url = str(e.get("url") or e.get("source_url") or e.get("source") or "").strip()
        title = str(e.get("title") or "").strip()
        key = (url or title).lower()
        if not key:
            continue
        if key in seen:
            continue
        seen.add(key)
        out.append(e)
        if len(out) >= max_total:
            break
    return out


def _web_evidence(state: CallState, min_items: int = 4, max_items: int = 8) -> Tuple[List[EvidenceRef], List[Dict[str, Any]]]:
    """
    Returns:
      - evidence_refs: List[EvidenceRef] for LLM prompting
      - evidence_print: List[dict] for finalize.py / ReviewPacket
    """
    cc = _get_cc(state)
    dx = _get_dx_cue(state)

    # Queries: use query-only generator if it exists, else deterministic.
    queries: List[str] = []
    try:
        qmod = importlib.import_module("app.clinical.query_llm")
        fn = getattr(qmod, "generate_evidence_queries", None)
        if callable(fn):
            queries = fn(state, max_queries=4) or []
    except Exception:
        queries = []

    queries = [str(q).strip() for q in (queries or []) if str(q).strip()]
    if not queries:
        anchor = dx or cc or "outpatient condition"
        queries = [
            f"{anchor} outpatient evaluation guideline",
            f"{anchor} treatment medication dosing duration contraindications",
            f"{anchor} red flags return precautions testing",
        ]

    # Fetch via llm_http_evidence (web retrieval tool)
    raw: List[Dict[str, Any]] = []
    try:
        from app.rag.llm_http_evidence import llm_http_evidence  # type: ignore
        raw = llm_http_evidence(
            chief_complaint=cc or "chief complaint",
            assessment_text=dx or None,
            queries=queries[:4],
            min_urls=max(min_items, 4),
            max_urls=max_items,
            max_queries=min(4, len(queries)),
            max_per_publisher=1,
            debug=False,
        ) or []
    except Exception:
        raw = []

    raw = [r for r in raw if isinstance(r, dict)]
    raw = _dedupe_by_url_or_title(raw, max_total=max_items)

    # Convert to EvidenceRef for prompt
    refs: List[EvidenceRef] = []
    for r in raw:
        # require URL-ish somewhere for auditability
        url = str(r.get("url") or r.get("source_url") or r.get("source") or "").strip()
        if not (url.startswith("http://") or url.startswith("https://")):
            continue
        try:
            refs.append(_mk_evidence_ref(ensure_evidence_dict(r)))
        except Exception:
            continue

    # Printable dicts for finalize/review packet
    today = datetime.now(timezone.utc).date().isoformat()
    ev_print: List[Dict[str, Any]] = []
    for r in raw:
        try:
            r2 = dict(r)
            if not r2.get("accessed"):
                r2["accessed"] = today
            # normalize url/source fields
            url = str(r2.get("url") or r2.get("source_url") or "").strip()
            if url and not r2.get("source"):
                r2["source"] = url
            ev_print.append(r2)
        except Exception:
            continue

    # Ensure minimum evidence count target if possible (without strict gating)
    if len(ev_print) < min_items:
        _opt2_debug_log(f"[web_evidence] WARNING: ev_print={len(ev_print)} (<{min_items}) cc={cc!r} dx={dx!r}")

    return refs, ev_print


# ----------------------------
# Note generation (preserve formatting via llm_note_writer)
# ----------------------------

def _generate_llm_soap(state: CallState, evidence_refs: List[EvidenceRef]) -> Tuple[str, str]:
    try:
        llm = importlib.import_module("app.clinical.llm_note_writer")
        build_prompt = getattr(llm, "build_prompt", None)
        generate_note_text = getattr(llm, "generate_note_text", None)
        if not callable(build_prompt) or not callable(generate_note_text):
            return ("", "llm_note_writer missing build_prompt/generate_note_text")

        prompt = build_prompt(state=state, evidence=evidence_refs)

        for attempt in range(3):
            try:
                txt = generate_note_text(prompt) or ""

                # If writer returns JSON, extract soap_text ONLY. Do NOT leak queries into the note.
                try:
                    raw = (txt or "").strip()
                    if raw.startswith("{") and raw.endswith("}"):
                        obj = json.loads(raw)
                        if isinstance(obj, dict):
                            soap = str(obj.get("soap_text") or "").strip()
                            if soap:
                                txt = soap
                except Exception:
                    pass

                if isinstance(txt, str) and txt.strip():
                    return (txt, "")
                return ("", "empty LLM output")
            except Exception as e:
                msg = str(e)
                # basic retry for 429
                if ("429" in msg) or ("rate" in msg.lower()):
                    if attempt < 2:
                        time.sleep(2.5 * (attempt + 1))
                        continue
                    return ("", "rate limit (429)")
                return ("", f"{type(e).__name__}: {msg[:160]}")
        return ("", "LLM failure")
    except Exception as e:
        return ("", f"{type(e).__name__}: {str(e)[:160]}")


def build_note(state: CallState) -> NoteDraft:
    """
    FINALIZE-ALIGNED behavior:
      - build SOAP via llm_note_writer (preserves your formatting rules there)
      - retrieve evidence via web only (4–8 sources)
      - attach printable dict evidence to NoteDraft.evidence (so finalize/review packet sees it)
      - no YAML/manifests/local library/reindex/title gates
      - no diagnosis-specific hard-coding
    """
    # Evidence first so it can guide the plan/assessment phrasing
    evidence_refs, evidence_print = _web_evidence(state, min_items=4, max_items=8)

    soap_text, err = _generate_llm_soap(state, evidence_refs)
    if not soap_text.strip():
        soap_text = f"(Warn) Could not build note: {err}\n"

    # Pregnancy sentence single placement (keep, but minimal)
    soap_text = _insert_preg_last_sentence_S(soap_text, _preg_sentence(_preg_norm(state)))

    # Med protocol loading can remain (no hard-coded dosing here)
    try:
        _ = load_med_protocol_for_state(state)
        _ = protocol_med_names(state)
    except Exception:
        pass

    return NoteDraft(
        soap=soap_text,
        patient_instructions=[],
        clinician_questions=[],
        risk_flags=[],
        evidence=evidence_print,  # IMPORTANT: dicts so finalize/_set_packet_evidence works
    )


def build_note_with_reason(state: CallState, *args, **kwargs):
    note = build_note(state)
    return note, None


def fallback_note_from_state(state: CallState) -> NoteDraft:
    return build_note(state)
