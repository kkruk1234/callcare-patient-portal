def _opt2_debug_log(msg: str):
    try:
        os.makedirs("logs", exist_ok=True)
        open("logs/opt2_debug.txt", "a", encoding="utf-8").write(msg + "\n")
    except Exception:
        pass


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def _model_field_names(model_cls) -> set:
    if hasattr(model_cls, "model_fields"):  # pydantic v2
        return set(model_cls.model_fields.keys())
    if hasattr(model_cls, "__fields__"):  # pydantic v1
        return set(model_cls.__fields__.keys())
    return set()


_EVID_FIELDS = _model_field_names(EvidenceRef)


def _mk_evidence_ref(data: Dict[str, Any]) -> EvidenceRef:
    """
    Normalize web evidence dict -> EvidenceRef.
    We prefer URL-backed sources (auditable) and sanitize titles for Evidence Used.
    """
    if isinstance(data, dict):
        src = (data.get("source") or "").strip()
        url = (data.get("url") or data.get("source_url") or data.get("link") or "").strip()
        if url and (src.startswith("library/") or src == ""):
            data = dict(data)
            data["source"] = url
        if url and "url" in _EVID_FIELDS:
            data = dict(data)
            data["url"] = url

    safe = {k: v for k, v in (data or {}).items() if k in _EVID_FIELDS}

    if "source" in _EVID_FIELDS and not safe.get("source"):
        safe["source"] = "Unknown source"
    if "snippet" in _EVID_FIELDS and safe.get("snippet") is None:
        safe["snippet"] = ""
    if "title" in _EVID_FIELDS and not safe.get("title"):
        safe["title"] = safe.get("source", "Evidence")

    ev = EvidenceRef(**safe)

    # Single-line title, collapse whitespace, cap length
    try:
        t = "" if ev.title is None else str(ev.title)
        parts = [x.strip() for x in t.splitlines() if x.strip()]
        t = parts[0] if parts else t.strip()
        t = re.sub(r"\s+", " ", t).strip()
        if len(t) > 160:
            t = t[:157].rstrip() + "..."
        ev.title = t
    except Exception:
        pass

    return ev


def _symptoms(state: CallState) -> Dict[str, Any]:
    sx = getattr(state, "symptoms", None) or {}
    return sx if isinstance(sx, dict) else {}


def _get_answers_dict(state: CallState) -> Dict[str, Any]:
    sx = _symptoms(state)
    a = sx.get("_answers")
    return a if isinstance(a, dict) else {}


def _get_cc(state: CallState) -> str:
    try:
        cc = (getattr(state, "chief_complaint", None) or "").strip()
        if cc:
            return cc
    except Exception:
        pass
    sx = _symptoms(state)
    for k in ("chief_complaint", "chief", "cc", "complaint"):
        v = sx.get(k)
        if isinstance(v, str) and v.strip():
            return v.strip()
    return ""


def _get_dx_cue(state: CallState) -> str:
    """
    Best-effort dx cue. NO hard-coded diagnoses. NO title-gating.
    """
    for k in ("working_diagnosis", "pathway_label", "pathway_id"):
        try:
            v = getattr(state, k, None)
            if isinstance(v, str) and v.strip():
                return v.strip().replace("_", " ")
        except Exception:
            pass

    sx = _symptoms(state)
    for k in ("_dx_inferred", "working_diagnosis", "diagnosis", "dx", "final_dx"):
        v = sx.get(k)
        if isinstance(v, str) and v.strip():
            return v.strip().replace("_", " ")

    raw = sx.get("_llm_intake_extract")
    if isinstance(raw, dict):
        for k in ("working_diagnosis", "diagnosis", "primary_diagnosis", "impression", "assessment"):
            v = raw.get(k)
            if isinstance(v, str) and v.strip():
                return v.strip()

    # fallback to CC
    return _get_cc(state)


# ----------------------------
# Pregnancy: enforce single placement in S: (minimal)
# ----------------------------

def _preg_norm(state: CallState) -> str:
    ans = _get_answers_dict(state)
    raw = ans.get("pregnancy_possible")
    if raw is None or str(raw).strip() == "":
        raw = getattr(state, "pregnancy_possible", None)
    s = ("" if raw is None else str(raw)).strip().lower()
    if not s:
        return ""
    if s in ("y", "yes", "true", "pregnant"):
        return "yes"
    if s in ("n", "no", "false", "not pregnant"):
        return "no"
    if s in ("na", "n/a", "not applicable", "not_applicable", "male"):
        return "not_applicable"
    return "unknown"


def _preg_sentence(norm: str) -> str:
    v = (norm or "").strip().lower()
    if v in ("not_applicable", "na", "n/a"):
        return ""
    if v == "yes":
        return "Patient is pregnant."
    if v == "no":
        return "Patient is not pregnant."
    if v in ("unknown", ""):
        return "Patient is unsure about pregnancy status."
    return "Patient is unsure about pregnancy status."


def _strip_preg_sentences(text: str) -> str:
    if not text:
        return text
    text = re.sub(r"\bPatient is pregnant\.\s*", "", text, flags=re.IGNORECASE)
    text = re.sub(r"\bPatient is not pregnant\.\s*", "", text, flags=re.IGNORECASE)
    text = re.sub(r"\bPatient is unsure about pregnancy status\.\s*", "", text, flags=re.IGNORECASE)
    return text


def _insert_preg_last_sentence_S(soap_text: str, preg_sentence: str) -> str:
    txt = (soap_text or "").strip()
    txt = _strip_preg_sentences(txt).strip()
    if not preg_sentence:
        return txt + ("\n" if txt and not txt.endswith("\n") else "")

    m = re.search(r"(?s)^\s*S:\s*(.*?)\n\s*O:\s*(.*?)\n\s*A:\s*(.*?)\n\s*P:\s*(.*)\s*$", txt)
    if not m:
        return txt + ("\n" if txt and not txt.endswith("\n") else "")

    s, o, a, p = [x.strip() for x in m.groups()]
    if s and not s.endswith((".", "!", "?")):
        s += "."
    s = (s + " " + preg_sentence).strip()

    out = f"S: {s}\n\nO: {o}\n\nA: {a}\n\nP:\n{p}".strip() + "\n"
    return out


