def _bool(v):
    if isinstance(v, bool):
        return v
    if v is None:
        return False
    s = str(v).strip().lower()
    return s in ("yes", "true", "y", "1")

def apply_new_pathway_rules(pathway_id: str, symptoms: dict, flags: dict) -> None:
    """
    Mutates flags dict:
      flags["ed_now"], flags["urgent_today"], flags["routine"], flags["cannot_rule_out"]
    """
    pid = (pathway_id or "").strip()

    def ed(code): flags["ed_now"].append(code)
    def urgent(code): flags["urgent_today"].append(code)
    def routine(code): flags["routine"].append(code)

    # Chest pain
    if pid == "chest_pain":
        severe_breathing = _bool(symptoms.get("severe_breathing"))
        syncope = _bool(symptoms.get("syncope"))
        high_risk = _bool(symptoms.get("high_risk_associated"))
        radiation = _bool(symptoms.get("radiation"))
        exertional = _bool(symptoms.get("exertional"))
        if severe_breathing or syncope:
            ed("chest_pain_severe_breathing_or_syncope")
        elif high_risk and (radiation or exertional):
            ed("chest_pain_high_risk_features")
        else:
            urgent("chest_pain_needs_same_day_eval")

    # Stroke/neuro
    if pid == "stroke_neuro":
        face = _bool(symptoms.get("face_droop"))
        arm = _bool(symptoms.get("one_sided_weakness"))
        speech = _bool(symptoms.get("speech_change"))
        onset = _bool(symptoms.get("sudden_recent_onset"))
        if onset and (face or arm or speech):
            ed("possible_stroke_fast_positive")
        else:
            urgent("neuro_symptoms_need_eval")

