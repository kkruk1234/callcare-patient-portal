def now_iso() -> str:
    try:
        return datetime.now(timezone.utc).isoformat()
    except Exception:
        return datetime.utcnow().replace(tzinfo=timezone.utc).isoformat()


def _safe_str(x: Any) -> str:
    try:
        return str(x if x is not None else "").strip()
    except Exception:
        return ""


def _get_answers_dict(state: Any) -> Dict[str, Any]:
    if state is None:
        return {}
    try:
        a = getattr(state, "answers", None)
        if isinstance(a, dict):
            return a
    except Exception:
        pass
    try:
        sx = getattr(state, "symptoms", None) or {}
        if isinstance(sx, dict):
            a = sx.get("_answers")
            if isinstance(a, dict):
                return a
    except Exception:
        pass
    return {}


def _set_answers_dict(state: Any, ans: Dict[str, Any]) -> None:
    if state is None or not isinstance(ans, dict):
        return
    try:
        if hasattr(state, "answers"):
            state.answers = ans
    except Exception:
        pass
    try:
        sx = getattr(state, "symptoms", None)
        if isinstance(sx, dict):
            a = sx.get("_answers")
            if isinstance(a, dict):
                a.update(ans)
                sx["_answers"] = a
    except Exception:
        pass


def _extract_cc_from_state(state: Any) -> str:
    try:
        return _safe_str(getattr(state, "chief_complaint", "") or getattr(state, "chief", "") or "")
    except Exception:
        return ""


def _extract_dx_cue_from_note(note: Any) -> str:
    soap = _safe_str(getattr(note, "soap", "") or "")
    if not soap:
        return ""
    m = re.search(r"(?ims)\nA:\s*\n(.*?)(?:\n\n|\nP:\s*\n|\Z)", soap)
    if m:
        first = (m.group(1) or "").strip().splitlines()[0].strip()
        return " ".join(first.split()[:16]).strip()
    m2 = re.search(r"(?im)^\s*A:\s*(.+)$", soap)
    if m2:
        return " ".join((m2.group(1) or "").strip().split()[:16]).strip()
    return ""


def _packet_fields() -> set:
    try:
        if hasattr(ReviewPacket, "model_fields"):
            return set(ReviewPacket.model_fields.keys())
        if hasattr(ReviewPacket, "__fields__"):
            return set(ReviewPacket.__fields__.keys())
    except Exception:
        pass
    return set()


def _evidence_ref_fields() -> set:
    """
    Detect whether EvidenceRef supports url/accessed. If not, we embed url/accessed
    into the title so your Evidence Used printout retains citations.
    """
    try:
        from app.core.models import EvidenceRef  # type: ignore
        if hasattr(EvidenceRef, "model_fields"):
            return set(EvidenceRef.model_fields.keys())
        if hasattr(EvidenceRef, "__fields__"):
            return set(EvidenceRef.__fields__.keys())
    except Exception:
        pass
    return set()


def _as_full_evidence_dicts(refs: List[Any]) -> List[Dict[str, Any]]:
    """
    Web-only evidence item shape:
      {title, source, url, accessed, snippet}
    Keep full dicts so note_builder + Evidence Used printing can cite properly.
    """
    today = ""
    try:
        today = date.today().isoformat()
    except Exception:
        today = ""

    out: List[Dict[str, Any]] = []
    seen = set()

    for r in refs or []:
        if r is None:
            continue
        if isinstance(r, dict):
            d = r
        else:
            d = {}
            try:
                for k in ("title", "source", "url", "accessed", "snippet"):
                    d[k] = getattr(r, k, None)
            except Exception:
                d = {}

        title = _safe_str(d.get("title") or "")
        url = _safe_str(d.get("url") or "")
        source = _safe_str(d.get("source") or "Source")
        accessed = _safe_str(d.get("accessed") or today)
        snippet = _safe_str(d.get("snippet") or d.get("text") or "")

        if not title and not url:
            continue

        key = url or title
        if key in seen:
            continue
        seen.add(key)

        out.append(
            {
                "title": title or (url[:160] if url else "Source"),
                "source": source or "Source",
                "url": url,
                "accessed": accessed,
                "snippet": snippet,
            }
        )

    return out


def _store_evidence_on_state(state: Any, evidence: List[Dict[str, Any]]) -> None:
    if state is None or not evidence:
        return
    try:
        if hasattr(state, "evidence_used"):
            state.evidence_used = evidence
    except Exception:
        pass

    ans = _get_answers_dict(state)
    if isinstance(ans, dict):
        ans["evidence_used"] = evidence
        ans["evidence"] = evidence
        _set_answers_dict(state, ans)

    try:
        sx = getattr(state, "symptoms", None)
        if isinstance(sx, dict):
            sx["evidence_used"] = evidence
            a = sx.get("_answers")
            if isinstance(a, dict):
                a["evidence_used"] = evidence
                a["evidence"] = evidence
                sx["_answers"] = a
    except Exception:
        pass


def _get_queries_from_query_llm(state: Any, note_for_context: Any, max_q: int = 4) -> List[str]:
    """
    STRICT:
    - Use query_llm output (answers['evidence_search_queries']) OR call query_llm.generate_evidence_queries(state).
    - No anatomy heuristics. No medication strings.
    - Generic fallback only if query_llm fails.
    """
    ans = _get_answers_dict(state)

    qs0 = None
    try:
        qs0 = ans.get("evidence_search_queries")
    except Exception:
        qs0 = None

    if isinstance(qs0, list):
        qs = [_safe_str(x) for x in qs0 if _safe_str(x)]
        if qs:
            return qs[:max_q]

    # Try query_llm
    try:
        import importlib
        qmod = importlib.import_module("app.clinical.query_llm")
        gen = getattr(qmod, "generate_evidence_queries", None)
        if callable(gen):
            out = gen(state)
            if isinstance(out, list):
                qs = [_safe_str(x) for x in out if _safe_str(x)]
                if qs:
                    ans = _get_answers_dict(state)
                    ans["evidence_search_queries"] = qs[:max_q]
                    _set_answers_dict(state, ans)
                    return qs[:max_q]
    except Exception:
        pass

    # Generic fallback
    cc = _extract_cc_from_state(state)
    dx = _extract_dx_cue_from_note(note_for_context)
    anchor = (dx or cc or "patient complaint").strip()

    qs = [
        f"{anchor} outpatient management guideline",
        f"{anchor} first line treatment dosing duration contraindications",
        f"{anchor} supportive care return precautions red flags",
        f"{anchor} evaluation when to image or refer",
    ]
    return [" ".join(_safe_str(x).split()) for x in qs if _safe_str(x)][:max_q]


def _title_with_citation(title: str, accessed: str, url: str) -> str:
    """
    Guarantee citations survive even if packet/printing only uses title.
    If schema doesn't support url/accessed, we embed them into title.
    """
    t = _safe_str(title)
    a = _safe_str(accessed)
    u = _safe_str(url)
    if u and a:
        return f"{t}. Accessed {a}. {u}"
    if u:
        return f"{t}. {u}"
    if a:
        return f"{t}. Accessed {a}."
    return t


def _set_packet_evidence(kwargs: Dict[str, Any], evidence_full: List[Dict[str, Any]]) -> None:
    """
    Build packet evidence; do NOT mutate evidence_full.
    If EvidenceRef lacks url/accessed, embed citations into title and snippet.
    """
    fields = _packet_fields()
    evref_fields = _evidence_ref_fields()
    allow_url = "url" in evref_fields
    allow_accessed = "accessed" in evref_fields

    ev_packet: List[Dict[str, str]] = []
    for e in evidence_full or []:
        if not isinstance(e, dict):
            continue
        title = _safe_str(e.get("title") or "")
        source = _safe_str(e.get("source") or "Source")
        url = _safe_str(e.get("url") or "")
        accessed = _safe_str(e.get("accessed") or "")
        snippet = _safe_str(e.get("snippet") or "")

        if not title:
            continue

        if not allow_url or not allow_accessed:
            title = _title_with_citation(title, accessed, url)

        row: Dict[str, str] = {"title": title, "source": source or "Source"}

        if allow_url:
            row["url"] = url
        if allow_accessed:
            row["accessed"] = accessed

        # Also preserve citations in snippet if schema doesn't support fields
        if (not allow_url) and url:
            snippet = (snippet + "\n" if snippet else "") + f"URL: {url}"
        if (not allow_accessed) and accessed:
            snippet = (snippet + "\n" if snippet else "") + f"Accessed: {accessed}"

        row["snippet"] = snippet
        ev_packet.append(row)

    if "evidence" in fields:
        kwargs["evidence"] = ev_packet
    if "evidence_used" in fields:
        kwargs["evidence_used"] = ev_packet


def _write_finalized(packet: Any, session_id: str) -> None:
    out_path = FINAL_DIR / f"{session_id}.json"
    try:
        if hasattr(packet, "model_dump_json"):
            out_path.write_text(packet.model_dump_json(indent=2), encoding="utf-8")
            return
    except Exception:
        pass
    try:
        if hasattr(packet, "json"):
            out_path.write_text(packet.json(indent=2), encoding="utf-8")
            return
    except Exception:
        pass
    try:
        out_path.write_text(json.dumps(packet, indent=2, default=str), encoding="utf-8")
    except Exception:
        pass


def finalize(session_id: str, note: Any, state: Any = None) -> Any:
    if session_id is None or not str(session_id).strip():
        session_id = str(uuid.uuid4())

    # 0) Ensure we have a note object for minimal context (dx cue) if query_llm fallback is needed
    note0 = note
    if note0 is None:
        try:
            from app.clinical.note_builder import fallback_note_from_state  # type: ignore
            note0 = fallback_note_from_state(state)
        except Exception:
            try:
                note0 = NoteDraft()  # type: ignore
            except Exception:
                note0 = {"soap": ""}

    try:
        if isinstance(note0, tuple):
            note0 = note0[0]
    except Exception:
        pass

    # 1) Queries (query_llm-owned)
    qs = _get_queries_from_query_llm(state, note0, max_q=4)
    ans = _get_answers_dict(state)
    if isinstance(ans, dict):
        ans["evidence_search_queries"] = qs
        _set_answers_dict(state, ans)

    # 2) Retrieve web evidence FIRST
    cc = _extract_cc_from_state(state)
    dx_cue = _extract_dx_cue_from_note(note0)

    evidence_full: List[Dict[str, Any]] = []
    try:
        from app.rag.llm_http_evidence import llm_http_evidence  # type: ignore
        assessment_text = (dx_cue or "").strip() or None

        refs = llm_http_evidence(
            chief_complaint=cc or "chief complaint",
            assessment_text=assessment_text,
            queries=qs,
            min_urls=4,
            max_urls=10,
            max_queries=min(4, len(qs)),
            max_per_publisher=2,
            debug=False,
        ) or []

        if isinstance(refs, list) and refs:
            evidence_full = _as_full_evidence_dicts(refs)
    except Exception:
        evidence_full = []

    if evidence_full:
        _store_evidence_on_state(state, evidence_full)

    # 3) Build note AFTER evidence exists (so Plan can use it)
    note_final = note
    try:
        from app.clinical.note_builder import build_note_with_reason  # type: ignore
        if state is not None:
            note_final, _ = build_note_with_reason(state)
    except Exception:
        note_final = note0

    try:
        if isinstance(note_final, tuple):
            note_final = note_final[0]
    except Exception:
        pass

    # Ensure note carries full evidence dicts (this is what your Evidence Used printer expects)
    try:
        if hasattr(note_final, "evidence"):
            cur = getattr(note_final, "evidence", None)
            if not isinstance(cur, list) or len(cur) == 0:
                setattr(note_final, "evidence", evidence_full)
    except Exception:
        pass

    # 4) Build ReviewPacket
    fields = _packet_fields()
    kwargs: Dict[str, Any] = {}

    if "packet_id" in fields:
        kwargs["packet_id"] = str(uuid.uuid4())
    if "created_at" in fields:
        kwargs["created_at"] = now_iso()
    if "session_id" in fields:
        kwargs["session_id"] = _safe_str(session_id)

    if "note" in fields:
        kwargs["note"] = note_final

    _set_packet_evidence(kwargs, evidence_full)

    if "state" in fields:
        kwargs["state"] = state

    try:
        packet = ReviewPacket(**kwargs) if ReviewPacket is not None else kwargs  # type: ignore
    except Exception:
        packet = kwargs

    _write_finalized(packet, _safe_str(session_id))
    return packet


