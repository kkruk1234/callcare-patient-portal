def _get_age_years(state: CallState) -> Optional[int]:
    for attr in ("age", "age_years", "patient_age"):
        val = getattr(state, attr, None)
        if val is None:
            continue
        s = str(val).strip()
        if not s:
            continue
        try:
            return int(float(s))
        except Exception:
            continue
    return None


def _get_chief(state: CallState) -> str:
    cc = (getattr(state, "chief_complaint", None) or "").strip()
    return cc


def _get_symptoms_dict(state: CallState) -> Dict[str, Any]:
    sym = getattr(state, "symptoms", None)
    return sym if isinstance(sym, dict) else {}


def _truthy(v: Any) -> bool:
    if v is True:
        return True
    if isinstance(v, (int, float)):
        return v != 0
    if isinstance(v, str):
        return v.strip().lower() in ("yes", "y", "true", "1", "present", "positive")
    return False


def _find_first(symptoms: Dict[str, Any], keys: List[str]) -> Optional[Any]:
    # direct match first
    for k in keys:
        if k in symptoms and symptoms[k] not in (None, ""):
            return symptoms[k]
    # case-insensitive / contains match
    lower_map = {str(k).lower(): k for k in symptoms.keys()}
    for k in keys:
        lk = k.lower()
        if lk in lower_map:
            orig = lower_map[lk]
            v = symptoms.get(orig)
            if v not in (None, ""):
                return v
    # contains
    for want in [k.lower() for k in keys]:
        for kk, vv in symptoms.items():
            if vv in (None, ""):
                continue
            if want in str(kk).lower():
                return vv
    return None


def _pregnancy_sentence(state: CallState) -> str:
    """
    Required phrasing rules:
    ✅ “Patient is not pregnant”
    ❌ “pregnancy not possible”
    Supports yes/no/unknown/not applicable when available.
    """
    # Try explicit status-like fields first
    for attr in ("pregnancy_status", "pregnancy", "pregnant"):
        v = getattr(state, attr, None)
        if v is None:
            continue
        if isinstance(v, str):
            s = v.strip().lower()
            if s in ("yes", "y", "true", "pregnant"):
                return "Patient is pregnant."
            if s in ("no", "n", "false", "not pregnant"):
                return "Patient is not pregnant."
            if s in ("unknown", "unsure", "not sure"):
                return "Pregnancy status is unknown."
            if s in ("na", "n/a", "not applicable", "not_applicable"):
                return "Pregnancy is not applicable."
        if v is True:
            return "Patient is pregnant."
        if v is False:
            return "Patient is not pregnant."

    # Fall back to pregnancy_possible boolean if that's what the state uses
    pp = getattr(state, "pregnancy_possible", None)
    if pp is True:
        # if pregnancy_possible is used as "could be pregnant"
        return "Pregnancy status is unknown."
    if pp is False:
        return "Patient is not pregnant."

    return ""


def _format_hours(value: Any) -> Optional[int]:
    if value is None:
        return None
    try:
        # allow "37", "37.0", 37
        h = int(round(float(str(value).strip())))
        if h < 0:
            return None
        return h
    except Exception:
        return None


def _tick_subjective_bits(state: CallState) -> List[str]:
    """
    Tick-bite-specific phrasing:
    - Attachment time is ATTACHMENT duration, not symptom duration.
    - Bullseye rash phrasing supported.
    """
    symptoms = _get_symptoms_dict(state)
    pid = str(getattr(state, "pathway_id", "") or getattr(state, "pathway", "") or "").strip().lower()
    if "tick" not in pid and "bite" not in pid:
        # still allow if symptoms contain strong tick markers
        has_tick_marker = any("tick" in str(k).lower() for k in symptoms.keys())
        if not has_tick_marker:
            return []

    out: List[str] = []

    # Bullseye / EM
    bullseye = _find_first(symptoms, ["bullseye_rash", "bullseye", "erythema_migrans", "em_rash"])
    if _truthy(bullseye):
        out.append("Reports a tick bite with a bullseye rash present.")
    else:
        # If they reported tick bite without bullseye, we can keep it neutral
        out.append("Reports a tick bite.")

    # Attachment duration (hours)
    attach = _find_first(symptoms, [
        "tick_attachment_hours",
        "tick_attached_hours",
        "attached_hours",
        "attachment_hours",
        "tick_attached_duration_hours",
        "tick_attached_duration",
    ])
    h = _format_hours(attach)
    if h is not None:
        out.append(f"Tick was attached for approximately {h} hours.")

    # Systemic symptoms
    systemic = _find_first(symptoms, ["systemic_symptoms", "fever", "chills", "body_aches", "myalgias"])
    if systemic is not None:
        if _truthy(systemic):
            out.append("Systemic symptoms reported.")
        else:
            out.append("No systemic symptoms reported.")

    # Location / exposure state
    loc = _find_first(symptoms, ["exposure_state", "state", "location_state", "exposure_location", "location"])
    if loc not in (None, ""):
        out.append(f"Exposure occurred in {str(loc).strip()}.")

    return out


def _build_subjective(state: CallState) -> str:
    age = _get_age_years(state)
    cc = _get_chief(state)

    bits: List[str] = []

    # Start sentence with age if available
    if age is not None:
        if cc:
            bits.append(f"{age}-year-old patient reports {cc}.")
        else:
            bits.append(f"{age}-year-old patient presents for a telephone visit.")
    else:
        if cc:
            bits.append(f"Patient reports {cc}.")
        else:
            bits.append("Patient presents for a telephone visit.")

    # Pathway-specific enrichment (tick for now; safe/no-regex)
    bits.extend(_tick_subjective_bits(state))

    # Pregnancy sentence (required)
    preg = _pregnancy_sentence(state)
    if preg:
        bits.append(preg)

    # De-duplicate identical sentences while preserving order
    seen = set()
    clean: List[str] = []
    for s in bits:
        s2 = " ".join(str(s).split()).strip()
        if not s2:
            continue
        if s2 in seen:
            continue
        seen.add(s2)
        clean.append(s2)

    return " ".join(clean).strip()


def _replace_subjective_in_soap(soap_text: str, new_subjective: str) -> str:
    """
    Replace S: section in an existing SOAP note text with deterministic Subjective.
    Avoid regex. Uses simple line scanning:
      S: ... until next line starting with O:/A:/P:
    If no S: found, prepend one.
    """
    if not new_subjective:
        return soap_text

    lines = (soap_text or "").splitlines()
    if not lines:
        return f"S:\n{new_subjective}\n"

    # find S: line
    s_idx = None
    for i, ln in enumerate(lines):
        if ln.strip().startswith("S:"):
            s_idx = i
            break

    if s_idx is None:
        # prepend Subjective
        return f"S:\n{new_subjective}\n" + (soap_text.strip() + "\n")

    # find end of S block
    end_idx = len(lines)
    for j in range(s_idx + 1, len(lines)):
        st = lines[j].strip()
        if st.startswith("O:") or st.startswith("A:") or st.startswith("P:"):
            end_idx = j
            break

    new_lines = []
    new_lines.extend(lines[:s_idx])
    new_lines.append("S:")
    new_lines.append(new_subjective)
    new_lines.extend(lines[end_idx:])
    return "\n".join(new_lines).rstrip() + "\n"


def _fallback_structured_soap(state: CallState) -> str:
    subj = _build_subjective(state)
    disposition, plan, safety = _decision_bits(state)
    lines: List[str] = []
    lines.append("S:")
    lines.append(subj if subj else "Chief complaint: Not stated")
    lines.append("O: Telephone encounter. No vitals available.")
    if disposition:
        lines.append(f"A: Disposition: {disposition}")
    else:
        lines.append("A: Assessment based on phone history and pathway logic.")
    lines.append("P:")
    if plan:
        for p in plan:
            lines.append(f"- {p}")
    else:
        lines.append("- Plan pending reviewer confirmation (Tier-based autonomy).")
    if safety:
        lines.append("Safety net:")
        for s in safety:
            lines.append(f"- {s}")
    return "\n".join(lines).strip() + "\n"


def _build_patient_instructions(disposition: str, safety_net: List[str], allow_otc: bool) -> List[str]:
    """
    Pathway-first patient instructions:
    - Use safety_net bullets as the core content (these should be pathway-specific).
    - Add only minimal framing (emergent vs non-emergent).
    - Avoid unrelated global red-flag boilerplate.
    """
    emergent = _is_emergent_disposition(disposition)
    out: List[str] = []

    if emergent:
        out.append("Based on this phone evaluation, seek emergency in-person evaluation now.")
        out.append("If you feel unsafe to travel, consider calling emergency services or having someone take you.")
    else:
        out.append("If you are not improving as expected, or if symptoms worsen, seek in-person medical care.")

    # Core pathway-specific safety net
    for s in safety_net[:10]:
        out.append(s)

    # Optional OTC line (only when appropriate)
    if allow_otc:
        out.append("Medication options you may consider if safe (no dosing by phone): acetaminophen (Tylenol) if you can take it safely; ibuprofen (Advil) if you can take it safely.")

    return out


def build_note(state: CallState) -> NoteDraft:
    disposition, plan, safety = _decision_bits(state)

    # Evidence: decision first, then RAG
    ev_dec = _evidence_from_decision(state)
    ev_rag = _evidence_from_rag(state, max_snips=6) if len(ev_dec) < 3 else []
    evidence = _merge_evidence(ev_dec, ev_rag, max_total=5)

    # Rich note via LLM writer if present
    soap_text = ""
    try:
        llm = importlib.import_module("app.clinical.llm_note_writer")
        build_prompt = getattr(llm, "build_prompt", None)
        generate_note_text = getattr(llm, "generate_note_text", None)
        if callable(build_prompt) and callable(generate_note_text):
            try:
                prompt = build_prompt(state=state, evidence=evidence)
            except TypeError:
                try:
                    prompt = build_prompt(state, evidence)
                except TypeError:
                    prompt = build_prompt(state)
            soap_text = generate_note_text(prompt) or ""
    except Exception:
        soap_text = ""

    if not soap_text.strip():
        soap_text = _fallback_structured_soap(state)

    # Deterministic Subjective always wins
    subj = _build_subjective(state)
    soap_text = _replace_subjective_in_soap(soap_text, subj)

    allow_otc = (not _is_emergent_disposition(disposition)) and (not _avoid_otc_from_text(plan, soap_text))

    patient_instructions = _build_patient_instructions(disposition, safety, allow_otc)

    clinician_questions: List[str] = []
    allergies = getattr(state, "allergies", None)
    if allergies:
        clinician_questions.append(f"Medication allergies: {allergies}")

    risk_flags: List[str] = []
    rf = getattr(state, "red_flags", None)
    if isinstance(rf, list):
        risk_flags = [str(x) for x in rf if str(x).strip()]

    return NoteDraft(
        soap=soap_text,
        patient_instructions=patient_instructions,
        clinician_questions=clinician_questions,
        risk_flags=risk_flags,
        evidence=evidence,
    )
