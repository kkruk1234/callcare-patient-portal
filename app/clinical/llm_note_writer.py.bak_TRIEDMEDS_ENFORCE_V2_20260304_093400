from __future__ import annotations

import json
import os
from typing import Any, Dict, List, Tuple

from openai import OpenAI
from app.core.models import CallState


CALLCARE_NOTE_SYSTEM_VOICE = """You are a practicing physician authoring a clinician-grade medical SOAP note.

WRITE AS THE TREATING CLINICIAN.
Do NOT write as an AI, triage agent, assistant, or decision-support tool.

STYLE:
- Use SOAP headers exactly: S:, O:, A:, P:
- Subjective MUST be narrative prose (no bullet points).
- Objective: phone-only limitations; do not invent vitals or exam.
- Assessment: working diagnosis + numbered differential.
- Plan: must match required headers and order exactly.

PROHIBITED META-LANGUAGE (never write any of these):
- pending review / reviewing physician / approval / decision-support
- Do NOT address a reviewer. This is the medical record.

TRUTHFULNESS:
- Use ONLY structured answers and stored symptom fields provided in the prompt.
- Do NOT invent negatives, PMH, meds list, vitals, exam, tests.
- If something was not asked, omit it (or write "Not assessed" only if necessary).
""".strip()


def _client_and_model() -> Tuple[OpenAI, str]:
    api_key = os.getenv("OPENAI_API_KEY", "").strip()
    if not api_key:
        raise RuntimeError("OPENAI_API_KEY is not set.")
    client = OpenAI(api_key=api_key)

    model = os.getenv("CALLCARE_LLM_MODEL", "").strip()
    if not model:
        model = "gpt-4.1-mini"
    return client, model


def _generate_from_prompt(prompt: str, system_voice: str, max_output_tokens: int) -> str:
    client, model = _client_and_model()
    resp = client.responses.create(
        model=model,
        input=[
            {"role": "system", "content": system_voice},
            {"role": "user", "content": prompt},
        ],
        temperature=0.2,
        max_output_tokens=max_output_tokens,
    )

    text = getattr(resp, "output_text", None)
    if text:
        return str(text)

    try:
        parts = []
        for o in resp.output:
            for c in getattr(o, "content", []) or []:
                if getattr(c, "type", "") == "output_text":
                    parts.append(getattr(c, "text", ""))
        return "\n".join([p for p in parts if p])
    except Exception:
        return ""


def _symptoms_dict(state: CallState) -> Dict[str, Any]:
    try:
        sx = getattr(state, "symptoms", None) or {}
        return sx if isinstance(sx, dict) else {}
    except Exception:
        return {}


def _answers_dict(state: CallState) -> Dict[str, Any]:
    sx = _symptoms_dict(state)
    a = sx.get("_answers", {})
    return a if isinstance(a, dict) else {}


def _chief_complaint(state: CallState) -> str:
    try:
        return str(getattr(state, "chief_complaint", "") or getattr(state, "chief", "") or "").strip()
    except Exception:
        return ""


def _pathway_id(state: CallState) -> str:
    try:
        return str(getattr(state, "pathway_id", "") or "").strip()
    except Exception:
        return ""


def _age_years(state: CallState):
    try:
        v = getattr(state, "age_years", None)
        if v is None:
            v = getattr(state, "age", None)
        return v
    except Exception:
        return None


def _flag_text(state: CallState, key: str) -> str:
    sx = _symptoms_dict(state)
    ans = _answers_dict(state)
    for d in (ans, sx):
        if isinstance(d, dict) and key in d:
            return str(d.get(key)).strip()
    try:
        if hasattr(state, key):
            return str(getattr(state, key)).strip()
    except Exception:
        pass
    return ""


def _evidence_text(evidence: List[Any]) -> str:
    """
    Provide evidence snippets to the model (for grounding), but do NOT require or emit citations in the plan.
    """
    lines: List[str] = []
    if not isinstance(evidence, list):
        return "(none)"

    for i, e in enumerate(evidence[:10], start=1):
        if isinstance(e, dict):
            title = str(e.get("title", "") or "").strip()
            url = str(e.get("url", "") or "").strip()
            source = str(e.get("source", "") or "").strip()
            accessed = str(e.get("accessed", "") or "").strip()
            snippet = str(e.get("snippet", "") or "").strip()
        else:
            title = str(getattr(e, "title", "") or "").strip()
            url = str(getattr(e, "url", "") or "").strip()
            source = str(getattr(e, "source", "") or getattr(e, "publisher", "") or "").strip()
            accessed = str(getattr(e, "accessed", "") or getattr(e, "date", "") or "").strip()
            snippet = str(getattr(e, "snippet", "") or getattr(e, "text", "") or "").strip()

        hdr = f"SOURCE_{i}: {title}".strip(": ").strip()
        if source:
            hdr += f" [{source}]"
        if accessed:
            hdr += f" (accessed {accessed})"
        lines.append(hdr)
        if url:
            lines.append(url)
        if snippet:
            t = snippet.replace("\r", " ").strip()
            if len(t) > 1800:
                t = t[:1800] + "…"
            lines.append(t)
        lines.append("---")

    return "\n".join(lines).strip() if lines else "(none)"


def build_prompt(state: CallState, evidence: List[Any]) -> str:
    pid = _pathway_id(state)
    cc = _chief_complaint(state)
    age = _age_years(state)

    ans = _answers_dict(state)
    sx = _symptoms_dict(state)

    preg = _flag_text(state, "pregnancy_possible")
    renal = _flag_text(state, "renal_disease")
    liver = _flag_text(state, "liver_disease")

    allergies = ""
    if isinstance(ans.get("allergies"), str):
        allergies = ans.get("allergies", "").strip()

    case_lines: List[str] = []
    if age is not None:
        case_lines.append(f"AGE_YEARS: {age}")
    case_lines.append(f"CHIEF_COMPLAINT: {cc or '(not captured)'}")
    case_lines.append(f"PATHWAY_ID: {pid or '(none)'}")
    case_lines.append(f"ALLERGIES: {allergies or 'not captured'}")
    case_lines.append(f"PREGNANCY_POSSIBLE: {preg or '(missing)'}")
    case_lines.append(f"RENAL_DISEASE: {renal or '(missing)'}")
    case_lines.append(f"LIVER_DISEASE: {liver or '(missing)'}")

    ev_text = _evidence_text(evidence)

    hard_rules = """
HARD RULES (PLAN FORMAT — MUST MATCH EXACTLY):
In P:, use exactly these headers, in this order:
 - First-line medication:
 - Alternatives:
 - Medication safety considerations:
 - Return precautions:
 - Testing:

MEDICATION/DOSING RULES (TIER-1 WITH ASYNC PHYSICIAN REVIEW):
- The system MUST provide treatment when clinically appropriate (non-emergent scenarios).
- Use evidence snippets to guide meds/dosing when possible.
- If you provide a medication with explicit dosing/frequency/max/day/duration AND the dosing is NOT clearly supported by the evidence snippets:
  - you MUST append this exact tag immediately after the dosing recommendation:
    "(Physician must verify medication/dosing)"
- If dosing IS supported by evidence snippets:
  - do NOT add any citation tags, evidence IDs, or source references in the plan.
- You MUST NOT use vague dosing phrases: "as directed", "per label", "use cautiously", "consider", "may", "if appropriate".

OUTPUT FORMAT:
- You MUST return ONLY valid JSON (no markdown, no extra keys).
- JSON schema:
{
  "soap_text": "S:...\\n\\nO:...\\n\\nA:...\\n\\nP:...\\n",
  "evidence_search_queries": ["...", "..."]
}

EVIDENCE SEARCH QUERY RULES:
- Generate 2–4 queries to improve evidence quality for THIS case's assessment and plan.
- Each query must be <= 12 words.
- Do NOT include URLs.
- Do NOT include site: operators.
- Do NOT output 'low back pain' unless the assessment explicitly indicates lumbar/low back.
""".strip()

    sx_public = {}
    try:
        if isinstance(sx, dict):
            sx_public = {k: v for k, v in sx.items() if not str(k).startswith("_")}
    except Exception:
        sx_public = {}

    return f"""
{hard_rules}

CASE DATA:
{chr(10).join(case_lines)}

STRUCTURED_ANSWERS (verbatim):
{json.dumps(ans, ensure_ascii=False, indent=2)}

STORED_SYMPTOM_FIELDS (verbatim):
{json.dumps(sx_public, ensure_ascii=False, indent=2)}

EVIDENCE SNIPPETS:
{ev_text}
""".strip()


def generate_note_text(prompt: str) -> str:
    return _generate_from_prompt(prompt, system_voice=CALLCARE_NOTE_SYSTEM_VOICE, max_output_tokens=1200)


def generate_note(state: CallState, evidence: List[Any]) -> str:
    return generate_note_text(build_prompt(state, evidence))
