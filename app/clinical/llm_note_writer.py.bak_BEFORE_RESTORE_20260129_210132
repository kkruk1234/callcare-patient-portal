# --- CALLCARE_EVIDENCE_DICTS_V1 ---
def _evidence_text(evidence) -> str:
    """
    Render evidence blocks for the LLM prompt.
    Supports either:
      - EvidenceRef-like objects (attrs: key/title/url/publisher/date/text)
      - dict chunks from app.rag.retrieve (keys: title/url/text/source/score)
    """
    if not evidence:
        return ""

    lines = []
    for i, e in enumerate(evidence, start=1):
        # Dict support
        if isinstance(e, dict):
            key = str(e.get("key") or f"EVID_{i}").strip()
            title = str(e.get("title") or "").strip()
            url = str(e.get("url") or "").strip()
            publisher = str(e.get("publisher") or "").strip()
            date = str(e.get("date") or "").strip()
            text = str(e.get("text") or "").strip()
        else:
            key = str(getattr(e, "key", "") or f"EVID_{i}").strip()
            title = str(getattr(e, "title", "") or "").strip()
            url = str(getattr(e, "url", "") or "").strip()
            publisher = str(getattr(e, "publisher", "") or "").strip()
            date = str(getattr(e, "date", "") or "").strip()
            text = str(getattr(e, "text", "") or "").strip()

        hdr = f"{key}: {title}".strip(": ").strip()
        if publisher:
            hdr += f" [{publisher}]"
        if date:
            hdr += f" ({date})"

        lines.append(hdr)
        if url:
            lines.append(url)
        if text:
            # Keep prompt size sane
            t = text.replace("\r", " ").strip()
            if len(t) > 1800:
                t = t[:1800] + "…"
            lines.append(t)
        lines.append("---")

    return "\n".join(lines).strip()
# --- END CALLCARE_EVIDENCE_DICTS_V1 ---
def build_prompt(state: CallState, evidence: List[EvidenceRef]) -> str:
    pid = _pathway_id(state)
    cc = _chief_complaint(state)
    age = _age_years(state)
    allergies = _allergies_text(state)

    sx = _symptoms_dict(state)
    ans = _answers_dict(state)

    preg_raw = _preg_raw(state)
    preg_sentence = _preg_sentence_from_raw(preg_raw) if preg_raw else ""

    attach_h = _tick_attachment_hours(state)
    exposure = _best_exposure_location(state)
    bullseye = _has_bullseye_rash(state)
    systemic_txt = _systemic_answer_text_for_tickbite(state)

    case_lines: List[str] = []
    if age is not None:
        case_lines.append(f"AGE_YEARS: {age}")
    case_lines.append(f"CHIEF_COMPLAINT: {cc or '(not captured)'}")
    case_lines.append(f"PATHWAY_ID: {pid or '(none)'}")
    case_lines.append(f"ALLERGIES: {allergies or 'no known medication allergies (or not captured)'}")

    if preg_sentence:
        case_lines.append(f"PREGNANCY_SENTENCE: {preg_sentence}")
    else:
        case_lines.append("PREGNANCY_SENTENCE: (do not mention pregnancy)")

    if pid == "tick_bite":
        if exposure:
            case_lines.append(f"EXPOSURE_LOCATION: {exposure}")
        if attach_h is not None:
            case_lines.append(f"TICK_ATTACHED_HOURS: {attach_h}")
        if bullseye is True:
            case_lines.append("RASH: expanding/bullseye-like rash reported (erythema migrans-like).")
        elif bullseye is False:
            case_lines.append("RASH: expanding/bullseye rash denied.")
        if systemic_txt:
            case_lines.append(f"SYSTEMIC_SYMPTOMS_RESPONSE: {systemic_txt}")

    ev_text = _evidence_text(evidence)

    hard_rules = """
HARD RULES (TRUTHFULNESS):
- Use ONLY the CASE DATA / STRUCTURED_ANSWERS / STORED_SYMPTOM_FIELDS. Do not invent negatives.
- Do NOT write “denies chest pain, dyspnea, palpitations, syncope, confusion, facial palsy, neurologic deficits” unless those were explicitly asked and present in structured data.
- If not asked, do NOT deny it.

HARD RULES (STYLE):
- Phone-only urgent care / primary care clinician note (NOT nurse triage).
- No vitals, no exam.

HARD RULES (TREATMENT):
- If PATHWAY_ID == tick_bite and bullseye/erythema migrans-like rash is reported, include a specific antibiotic regimen with dose + frequency + duration (adult) AND list alternatives.
- Phrase prescribing as: “Recommended regimen; reviewing physician will confirm appropriateness and prescribe if indicated.”
""".strip()

    # Your formatting preferences, enforced ONLY for tick_bite
    style_preferences = ""
    if pid == "tick_bite":
        style_preferences = """
TICK_BITE FORMAT PREFERENCES (MUST FOLLOW):
- Objective must start exactly:
  "O: No physical exam available due to phone-only encounter. Patient describes a characteristic bullseye rash consistent with erythema migrans at the tick bite site."
  Then add ONE sentence about systemic symptoms:
  - If systemic symptoms response was None/No: "No reported systemic signs or symptoms."
  - If systemic symptoms reported: list only what was reported (do not invent).
- Assessment format must be:
A:
   - Working diagnosis (most likely): <diagnosis> is likely because <1–2 clauses using only the patient’s answered features>.
 - Differential:
  1. ...
  2. ...
  3. ...
  4. ...
 - Red flags considered: No systemic symptoms reported (fever, chills, severe headache, body aches, stiff neck).
- Differential for erythema migrans should include (as appropriate):
  1. Early localized Lyme disease
  2. Southern tick-associated rash illness (STARI)
  3. Cellulitis or local skin infection
  4. Allergic reaction to tick bite
""".strip()

    tickbite_regimens = ""
    if pid == "tick_bite":
        tickbite_regimens = """
TICK BITE / ERYTHEMA MIGRANS REGIMENS (include in Plan when appropriate):
- Adult first-line (if not pregnant and no contraindication): doxycycline 100 mg PO twice daily x 10 days.
- Adult alternatives: amoxicillin 500 mg PO three times daily x 14 days OR cefuroxime axetil 500 mg PO twice daily x 14 days.
- If unable to take doxycycline/amoxicillin/cefuroxime: azithromycin 500 mg PO daily x 7 days (less effective; use only if needed).
- Pregnancy note (only if pregnancy was captured as possible/yes): avoid doxycycline; prefer amoxicillin.
""".strip()

    return f"""
{hard_rules}

{style_preferences}

{tickbite_regimens}

CASE DATA:
{chr(10).join(case_lines)}

STRUCTURED_ANSWERS (verbatim):
{ans}

STORED_SYMPTOM_FIELDS (verbatim):
{ {k: v for k, v in sx.items() if not str(k).startswith("_")} }

EVIDENCE SNIPPETS:
{ev_text}

OUTPUT FORMAT (plain text; headings exactly):
S:
O:
A:
 - Working diagnosis (most likely):
 - Differential:
  1.
  2.
  3.
  4.
 - Red flags considered:
P:
 - Disposition:
 - Plan:
 - Safety net:
""".strip()


# ============================
# LLM call
# ============================

def _client_and_model() -> Tuple[OpenAI, str]:
    api_key = os.getenv("OPENAI_API_KEY", "").strip()
    if not api_key:
        raise RuntimeError("OPENAI_API_KEY is not set.")
    client = OpenAI(api_key=api_key)

    model = os.getenv("CALLCARE_LLM_MODEL", "").strip()
    if not model:
        model = "gpt-4.1-mini"
    return client, model


def _generate_from_prompt(prompt: str) -> str:
    client, model = _client_and_model()

    resp = client.responses.create(
        model=model,
        input=[
            {
                "role": "system",
                "content": CALLCARE_NOTE_SYSTEM_VOICE},
            {"role": "user", "content": prompt},
        ],
        temperature=0.2,
        max_output_tokens=900,
    )

    text = getattr(resp, "output_text", None)
    if not text:
        try:
            parts = []
            for o in resp.output:
                for c in getattr(o, "content", []) or []:
                    if getattr(c, "type", "") == "output_text":
                        parts.append(getattr(c, "text", ""))
            text = "\n".join([p for p in parts if p])
        except Exception:
            text = ""
    return (text or "").strip()


def generate_note(state: CallState, evidence: List[EvidenceRef]) -> str:
    prompt = build_prompt(state, evidence)
    # --- CALLCARE_ANSWERED_FIELDS_GUARD_V1 ---
    sx = getattr(state, 'symptoms', None) or {}
    ans = {}
    if isinstance(sx, dict):
        a = sx.get('_answers', {})
        if isinstance(a, dict):
            ans = dict(a)
    # Normalize allergies
    allergies_val = ''
    if isinstance(ans.get('allergies'), str):
        allergies_val = ans.get('allergies')
    elif getattr(state, 'allergies', None) is not None:
        allergies_val = str(getattr(state, 'allergies'))
    allergies_norm = allergies_val.strip().lower()
    if allergies_norm in ('no', 'none', 'nope', 'n'):
        allergies_norm = 'none'
    if allergies_norm:
        ans['allergies'] = allergies_norm
    answered_lines = []
    for key in sorted(ans.keys()):
        answered_lines.append('- ' + str(key) + ': ' + str(ans.get(key)))
    answered_block = '\n'.join(answered_lines) if answered_lines else '(none)'
    guard = 'CRITICAL RULES (DO NOT VIOLATE):\n- You may ONLY state symptoms, negatives, history, or treatments that are explicitly present in the structured answers provided below.\n- If something was not asked, you MUST NOT state or imply it. Either omit it or write "Not assessed."\n- Do NOT infer or assume typical findings. Do NOT invent negatives.\n- Allergy phrasing rule:\n  - If allergies == \'none\' or empty: you may say "No known drug allergies."\n  - If allergies is non-empty: list the allergy(ies) plainly and DO NOT say "no known allergies."\n'
    prompt = guard + '\n\nANSWERED_FIELDS (anything not listed here was NOT ASKED):\n' + answered_block + '\n\n' + prompt
    # --- END CALLCARE_ANSWERED_FIELDS_GUARD_V1 ---

    return _generate_from_prompt(prompt)


# ============================
# Exports / back-compat
# ============================

def generate_llm_note(state: CallState, evidence: Optional[List[EvidenceRef]] = None) -> str:
    return generate_note(state, evidence or [])

def write_llm_note(state: CallState, evidence: Optional[List[EvidenceRef]] = None) -> str:
    return generate_note(state, evidence or [])

def create_llm_note(state: CallState, evidence: Optional[List[EvidenceRef]] = None) -> str:
    return generate_note(state, evidence or [])

def create_note_text(state: CallState, evidence: Optional[List[EvidenceRef]] = None) -> str:
    return generate_note(state, evidence or [])


def generate_note_text(prompt_or_state: Union[str, CallState], evidence: Optional[List[EvidenceRef]] = None) -> str:
    if isinstance(prompt_or_state, str):
        return _generate_from_prompt(prompt_or_state)
    return generate_note(prompt_or_state, evidence or [])
