def _pick_pathway(chief: str, state: Optional[CallState] = None) -> Dict[str, Any]:
    """
    Deterministic routing first, then fallback keyword scoring from YAML (very minimal).
    """
    chief_l = _norm(chief)

    # Batch6 guards for patient-like phrasing
    if any(k in chief_l for k in ["stye", "sty", "eyelid bump", "pimple on eyelid", "tender eyelid"]):
        return {"id": "eye_stye_hordeolum", "score": 999}
    if ("ear" in chief_l) and any(k in chief_l for k in ["swimmer", "after swimming", "hurts when i pull", "ear canal", "itchy ear canal"]):
        return {"id": "otitis_externa", "score": 999}
    if ("vagin" in chief_l or "vulv" in chief_l) and any(k in chief_l for k in ["itch", "itching", "thick white", "cottage cheese", "yeast"]):
        return {"id": "vaginal_yeast", "score": 999}
    if any(k in chief_l for k in ["cut my", "laceration", "open cut", "won\'t stop bleeding", "wont stop bleeding", "deep cut"]):
        return {"id": "minor_laceration_cut", "score": 999}
    if any(k in chief_l for k in ["hand foot mouth", "mouth sores", "sores in mouth", "rash on hands", "rash on feet", "blisters on hands", "blisters on feet"]):
        return {"id": "hand_foot_mouth_child", "score": 999}

    # Nosebleed guard: patient-like phrasing often says "nose is bleeding"
    if ("nose" in chief_l) and (("bleed" in chief_l) or ("bloody" in chief_l)):
        return {"id": "nosebleed_epistaxis", "score": 999}

    # vomiting+diarrhea food trigger -> food_poisoning (patient-like phrasing)
    if ("vomit" in chief_l or "vomiting" in chief_l or "throwing up" in chief_l) and ("diarrhea" in chief_l or "loose stool" in chief_l or "watery stool" in chief_l):
        if any(k in chief_l for k in ["after eating", "after i ate", "restaurant", "takeout", "food", "ate", "meal"]):
            return {"id": "food_poisoning", "score": 999}


    # COPD guard: if caller explicitly mentions COPD/emphysema/chronic bronchitis, force COPD pathway.
    if any(k in chief_l for k in ["copd", "emphysema", "chronic bronchitis"]):
        return {"id": "copd_exacerbation", "score": 999}

    direct = [
        # Core original
        (["dysuria", "uti", "burning urination", "burning when i pee", "painful urination", "urinary urgency", "urinary frequency"], "dysuria_uti"),
        (["vomit", "vomiting", "nausea", "throwing up", "emesis"], "nausea_vomiting"),
        (["diarrhea", "loose stool", "watery stool", "gastroenteritis"], "diarrhea"),
        (["ear pain", "earache", "otitis", "swimmer's ear"], "ear_pain"),
        (["pink eye", "conjunctivitis", "red eye", "eye discharge"], "red_eye"),
        (["back pain", "low back", "sciatica", "lumbar"], "low_back_pain"),
        (["sore throat", "throat pain", "strep"], "sore_throat"),
        (["cough", "runny nose", "congestion", "cold", "uri"], "cough_uri"),
        (["rash", "skin infection", "cellulitis", "impetigo"], "rash_skin_infection"),
        (["abdominal pain", "belly pain", "stomach pain"], "abdominal_pain"),
        (["headache", "migraine", "worst headache", "thunderclap"], "headache"),
        (["med refill", "refill", "renew medication", "prescription renewal"], "med_refill"),

        # Added batches (routing phrases are intentionally patient-like)
        (["constipated", "no bowel movement", "can't poop", "hard stool"], "constipation"),
        (["toothache", "gum swollen", "dental pain", "tooth pain"], "dental_pain"),
        (["acid reflux", "heartburn", "burning in chest after eating"], "heartburn_gerd"),
        (["sinus pressure", "facial pressure", "postnasal drip", "green mucus"], "sinusitis"),
        (["twisted my ankle", "sprained my ankle", "ankle injury", "sprain", "strain"], "sprain_strain"),

        (["hay fever", "seasonal allergies", "itchy nose", "sneezing a lot"], "allergic_rhinitis"),
        (["panic attack", "anxiety attack", "sudden panic"], "anxiety_panic"),
        (["toddler constipated", "child constipated", "kid constipated"], "constipation_child"),
        (["bee sting", "wasp sting", "insect sting", "bug bite"], "insect_bite_sting"),
        (["minor burn", "burned my hand", "small burn"], "minor_burn"),

        (["child fever", "kid fever", "baby fever", "toddler fever"], "fever_child"),

        (["chest pressure", "pressure in chest", "chest pain with sweating"], "chest_pain"),
        (["face drooped", "slurred speech", "stroke symptoms", "can't speak"], "stroke_neuro"),

        (["burning blistering rash on one side", "painful blistering rash one side"], "shingles"),
        (["cold sore", "blister on lip"], "cold_sore_hsv"),

        (["asthma", "asthma attack", "wheezing", "wheezy", "chest tightness", "inhaler not helping", "rescue inhaler not helping", "albuterol not helping"], "asthma_wheeze"),
        (["fever chills body aches", "flu like", "body aches with fever"], "flu_like_illness"),
        (["fishy smell discharge", "vaginal discharge"], "vaginal_discharge"),
        (["severe pelvic pain", "pelvic pain and dizziness"], "pelvic_pain"),
        (["rectal pain", "bright red blood when wiping"], "hemorrhoids_rectal_pain"),
        (["heartburn and nausea", "acid reflux and nausea"], "gerd_nausea"),

        (["itchy watery eyes", "my eyes are watery", "eyes are watery", "eye itching with watery tears"], "conjunctivitis_allergic"),

        (["child ear pain with fever", "kid ear pain with fever"], "otitis_media"),
        (["sinus pressure and congestion", "facial pressure and congestion"], "uri_sinus_overlap"),
        (["hives", "itchy welts"], "urticaria_hives"),
        (["hit my head", "head injury", "concussion"], "minor_head_injury"),

        (["flank pain and blood in urine", "kidney stone", "stone in kidney"], "kidney_stone"),
        (["dehydrated", "not peeing much", "dry mouth and dizzy"], "dehydration"),
        (["started a new medication", "new medication", "side effect", "adverse drug reaction"], "med_side_effect"),
        (["tick bite", "bullseye rash"], "tick_bite"),
        (["complicated uti", "uti with fever and flank pain"], "uti_complicated"),

        (["shooting pain down my leg", "pain down my leg", "radiating leg pain", "pinched nerve"], "sciatica_radiculopathy"),
        (["big toe red hot swollen", "gout attack", "podagra"], "gout_flare"),
        (["throbbing headache with light sensitivity", "aura", "migraine"], "migraine"),
        (["room spinning", "positional vertigo", "dizzy when turning in bed"], "vertigo_bppv"),
        (["boil", "abscess", "pus pocket", "painful lump with pus"], "skin_abscess"),

        (["copd flare", "copd acting up", "more sputum than usual", "change in sputum color"], "copd_exacerbation"),
        (["skin redness spreading", "hot red skin", "red swollen skin"], "cellulitis"),
        (["burning when i pee and frequency", "uti symptoms"], "uti_uncomplicated"),
        (["watery diarrhea and dehydrated", "acute diarrhea"], "acute_diarrhea"),

        (["flashes of light", "new floaters", "curtain over vision", "shadow in vision"], "eye_floaters_flashes"),
        (["something in my eye", "grit in my eye", "metal in my eye", "eye scratch", "dust in my eye", "gritty feeling in my eye", "something stuck in my eye", "eye feels scratched", "after sanding", "after grinding"], "eye_foreign_body"),
        (["nosebleed", "bloody nose", "bleeding from nose", "nose is bleeding", "my nose is bleeding", "bleeding from my nose"], "nosebleed_epistaxis"),
        (["can't pee", "unable to urinate", "bladder feels full but can't pee", "urinary retention"], "urinary_retention"),
        (["sick after eating", "vomiting and diarrhea after restaurant", "food poisoning"], "food_poisoning"),
    ]

    for keys, pid in direct:
        if any(k in chief_l for k in keys):
            return {"id": pid, "score": 999}

    # Fallback: minimal keyword scoring from YAML `match:any_keywords: [...]`
    best = ("cough_uri", 0)
    if PATHWAYS_DIR.exists():
        for fp in PATHWAYS_DIR.glob("*.yaml"):
            raw = fp.read_text(encoding="utf-8", errors="ignore")
            pid = ""
            kws: List[str] = []
            for line in raw.splitlines():
                s = line.strip()
                if s.startswith("id:"):
                    pid = s.split(":", 1)[1].strip()
                if "any_keywords:" in s and "[" in s and "]" in s:
                    inside = s.split("[", 1)[1].rsplit("]", 1)[0]
                    parts = [p.strip().strip('"').strip("'") for p in inside.split(",") if p.strip()]
                    kws.extend([p.lower() for p in parts if p])
            if not pid:
                continue
            score = sum(1 for k in kws if k and k in chief_l)
            if score > best[1]:
                best = (pid, score)

    return {"id": best[0], "score": best[1]}


