from __future__ import annotations

import os
import re
from typing import Any, Dict, List, Optional, Tuple

from app.core.models import CallState

try:
    import yaml  # type: ignore
except Exception:  # pragma: no cover
    yaml = None


# ----------------------------
# Core helpers
# ----------------------------

def _symptoms_dict(state: CallState) -> Dict[str, Any]:
    sx = getattr(state, "symptoms", None) or {}
    return sx if isinstance(sx, dict) else {}


def _pathway_id(state: CallState) -> str:
    sx = _symptoms_dict(state)
    p = sx.get("_pathway", {})
    if isinstance(p, dict) and p.get("id"):
        return str(p["id"]).strip()
    pid = getattr(state, "pathway_id", None) or getattr(state, "pathway", None)
    return str(pid).strip() if pid else ""


def _protocol_path_for_pathway_id(pathway_id: str) -> str:
    return os.path.join("data", "protocols", "meds", f"{pathway_id}.yaml")


# ----------------------------
# Loaders
# ----------------------------

def load_med_protocol_for_state(state: CallState) -> Tuple[Optional[Dict[str, Any]], str]:
    """
    Load meds protocol YAML for the pathway in `state`.
    Returns (protocol_dict, error_reason). Never raises.
    """
    if yaml is None:
        return (None, "PyYAML not installed (cannot load meds protocol).")

    pid = _pathway_id(state)
    if not pid:
        return (None, "No pathway_id available at note time.")

    path = _protocol_path_for_pathway_id(pid)
    if not os.path.exists(path):
        return (None, f"No meds protocol file found for pathway_id={pid} ({path}).")

    try:
        with open(path, "r", encoding="utf-8") as f:
            data = yaml.safe_load(f) or {}
        if not isinstance(data, dict):
            return (None, f"Invalid meds protocol YAML structure in {path} (expected mapping).")
        return (data, "")
    except Exception as e:
        return (None, f"Failed to read meds protocol {path}: {type(e).__name__}: {str(e)[:160]}")


def load_med_protocol_for_pathway_id(pathway_id: str) -> Tuple[Optional[Dict[str, Any]], str]:
    """
    Load meds protocol YAML for a known pathway_id.
    Returns (protocol_dict, error_reason). Never raises.
    """
    if yaml is None:
        return (None, "PyYAML not installed (cannot load meds protocol).")
    if not pathway_id:
        return (None, "No pathway_id provided.")

    path = _protocol_path_for_pathway_id(pathway_id)
    if not os.path.exists(path):
        return (None, f"No meds protocol file found for pathway_id={pathway_id} ({path}).")

    try:
        with open(path, "r", encoding="utf-8") as f:
            data = yaml.safe_load(f) or {}
        if not isinstance(data, dict):
            return (None, f"Invalid meds protocol YAML structure in {path} (expected mapping).")
        return (data, "")
    except Exception as e:
        return (None, f"Failed to read meds protocol {path}: {type(e).__name__}: {str(e)[:160]}")


def load_protocol_text(pathway_id: str) -> str:
    """
    BACK-COMPAT:
    Some parts of the codebase import `load_protocol_text` from this module.
    Return raw YAML text for a pathway's meds protocol, or "" if missing/unreadable.
    """
    try:
        if not pathway_id:
            return ""
        path = _protocol_path_for_pathway_id(pathway_id)
        if not os.path.exists(path):
            return ""
        return PathLikeReadText(path)
    except Exception:
        return ""


def PathLikeReadText(path: str) -> str:
    # Small wrapper to keep load_protocol_text robust across environments.
    try:
        with open(path, "r", encoding="utf-8") as f:
            return f.read()
    except Exception:
        return ""


