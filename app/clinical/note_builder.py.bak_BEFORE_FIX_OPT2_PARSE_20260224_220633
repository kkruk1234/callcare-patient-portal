# --- CALLCARE_PREG_DUPLICATE_STRIP_V1 ---
def _strip_redundant_no_preg_pos_sentence(soap_text: str, preg_sentence: str) -> str:
    """Remove redundant phrases like 'There is no pregnancy possibility.' while keeping canonical 'Patient is not pregnant.'"""
    import re as _re

    txt = soap_text or ""
    ps = (preg_sentence or "").strip().lower()

    # Only apply when explicitly stating not pregnant.
    if "not pregnant" not in ps:
        return txt

    patterns = [
        r'\bThere is no pregnancy possibility\.?\s*',
        r'\bThere is no possibility of pregnancy\.?\s*',
        r'\bNo pregnancy possibility\.?\s*',
        r'\bNo possibility of pregnancy\.?\s*',
    ]
    for pat in patterns:
        txt = _re.sub(pat, "", txt, flags=_re.IGNORECASE)

    txt = _re.sub(r' +', ' ', txt)
    txt = _re.sub(r'\n\n\n+', '\n\n', txt)
    return txt



