def _cc_filter_junk_evidence(state, evidence):
    """CallCare: prune non-auditable + irrelevant evidence entries.

    Scalable rules (no drug lists, no drug classes):
    - Drop local library paths (library/<id>/content.txt) because not auditable.
    - Drop MedlinePlus/DailyMed drug monographs unless the drug name is mentioned elsewhere
      in NON-monograph encounter evidence.
    - Drop evidence that doesn't match encounter tokens (chief complaint / dx), so we don't
      fill Evidence Used with unrelated etiologies.
    """
    import re as _re

    if not evidence:
        return []

    def _val(e, key):
        # dict or object attribute
        try:
            if isinstance(e, dict):
                return e.get(key)
        except Exception:
            pass
        try:
            return getattr(e, key, None)
        except Exception:
            return None

    def _get_title(e):
        return str(_val(e, 'title') or '').strip()

    def _get_url(e):
        # canonical is 'source' in your system; tolerate url/source_url too
        return str(_val(e, 'source') or _val(e, 'url') or _val(e, 'source_url') or '').strip()

    def _get_snip(e):
        return str(_val(e, 'snippet') or '').strip()

    def _is_local(u: str) -> bool:
        u = (u or '').strip().lower()
        return u.startswith('library/') or u.endswith('/content.txt') or 'library/' in u

    def _is_monograph(u: str) -> bool:
        u = (u or '').lower()
        return ('medlineplus.gov/druginfo/meds/' in u) or ('dailymed.nlm.nih.gov' in u)

    def _drug_from_title(t: str) -> str:
        # first token only (e.g., 'brentuximab')
        t = (t or '').strip()
        if not t:
            return ''
        t = t.split(':', 1)[0].strip()
        t = t.split('-', 1)[0].strip()
        words = [w for w in _re.split(r'[^A-Za-z0-9]+', t) if w]
        return (words[0].lower().strip() if words else '')

    def _encounter_text() -> str:
        parts = []
        # symptoms dict
        try:
            sx = getattr(state, 'symptoms', None) or {}
            if isinstance(sx, dict):
                for k in ('chief_complaint','cc','complaint','presenting_complaint','_llm_intake_summary'):
                    v = sx.get(k)
                    if v:
                        parts.append(str(v))
        except Exception:
            pass
        # state attributes
        for k in ('chief_complaint','cc','complaint','presenting_complaint'):
            try:
                v = getattr(state, k, None)
                if v:
                    parts.append(str(v))
            except Exception:
                pass
        # decision dx if present
        try:
            d = getattr(state, 'decision', None)
            if d is not None:
                wd = getattr(d, 'working_diagnosis', None) or getattr(d, 'diagnosis', None)
                if wd:
                    parts.append(str(wd))
        except Exception:
            pass
        return ' '.join(parts)

    def _tokens(txt: str):
        txt = (txt or '').lower()
        # keep meaningful tokens; special-case common back terms if present in text
        words = [w for w in _re.split(r'[^a-z0-9]+', txt) if len(w) >= 4]
        # also include phrases like 'back pain', 'low back'
        phrases = []
        for i in range(len(words)-1):
            phrases.append(words[i] + ' ' + words[i+1])
        out = []
        seen = set()
        for w in words + phrases:
            if w and w not in seen:
                seen.add(w)
                out.append(w)
        return out[:24]

    enc = _encounter_text()
    toks = _tokens(enc)

    # Build NON-monograph blob for monograph relevance gating
    nonmono_blob = ''
    for e in evidence:
        u = _get_url(e)
        if _is_monograph(u):
            continue
        nonmono_blob += ' ' + _get_title(e).lower() + ' ' + _get_snip(e).lower()

    out = []
    for e in evidence:
        title = _get_title(e)
        url = _get_url(e)
        snip = _get_snip(e)

        if _is_local(url):
            continue

        if _is_monograph(url):
            drug = _drug_from_title(title)
            if drug and (drug not in nonmono_blob):
                continue

        # Scalable relevance: require encounter token match when we have tokens
        if toks:
            blob = (title + ' ' + url + ' ' + snip).lower()
            if not any(t in blob for t in toks):
                continue

        out.append(e)

    return out

def _cc_topup_dosing_evidence(state, evidence, max_total: int = 10):
    """Top up evidence with dosing-capable sources.

    This function is the *dosing evidence safety net*:
      1) Try local RAG (FAISS) first (fast).
      2) If still missing dosing-capable evidence, auto-acquire + ingest + attach (time-bounded)
         so the CURRENT patient benefits and the library persists for future calls.

    No hardcoded dosing anchors. No disease-specific hacks.
    """
    # CALLCARE_TOPUP_ENTRY_LOG_V1
    try:
        import os, json, time
        os.makedirs('logs', exist_ok=True)
        cc0 = str(getattr(state, 'chief_complaint', '') or '').strip()
        hd0 = False
        try:
            hd0 = bool(_cc_has_dosing_adjustment_evidence(evidence or []))
        except Exception:
            hd0 = False
        with open('logs/topup_dosing_entry.jsonl','a',encoding='utf-8') as f:
            f.write(json.dumps({'ts': time.time(), 'cc': cc0, 'in_n': len(evidence or []), 'max_total': max_total, 'has_dosing': hd0}, default=str) + '\n')
    except Exception:
        pass

    if not evidence:
        evidence = []
    evidence = _cc_filter_junk_evidence(state, evidence)

    # If we already have dosing/adjustment-capable evidence, stop.
    if _cc_has_dosing_adjustment_evidence(evidence):
        return evidence

    cc = str(getattr(state, "chief_complaint", "") or "").strip()

    renal_or_liver = (
        _cc_flag_yes(state, "renal_disease", "kidney_disease")
        or _cc_flag_yes(state, "liver_disease")
    )

    # Query modes:
    # - Adjustment mode when renal/hepatic flags are present
    # - General OTC/analgesic dosing mode otherwise
    if renal_or_liver:
        query = (cc + " dosing adjustment renal hepatic antibiotic NSAID acetaminophen guideline").strip()
    else:
        query = (cc + " dosing acetaminophen ibuprofen naproxen guideline").strip()

    out = list(evidence)
    existing = set([_cc_ev_url(e) for e in out if _cc_ev_url(e)])

    # -------------------------
    # 1) Local RAG top-up first
    # -------------------------
    try:
        chunks = _cc_rag_retrieve(query, k=12) or []
    except Exception:
        chunks = []

    topups_added = 0
    for c in chunks:
        if len(out) >= max_total:
            break

        url = str(c.get("url") or c.get("source") or "").strip()
        title = str(c.get("title") or c.get("name") or "").strip()

        # Skip junk lab-test pages here too
        u_l = url.lower()
        t_l = title.lower()
        if ("medlineplus.gov/lab-tests/" in u_l) or ("medlineplus medical test" in t_l):
            continue

        if url and url in existing:
            continue

        c = dict(c)
        c["key"] = c.get("key") or f"EVID_TOPUP_{len(out)+1}"
        out.append(c)
        topups_added += 1

        if url:
            existing.add(url)

        # Keep modest: add at most 2 from local RAG
        if topups_added >= 2:
            break

    out = _cc_filter_junk_evidence(state, out)

    # If local RAG achieved dosing evidence, stop.
    if _cc_has_dosing_adjustment_evidence(out):
        return out

    # --------------------------------------------
    # 2) Auto-acquire fallback when still insufficient
    # --------------------------------------------
    # Only attempt if we still have room and we have a usable complaint string.
    if len(out) >= max_total or not cc:
        return out

    # Time-bounded web acquire+ingest+attach (no index rebuild here).
    try:
        from app.rag.auto_acquire_fast import acquire_ingest_attach
    except Exception:
        return out

    # Build a dosing-focused query that works even without a precise dx label.
    if renal_or_liver:
        q_web = (cc + " outpatient pain treatment acetaminophen maximum daily dose liver disease NSAID avoid chronic kidney disease dosing").strip()
    else:
        q_web = (cc + " outpatient pain treatment ibuprofen dosing naproxen dosing acetaminophen dosing adult maximum daily dose").strip()

    acquired_docs = []
    try:
        r = acquire_ingest_attach(query=q_web, max_urls=5, time_budget_sec=10.0)
        acquired_docs = (r.ingested_docs or []) if r is not None else []
        # CALLCARE_ACQRESULT_LOG_V1
        try:
            import os, json, time
            os.makedirs('logs', exist_ok=True)
            _loc = locals()
            payload = {
                'ts': time.time(),
                'cc': _loc.get('cc'),
                'renal_or_liver': bool(_loc.get('renal_or_liver')),
                'q_web': _loc.get('q_web'),
                'has_r': bool(_loc.get('r') is not None),
                'r_type': str(type(_loc.get('r'))),
                'ingested_docs_n': (len(_loc.get('acquired_docs') or []) if isinstance(_loc.get('acquired_docs'), list) else None),
            }
            with open('logs/topup_autoacquire_result.jsonl','a',encoding='utf-8') as f:
                f.write(json.dumps(payload, default=str) + '\n')
        except Exception:
            pass

    except Exception:
        acquired_docs = []

    incoming = []
    for d in acquired_docs:
        try:
            title = d.get("title") or d.get("doc_title") or ""
            url = d.get("url") or d.get("source_url") or d.get("source") or ""
            text = d.get("text") or d.get("content") or d.get("snippet") or ""
            incoming.append({
                "title": str(title or "").strip(),
                "source": str(url or "").strip(),
                "snippet": (str(text or "")[:360]),
            })
        except Exception:
            continue

    # Merge and clamp
    try:
        out2 = _merge_evidence(out, incoming, max_total=max_total)
    except Exception:
        out2 = out

    out2 = _cc_filter_junk_evidence(state, out2)

    # Log what happened (audit)
    try:
        import os, json, time
        os.makedirs("logs", exist_ok=True)
        with open("logs/auto_acquire_attempts.jsonl", "a", encoding="utf-8") as f:
            f.write(json.dumps({
                "ts": time.time(),
                "kind": "dosing_topup_fallback",
                "cc": cc,
                "renal_or_liver": bool(renal_or_liver),
                "query_rag": query,
                "query_web": q_web,
                "before_n": len(evidence),
                "after_n": len(out2),
                "added_web_docs": len(incoming),
            }, default=str) + "\n")
    except Exception:
        pass

    return out2

def _cc_has_renal_disease(state) -> bool:
    """
    Robustly infer renal disease flag from CallState.
    Accepts bool-like fields and common answer keys.
    """
    def _is_yes(v) -> bool:
        if v is True:
            return True
        s = str(v or "").strip().lower()
        return s in ("yes", "y", "true", "1")

    # direct attributes (varies across versions)
    for attr in ("renal_disease", "kidney_disease", "has_renal_disease", "reduced_kidney_function"):
        try:
            if _is_yes(getattr(state, attr, None)):
                return True
        except Exception:
            pass

    # answers dict-like
    try:
        ans = getattr(state, "answers", None)
        if isinstance(ans, dict):
            for k in ("renal_disease", "kidney_disease", "reduced_kidney_function", "ckd", "has_ckd"):
                if k in ans and _is_yes(ans.get(k)):
                    return True
    except Exception:
        pass

    return False




def _cc_adjust_plan_analgesics_for_renal(soap_text: str, state) -> str:
    """
    Analgesic precedence (deterministic, general):
      1) Renal disease -> acetaminophen first-line (avoid NSAIDs)
      2) Else liver disease -> NSAID first-line (limit acetaminophen)
      3) Else -> no change

    Handles both Plan formats:
      A) Has 'First-line medication:' header (drug may be on next line)
      B) No header; first medication bullet under P: is treated as first-line

    Also:
      - strips leftover 'First-line medication:' labels from demoted lines
      - removes '(avoid in renal disease...)' when renal is false
    """
    if not soap_text:
        return soap_text

    def _is_yes(v) -> bool:
        if v is True:
            return True
        s = str(v or "").strip().lower()
        return s in ("yes", "y", "true", "1")

    def _ans(key: str):
        try:
            a = getattr(state, "answers", None)
            if isinstance(a, dict):
                return a.get(key)
        except Exception:
            return None
        return None

    # --- flags ---
    renal = False
    liver = False

    # Prefer existing helper if present
    try:
        renal = bool(_cc_has_renal_disease(state))
    except Exception:
        renal = False

    renal = renal or _is_yes(getattr(state, "renal_disease", None)) or _is_yes(getattr(state, "kidney_disease", None))
    renal = renal or _is_yes(_ans("renal_disease")) or _is_yes(_ans("kidney_disease")) or _is_yes(_ans("reduced_kidney_function")) or _is_yes(_ans("ckd"))

    liver = liver or _is_yes(getattr(state, "liver_disease", None)) or _is_yes(getattr(state, "hepatic_disease", None))
    liver = liver or _is_yes(_ans("liver_disease")) or _is_yes(_ans("hepatic_disease")) or _is_yes(_ans("cirrhosis")) or _is_yes(_ans("hepatitis"))

    low_all = soap_text.lower()
    if not renal and any(k in low_all for k in ("renal disease", "renal impairment", "chronic kidney", "ckd", "dialysis", "egfr")):
        renal = True
    if not liver and any(k in low_all for k in ("liver disease", "hepatic", "cirrhosis", "hepatitis")):
        liver = True

    if not renal and not liver:
        return soap_text

    def is_apap(s: str) -> bool:
        s = (s or "").lower()
        return ("acetaminophen" in s) or ("paracetamol" in s) or ("tylenol" in s)

    def is_nsaid(s: str) -> bool:
        s = (s or "").lower()
        return any(d in s for d in ("ibuprofen", "naproxen", "diclofenac", "celecoxib", "indomethacin")) or ("nsaid" in s)

    def strip_firstline_label(s: str) -> str:
        t = (s or "").strip()
        for pref in ("First-line medication:", "First-Line medication:", "First-line Medication:", "FIRST-LINE MEDICATION:"):
            if pref in t:
                t = t.replace(pref, "").strip()
        return t

    def strip_renal_suffix_if_not_renal(s: str) -> str:
        if renal:
            return s
        t = (s or "")
        low = t.lower()
        k = low.find(" (avoid in renal disease")
        if k != -1:
            return t[:k].rstrip()
        return t

    def looks_like_bullet(s: str) -> bool:
        st = (s or "").lstrip()
        return st.startswith("-") or st.startswith("•")

    # --- find Plan block ---
    lines = soap_text.splitlines()

    plan_i = None
    for i, ln in enumerate(lines):
        l = ln.strip().lower()
        if l in ("p:", "plan:", "plan") or l.startswith("p:") or l.startswith("plan:"):
            plan_i = i
            break
    if plan_i is None:
        return soap_text

    headings = ("subjective:", "s:", "objective:", "o:", "assessment:", "a:", "mdm:", "medical decision")
    end_i = len(lines)
    for j in range(plan_i + 1, len(lines)):
        l = lines[j].strip().lower()
        if any(l.startswith(h) for h in headings):
            end_i = j
            break

    plan = lines[plan_i:end_i]

    # find Alternatives header if present
    alt_hdr = None
    for i, ln in enumerate(plan):
        if "alternatives" in (ln or "").lower():
            alt_hdr = i
            break

    def ensure_alt(after_idx: int) -> int:
        nonlocal alt_hdr, plan
        if alt_hdr is not None:
            return alt_hdr
        insert_at = min(after_idx + 1, len(plan))
        plan.insert(insert_at, " - Alternatives:")
        alt_hdr = insert_at
        return alt_hdr

    # Determine first-line content line
    fl_hdr = None
    for i, ln in enumerate(plan):
        if "first-line medication" in (ln or "").lower():
            fl_hdr = i
            break

    fl_idx = None
    fl_line = None

    if fl_hdr is not None:
        # header exists; drug may be on same line or next non-empty line
        if is_apap(plan[fl_hdr]) or is_nsaid(plan[fl_hdr]):
            fl_idx, fl_line = fl_hdr, plan[fl_hdr]
        else:
            k = fl_hdr + 1
            while k < len(plan) and plan[k].strip() == "":
                k += 1
            if k < len(plan):
                fl_idx, fl_line = k, plan[k]
    else:
        # no header; treat first bullet after P: as first-line
        k = 1
        while k < len(plan) and (plan[k].strip() == "" or not looks_like_bullet(plan[k]) or "alternatives" in plan[k].lower()):
            k += 1
        if k < len(plan):
            fl_idx, fl_line = k, plan[k]

    if fl_idx is None or fl_line is None:
        return soap_text

    # Find candidate NSAID and APAP lines in plan (excluding headers)
    apap_idx = None
    nsaid_idx = None
    for i, ln in enumerate(plan):
        low = (ln or "").lower()
        if "alternatives" in low or "first-line medication" in low:
            continue
        if apap_idx is None and is_apap(ln):
            apap_idx = i
        if nsaid_idx is None and is_nsaid(ln):
            nsaid_idx = i
        if apap_idx is not None and nsaid_idx is not None:
            break

    # --- precedence ---
    # Renal wins over liver
    if renal and is_nsaid(fl_line):
        # promote APAP
        if apap_idx is not None:
            apap_line = strip_firstline_label(plan[apap_idx]).lstrip("-").strip()
        else:
            apap_line = "Acetaminophen 500–1000 mg orally every 6 hours as needed for pain; max 3 grams/day (adjust for liver disease)."

        demoted = strip_firstline_label(fl_line).lstrip("-").strip()
        demoted = strip_renal_suffix_if_not_renal(demoted)
        demoted = f"{demoted} (avoid in renal disease; especially severe CKD/dialysis)"

        plan[fl_idx] = ("- " + apap_line) if looks_like_bullet(plan[fl_idx]) else apap_line

        # remove promoted apap elsewhere
        if apap_idx is not None and apap_idx != fl_idx:
            plan.pop(apap_idx)
            if apap_idx < fl_idx:
                fl_idx -= 1
            if alt_hdr is not None and apap_idx < alt_hdr:
                alt_hdr -= 1

        ah = ensure_alt(fl_idx)
        plan.insert(ah + 1, f" - {demoted}")
        return "\n".join(lines[:plan_i] + plan + lines[end_i:])

    if (liver and not renal) and is_apap(fl_line):
        # promote NSAID
        if nsaid_idx is None:
            return soap_text

        nsaid_line = strip_firstline_label(plan[nsaid_idx]).lstrip("-").strip()
        nsaid_line = strip_renal_suffix_if_not_renal(nsaid_line)

        apap_demoted = strip_firstline_label(fl_line).lstrip("-").strip()
        apap_demoted = strip_renal_suffix_if_not_renal(apap_demoted)
        apap_demoted = f"{apap_demoted} (use caution in liver disease; consider lower max daily dose)"

        plan[fl_idx] = ("- " + nsaid_line) if looks_like_bullet(plan[fl_idx]) else nsaid_line

        if nsaid_idx != fl_idx:
            plan.pop(nsaid_idx)
            if nsaid_idx < fl_idx:
                fl_idx -= 1
            if alt_hdr is not None and nsaid_idx < alt_hdr:
                alt_hdr -= 1

        ah = ensure_alt(fl_idx)
        plan.insert(ah + 1, f" - {apap_demoted}")
        return "\n".join(lines[:plan_i] + plan + lines[end_i:])

    return soap_text


def build_note(state: CallState) -> NoteDraft:

    # CALLCARE_BUILDNOTE_HEARTBEAT_V1
    # Always write a tiny log so we can prove build_note() ran and see dx fields at entry.
    try:
        import os, json, time
        os.makedirs("logs", exist_ok=True)
        sx = getattr(state, "symptoms", None) or {}
        if not isinstance(sx, dict):
            sx = {}
        with open("logs/build_note_entry.jsonl", "a", encoding="utf-8") as f:
            f.write(json.dumps({
                "ts": time.time(),
                "state_pathway_id": getattr(state, "pathway_id", None),
                "state_pathway_label": getattr(state, "pathway_label", None),
                "state_working_diagnosis": getattr(state, "working_diagnosis", None),
                "state_chief_complaint": getattr(state, "chief_complaint", None),
                "sx_keys": sorted(list(sx.keys()))[:60],
                "sx__dx_inferred": sx.get("_dx_inferred"),
                "sx__pathway": sx.get("_pathway"),
                "sx__llm_intake_extract_type": str(type(sx.get("_llm_intake_extract"))),
                "sx__llm_intake_summary_len": len(str(sx.get("_llm_intake_summary") or "")),
            }, default=str) + "\n")
    except Exception:
        pass


    # CALLCARE_DX_SET_FROM_EXTRACT_V1
    # Set a usable working_diagnosis BEFORE evidence retrieval/auto-acquire.
    # Prefer structured LLM intake extract; fall back to chief complaint.
    try:
        import os, json, time
        os.makedirs("logs", exist_ok=True)

        sx = getattr(state, "symptoms", None) or {}
        if not isinstance(sx, dict):
            sx = {}

        chosen = ""

        raw = sx.get("_llm_intake_extract")
        if isinstance(raw, dict):
            for k in ("working_diagnosis","diagnosis","primary_diagnosis","impression","assessment"):
                v = raw.get(k)
                if isinstance(v, str) and v.strip():
                    chosen = v.strip()
                    break

        if not chosen:
            cc = (getattr(state, "chief_complaint", "") or "").strip()
            if cc:
                chosen = cc

        if chosen:
            try:
                if not str(getattr(state, "working_diagnosis", "") or "").strip():
                    state.working_diagnosis = chosen
            except Exception:
                pass
            try:
                if not str(getattr(state, "pathway_label", "") or "").strip():
                    state.pathway_label = chosen
            except Exception:
                pass
            try:
                sx["_dx_inferred"] = chosen
            except Exception:
                pass

        with open("logs/dx_set_pre_note.jsonl", "a", encoding="utf-8") as f:
            f.write(json.dumps({
                "ts": time.time(),
                "chosen": chosen,
                "from_extract": isinstance(raw, dict),
                "extract_keys": sorted(list(raw.keys()))[:40] if isinstance(raw, dict) else [],
                "chief_complaint": getattr(state, "chief_complaint", None),
            }, default=str) + "\n")

    except Exception:
        pass

    # CALLCARE_HYDRATE_PATHWAY_ID_FROM_SYMPTOMS_V1
    # Ensure we have a pathway_id/working_diagnosis available at note-build time.
    try:
        pid = getattr(state, "pathway_id", None)
        if not pid:
            sx = getattr(state, "symptoms", None) or {}
            pw = None
            try:
                pw = sx.get("_pathway")
            except Exception:
                pw = None
            if isinstance(pw, dict):
                pid = pw.get("id") or pw.get("pathway_id") or pid
        if pid:
            try: state.pathway_id = str(pid)
            except Exception: pass
            try:
                if not getattr(state, "working_diagnosis", None):
                    state.working_diagnosis = str(pid).replace("_"," ")
            except Exception:
                pass
    except Exception:
        pass

    
    # CALLCARE_DX_FROM_INTAKE_V2
    # Ensure working_diagnosis exists BEFORE evidence building / auto-acquire.
    # Always logs what happened so we never guess again.
    try:
        sx = getattr(state, "symptoms", None) or {}
        if not isinstance(sx, dict):
            sx = {}

        candidates = []

        def _add(v, src):
            try:
                s = "" if v is None else str(v).strip()
                if s:
                    candidates.append((s, src))
            except Exception:
                pass

        # 0) If already set on state, keep it
        _add(getattr(state, "working_diagnosis", None), "state.working_diagnosis")
        _add(getattr(state, "pathway_label", None), "state.pathway_label")
        _add(getattr(state, "pathway_id", None), "state.pathway_id")

        # 1) Common symptom keys (LLM era / misc)
        for k in ("_dx_inferred","dx","diagnosis","working_diagnosis","primary_diagnosis","impression","assessment","route","routing"):
            _add(sx.get(k), f"symptoms[{k}]")

        # 2) RAG bundle sometimes carries a diagnosis label
        try:
            rag = sx.get("_rag")
            if isinstance(rag, dict):
                for k in ("working_diagnosis","diagnosis","label","pathway_label","pathway_id"):
                    _add(rag.get(k), f"symptoms[_rag][{k}]")
        except Exception:
            pass

        # 3) Structured intake extract (dict or JSON string)
        raw = sx.get("_llm_intake_extract")
        if isinstance(raw, dict):
            for k in ("working_diagnosis","diagnosis","primary_diagnosis","impression","assessment","chief_complaint","cc"):
                _add(raw.get(k), f"symptoms[_llm_intake_extract][{k}]")
        elif isinstance(raw, str) and raw.strip():
            s = raw.strip()
            if s.startswith("{") and s.endswith("}"):
                try:
                    import json
                    obj = json.loads(s)
                    if isinstance(obj, dict):
                        for k in ("working_diagnosis","diagnosis","primary_diagnosis","impression","assessment","chief_complaint","cc"):
                            _add(obj.get(k), f"json(_llm_intake_extract)[{k}]")
                except Exception:
                    pass

        # 4) Intake summary text heuristic
        summ = sx.get("_llm_intake_summary")
        if isinstance(summ, str) and summ.strip():
            import re
            m = re.search(r"(working diagnosis|diagnosis|impression|assessment)\s*[:\-]\s*([^\n\r]{4,140})", summ, flags=re.I)
            if m:
                _add(m.group(2), "symptoms[_llm_intake_summary] heuristic")

        # 5) Last fallback: chief complaint
        _add(getattr(state, "chief_complaint", None), "state.chief_complaint")

        chosen = candidates[0][0] if candidates else ""

        # Persist onto state if missing
        try:
            if chosen and not str(getattr(state, "working_diagnosis", "") or "").strip():
                state.working_diagnosis = chosen
        except Exception:
            pass
        try:
            if chosen and not str(getattr(state, "pathway_label", "") or "").strip():
                state.pathway_label = chosen
        except Exception:
            pass
        try:
            if chosen:
                sx["_dx_inferred"] = chosen
        except Exception:
            pass

        # ALWAYS log
        try:
            import json, time
            Path("logs").mkdir(exist_ok=True)
            with open("logs/dx_set_pre_note.jsonl", "a", encoding="utf-8") as f:
                f.write(json.dumps({
                    "ts": time.time(),
                    "chosen": chosen,
                    "n_candidates": len(candidates),
                    "top_sources": [src for _,src in candidates[:6]],
                    "has_extract": isinstance(raw, (dict,str)) and bool(str(raw).strip()),
                    "has_summary": isinstance(summ, str) and bool(summ.strip()),
                    "sx_keys_sample": sorted(list(sx.keys()))[:80],
                }, default=str) + "\n")
        except Exception:
            pass

    except Exception:
        pass

    # CALLCARE_BUILDNOTE_POSTDX_HEARTBEAT_V1
    try:
        import os, json, time
        os.makedirs("logs", exist_ok=True)
        sx = getattr(state, "symptoms", None) or {}
        if not isinstance(sx, dict):
            sx = {}
        with open("logs/build_note_postdx.jsonl", "a", encoding="utf-8") as f:
            f.write(json.dumps({
                "ts": time.time(),
                "state_pathway_id": getattr(state, "pathway_id", None),
                "state_pathway_label": getattr(state, "pathway_label", None),
                "state_working_diagnosis": getattr(state, "working_diagnosis", None),
                "sx__dx_inferred": sx.get("_dx_inferred"),
            }, default=str) + "\n")
    except Exception:
        pass

    disposition, plan, safety = _decision_bits(state)
    ev_mf = _evidence_from_manifest(state)
    ev_dec = _evidence_from_decision(state)

    # Prefer manifest evidence (pathway-specific). Only use RAG to top up if we still have <3 unique items.
    evidence = _merge_evidence(ev_mf, ev_dec, max_total=8)
    # CallCare: apply urinary relevance filter to final evidence
    evidence = _cc_filter_evidence_urinary(state, evidence)

    if len(evidence) < 3:
        ev_rag = _evidence_from_rag(state, max_snips=6)
        evidence = _merge_evidence(evidence, ev_rag, max_total=8)
        # CallCare: apply urinary evidence clamp
        evidence = _cc_filter_urinary_evidence(state, evidence)
        # CallCare: enforce min 3 unique sources
        evidence = _cc_topup_evidence_min3(state, evidence, min_unique=3, max_total=10)

    evidence = _cc_topup_dosing_evidence(state, evidence, max_total=10)

    preg_norm = _sync_pregnancy_from_answers(state)
    preg_sentence = _preg_sentence_from_norm(preg_norm)

    soap_text, err = _generate_llm_soap_with_retry(state, evidence)

    # CALLCARE_DX_FROM_SOAP_V1
    try:
        import os, json, time
        os.makedirs('logs', exist_ok=True)
        with open('logs/soaplen_at_dxblock.jsonl','a',encoding='utf-8') as f:
            f.write(json.dumps({'ts': time.time(), 'soap_len': len(soap_text or ''), 'soap_head': (soap_text or '')[:120], 'cc': str(getattr(state,'chief_complaint','') or '')}, default=str) + '\n')
    except Exception:
        pass
    dx_from_soap = ''
    try:
        import re
        _t = soap_text or ''
        # 1) Prefer Differential #1 if present
        m0 = re.search(r'Differential\s*:\s*\n\s*1\.?\s*([^\n\r]{4,160})', _t, flags=re.IGNORECASE)
        if m0:
            dx_from_soap = m0.group(1).strip()
        # 2) Otherwise, try 'consistent with <dx>'
        if not dx_from_soap:
            m1 = re.search(r'consistent\s+with\s+([^\n\r\.]{4,140})', _t, flags=re.IGNORECASE)
            if m1:
                dx_from_soap = m1.group(1).strip()
        # 3) Otherwise, take first A: line
        if not dx_from_soap:
            m2 = re.search(r'\nA:\s*(.{6,260})', _t, flags=re.IGNORECASE)
            if m2:
                dx_from_soap = m2.group(1).split('Differential')[0].strip()
    except Exception:
        dx_from_soap = ''

    # Persist onto state (helps other downstream components; safe if fields exist)
    try:
        if dx_from_soap and not getattr(state, 'working_diagnosis', None):
            state.working_diagnosis = dx_from_soap
    except Exception:
        pass

    # Run auto-acquire using the dx we already have in the SOAP (this is the first reliable dx)
    try:
        evidence = _cc_auto_acquire_if_needed(evidence, dx_text=dx_from_soap)
    except Exception:
        pass

    # Log what dx was extracted so we can verify without re-running sims forever
    try:
        import os, json, time
        os.makedirs('logs', exist_ok=True)
        with open('logs/dx_from_soap.jsonl','a',encoding='utf-8') as f:
            f.write(json.dumps({'ts': time.time(), 'dx_from_soap': dx_from_soap, 'cc': str(getattr(state,'chief_complaint','') or '')}, default=str) + '\n')
    except Exception:
        pass
    # CALLCARE_SOAPTEXT_TYPE_GUARD_V1
    if not isinstance(soap_text, str):
        try:
            import os, json, time
            os.makedirs('logs', exist_ok=True)
            with open('logs/soap_text_type_error.jsonl','a',encoding='utf-8') as f:
                f.write(json.dumps({'ts': time.time(), 'type': str(type(soap_text))}, default=str) + '\n')
        except Exception:
            pass
        soap_text = ''
    if not soap_text.strip():
        soap_text = f"(NOTE: LLM note generation unavailable: {err})\n"

    # Pregnancy: single canonical placement (last sentence of Subjective) + cleanup elsewhere
    soap_text = _cc_remove_canonical_preg_sentence(soap_text, preg_sentence)
    soap_text = _insert_preg_sentence_as_last_subjective_sentence(soap_text, preg_sentence)

    soap_text = _cc_adjust_plan_analgesics_for_renal(soap_text, state)

    soap_text = _strip_redundant_no_preg_pos_sentence(soap_text, preg_sentence)

    soap_text = _fix_tick_attachment_wording_in_subjective(soap_text)
    # (CallCare) Med protocol injection disabled (RAG/LLM-only)
# Deterministic meds support insertion (RAG-first, clinician-ordered)
# CALLCARE_DISABLED_MED_SUPPORT_V1:     soap_text = _inject_med_support_into_plan(soap_text, state, evidence)

    if getattr(state, "pathway_id", "") == "dvt_possible":
        soap_text = _postprocess_dvt_possible_soap(soap_text)

    allow_otc = (not _is_emergent_disposition(disposition)) and (not _avoid_otc_from_text(plan, soap_text))
    if getattr(state, "pathway_id", "") == "dvt_possible":
        allow_otc = False
    # Patient instructions: derived from decision/safety-net (non-protocol)
    patient_instructions = _build_patient_instructions(disposition, safety, allow_otc)
    # (CallCare) Protocol-derived patient instructions disabled
# --- CALLCARE_STRIP_PREG_SAFETY_PI_V2 ---
    # If pregnancy is explicitly "not pregnant" (or patient answered pregnancy_possible = no), remove generic pregnancy-safety bullet.
    try:
        ps_l = (preg_sentence or "").lower()
        answers = (getattr(state, "symptoms", {}) or {}).get("_answers") or {}
        preg_ans = answers.get("pregnancy_possible")
        preg_no = False
        if isinstance(preg_ans, list):
            preg_no = any(str(x).strip().lower() in ("no", "n") for x in preg_ans)
        elif isinstance(preg_ans, str):
            preg_no = (preg_ans.strip().lower() in ("no", "n"))

        if ("not pregnant" in ps_l) or preg_no:
            patient_instructions = [
                x for x in patient_instructions
                if not str(x).strip().lower().startswith("pregnancy safety:")
            ]
    except Exception:
        pass

    # DVT_PATIENT_INSTRUCTIONS_OVERRIDE
    # For dvt_possible: instructions must be urgent-now (not contingent on worsening), ED/911-forward, and never mention meds.
