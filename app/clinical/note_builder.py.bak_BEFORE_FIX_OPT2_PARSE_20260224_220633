# CallCare: enforce min unique evidence sources
def _cc_unique_sources(evidence):
    seen = set()
    out = []
    for ev in (evidence or []):
        src = ''
        try:
            src = str(getattr(ev, 'source', '') or '').strip()
        except Exception:
            src = ''
        if not src or src in seen:
            continue
        seen.add(src)
        out.append(ev)
    return out

def _cc_topup_evidence_min3(state, evidence, min_unique=3, max_total=10):
    # Ensure at least min_unique distinct EvidenceRef.source URLs.
    evidence = _cc_unique_sources(evidence)
    if len(evidence) >= min_unique:
        return evidence[:max_total]
    try:
        from app.rag.retrieve import retrieve
    except Exception:
        return evidence[:max_total]
    # Overfetch and add new sources
    try:
        q = _build_query(state)
    except Exception:
        q = ''
    if not q:
        return evidence[:max_total]
    hits = retrieve(q, k=60)
    seen = set([str(getattr(ev, 'source', '') or '').strip() for ev in evidence])
    for h in hits:
        if not isinstance(h, dict):
            continue
        u = (h.get('url') or h.get('source') or '').strip()
        if not u or u in seen:
            continue
        seen.add(u)
        try:
            ev = _mk_evidence_ref(h)
        except Exception:
            continue
        evidence.append(ev)
        evidence = _cc_unique_sources(evidence)
        if len(evidence) >= min_unique:
            break
    return evidence[:max_total]
# --- End min-unique enforcement ---


# CallCare: strong pregnancy dedupe clamp
def _cc_dedupe_preg_strong(text):
    if not text:
        return text
    # Remove duplicate pregnancy-status sentences regardless of phrasing.
    # If the text contains any 'not pregnant' sentence, drop subsequent ones.
    # If it contains any 'pregnant' sentence, drop subsequent ones.
    out = text
    # normalize whitespace
    out = re.sub(r'\s+', ' ', out)
    # Deduplicate 'not pregnant' (keep first)
    m = re.search(r'\bnot pregnant\b', out, flags=re.IGNORECASE)
    if m:
        # remove any later sentence that contains 'not pregnant'
        parts = re.split(r'(?<=[.!?])\s+', out)
        kept = []
        seen = False
        for sent in parts:
            if re.search(r'\bnot pregnant\b', sent, flags=re.IGNORECASE):
                if seen:
                    continue
                seen = True
            kept.append(sent)
        out = ' '.join([x for x in kept if x])
    # Deduplicate 'pregnant' (keep first) but don't remove 'not pregnant'
    # Only runs if there is a 'pregnant' sentence that is not the 'not pregnant' phrase.
    parts = re.split(r'(?<=[.!?])\s+', out)
    kept = []
    seen = False
    for sent in parts:
        is_preg = re.search(r'\bpregnant\b', sent, flags=re.IGNORECASE) is not None
        is_not = re.search(r'\bnot pregnant\b', sent, flags=re.IGNORECASE) is not None
        if is_preg and (not is_not):
            if seen:
                continue
            seen = True
        kept.append(sent)
    out = ' '.join([x for x in kept if x])
    return out
# --- End strong clamp ---


