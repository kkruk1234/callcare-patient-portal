def _sync_pregnancy_from_answers(state: CallState) -> str:
    """
    Normalize pregnancy_possible to one of:
      - "yes"
      - "no"
      - "unknown"
      - "not_applicable"
      - "" (missing)
    """
    try:
        sx = getattr(state, "symptoms", None) or {}
        if not isinstance(sx, dict):
            sx = {}
        ans = sx.get("_answers", {}) or {}
        if not isinstance(ans, dict):
            ans = {}

        raw = ans.get("pregnancy_possible")
        if raw is None or str(raw).strip() == "":
            raw = getattr(state, "pregnancy_possible", None)
        if raw is None or str(raw).strip() == "":
            raw = sx.get("pregnancy_possible", None)

        if raw is None:
            return ""

        s = str(raw).strip().lower()

        if s in ("y", "yes", "yeah", "yep", "true", "pregnant"):
            return "yes"
        if s in ("n", "no", "nope", "false", "not pregnant"):
            return "no"
        if s in ("unknown", "unsure", "not sure", "dont know", "don't know", "maybe", "possible"):
            return "unknown"
        if s in ("na", "n/a", "not applicable", "not-applicable", "not_applicable", "notapplicable", "male"):
            return "not_applicable"

        return "unknown"
    except Exception:
        return ""


def _preg_sentence_from_norm(preg_norm: str) -> str:
    """
    Convert normalized pregnancy response into a clinician-facing declarative sentence.

    Canonical outputs (ONLY these):
      - Patient is pregnant.
      - Patient is not pregnant.
      - Patient is unsure about pregnancy status.
      - "" (not applicable / do not mention)
    """
    v = (str(preg_norm or "").strip().lower())

    # not_applicable (e.g., male sex-at-birth): do not mention pregnancy at all
    if v in ("not_applicable", "n/a", "na", "not applicable"):
        return ""

    if v in ("yes", "y", "pregnant", "true"):
        return "Patient is pregnant."

    if v in ("no", "n", "not pregnant", "false"):
        return "Patient is not pregnant."

    # Unknown / unsure / unclear
    if v in ("unknown", "unsure", "uncertain", "not sure", "maybe", "possible", "?", ""):
        return "Patient is unsure about pregnancy status."

    # Fallback: treat unexpected values as unsure rather than inventing
    return "Patient is unsure about pregnancy status."



def _cc_remove_canonical_preg_sentence(soap_text: str, preg_sentence: str) -> str:
    """
    Deterministic de-dupe: remove ALL occurrences of the canonical pregnancy sentence (case-insensitive)
    before we re-insert it once as the last sentence of Subjective.
    Does not change wording; only removes exact canonical sentence.
    """
    if not soap_text or not preg_sentence:
        return soap_text
    # Escape and remove any number of occurrences with trailing whitespace
    pat = re.compile(re.escape(preg_sentence) + r"\s*", flags=re.IGNORECASE)
    return pat.sub("", soap_text)

def _preg_line_should_remove(line: str) -> bool:
    """
    Remove ONLY status/fragments, not clinically-relevant protocol cautions like
    'pregnancy/trimester matters' which belong in medication notes.
    """
    s = (line or "").strip()
    if not s:
        return False

    low = s.lower()

    # Keep protocol cautions containing "trimester"
    if "trimester" in low:
        return False

    # Remove standalone status lines / fragments
    patterns = [
        r"(?i)^\s*-?\s*patient\s+is\s+pregnant\.?\s*$",
        r"(?i)^\s*-?\s*patient\s+is\s+not\s+pregnant\.?\s*$",
        r"(?i)^\s*-?\s*pregnancy\s+status\s+is\s+unknown\.?\s*$",
        r"(?i)^\s*-?\s*pregnancy\s+status\s+is\s+not\s+applicable\.?\s*$",
        r"(?i)^\s*-?\s*since\s+patient\s+is\s+pregnant\.?\s*$",
        r"(?i)^\s*-?\s*since\s+patient\s+is\s+not\s+pregnant\.?\s*$",
        # common nurse-triage boilerplate we do NOT want in A/P
        r"(?i).*possible\s+pregnancy\s+status\s+affecting\s+treatment\s+choices.*",
    ]
    for pat in patterns:
        if re.match(pat, s):
            return True
    return False


def _insert_preg_sentence_as_last_subjective_sentence(soap_text: str, preg_sentence: str) -> str:
    """
    Policy:
      - pregnancy status sentence appears ONLY in Subjective
      - it is appended as the LAST sentence of the Subjective narrative (NOT on its own line)
      - never duplicated
      - if preg_sentence is empty -> do nothing (still remove obvious fragments elsewhere)
    """
    try:
        if not soap_text:
            return soap_text

        # If no pregnancy sentence, just clean fragments and return.
        if not preg_sentence:
            lines0 = soap_text.splitlines()
            cleaned0 = [ln for ln in lines0 if not _preg_line_should_remove(ln)]
            return "\n".join(cleaned0)

        # Remove any existing pregnancy status lines/fragments anywhere first.
        lines0 = soap_text.splitlines()
        lines = [ln for ln in lines0 if not _preg_line_should_remove(ln)]

        # Locate Subjective header ("S:" or "Subjective:") — allow same-line content (e.g., "S: ...")
        subj_idx = None
        for i, ln in enumerate(lines):
            if re.match(r"^\s*S\s*:\s*", ln):
                subj_idx = i
                break
        if subj_idx is None:
            for i, ln in enumerate(lines):
                if re.match(r"^\s*Subjective\s*:\s*", ln, flags=re.IGNORECASE):
                    subj_idx = i
                    break

        # If no Subjective header found, append at end (last resort)
        if subj_idx is None:
            out = "\n".join(lines).rstrip()
            if out.endswith((".", "!", "?")):
                return (out + " " + preg_sentence).rstrip() + "\n"
            return (out + ". " + preg_sentence).rstrip() + "\n"

        # Find end of Subjective section: next header O:/A:/P: or end of doc
        end_idx = len(lines)
        for j in range(subj_idx + 1, len(lines)):
            if re.match(r"^\s*(O|A|P)\s*:\s*$", lines[j].strip()):
                end_idx = j
                break
            if re.match(r"^\s*(Objective|Assessment|Plan)\s*:\s*$", lines[j].strip(), flags=re.IGNORECASE):
                end_idx = j
                break

        # Find last non-empty content line within Subjective body
        k = end_idx - 1
        while k > subj_idx and not lines[k].strip():
            k -= 1

        if k <= subj_idx:
            # Subjective body empty; create a line after header (rare)
            lines.insert(subj_idx + 1, preg_sentence)
            return "\n".join(lines)

        last_line = lines[k].rstrip()

        # Append as last sentence to the existing last subjective line
        if last_line.endswith((".", "!", "?")):
            lines[k] = last_line + " " + preg_sentence
        else:
            lines[k] = last_line + ". " + preg_sentence

        return "\n".join(lines)
    except Exception:
        return soap_text


def _fix_tick_attachment_wording_in_subjective(soap_text: str) -> str:
    try:
        if not soap_text:
            return soap_text

        lines = soap_text.splitlines()

        s_idx = None
        for i, line in enumerate(lines):
            if line.strip() == "S:" or line.strip().startswith("S:"):
                s_idx = i
                break
        if s_idx is None:
            return soap_text

        start = s_idx + 1 if lines[s_idx].strip() == "S:" else s_idx

        for j in range(start, len(lines)):
            txt = lines[j]

            if j != s_idx and txt.strip() == "":
                break
            if txt.strip().startswith(("O:", "A:", "P:")):
                break

            if re.search(r"\btick\b.*\battached\b.*\bhours?\b", txt, flags=re.IGNORECASE):
                continue

            m = re.search(
                r"(tick bite)\s+sustained(?:\s+in\s+([A-Za-z][A-Za-z .'-]{1,40}))?\s+approximately\s+(\d{1,3})\s*hours?\s+ago",
                txt,
                flags=re.IGNORECASE,
            )
            if not m:
                continue

            loc = (m.group(2) or "").strip()
            hours = int(m.group(3))

            if loc:
                replacement = f"tick bite after exposure in {loc} with the tick attached for approximately {hours} hours"
            else:
                replacement = f"tick bite with the tick attached for approximately {hours} hours"

            lines[j] = re.sub(
                r"(tick bite)\s+sustained(?:\s+in\s+[A-Za-z][A-Za-z .'-]{1,40})?\s+approximately\s+\d{1,3}\s*hours?\s+ago",
                replacement,
                txt,
                flags=re.IGNORECASE,
            )

        return "\n".join(lines)
    except Exception:
        return soap_text


