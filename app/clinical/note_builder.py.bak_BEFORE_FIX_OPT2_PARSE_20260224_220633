    """
    Pull evidence directly from the pathway's manifest.json and convert to EvidenceRef.
    This is deterministic and prevents generic RAG results from dominating Evidence Used.
    """
    pid = (getattr(state, "pathway_id", "") or (getattr(state, "symptoms", {}) or {}).get("_pathway", {}).get("id") or "").strip()
    if not pid:
