def _merge_evidence(a, b, max_total: int = 5):
    """
    Merge two evidence lists (EvidenceRef-like objects and/or dict chunks) with stable de-duplication.
    Avoids putting dicts into sets (prevents: unhashable type: 'dict').

    De-dupe key priority:
      1) URL (or dict 'url'/'source' if it looks like a URL)
      2) source/publisher + title
      3) title only
      4) repr fallback
    Preserves order: items from a first, then b until max_total.
    """

    def _ev_fields(ev):
        if isinstance(ev, dict):
            title = str(ev.get('title') or '').strip()
            url = str(ev.get('url') or '').strip()
            source = str(ev.get('source') or ev.get('publisher') or '').strip()
            if (not url) and isinstance(ev.get('source'), str) and ev.get('source', '').startswith(('http://','https://')):
                url = str(ev.get('source') or '').strip()
            return title, url, source

        title = str(getattr(ev, 'title', '') or '').strip()
        url = str(getattr(ev, 'url', '') or '').strip()
        source = str(getattr(ev, 'source', '') or getattr(ev, 'publisher', '') or '').strip()
        if (not url) and isinstance(getattr(ev, 'source', None), str) and str(getattr(ev, 'source')).startswith(('http://','https://')):
            url = str(getattr(ev, 'source') or '').strip()
        return title, url, source

    def _ev_key(ev) -> str:
        title, url, source = _ev_fields(ev)
        if url:
            return ('url:' + url).lower()
        if source or title:
            return ('st:' + (source + ' | ' + title)).lower().strip()
        try:
            return ('repr:' + repr(ev)).lower()
        except Exception:
            return 'repr:<unknown>'

    out = []
    seen = set()

    for lst in (a or [], b or []):
        if not isinstance(lst, list):
            continue
        for ev in lst:
            if ev is None:
                continue
            k = _ev_key(ev)
            if k in seen:
                continue
            seen.add(k)
            out.append(ev)
            if len(out) >= max_total:
                return out

    return out

def _patient_instructions_from_protocol_state(state: CallState) -> List[str]:
    """If a meds protocol exists for this pathway, convert supportive_care + followup_and_safety into patient-facing bullets."""
    try:
        from app.clinical.med_protocols import load_med_protocol_for_state
    except Exception:
        return []

    try:
        protocol = load_med_protocol_for_state(state) if state is not None else None
    except Exception:
        protocol = None

    if not isinstance(protocol, dict):
        return []

    bullets: List[str] = []

    for section_name in ("supportive_care", "followup_and_safety"):
        section = protocol.get(section_name) or []
        if not isinstance(section, list):
            continue

        for item in section:
            if not isinstance(item, dict):
                continue
            title = (item.get("item") or "").strip()
            details = (item.get("details") or "").strip()
            if title and details:
                bullets.append(title + ": " + details)
            elif title:
                bullets.append(title)
            elif details:
                bullets.append(details)

    # Deduplicate while preserving order
    seen = set()
    out: List[str] = []
    for b in bullets:
        b2 = " ".join(str(b).split()).strip()
        if b2 and b2 not in seen:
            out.append(b2)
            seen.add(b2)
    return out


def _build_patient_instructions(disposition: str, safety_net: List[str], allow_otc: bool) -> List[str]:
    """
    Build patient-facing instructions.

    DVT / urgent-eval rules:
    - Never rely solely on LLM SOAP phrasing.
    - If disposition OR safety-net content implies urgency, do NOT use 'if worsening' boilerplate.
    - Telephone-only wording: use 'go to the emergency department / call 911' rather than 'call or return'.
    """
    out: List[str] = []

    disp = (disposition or "").strip()
    disp_l = disp.lower()

    def _ireplace(text: str, old: str, new: str) -> str:
        t = text
        old_l = old.lower()
        while True:
            i = t.lower().find(old_l)
            if i == -1:
                return t
            t = t[:i] + new + t[i+len(old):]

    def _urgent_from_disposition(d: str) -> bool:
        markers = [
            "urgent", "same-day", "emergency", "emergency department", "ed",
            "immediate", "go now", "in-person evaluation", "in person evaluation"
        ]
        return any(x in d for x in markers)

    def _urgent_from_safety(sn: List[str]) -> bool:
        hay = " ".join([str(x) for x in (sn or [])]).lower()
        # If we're talking PE red flags / ED language, treat as urgent.
        markers = ["chest pain", "shortness of breath", "difficulty breathing", "call 911", "emergency department", "ed"]
        return any(x in hay for x in markers)

    urgent = _urgent_from_disposition(disp_l) or _urgent_from_safety(safety_net)

    if urgent:
        out.append("This needs urgent in-person evaluation today.")
    else:
        
        pass
    normalized: List[str] = []
    for s in (safety_net or [])[:10]:
        s2 = str(s).strip()
        if not s2:
            continue

        # Convert telephone-only phrasing.
        s2 = _ireplace(s2, "call or return", "go immediately to your local emergency department")
        s2 = _ireplace(s2, "return immediately", "go immediately to your local emergency department")
        s2 = _ireplace(s2, "call immediately", "go immediately to your local emergency department")

        if urgent:
            s2_l = s2.lower()
            already = ("emergency department" in s2_l) or ("call 911" in s2_l) or ("go immediately" in s2_l)
            if not already:
                s2 = "Go immediately to your local emergency department (or call 911) if " + s2.rstrip(".") + "."

        normalized.append(s2)

    if urgent:
        out.append("Emergency warning signs (go to the emergency department immediately / call 911):")

    out.extend(normalized)
    return out
