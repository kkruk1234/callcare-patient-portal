                    _dx_from_decision = str(v)
                    break
            if not _dx_from_decision:
                # fallback: id/pathway_id -> turn underscores into spaces
                pid = _decision.get("pathway_id") or _decision.get("id") or _decision.get("pathway")
                if pid:
                    _dx_from_decision = str(pid).replace("_"," ")
    
        # Mirror onto state if those fields exist (so other code can use them)
        try:
            if _dx_from_decision:
                if getattr(state, "working_diagnosis", None) in (None, "", "None"):
                    state.working_diagnosis = _dx_from_decision
        except Exception:
            pass
        try:
            if isinstance(_decision, dict):
                pid = _decision.get("pathway_id") or _decision.get("id") or _decision.get("pathway")
                if pid and getattr(state, "pathway_id", None) in (None, "", "None"):
                    state.pathway_id = str(pid)
        except Exception:
            pass
    
        # Log what we found
        try:
            Path("logs").mkdir(exist_ok=True)
            with open("logs/dx_from_decision.jsonl","a",encoding="utf-8") as f:
                f.write(json.dumps({"ts": time.time(), "decision_type": str(type(_decision)), "decision": _decision, "dx_from_decision": _dx_from_decision} , default=str) + "\n")
        except Exception:
            pass
    except Exception:
        pass

    return NoteDraft(
        soap=soap_text,
        patient_instructions=patient_instructions,
        clinician_questions=clinician_questions,
        risk_flags=risk_flags,
        evidence=evidence,
    )


# --- CallCare API shim: finalize.py expects build_note_with_reason ---
def build_note_with_reason(state, *args, **kwargs):
    # Return (note, reason). reason may be None.
    for name in (
        'build_note',
        'build_note_draft',
        'build_note_from_state',
        'build_note_for_state',
    ):
        fn = globals().get(name)
        if callable(fn):
            out = fn(state, *args, **kwargs)
            if isinstance(out, tuple) and len(out) == 2:
                return out
            return out, None
    raise ImportError('No compatible build_note* function found in note_builder.py')
# --- End shim ---



def _cc_evidence_sufficiency_flags(evidence_list, dx_text: str):
    """
    General, deterministic sufficiency detector.
    Returns (need_dx_more, need_treatment_more, need_dosing_more).
    """
    dx = (dx_text or "").lower().strip()
    if not dx:
        return (True, True, True)

    dx_hits = 0
    dosing_hits = 0
    treat_hits = 0

    for e in (evidence_list or []):
        try:
            title = str(e.get("title") or "").lower()
            url = str(e.get("url") or "").lower()
            snip = str(e.get("snippet") or "").lower()
        except Exception:
            continue

        blob = " ".join([title, url, snip[:400]])
        if dx and dx in blob:
            dx_hits += 1

        # dosing signals (general)
        if any(k in blob for k in [" mg", " mcg", " g/", " qd", " bid", " tid", " q6", " q8", " q12", "max daily", "maximum daily", "daily dose"]):
            dosing_hits += 1

        # treatment signals (general)
        if any(k in blob for k in ["treat", "therapy", "management", "guideline", "recommend", "first-line", "first line"]):
            treat_hits += 1

    need_dx_more = dx_hits < 3
    need_dosing_more = dosing_hits < 1
    need_treatment_more = treat_hits < 1

    return (need_dx_more, need_treatment_more, need_dosing_more)


def _cc_merge_evidence(existing, incoming, *, max_total: int = 10):
    seen = set()
    out = []
    for e in (existing or []):
        e2 = ensure_evidence_dict(e)
        key = (str(e2.get("url") or ""), str(e2.get("title") or ""))
        if key in seen:
            continue
        seen.add(key)
        out.append(e2)
        if len(out) >= max_total:
            return out
    for e in (incoming or []):
        e2 = ensure_evidence_dict(e)
        key = (str(e2.get("url") or ""), str(e2.get("title") or ""))
        if key in seen:
            continue
        seen.add(key)
        out.append(e2)
        if len(out) >= max_total:
            break
    return out


def _cc_auto_acquire_if_needed(evidence_list, dx_text: str):
    """
    Time-bounded auto-acquire that improves the CURRENT call by attaching freshly ingested docs directly.
    No FAISS rebuild here.
    """
    try:
        from app.rag.auto_acquire_fast import acquire_ingest_attach
    except Exception:
        return evidence_list

    need_dx_more, need_treat_more, need_dose_more = _cc_evidence_sufficiency_flags(evidence_list, dx_text)

    if not (need_dx_more or need_treat_more or need_dose_more):
        return evidence_list

    # Strict time budget to avoid freezing calls
    time_budget = 25.0

    acquired_docs = []

    if need_dx_more or need_treat_more:
        q1 = f"{dx_text} guideline treatment management"
        r1 = acquire_ingest_attach(query=q1, max_urls=4, time_budget_sec=time_budget)
        acquired_docs.extend(r1.ingested_docs or [])

    if need_dose_more:
        q2 = f"{dx_text} ibuprofen dosing naproxen dosing adult maximum daily dose"
        r2 = acquire_ingest_attach(query=q2, max_urls=4, time_budget_sec=time_budget)
        acquired_docs.extend(r2.ingested_docs or [])

    # Convert ingested docs into evidence dicts (schema-safe)
    incoming = []
    for d in acquired_docs:
        # tolerate various doc-handle shapes
        title = d.get("title") or d.get("doc_title") or ""
        url = d.get("url") or d.get("source_url") or ""
        text = d.get("text") or d.get("content") or d.get("snippet") or ""
        incoming.append({"title": title, "source": (url or "").strip(), "snippet": (text or "")[:360]})

    return _cc_merge_evidence(evidence_list, incoming, max_total=10)




def _cc_filter_evidence_for_dx(evidence_list, dx_text: str, *, keep_max: int = 10):
    """
    Deterministic relevance filter:
    - Keep evidence that mentions dx in title/url/snippet
    - Also keep high-value med monographs (dailymed/medlineplus) ONLY if they contain dosing signals
    """
    dx = (dx_text or "").lower().strip()
    if not evidence_list:
        return evidence_list
    if not dx:
        return evidence_list[:keep_max]

    def has_dx(e):
        t = str(e.get("title") or "").lower()
        u = str(e.get("url") or "").lower()
        s = str(e.get("snippet") or "").lower()
        blob = " ".join([t, u, s[:500]])
        return dx in blob

    def is_dosing_monograph(e):
        u = str(e.get("url") or "").lower()
        s = str(e.get("snippet") or "").lower()
        if ("dailymed" in u) or ("medlineplus" in u):
            return any(k in s for k in [" mg", " mcg", "maximum", "max daily", "daily dose", "q6", "q8", "q12", "bid", "tid"])
        return False

    kept = []
    for e in evidence_list:
        if has_dx(e) or is_dosing_monograph(e):
            kept.append(e)
        if len(kept) >= keep_max:
            break

    # Fallback: if filter becomes too strict, keep original top few rather than emptying evidence.
    if len(kept) >= 2:
        return kept
    return evidence_list[:keep_max]




