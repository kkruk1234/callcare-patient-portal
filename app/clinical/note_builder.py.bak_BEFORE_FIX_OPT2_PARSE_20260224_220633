    except Exception:
        return []

    items = None
    if isinstance(data, dict):
        for key in ("sources", "evidence", "items", "references"):
            v = data.get(key)
            if isinstance(v, list):
                items = v
                break
    elif isinstance(data, list):
        items = data

    if not items:
        return []

    out: List[EvidenceRef] = []
    for it in items:
        if isinstance(it, dict):
