# _PREGNANCY_GATE_V2
def _protocol_requires_pregnancy_status(pathway_id: str) -> bool:
    \"\"\"True if meds protocol YAML includes requires_pregnancy_status: true\"\"\"
    try:
        import os
        try:
            import yaml  # type: ignore
        except Exception:
            yaml = None
        if yaml is None:
            return False
        proto_path = os.path.join("data", "protocols", "meds", f"{pathway_id}.yaml")
        if not os.path.exists(proto_path):
            return False
        data = yaml.safe_load(Path(proto_path).read_text(encoding="utf-8")) or {}
        if not isinstance(data, dict):
            return False
        v = data.get("requires_pregnancy_status", False)
        if isinstance(v, bool):
            return v
        return str(v).strip().lower() in ("1", "true", "yes", "y", "on")
    except Exception:
        return False


def _pregnancy_already_captured(state) -> bool:
    try:
        sx = getattr(state, "symptoms", None) or {}
        if not isinstance(sx, dict):
            sx = {}
        for v in (
            getattr(state, "pregnancy_possible", None),
            sx.get("pregnancy_possible", None),
            (sx.get("_answers", {}) or {}).get("pregnancy_possible", None) if isinstance(sx.get("_answers", {}), dict) else None,
        ):
            if v is not None and str(v).strip() != "":
                return True
        return False
    except Exception:
        return False


def _append_pregnancy_question_if_needed(questions: list, pathway_id: str, state) -> list:
    \"\"\"Append pregnancy question to pathway questions if protocol requires it and not already captured.\"\"\"
    try:
        if not _protocol_requires_pregnancy_status(pathway_id):
            return questions
        if _pregnancy_already_captured(state):
            return questions

        # Avoid duplicates
        for q in questions:
            if isinstance(q, dict) and (q.get("id") == "pregnancy_possible" or q.get("store_as") == "pregnancy_possible"):
                return questions

        questions.append({
            "id": "pregnancy_possible",
            "prompt": "Is there any chance you could be pregnant? You can answer yes, no, unknown, or not applicable.",
            "store_as": "pregnancy_possible",
            "type": "text"
        })
        return questions
    except Exception:
        return questions


# _PREGNANCY_GATE_V1
def _protocol_requires_pregnancy_status(pathway_id: str) -> bool:
    """
    True if meds protocol YAML includes:
      requires_pregnancy_status: true
    """
    try:
        import os
        try:
            import yaml  # type: ignore
        except Exception:
            yaml = None

        if yaml is None:
            return False

        proto_path = os.path.join("data", "protocols", "meds", f"{pathway_id}.yaml")
        if not os.path.exists(proto_path):
            return False

        data = yaml.safe_load(Path(proto_path).read_text(encoding="utf-8")) or {}
        if not isinstance(data, dict):
            return False

        v = data.get("requires_pregnancy_status", False)
        if isinstance(v, bool):
            return v
        s = str(v).strip().lower()
        return s in ("1", "true", "yes", "y", "on")
    except Exception:
        return False


def _should_ask_pregnancy_for_pathway(pathway_id: str, state) -> bool:
    """
    Ask pregnancy if:
      - meds protocol requires it
      - pregnancy not already captured
      - sex_at_birth is unknown OR female
    """
    try:
        sx = getattr(state, "symptoms", None) or {}
        if not isinstance(sx, dict):
            sx = {}

        # Already captured anywhere? then don't ask again
        preg = getattr(state, "pregnancy_possible", None)
        if preg is None or str(preg).strip() == "":
            preg = sx.get("pregnancy_possible", None)
        if preg is None or str(preg).strip() == "":
            ans = sx.get("_answers", {}) or {}
            if isinstance(ans, dict):
                preg = ans.get("pregnancy_possible", None)
        if preg is not None and str(preg).strip() != "":
            return False

        sex = sx.get("sex_at_birth", None) or getattr(state, "sex_at_birth", None)
        sex_s = ("" if sex is None else str(sex)).strip().lower()
        sex_unknown = (sex_s == "" or sex_s in ("unknown", "unsure", "not sure", "?"))
        sex_female = sex_s in ("female", "f", "woman", "girl")

        if not (sex_unknown or sex_female):
            # If explicitly male, do not ask
            return False

        return _protocol_requires_pregnancy_status(pathway_id)
    except Exception:
        return False


def _inject_pregnancy_question_if_needed(questions: list, pathway_id: str, state) -> list:
    """
    Returns questions (possibly appended with pregnancy question).
    """
    try:
        if not _should_ask_pregnancy_for_pathway(pathway_id, state):
            return questions

        # Don't duplicate if already present
        for q in questions:
            if isinstance(q, dict) and (q.get("id") == "pregnancy_possible" or q.get("store_as") == "pregnancy_possible"):
                return questions

        questions.append({
            "id": "pregnancy_possible",
            "prompt": "Is there any chance you could be pregnant? You can answer yes, no, unknown, or not applicable.",
            "store_as": "pregnancy_possible",
            "type": "text"
        })
        return questions
    except Exception:
        return questions

def _norm(s: str) -> str:
    return (s or "").strip().lower()


def _yesno(s: str) -> Optional[bool]:
    s = _norm(s)
    if s in ["y", "yes", "yeah", "yep", "sure", "ok", "okay"]:
        return True
    if s in ["n", "no", "nope"]:
        return False
    return None


def _parse_age_years(text: str) -> Optional[float]:
    """
    Accepts:
      - "37"
      - "1.5"
      - "18 months" (converted)
      - "6 weeks" (converted)
      - "2 years"
    """
    t = _norm(text)
    if not t:
        return None

    # months / weeks handling
    m = re.search(r"(\d+(\.\d+)?)\s*(month|months|mo)\b", t)
    if m:
        return float(m.group(1)) / 12.0

    w = re.search(r"(\d+(\.\d+)?)\s*(week|weeks|wk|wks)\b", t)
    if w:
        return float(w.group(1)) / 52.0

    y = re.search(r"(\d+(\.\d+)?)\s*(year|years|yr|yrs)\b", t)
    if y:
        return float(y.group(1))

    # bare number
    m2 = re.search(r"(\d+(\.\d+)?)", t)
    if m2:
        return float(m2.group(1))

    return None


def _age_band(age_years: Optional[float]) -> str:
    if age_years is None:
        return "unknown"
    if age_years < 3:
        return "0-2"
    if age_years < 13:
        return "3-12"
    if age_years < 18:
        return "13-17"
    if age_years < 65:
        return "18-64"
    return "65+"


def _parse_weight(text: str) -> Tuple[Optional[float], Optional[str]]:
    """
    Returns (weight_kg, raw_unit)
    Accepts:
      - "28 pounds", "28 lbs"
      - "12.5 kg", "12 kilograms"
      - "28" (unknown unit -> None)
    """
    t = _norm(text)
    if not t:
        return None, None

    mkg = re.search(r"(\d+(\.\d+)?)\s*(kg|kilogram|kilograms)\b", t)
    if mkg:
        return float(mkg.group(1)), "kg"

    mlb = re.search(r"(\d+(\.\d+)?)\s*(lb|lbs|pound|pounds)\b", t)
    if mlb:
        lbs = float(mlb.group(1))
        return lbs * 0.45359237, "lb"

    return None, None


def _load_questions_for(pathway_id: str, state=None) -> List[dict]:
    """
    Minimal YAML-ish parser for our simple pathway YAML shape.
    Reads:
      - questions:
        - id:
          prompt:
          store_as:
          type:
    """
    fp = PATHWAYS_DIR / f"{pathway_id}.yaml"
    if not fp.exists():
        return []

    txt = fp.read_text(encoding="utf-8", errors="ignore").splitlines()

    questions: List[dict] = []
    in_questions = False
    current: Optional[dict] = None

    for line in txt:
        if line.strip().startswith("questions:"):
            in_questions = True
            continue
        if not in_questions:
            continue

        if line.strip().startswith("- id:"):
            if current:
                questions.append(current)
            current = {"id": line.split(":", 1)[1].strip(), "prompt": "", "store_as": "", "type": "text"}
            continue

        if current is None:
            continue

        s = line.strip()
        if s.startswith("prompt:"):
            val = s.split(":", 1)[1].strip().strip('"').strip("'")
            current["prompt"] = val
        elif s.startswith("store_as:"):
            current["store_as"] = s.split(":", 1)[1].strip()
        elif s.startswith("type:"):
            current["type"] = s.split(":", 1)[1].strip()

    if current:
        questions.append(current)

    return questions


