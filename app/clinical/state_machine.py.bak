from __future__ import annotations

import json
from pathlib import Path
from typing import Any, Dict, Optional, Tuple

from app.core.models import CallState, RedFlag

PATHWAYS_DIR = Path("app/clinical/pathways")
PACKS_DIR = Path("data/sources/pathways")  # manifests live here, but packs are built elsewhere
QUESTION_PACKS_DIR = Path("data/index/question_packs")  # created by build_question_packs


def _norm(s: str) -> str:
    return (s or "").strip().lower()


def _yesno(s: str) -> Optional[bool]:
    s = _norm(s)
    if s in ["y", "yes", "yeah", "yep", "sure", "ok", "okay"]:
        return True
    if s in ["n", "no", "nope"]:
        return False
    return None


def _load_pathways() -> Dict[str, dict]:
    out: Dict[str, dict] = {}
    if PATHWAYS_DIR.exists():
        for fp in PATHWAYS_DIR.glob("*.yaml"):
            # naive YAML reader: we only need a few fields; treat as key:value with indentation
            # To avoid adding PyYAML dependency, we use a tiny fallback loader for our simple format.
            txt = fp.read_text(encoding="utf-8", errors="ignore")
            out[fp.stem] = {"_raw": txt}
    return out


def _extract_keywords(yaml_text: str) -> Tuple[str, list]:
    """
    Extract pathway id and keywords from our simple YAML shape.
    We rely on the structure you created (match:any_keywords).
    """
    pid = ""
    keywords = []
    for line in yaml_text.splitlines():
        line_stripped = line.strip()
        if line_stripped.startswith("id:"):
            pid = line_stripped.split(":", 1)[1].strip()
        if "any_keywords:" in line_stripped:
            # subsequent line(s) contain the list; simplest: parse the bracket list if present
            # example: any_keywords: ["a","b"]
            if "[" in line_stripped and "]" in line_stripped:
                inside = line_stripped.split("[", 1)[1].rsplit("]", 1)[0]
                parts = [p.strip().strip('"').strip("'") for p in inside.split(",") if p.strip()]
                keywords.extend(parts)
    return pid, [k.lower() for k in keywords if k]


def _pick_pathway(chief: str) -> Dict[str, Any]:
    """
    Deterministic routing first, then fallback keyword scoring.
    This prevents obvious misroutes (e.g., dysuria -> cough_uri).
    """
    chief_l = _norm(chief)

    # 1) High-confidence direct mapping
    direct = [
        (["dysuria", "uti", "burning urination", "burning when i pee", "painful urination", "urinary"], "dysuria_uti"),
        (["vomit", "vomiting", "nausea", "throwing up", "emesis"], "nausea_vomiting"),
        (["diarrhea", "loose stool", "watery stool", "gastroenteritis"], "diarrhea"),
        (["ear pain", "earache", "otitis", "swimmer's ear"], "ear_pain"),
        (["pink eye", "conjunctivitis", "red eye", "eye discharge"], "red_eye"),
        (["back pain", "low back", "sciatica", "lumbar"], "low_back_pain"),
        (["sore throat", "throat pain", "strep"], "sore_throat"),
        (["cough", "runny nose", "congestion", "cold", "uri"], "cough_uri"),
        (["rash", "skin infection", "cellulitis", "impetigo"], "rash_skin_infection"),
        (["abdominal pain", "belly pain", "stomach pain"], "abdominal_pain"),
        (["headache", "migraine", "worst headache", "thunderclap"], "headache"),
        (["med refill", "refill", "renew medication", "prescription renewal"], "med_refill"),
    ]

    for keys, pid in direct:
        if any(k in chief_l for k in keys):
            return {"id": pid, "score": 999}

    # 2) Fallback: keyword scoring from YAML
    best = ("cough_uri", 0)
    for _, meta in _load_pathways().items():
        raw = meta.get("_raw", "")
        pid, kws = _extract_keywords(raw)
        if not pid:
            continue
        score = sum(1 for k in kws if k and k in chief_l)
        if score > best[1]:
            best = (pid, score)

    return {"id": best[0], "score": best[1]}
    for _, meta in _load_pathways().items():
        raw = meta.get("_raw", "")
        pid, kws = _extract_keywords(raw)
        if not pid:
            continue
        score = sum(1 for k in kws if k and k in chief_l)
        if score > best[1]:
            best = (pid, score)

    return {"id": best[0], "score": best[1]}


def _load_questions_for(pathway_id: str) -> list:
    """
    Load questions from the YAML itself in a minimal way (prompt + id + store_as + type).
    This avoids relying on packs if packs dir path differs.
    """
    fp = PATHWAYS_DIR / f"{pathway_id}.yaml"
    if not fp.exists():
        return []

    txt = fp.read_text(encoding="utf-8", errors="ignore").splitlines()

    questions = []
    in_questions = False
    current = None

    for line in txt:
        if line.strip().startswith("questions:"):
            in_questions = True
            continue
        if not in_questions:
            continue

        if line.strip().startswith("- id:"):
            # start new question
            if current:
                questions.append(current)
            current = {"id": line.split(":", 1)[1].strip(), "prompt": "", "store_as": "", "type": "text"}
            continue

        if current is None:
            continue

        s = line.strip()
        if s.startswith("prompt:"):
            # prompt may be quoted; remove surrounding quotes if present
            val = s.split(":", 1)[1].strip()
            val = val.strip('"').strip("'")
            current["prompt"] = val
        elif s.startswith("store_as:"):
            current["store_as"] = s.split(":", 1)[1].strip()
        elif s.startswith("type:"):
            current["type"] = s.split(":", 1)[1].strip()

    if current:
        questions.append(current)

    return questions


def next_prompt(state: CallState) -> str:
    # Ensure containers exist
    state.symptoms.setdefault("_answers", {})
    state.symptoms.setdefault("_pathway", {})

    # If we are reprompting a yes/no question, do that first
    if state.stage == "PATHWAY_Q" and state.symptoms.get("_reprompt"):
        return state.symptoms["_reprompt"]

    if state.stage == "CONSENT":
        return (
            "I'm an automated medical assistant. "
            "If this is an emergency, hang up and call 911. "
            "Do you consent to continue? (yes/no)"
        )

    if state.stage == "CHIEF":
        return "What's your main concern?"

    if state.stage == "AGE_BAND":
        return "How old are you? (0-2, 3-12, 13-17, 18-64, 65+)"

    if state.stage == "PATHWAY_Q":
        pathway_id = state.symptoms.get("_pathway", {}).get("id") or "cough_uri"
        questions = _load_questions_for(pathway_id)
        idx = int(state.symptoms.get("_q_idx", 0))

        if idx >= len(questions):
            state.stage = "DECIDE"
            return ""

        q = questions[idx]
        return q.get("prompt") or "Please tell me more."

    if state.stage == "DECIDE":
        return ""

    # Fallback safety
    return "I'm sorry — I got lost. Let's start over. What's your main concern?"


def process_answer(state: CallState, text: str) -> None:
    state.symptoms.setdefault("_answers", {})
    state.symptoms.setdefault("_pathway", {})

    t = _norm(text)

    if state.stage == "CONSENT":
        yn = _yesno(t)
        if yn is True:
            state.stage = "CHIEF"
        else:
            # No consent -> end quickly
            state.stage = "DECIDE"
        return

    if state.stage == "CHIEF":
        state.chief_complaint = text.strip()
        state.symptoms["_pathway"] = _pick_pathway(state.chief_complaint)
        state.symptoms["_q_idx"] = 0
        state.stage = "AGE_BAND"
        return

    if state.stage == "AGE_BAND":
        state.age_band = text.strip()
        state.stage = "PATHWAY_Q"
        return

    if state.stage == "PATHWAY_Q":
        pathway_id = state.symptoms.get("_pathway", {}).get("id") or "cough_uri"
        questions = _load_questions_for(pathway_id)
        idx = int(state.symptoms.get("_q_idx", 0))

        if idx >= len(questions):
            state.stage = "DECIDE"
            return

        q = questions[idx]
        qid = q.get("id") or f"q{idx}"
        store_as = q.get("store_as") or qid
        qtype = q.get("type") or "text"

        if qtype == "yesno":
            yn = _yesno(t)
            if yn is None:
                # do NOT advance; ask again
                state.symptoms["_reprompt"] = f"Please answer yes or no. {q.get('prompt','')}"
                return
            state.symptoms["_answers"][qid] = "yes" if yn else "no"
            state.symptoms[store_as] = yn
        else:
            state.symptoms["_answers"][qid] = text.strip()
            state.symptoms[store_as] = text.strip()

        state.symptoms["_q_idx"] = idx + 1
        state.symptoms.pop("_reprompt", None)
        return

    # fallback reset
    state.stage = "CONSENT"
