from __future__ import annotations\n\nimport os\n\nfrom dataclasses import dataclass\nfrom typing import Any, Dict, List, Optional, Tuple\n\n\n# ----------------------------\n# Time helpers (used by finalize.py)\n# ----------------------------\ndef now_iso() -> str:\n    """UTC timestamp in ISO-8601 format (seconds)."""\n    import datetime as _dt\n    return _dt.datetime.now(_dt.timezone.utc).replace(microsecond=0).isoformat()\n\nfrom app.core.models import CallState, EvidenceRef, NoteDraft\n\n# Existing note writer (LLM)\nimport importlib\n\n# RAG retrieval\nfrom app.rag.retrieve import retrieve as rag_retrieve\n\n# Adapter: dict chunks -> EvidenceRef\nfrom app.clinical.evidence_adapter import as_evidence_refs\n\n\n# ----------------------------\n# Evidence selection\n# ----------------------------\n\ndef _is_rag_active(state: CallState) -> bool:\n    """\n    Treat RAG as active if:\n      - state.symptoms['_rag'] exists (orchestrator artifacts), OR\n      - pathway_id is 'rag_intake', OR\n      - CALLCARE_RAG_INTAKE_DEFAULT=1 and not CALLCARE_RAG_DISABLED=1\n    """\n    if os.getenv("CALLCARE_RAG_DISABLED", "0") == "1":\n        return False\n\n    sx = getattr(state, "symptoms", None) or {}\n    if isinstance(sx, dict):\n        rag = sx.get("_rag") or {}\n        if isinstance(rag, dict) and (rag.get("plan") or rag.get("evidence") or rag.get("mode") == "rag"):\n            return True\n        pid = (sx.get("_pathway") or {}).get("id") if isinstance(sx.get("_pathway"), dict) else ""\n        if str(pid or "") == "rag_intake":\n            return True\n\n    # Env default-on\n    return os.getenv("CALLCARE_RAG_INTAKE_DEFAULT", "0") == "1"\ndef _get_chief(state: CallState) -> str:\n    return (getattr(state, "chief_complaint", "") or "").strip()\n\ndef _get_demographics_text(state: CallState) -> str:\n    sx = getattr(state, "symptoms", None) or {}\n    if not isinstance(sx, dict):\n        sx = {}\n    age = sx.get("age_years") or getattr(state, "age_years", None)\n    preg = sx.get("pregnancy_possible") or getattr(state, "pregnancy_possible", None)\n    sex = sx.get("sex_at_birth") or sx.get("sex") or getattr(state, "sex_at_birth", None)\n    parts = []\n    if age is not None:\n        parts.append(f"age_years={age}")\n    if sex:\n        parts.append(f"sex_at_birth={sex}")\n    if preg:\n        parts.append(f"pregnancy_possible={preg}")\n    return " ".join(parts).strip()\n\ndef _retrieve_evidence_for_state(state: CallState, top_n: int = 8) -> List[Dict[str, Any]]:\n    """\n    Retrieve evidence chunks (dicts) from the global index.\n    retrieve() currently returns dicts with: score, source, title, url, text.\n    """\n    q = _get_chief(state)\n    demo = _get_demographics_text(state)\n    query = q if not demo else f"{q}\n\n{demo}"\n    chunks = rag_retrieve(query) or []\n    # Ensure list[dict]\n    out: List[Dict[str, Any]] = []\n    for c in chunks:\n        if isinstance(c, dict):\n            out.append(c)\n    return out[: max(1, int(top_n))]\n\ndef _evidence_from_state_rag_cache(state: CallState) -> List[Dict[str, Any]]:\n    """\n    If state.symptoms['_rag']['evidence'] exists (your orchestrator stores it),\n    use it preferentially.\n    """\n    sx = getattr(state, "symptoms", None) or {}\n    if not isinstance(sx, dict):\n        return []\n    rag = sx.get("_rag") or {}\n    if not isinstance(rag, dict):\n        return []\n    ev = rag.get("evidence") or []\n    if not isinstance(ev, list):\n        return []\n    out: List[Dict[str, Any]] = []\n    for e in ev:\n        if isinstance(e, dict):\n            out.append(e)\n    return out\n\ndef _best_snippets(state: CallState, max_snips: int = 6) -> List[EvidenceRef]:\n    """\n    Unified evidence selection:\n    - If RAG intake is active and cached evidence exists, use it.\n    - Else retrieve from global index using chief + demographics.\n    - Convert to EvidenceRef using adapter.\n    """\n    # 1) Use cached orchestrator evidence if present\n    cached = _evidence_from_state_rag_cache(state)\n    if cached:\n        # Add deterministic EVID keys\n        for i, d in enumerate(cached, start=1):\n            d.setdefault("key", f"EVID_{i}")\n        return [e for e in as_evidence_refs(cached) if e]\n\n    # 2) Otherwise, retrieve fresh from index if RAG is active\n    if _is_rag_active(state):\n        chunks = _retrieve_evidence_for_state(state, top_n=max_snips)\n        for i, d in enumerate(chunks, start=1):\n            d.setdefault("key", f"EVID_{i}")\n        return [e for e in as_evidence_refs(chunks) if e]\n\n    # 3) Fallback: no RAG evidence (keep empty)\n    return []\n\n\n# ----------------------------\n# Prompt builder\n# ----------------------------\n\ndef _build_prompt(state: CallState, evidence: List[EvidenceRef]) -> str:\n    """\n    If your llm_note_writer has build_prompt(state,evidence), use it.\n    Otherwise, build a basic prompt here.\n    """\n    try:\n        llm = importlib.import_module("app.clinical.llm_note_writer")\n        build_prompt = getattr(llm, "build_prompt", None)\n        if callable(build_prompt):\n            return build_prompt(state=state, evidence=evidence)\n    except Exception:\n        pass\n\n    # Minimal fallback prompt if build_prompt missing\n    chief = _get_chief(state)\n    sx = getattr(state, "symptoms", None) or {}\n    ans = (sx.get("_answers") if isinstance(sx, dict) else {}) or {}\n    if not isinstance(ans, dict):\n        ans = {}\n\n    lines = []\n    lines.append("You are writing a clinician-grade SOAP note for a phone-only encounter.")\n    lines.append("Use ONLY the structured answers provided. Do NOT invent symptoms or negatives.")\n    lines.append("")\n    lines.append(f"CHIEF_COMPLAINT: {chief}")\n    lines.append("")\n    lines.append("STRUCTURED_ANSWERS:")\n    for k in sorted(ans.keys()):\n        lines.append(f"- {k}: {ans.get(k)}")\n\n    lines.append("")\n    lines.append("CONSISTENCY_FACTS (derived only from structured answers):")\n    pain_raw = str(ans.get("morph_pain_itch") or "").strip().lower()\n    pain_fact = ""\n    if pain_raw:\n        if pain_raw.startswith("y"):\n            pain_fact = "yes"\n        elif pain_raw.startswith("n"):\n            pain_fact = "no"\n        elif pain_raw in ("unknown", "not sure", "unsure", "?"):\n            pain_fact = "unknown"\n    if pain_fact:\n        lines.append(f"- PAIN_OR_ITCH_PRESENT: {pain_fact}")\n    lines.append("")\n    lines.append("CRITICAL CONSISTENCY RULES:")\n    lines.append("- You MUST NOT contradict any structured answer.")\n    lines.append("- If PAIN_OR_ITCH_PRESENT is 'yes', you MUST NOT state or imply 'no pain' anywhere.")\n    lines.append("- If PAIN_OR_ITCH_PRESENT is 'no', you MUST NOT state or imply pain/itch is present.")\n    lines.append("- If unknown/absent, say 'not assessed' or omit.")\n\n    # Pregnancy status sentence (use patient's answer only; no inference)\n    preg_raw = str(ans.get("pregnancy") or "").strip().lower()\n    preg_sentence = ""\n    if preg_raw:\n        if preg_raw.startswith("n"):\n            preg_sentence = "Patient is not pregnant."\n        elif preg_raw.startswith("y"):\n            preg_sentence = "Patient is pregnant."\n        elif preg_raw in ("unknown", "not sure", "unsure", "?"):\n            preg_sentence = "Patient is unsure of pregnancy status."\n    if preg_sentence:\n        lines.append("")\n        lines.append("PREGNANCY_STATUS_SENTENCE:")\n        lines.append(preg_sentence)\n        lines.append("")\n        lines.append("In the SOAP note Subjective, include the pregnancy status sentence verbatim if present.")\n    lines.append("")\n    lines.append("EVIDENCE:")\n    if evidence:\n        for i, e in enumerate(evidence, 1):\n            key = getattr(e, "key", f"EVID_{i}")\n            title = getattr(e, "title", "")\n            url = getattr(e, "url", "")\n            txt = getattr(e, "text", "")\n            lines.append(f"{key}: {title}")\n            if url:\n                lines.append(url)\n            if txt:\n                t = (txt or "").strip().replace("\r", " ")\n                if len(t) > 1200:\n                    t = t[:1200] + "…"\n                lines.append(t)\n            lines.append("---")\n    else:\n        lines.append("(No evidence snippets retrieved.)")\n\n    lines.append("")\n    # --- NO_INVENTED_NEGATIVES_RULE_V1 ---\n    lines.append('')\n    lines.append('STRICT RULES:')\n    lines.append('- You MUST NOT invent negatives (e.g., \'no pain\', \'no bleeding\') unless the patient explicitly answered that specific symptom as \'no\'.')\n    lines.append('- If a symptom question was combined (e.g., pain/burning/itch), a \'yes\' means at least one is present; you MUST NOT claim the others are absent.')\n    lines.append('- If something was not asked, write \'not assessed\' or omit.')\n    # --- END NO_INVENTED_NEGATIVES_RULE_V1 ---\n    lines.append("Output format: S:, O:, A:, P: with a numbered differential in A when appropriate.")\n    return "\n".join(lines).strip() + "\n"\n\n\n# ----------------------------\n\n# ----------------------------\n# Note generation entrypoint\n# ----------------------------\n\ndef build_note_with_reason(state: CallState) -> Tuple[Optional[NoteDraft], str]:\n    """\n    Internal helper returning (NoteDraft|None, error_reason).\n    """\n    evidence = _best_snippets(state, max_snips=8)\n    # --- MIN_EVID_HOST_DIVERSITY_V1 ---\n    # Ensure >=3 evidence items from >=3 unique hostnames when possible (best effort).\n    # Deterministic: expands retrieval pool and selects diverse sources; does not invent evidence.\n    if _is_rag_active(state):\n        try:\n            from urllib.parse import urlparse\n        except Exception:\n            urlparse = None\n\n        def _host(ev) -> str:\n            u = (getattr(ev, 'url', '') or '').strip()\n            if u and urlparse:\n                try:\n                    return (urlparse(u).netloc or '').lower()\n                except Exception:\n                    return ''\n            return ''\n\n        # If EvidenceRef lacks url fields in this repo, host diversity may be limited; we still top up by count.\n        hosts = set([h for h in (_host(e) for e in (evidence or [])) if h])\n\n        if len(evidence or []) < 3 or len(hosts) < 3:\n            # Pull a larger pool and rebuild evidence list, preferring host diversity\n            more_chunks = _retrieve_evidence_for_state(state, top_n=40)\n            for j, d in enumerate(more_chunks, start=1):\n                if isinstance(d, dict):\n                    d.setdefault('key', f'EVID_{j}')\n            more_refs = [e for e in as_evidence_refs(more_chunks) if e]\n\n            chosen = []\n            seen_hosts = set()\n            # 1) Prefer one per host\n            for e in more_refs:\n                h = _host(e)\n                if h and h in seen_hosts:\n                    continue\n                chosen.append(e)\n                if h:\n                    seen_hosts.add(h)\n                if len(chosen) >= 8:  # keep bounded\n                    break\n\n            # 2) If still <3, fill regardless of host\n            if len(chosen) < 3:\n                for e in more_refs:\n                    if e in chosen:\n                        continue\n                    chosen.append(e)\n                    if len(chosen) >= 8:\n                        break\n\n            evidence = chosen if chosen else evidence\n    # --- END MIN_EVID_HOST_DIVERSITY_V1 ---\n    # --- MIN_EVIDENCE_ENFORCE_V1 ---\n    # Ensure Evidence Used has >=3 unique items when RAG is active (best effort).\n    # This is deterministic and does not invent evidence; it only expands retrieval pool and dedupes.\n    if _is_rag_active(state):\n        def _ev_key(e):\n            src_id = (getattr(e, 'source', '') or '').strip()\n            title = (getattr(e, 'title', '') or '').strip()\n            snip = (getattr(e, 'snippet', '') or '')[:80].strip()\n            return (src_id, title, snip)\n        # Deduplicate current list\n        seen = set()\n        dedup = []\n        for e in (evidence or []):\n            k = _ev_key(e)\n            if k in seen:\n                continue\n            seen.add(k)\n            dedup.append(e)\n        evidence = dedup\n\n        if len(evidence) < 3:\n            # Expand retrieval pool and merge/dedupe\n            try:\n                more_chunks = _retrieve_evidence_for_state(state, top_n=24)\n                for j, d in enumerate(more_chunks, start=1):\n                    if isinstance(d, dict):\n                        d.setdefault('key', f'EVID_{j}')\n                more_refs = [e for e in as_evidence_refs(more_chunks) if e]\n            except Exception:\n                more_refs = []\n            for e in more_refs:\n                k = _ev_key(e)\n                if k in seen:\n                    continue\n                seen.add(k)\n                evidence.append(e)\n            # Keep evidence list bounded for prompt size\n            evidence = evidence[:8]\n    # --- END MIN_EVIDENCE_ENFORCE_V1 ---\n    prompt = _build_prompt(state, evidence)\n\n    try:\n        llm = importlib.import_module("app.clinical.llm_note_writer")\n        generate_note_text = getattr(llm, "generate_note_text", None)\n        if not callable(generate_note_text):\n            return None, "llm_note_writer.generate_note_text not callable"\n\n        txt = generate_note_text(prompt) or ""\n        txt = str(txt)\n\n        # NoteDraft schema in your repo expects list[str] for patient_instructions\n        patient_instructions: List[str] = []\n        clinician_questions: List[str] = []\n        risk_flags: List[str] = []\n\n        draft = NoteDraft(\n            soap=txt.strip() + ("\n" if txt and not txt.endswith("\n") else ""),\n            patient_instructions=patient_instructions,\n            clinician_questions=clinician_questions,\n            risk_flags=risk_flags,\n            evidence=evidence,\n        )\n        return draft, ""\n    except Exception as e:\n        return None, str(e)\n\ndef build_note(state: CallState) -> Optional[NoteDraft]:\n    """\n    Public API used by finalize.py. MUST return NoteDraft (or None), not a tuple.\n    """\n    draft, _reason = build_note_with_reason(state)\n    return draft\n\n