from __future__ import annotations

from typing import Any, Dict, List

from app.core.models import EvidenceRef


def _clean_snippet(text: str, max_len: int = 360) -> str:
    t = (text or "").strip().replace("\r", " ").replace("\n", " ")
    while "  " in t:
        t = t.replace("  ", " ")
    if len(t) > max_len:
        t = t[:max_len].rstrip() + "…"
    return t


def as_evidence_refs(chunks: List[Dict[str, Any]]) -> List[EvidenceRef]:
    """
    Convert retrieve() dict chunks into EvidenceRef.

    Your EvidenceRef schema requires:
      - source (string)  -> we prefer URL if present so citations are actionable
      - snippet (string) -> derived from chunk['text'] (or title as last resort)

    We do NOT drop items unless we truly cannot form a non-empty snippet and source.
    """
    out: List[EvidenceRef] = []
    seen = set()

    for c in (chunks or []):
        if not isinstance(c, dict):
            continue

        title = str(c.get("title") or "").strip()
        url = str(c.get("url") or "").strip()
        source_path = str(c.get("source") or "").strip()

        # "source" field in EvidenceRef should be something the reviewer can use.
        # Prefer URL; fall back to source path if URL missing.
        source = url or source_path or title

        text = str(c.get("text") or "").strip()
        snippet = _clean_snippet(text) if text else _clean_snippet(title)

        # As last resort, if snippet still empty, skip.
        if not source or not snippet:
            continue

        # Deduplicate: by source + snippet head + title
        key = (source, snippet[:80], title)
        if key in seen:
            continue
        seen.add(key)

        try:
            out.append(EvidenceRef(title=title, source=source, snippet=snippet))
        except Exception:
            # If something unexpected happens, skip this item rather than crashing note generation.
            continue

    return out
