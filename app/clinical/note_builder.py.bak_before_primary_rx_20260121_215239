def _build_query(state: CallState) -> str:
    parts: List[str] = []
    cc = (getattr(state, "chief_complaint", None) or "").strip()
    if cc:
        parts.append(cc)

    pid = _pathway_id(state)
    if pid:
        parts.append(pid)

    sx = _symptoms(state)
    for k, v in sx.items():
        if str(k).startswith("_"):
            continue
        if v is None or v == "":
            continue
        parts.append(f"{k}:{v}")

    age_years = getattr(state, "age_years", None)
    if age_years is not None and str(age_years).strip() != "":
        parts.append(f"age:{age_years}")

    return " ".join(parts).strip() or "general safety guidance"


def _try_rag_search(query: str, k: int = 5):
    candidates = [
        ("app.rag.retriever", "search"),
        ("app.rag.retriever", "retrieve"),
        ("app.rag.search", "search"),
        ("app.rag.search", "search_snippets"),
        ("app.rag.index", "search"),
        ("app.rag.query", "query"),
        ("app.rag.rag", "query"),
    ]
    for mod_name, fn_name in candidates:
        try:
            mod = importlib.import_module(mod_name)
            fn = getattr(mod, fn_name, None)
            if not callable(fn):
                continue
            try:
                res = fn(query, k=k)
            except TypeError:
                try:
                    res = fn(query, top_k=k)
                except TypeError:
                    res = fn(query)

            if res is None:
                return []
            if isinstance(res, dict) and "results" in res:
                res = res["results"]
            if isinstance(res, list):
                out = []
                for item in res:
                    if isinstance(item, dict):
                        out.append(item)
                    else:
                        out.append({
                            "title": getattr(item, "title", "") or "",
                            "source": getattr(item, "source", "") or "",
                            "url": getattr(item, "url", "") or "",
                            "snippet": getattr(item, "snippet", "") or getattr(item, "text", "") or "",
                        })
                return out
        except Exception:
            continue
    return []


def _evidence_from_decision(state: CallState) -> List[EvidenceRef]:
    decision = getattr(state, "decision", None)
    if not decision:
        return []
    dev = getattr(decision, "evidence", None)
    if not dev:
        return []

    out: List[EvidenceRef] = []
    for e in list(dev):
        if isinstance(e, EvidenceRef):
            out.append(e)
            continue

        if isinstance(e, dict):
            title = (e.get("title") or "").strip()
            source = (e.get("source") or "").strip()
            url = (e.get("url") or "").strip()
            snippet = (e.get("snippet") or e.get("text") or "").strip()
        else:
            title = (getattr(e, "title", "") or "").strip()
            source = (getattr(e, "source", "") or "").strip()
            url = (getattr(e, "url", "") or "").strip()
            snippet = (getattr(e, "snippet", "") or getattr(e, "text", "") or "").strip()

        if not (title or source or snippet):
            continue

        out.append(_mk_evidence_ref({
            "title": title or source or "Evidence",
            "source": source or title or "Source",
            "url": url,
            "snippet": snippet[:1200],
        }))
    return out


def _evidence_from_rag(state: CallState, max_snips: int = 6) -> List[EvidenceRef]:
    hits = _try_rag_search(_build_query(state), k=max_snips)
    out: List[EvidenceRef] = []
    for h in hits:
        title = (h.get("title") or "").strip()
        source = (h.get("source") or "").strip()
        url = (h.get("url") or "").strip()
        snippet = (h.get("snippet") or h.get("text") or "").strip()
        if not (title or source or snippet):
            continue
        out.append(_mk_evidence_ref({
            "title": title or source or "Evidence",
            "source": source or title or "Source",
            "url": url,
            "snippet": snippet[:1200],
        }))
    return out


def _merge_evidence(primary: List[EvidenceRef], secondary: List[EvidenceRef], max_total: int = 5) -> List[EvidenceRef]:
    seen = set()
    merged: List[EvidenceRef] = []
    for ev in primary + secondary:
        key = (
            (getattr(ev, "title", "") or ""),
            (getattr(ev, "source", "") or ""),
            (getattr(ev, "url", "") or ""),
            ((getattr(ev, "snippet", "") or "")[:120] if hasattr(ev, "snippet") else ""),
        )
        if key in seen:
            continue
        seen.add(key)
        merged.append(ev)
        if len(merged) >= max_total:
            break
    return merged


def _build_patient_instructions(disposition: str, safety_net: List[str], allow_otc: bool) -> List[str]:
    emergent = _is_emergent_disposition(disposition)
    out: List[str] = []

    if emergent:
        out.append("Based on this phone evaluation, seek emergency in-person evaluation now.")
        out.append("If you feel unsafe to travel, consider calling emergency services or having someone take you.")
    else:
        out.append("If you are not improving as expected, or if symptoms worsen, seek in-person medical care.")

    for s in safety_net[:10]:
        out.append(s)

    if allow_otc:
        out.append("Medication options you may consider if safe (no dosing by phone): acetaminophen (Tylenol) if you can take it safely; ibuprofen (Advil) if you can take it safely.")

    return out


def _generate_llm_soap_with_retry(state: CallState, evidence: List[EvidenceRef]) -> Tuple[str, str]:
    if os.environ.get("CALLCARE_NO_LLM", "").strip() in ("1", "true", "yes", "on"):
        return ("", "CALLCARE_NO_LLM enabled")

    try:
        llm = importlib.import_module("app.clinical.llm_note_writer")
        build_prompt = getattr(llm, "build_prompt", None)
        generate_note_text = getattr(llm, "generate_note_text", None)
        if not callable(build_prompt) or not callable(generate_note_text):
            return ("", "llm_note_writer missing required functions")

        prompt = build_prompt(state=state, evidence=evidence)

        for attempt in range(3):
            try:
                txt = generate_note_text(prompt) or ""
                if txt.strip():
                    return (txt, "")
                return ("", "empty LLM output")
            except Exception as e:
                msg = str(e)
                if ("RateLimitError" in type(e).__name__) or ("rate_limit" in msg.lower()) or ("429" in msg):
                    if attempt < 2:
                        time.sleep(2.5 * (attempt + 1))
                        continue
                    return ("", "rate limit (429)")
                return ("", f"{type(e).__name__}: {msg[:160]}")
        return ("", "rate limit (429)")
    except Exception as e:
        return ("", f"{type(e).__name__}: {str(e)[:160]}")


def build_note(state: CallState) -> NoteDraft:
    disposition, plan, safety = _decision_bits(state)

    ev_dec = _evidence_from_decision(state)
    ev_rag = _evidence_from_rag(state, max_snips=6) if len(ev_dec) < 3 else []
    evidence = _merge_evidence(ev_dec, ev_rag, max_total=5)

    preg_norm = _sync_pregnancy_from_answers(state)
    preg_sentence = _preg_sentence_from_norm(preg_norm)

    soap_text, err = _generate_llm_soap_with_retry(state, evidence)
    if not soap_text.strip():
        soap_text = f"(NOTE: LLM note generation unavailable: {err})\n"

    soap_text = _inject_preg_sentence_into_subjective(soap_text, preg_sentence)
    soap_text = _fix_tick_attachment_wording_in_subjective(soap_text)

    # Deterministic meds injection (and strip duplicate LLM dosing in Plan if present)
    soap_text = _inject_med_protocol_into_plan(soap_text, state)

    allow_otc = (not _is_emergent_disposition(disposition)) and (not _avoid_otc_from_text(plan, soap_text))
    patient_instructions = _build_patient_instructions(disposition, safety, allow_otc)

    clinician_questions: List[str] = []
    allergies = getattr(state, "allergies", None)
    if allergies:
        clinician_questions.append(f"Medication allergies: {allergies}")

    risk_flags: List[str] = []
    rf = getattr(state, "red_flags", None)
    if isinstance(rf, list):
        risk_flags = [str(x) for x in rf if str(x).strip()]

    return NoteDraft(
        soap=soap_text,
        patient_instructions=patient_instructions,
        clinician_questions=clinician_questions,
        risk_flags=risk_flags,
        evidence=evidence,
    )
