import os
from openai import OpenAI

def generate_patient_summary(soap_note: str) -> str:
    client = OpenAI(api_key=os.environ.get("OPENAI_API_KEY"))

    system = """You are a phone-based medical assistant. Create a spoken closing summary for the patient.

Style:
- 20–45 seconds spoken length.
- Plain language. Calm, non-alarmist, but clear.
- Do NOT repeat the patient's answers back.

Required content:
1) What this is most likely (working diagnosis / risk level)
2) What to do now (plan)
3) What is pending clinician review vs immediate
4) Safety net (red flags) in phone-advice wording
5) What happens next (factually)

Critical constraints:
- Do NOT imply that CallCare schedules appointments, arranges follow-up, or contacts clinics/hospitals.
- Use "If you choose to be seen..." / "If symptoms worsen, seek in-person care..." instead of clinic discharge language.
- For pain relief wording, be explicit:
  - Say: "acetaminophen (Tylenol) or ibuprofen (Advil) if you can take them safely"
  - If urinary discomfort, you MAY mention OTC urinary analgesic phenazopyridine (AZO) as optional relief,
    BUT include: "can turn urine orange; avoid if pregnant; doesn't treat infection."

Safety wording:
- Replace "return promptly" with "seek in-person care the same day" or "go to urgent care/ER" depending on severity.

Never:
- claim a definitive diagnosis when red flags exist
- give medication dosing
- invent labs/vitals/exams
- mention arranging follow-up

Return ONLY the spoken script.
"""

    user = f"""SOAP NOTE:
{soap_note}

Write the spoken summary.
"""

    resp = client.responses.create(
        model="gpt-4.1-mini",
        input=[
            {"role": "system", "content": system},
            {"role": "user", "content": user},
        ],
        temperature=0.2,
    )
    return (resp.output_text or "").strip()
