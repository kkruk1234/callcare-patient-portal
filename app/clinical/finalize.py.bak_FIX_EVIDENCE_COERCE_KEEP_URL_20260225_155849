def _cc_unique_urls(urls):
    out = []
    seen = set()
    for u in urls or []:
        u2 = _cc_safe_str(u)
        if not u2:
            continue
        if u2 in seen:
            continue
        seen.add(u2)
        out.append(u2)
    return out

def _cc_llm_pick_urls(dx, cc, preg, renal, liver, need_meds=True):
    """
    LLM proposes URLs from a small authoritative allowlist.
    This does NOT use FAISS. It returns a list of URL strings.
    """
    # Keep this allowlist short + high-signal; expand later.
    allow_domains = [
        "aafp.org",
        "nice.org.uk",
        "nhs.uk",
        "cdc.gov",
        "medlineplus.gov",
        "ncbi.nlm.nih.gov",
        "accessdata.fda.gov",
    ]
    constraints = (
        "Return ONLY URLs (one per line). No bullets, no commentary.\n"
        "Pick sources that directly match the diagnosis (not generic neighbors).\n"
        "Prefer condition guidelines/management pages. Avoid irrelevant drug monographs.\n"
        "If meds are needed, include at least one dosing-capable source (FDA label or MedlinePlus drug info) ONLY for drugs actually relevant.\n"
        f"Allowed domains: {', '.join(allow_domains)}.\n"
        "Max 6 URLs.\n"
    )
    context = f"DX: {dx}\nCC: {cc}\nPregnancy: {preg or 'unknown'}\nRenal: {renal or 'unknown'}\nLiver: {liver or 'unknown'}\n"
    meds_line = "We need outpatient medication options + dosing." if need_meds else "Focus on diagnosis + outpatient management (no drug dosing required)."
    prompt = constraints + "\n" + context + meds_line

    # Call your existing LLM client via llm_note_writer if present.
    # If not available, fall back to deterministic empty list (auto-acquire will still run via query string).
    try:
        import importlib
        lw = importlib.import_module("app.clinical.llm_note_writer")
        # Try common call names (best-effort)
        for fn_name in ("call_llm_text", "llm_text", "complete_text", "generate_text"):
            fn = getattr(lw, fn_name, None)
            if callable(fn):
                out = fn(prompt)
                break
        else:
            out = ""
    except Exception:
        out = ""

    urls = []
    for line in (out or "").splitlines():
        line = line.strip()
        if line.startswith("http://") or line.startswith("https://"):
            urls.append(line)
    return _cc_unique_urls(urls)[:6]

def _cc_auto_acquire(query, urls_hint=None, max_urls_allowed=3):
    """
    Uses app/rag/auto_acquire_fast.py to fetch/ingest.
    Returns list of URLs that were allowed/ingested (best effort).
    """
    urls_hint = _cc_unique_urls(urls_hint or [])
    try:
        from app.rag.auto_acquire_fast import acquire_ingest_attach
    except Exception:
        return []

    # Pass only kwargs that the function accepts (signature-safe)
    import inspect
    kw = {}
    try:
        sig = inspect.signature(acquire_ingest_attach)
        params = set(sig.parameters.keys())
        if "query" in params:
            kw["query"] = query
        else:
            # some versions take positional query
            pass
        if "urls" in params:
            kw["urls"] = urls_hint
        if "urls_hint" in params:
            kw["urls_hint"] = urls_hint
        if "max_urls_allowed" in params:
            kw["max_urls_allowed"] = max_urls_allowed
        if "urls_allowed" in params:
            kw["urls_allowed"] = max_urls_allowed
        if "max_urls" in params:
            kw["max_urls"] = max_urls_allowed
    except Exception:
        kw = {}

    try:
        if kw.get("query") is not None:
            res = acquire_ingest_attach(**kw)
        else:
            # positional query
            res = acquire_ingest_attach(query, **kw)
    except Exception:
        return []

    # res may be dict-like; try to extract pack_path then read urls
    pack_path = ""
    try:
        pack_path = _cc_safe_str(getattr(res, "pack_path", "") or (res.get("pack_path") if isinstance(res, dict) else ""))
    except Exception:
        pack_path = ""

    urls_out = []
    if pack_path:
        try:
            import json
            j = json.loads(Path(pack_path).read_text(encoding="utf-8"))
            # Pack format: list of dicts or dict with items
            if isinstance(j, list):
                for it in j:
                    if isinstance(it, dict) and it.get("url"):
                        urls_out.append(it["url"])
            elif isinstance(j, dict):
                for k in ("allowed", "urls_allowed", "urls", "items"):
                    v = j.get(k)
                    if isinstance(v, list):
                        for it in v:
                            if isinstance(it, dict) and it.get("url"):
                                urls_out.append(it["url"])
                            elif isinstance(it, str):
                                urls_out.append(it)
        except Exception:
            pass

    # Also try fields on res itself
    if not urls_out:
        try:
            if isinstance(res, dict):
                for k in ("urls_allowed", "urls_ingested", "urls_found"):
                    v = res.get(k)
                    if isinstance(v, list):
                        urls_out.extend([x.get("url") if isinstance(x, dict) else x for x in v])
        except Exception:
            pass

    return _cc_unique_urls(urls_out)

def _cc_attach_evidence(note, urls):
    ev = []
    try:
        ev = getattr(note, "evidence", None) or []
    except Exception:
        ev = []
    if not isinstance(ev, list):
        ev = []
    seen = set()
    def key(e):
        try:
            return _cc_safe_str(getattr(e, "url", "") or getattr(e, "source", "") or (e.get("url") if isinstance(e, dict) else "") or (e.get("source") if isinstance(e, dict) else ""))
        except Exception:
            return ""
    for e in ev:
        k = key(e)
        if k:
            seen.add(k)
    for u in urls:
        if u in seen:
            continue
        seen.add(u)
        ev.append(_cc_make_evref(u, title=u))
    try:
        note.evidence = ev
    except Exception:
        pass
    return note

def _cc_build_plan_phone_only(note, state):
    """
    Deterministic structured plan (fast) with dosing + contraindication notes.
    (If you later wire a true LLM plan writer, keep this as fallback.)
    """
    preg, renal, liver = _cc_patient_flags(state)
    age = _cc_note_age_years(state)

    # acetaminophen
    if liver.lower() in ("yes","y","true"):
        apap = "Acetaminophen 500 mg PO every 6 hours as needed; MAX 2 g/day (liver disease)."
    else:
        apap = "Acetaminophen 650–1000 mg PO every 6 hours as needed; MAX 4 g/day (use lowest effective dose; consider lower max if regular alcohol use or other hepatic risk)."

    # NSAID line (not blanket contraindicated unless renal/GI/etc)
    nsaid = "Ibuprofen 400 mg PO every 6–8 hours as needed with food; avoid if CKD (esp severe), GI ulcer/bleed, anticoagulation, or uncontrolled HTN."

    topical = "Topical diclofenac gel to focal area up to 4x/day (avoid broken skin; caution with NSAID allergy)."

    nonpharm = "Non-pharmacologic: relative rest, gentle mobility, avoid provoking activity; heat or ice based on comfort; consider stretching/physical therapy if not improving."

    # Add pregnancy note if relevant
    preg_note = ""
    if preg.lower() in ("yes","y","true","possible"):
        preg_note = "Pregnancy: avoid NSAIDs (especially after 20 weeks); acetaminophen preferred—confirm gestational age and coordinate with OB if needed."
    elif preg.lower() in ("unknown","unsure","not sure"):
        preg_note = "Pregnancy status unclear: prefer acetaminophen; avoid NSAIDs until pregnancy status clarified."

    renal_note = "Renal disease: avoid NSAIDs if CKD or reduced kidney function; prefer acetaminophen and topical options; ensure hydration; seek in-person care if concern for kidney injury."
    liver_note = "Liver disease: limit acetaminophen as above; avoid alcohol; consider in-person evaluation if jaundice, RUQ pain, or systemic symptoms."

    # Build structured P section (telephone-only wording)
    lines = []
    lines.append("P:")
    lines.append("- First-line treatment:")
    lines.append(f"  - {apap}")
    lines.append(f"  - {nonpharm}")
    lines.append("- Alternatives:")
    lines.append(f"  - {nsaid}")
    lines.append(f"  - {topical}")
    lines.append("- Medication notes (key exclusions):")
    lines.append("  - NSAIDs: avoid with CKD/renal disease, prior GI ulcer/bleed, anticoagulants, or NSAID allergy; take with food.")
    if preg_note:
        lines.append(f"  - {preg_note}")
    if renal.lower() in ("yes","y","true"):
        lines.append(f"  - {renal_note}")
    if liver.lower() in ("yes","y","true"):
        lines.append(f"  - {liver_note}")
    lines.append("- Testing (telephone-only constraints):")
    lines.append("  - No labs/imaging available by phone. If severe/worsening symptoms or red flags develop, seek in-person urgent care/ED for evaluation/testing.")
    lines.append("- Return precautions (when to seek in-person care):")
    lines.append("  - Go to urgent care/ED now for chest pain, shortness of breath, severe weakness/numbness, fainting, fever with worsening pain, or rapidly worsening symptoms.")
    lines.append("  - Seek in-person evaluation within 24–72 hours if pain is not improving with treatment, limits function, or new symptoms develop.")
    # Replace P: section in SOAP
    soap = _cc_safe_str(getattr(note, "soap", "") or "")
    if "\nP:" in soap:
        soap = re.sub(r"(?ims)\nP:\s*\n.*$", "\n" + "\n".join(lines) + "\n", soap)
    else:
        soap = soap.rstrip() + "\n\n" + "\n".join(lines) + "\n"
    try:
        note.soap = soap
    except Exception:
        pass
    return note

def _cc_llm_only_evidence_and_plan(note, state, min_sources=3):
    dx, cc, _soap = _cc_extract_dx_cc(note, state)
    preg, renal, liver = _cc_patient_flags(state)

    # 1) LLM proposes URL hints (fast) -> auto-acquire ingests -> attach evidence
    urls_hint = _cc_llm_pick_urls(dx, cc, preg, renal, liver, need_meds=True)

    # Build 2 focused queries: condition mgmt + meds/dosing
    q_mgmt = f"{dx} outpatient management guideline"
    q_meds = f"{dx} first line medication dosing alternatives contraindications pregnancy renal liver"

    urls1 = _cc_auto_acquire(q_mgmt, urls_hint=urls_hint, max_urls_allowed=2)
    urls2 = _cc_auto_acquire(q_meds, urls_hint=urls_hint, max_urls_allowed=2)

    urls = _cc_unique_urls((urls1 or []) + (urls2 or []) + (urls_hint or []))

    # Ensure minimum sources (one more pass if still thin)
    if len(urls) < int(min_sources):
        q_more = f"{dx} guideline treatment dosing"
        urls3 = _cc_auto_acquire(q_more, urls_hint=urls_hint, max_urls_allowed=3)
        urls = _cc_unique_urls(urls + (urls3 or []))

    note = _cc_attach_evidence(note, urls[: max(int(min_sources), 6)])

    # 2) Plan: build structured phone-only plan quickly (fallback)
    note = _cc_build_plan_phone_only(note, state)
    return note

