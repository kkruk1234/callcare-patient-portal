def _gate_rx_candidates_by_note_text(note, med_suggestions):
    """
    Prevent hallucinated rx_candidates (e.g., methotrexate/isotretinoin) from polluting meds.
    Keep a med suggestion ONLY if the drug name appears in the note text OR it's already a protocol med.
    """
    soap = (getattr(note, "soap", "") or "").lower()
    if not isinstance(med_suggestions, list) or not med_suggestions:
        return med_suggestions

    out = []
    for m in med_suggestions:
        if not isinstance(m, dict):
            continue
        name = str(m.get("drug") or m.get("med") or m.get("name") or "").strip()
        if not name:
            continue
        nlow = name.lower()

        # If the note never mentions it, drop it.
        # (Protocol meds typically ARE mentioned; rx_candidates often are not.)
        if nlow not in soap:
            continue

        out.append(m)

    return out
