        else:
            try:
                ev_lines.append(f"- {getattr(e,'title','')} | {getattr(e,'url','') or getattr(e,'source','')}")
            except Exception:
                pass
    ev_txt = "\n".join(ev_lines)[:4000]

    prompt = (
        "Write the PLAN section for a TELEPHONE-ONLY telemedicine encounter.\n"
        "No clinic / no immediate labs or imaging by phone.\n"
        "Do NOT say 'return to clinic'. Use conditional instructions (if not improving in X days, if worsening, etc.).\n\n"
