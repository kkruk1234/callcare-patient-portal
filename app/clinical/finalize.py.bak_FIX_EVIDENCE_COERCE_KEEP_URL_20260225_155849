        "- Include supportive care (ice/heat/activity modification) when appropriate.\n"
        "- Keep concise.\n"
    )
    return (_cc_try_llm_complete(prompt, temperature=0.2, max_tokens=950) or "").strip()


def _cc_replace_P_section(soap_text: str, new_plan: str) -> str:
    import re
    soap = str(soap_text or "")
    plan = str(new_plan or "").strip()
    if not plan:
        return soap
    if not plan.startswith("P:"):
        plan = "P:\n" + plan

    # Replace existing P: ... to end
    if "P:" in soap:
        out = re.sub(r"(?ims)\nP:\s*\n.*\Z", "\n" + plan + "\n", soap)
        return out
    # If no P: exists, append
    return soap.rstrip() + "\n\n" + plan + "\n"


def _cc_llm_only_evidence_and_plan(note, state, *, min_sources: int = 3, max_sources: int = 6):
    try:
        if state is None:
