def _cc_safe_str(x):
    try:
        return str(x or "").strip()
    except Exception:
        return ""

def _cc_extract_dx_cc(note, state):
    # Prefer assessment first line, else chief complaint
    dx = ""
    soap = _cc_safe_str(getattr(note, "soap", "") or "")
    try:
        m = re.search(r"(?ims)\nA:\s*\n(.*?)(?:\n\n|\nP:\s*\n)", soap)
        if m:
            dx = (m.group(1) or "").strip().splitlines()[0].strip()
        else:
            m2 = re.search(r"(?im)^\s*A:\s*(.+)$", soap)
            if m2:
                dx = (m2.group(1) or "").strip()
    except Exception:
        dx = ""
    cc = _cc_safe_str(getattr(state, "chief_complaint", "") if state is not None else "")
    return dx, cc, soap

def _cc_note_age_years(state):
    # best-effort: you already sync numeric age in simulator
    for k in ("age_years", "age", "patient_age"):
        try:
            v = getattr(state, k, None)
            if v is None: 
