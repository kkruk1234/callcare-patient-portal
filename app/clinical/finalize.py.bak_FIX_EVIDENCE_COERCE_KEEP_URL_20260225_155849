    except Exception:
        pass

    fn_names = ["complete","chat_complete","chat","call_llm","llm_complete","ask","ask_llm","run","generate"]
    for mod in mods:
        for name in fn_names:
            fn = getattr(mod, name, None)
            if callable(fn):
                try:
                    try:
                        out = fn(prompt, temperature=temperature, max_tokens=max_tokens)
                    except TypeError:
                        out = fn(prompt)
                    if isinstance(out, dict):
                        out = out.get("text") or out.get("content") or out.get("message") or ""
                    if isinstance(out, (list, tuple)) and out:
                        out = out[0]
                    out = str(out or "").strip()
                    if out:
                        return out
                except Exception:
                    continue
    return ""


def _cc_json_from_text(s: str):
    import json, re
    s = str(s or "")
    try:
        return json.loads(s)
    except Exception:
        pass
    m = re.search(r"(\{.*\}|\[.*\])", s, flags=re.S)
    if not m:
        return None
    try:
        return json.loads(m.group(1))
    except Exception:
        return None


def _cc_domains_allowlist():
    return [
        "aafp.org",
        "nice.org.uk",
        "nhs.uk",
        "cdc.gov",
        "medlineplus.gov",
        "nih.gov",
        "ncbi.nlm.nih.gov",
        "accessdata.fda.gov",
        "idsociety.org",
        "acog.org",
        "who.int",
    ]


def _cc_filter_allowed_urls(urls):
    allowed = _cc_domains_allowlist()
    out = []
    for u in (urls or []):
        u = str(u or "").strip()
        if not u:
            continue
        low = u.lower()
        if not (low.startswith("http://") or low.startswith("https://")):
            continue
        if any(d in low for d in allowed):
            out.append(u)
    # de-dupe preserve order
    seen = set()
    final = []
    for u in out:
        if u in seen:
            continue
        seen.add(u)
        final.append(u)
    return final


def _cc_guess_title_from_url(url: str) -> str:
    try:
        from urllib.parse import urlparse
        p = urlparse(url)
        host = (p.netloc or "").replace("www.","")
        path = (p.path or "").strip("/")
        if not path:
            return host
        tail = path.split("/")[-1]
        tail = tail.replace("-", " ").replace("_", " ")
        if len(tail) < 3:
            return host
        return f"{host}: {tail[:80]}"
    except Exception:
        return str(url)[:80]


def _cc_llm_propose_evidence_urls(dx_cue: str, cc: str, *, min_sources: int = 3):
    allow = _cc_domains_allowlist()
    prompt = (
        "You are selecting authoritative sources for a physician note.\n"
        "You MUST ONLY return URLs from these domains:\n"
        + "\n".join([f"- {d}" for d in allow]) +
        "\n\n"
        f"WORKING DIAGNOSIS: {dx_cue}\n"
        f"CHIEF COMPLAINT: {cc}\n\n"
        "Return JSON ONLY as: {\"sources\": [{\"title\":\"...\",\"url\":\"https://...\"}, ...]}.\n"
        f"Return 4-6 sources. MINIMUM {min_sources} must be clearly relevant.\n"
        "Mix:\n"
        "- condition management/guidelines\n"
        "- treatment/medication guidance (including dosing-capable sources when meds are typical)\n"
        "Do NOT include unrelated diagnoses or unrelated drug monographs.\n"
    )
    out = _cc_try_llm_complete(prompt, temperature=0.2, max_tokens=650)
    obj = _cc_json_from_text(out) or {}
    items = obj.get("sources") if isinstance(obj, dict) else None
    if not isinstance(items, list):
        # fallback: maybe {urls:[...]}
        urls = obj.get("urls") if isinstance(obj, dict) else None
        if isinstance(urls, list):
            urls = _cc_filter_allowed_urls(urls)
            return [{"title": _cc_guess_title_from_url(u), "url": u} for u in urls]
        return []

    cleaned = []
    for it in items:
        if not isinstance(it, dict):
            continue
        url = it.get("url") or ""
        title = it.get("title") or ""
        url = str(url).strip()
        title = str(title).strip()
        if not url:
            continue
        if url not in _cc_filter_allowed_urls([url]):
            continue
        if not title:
            title = _cc_guess_title_from_url(url)
        cleaned.append({"title": title[:160], "url": url})

    # de-dupe by url
    seen = set()
    final = []
    for it in cleaned:
        u = it["url"]
        if u in seen:
            continue
        seen.add(u)
        final.append(it)
    return final


def _cc_attach_evidence_to_note(note, sources, *, min_sources: int = 3, max_sources: int = 6):
    sources = list(sources or [])
    if len(sources) < min_sources:
        # best effort: keep what we have; caller should have tried 4-6
        pass
    sources = sources[:max_sources]
    ev = []
    for s in sources:
        if not isinstance(s, dict):
            continue
        ev.append({
            "title": s.get("title") or _cc_guess_title_from_url(s.get("url","")),
            "source": s.get("url") or "",
            "url": s.get("url") or "",
            "snippet": s.get("snippet") or "",
        })
    try:
        setattr(note, "evidence", ev)
    except Exception:
        pass
    return note


def _cc_llm_build_plan(dx_cue: str, cc: str, age_years, preg, renal, liver, evidence_sources):
