        if len(sources) < min_sources:
            sources2 = _cc_llm_propose_evidence_urls(dx_cue, cc, min_sources=min_sources)
            if len(sources2) > len(sources):
                sources = sources2

        # Hard enforce: keep at least min_sources if possible
        sources = sources[:max_sources]
        if len(sources) < min_sources:
            # We still attach what we have; but at least it will not be random off-topic.
            pass

        # Attach evidence directly (NO FAISS)
        note = _cc_attach_evidence_to_note(note, sources, min_sources=min_sources, max_sources=max_sources)

