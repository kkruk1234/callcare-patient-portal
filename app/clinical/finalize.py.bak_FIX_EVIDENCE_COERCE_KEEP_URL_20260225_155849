                    try:
                        acquire_ingest_attach(urls)
                    except Exception:
                        pass
        except Exception:
            pass

        # Build plan with exclusions + dosing
        age_years = getattr(state, "age_years", None) or getattr(state, "age", None) or ""
        preg = getattr(state, "pregnancy_possible", "") or ""
        sx = getattr(state, "symptoms", None) or {}
