def _load_manifest_sources(pathway_id: str) -> List[dict]:
    if not pathway_id:
        return []
    manifest_path = MANIFESTS_DIR / pathway_id / "manifest.json"
    if not manifest_path.exists():
        return []

    try:
        data = json.loads(manifest_path.read_text(encoding="utf-8"))
    except Exception:
        return []

    sources = data.get("sources") or []
    if not isinstance(sources, list):
        return []

    out: List[dict] = []
    for s in sources:
        if isinstance(s, dict):
            out.append(s)
    return out


def _mk_evidence_ref(title: str, url: str, snippet: str, sid: str) -> EvidenceRef:
    payload = {}
    if hasattr(EvidenceRef, "model_fields"):  # pydantic v2
        fields = set(EvidenceRef.model_fields.keys())
    else:
        fields = set(getattr(EvidenceRef, "__fields__", {}).keys())

    if "title" in fields:
        payload["title"] = title
    if "url" in fields:
        payload["url"] = url
    if "source" in fields:
        payload["source"] = url or title
    if "snippet" in fields:
        payload["snippet"] = snippet
    if "source_id" in fields:
        payload["source_id"] = sid

    if "url" not in fields and url:
        if "source" in fields and not payload.get("source"):
            payload["source"] = url
        elif "snippet" in fields and url not in str(payload.get("snippet", "")):
            payload["snippet"] = (str(payload.get("snippet", "")) + " " + url).strip()

    return EvidenceRef(**payload)


def _set_note_evidence_from_manifest(note: NoteDraft, pathway_id: str) -> None:
    sources = _load_manifest_sources(pathway_id)
    if not sources:
        return

    ev: List[EvidenceRef] = []

    for s in sources:
        title = str(s.get("title") or s.get("id") or pathway_id).strip()
        url = str(s.get("url") or "").strip()
        sid = str(s.get("id") or "").strip()
        snippet = "Listed in pathway manifest"

        ev.append(_mk_evidence_ref(title=title, url=url, snippet=snippet, sid=sid))

    try:
        note.evidence = ev
    except Exception:
        pass


def _age_years_from_state(state: Optional[CallState]) -> Optional[int]:
    if state is None:
        return None
    sx = getattr(state, "symptoms", None) or {}
    for k in ("age_years", "age", "age_in_years"):
        v = sx.get(k) if isinstance(sx, dict) else None
        if v is not None and str(v).strip() != "":
            try:
                return int(float(v))
            except Exception:
                pass
    for attr in ("age_years", "age"):
        v = getattr(state, attr, None)
        if v is not None and str(v).strip() != "":
            try:
                return int(float(v))
            except Exception:
                pass
    return None


def _ensure_age_in_subjective(note: NoteDraft, state: Optional[CallState]) -> None:
    try:
        soap = getattr(note, "soap", "") or ""
    except Exception:
        return
    soap_s = str(soap)

    age = _age_years_from_state(state)
    if age is None:
        return

    if re.search(rf"\b{age}\s*-\s*year\s*-\s*old\b|\b{age}\s*year\s*old\b|\b{age}\s*-\s*year\s*old\b|\b{age}-year-old\b", soap_s, flags=re.IGNORECASE):
        return

    if re.search(r"\b\d{1,3}\s*-\s*year\s*-\s*old\b|\b\d{1,3}-year-old\b", soap_s, flags=re.IGNORECASE):
        return

    lines = soap_s.splitlines()
    out = []
    injected = False

    for ln in lines:
        if not injected and ln.lstrip().startswith("S:"):
            if ln.strip() == "S:" or ln.strip() == "S:":
                out.append(ln.rstrip())
                out.append(f"Patient is a {age}-year-old presenting by phone.")
            else:
                out.append(ln.rstrip() + f" Patient is a {age}-year-old.")
            injected = True
        else:
            out.append(ln.rstrip())

    new_soap = "\n".join(out).strip() + "\n"
    try:
        setattr(note, "soap", new_soap)
    except Exception:
        pass


def finalize(session_id: str, note: NoteDraft, state: Optional[CallState] = None) -> ReviewPacket:
    _tmark('finalize_start')
    # __CC_ORIG_EVIDENCE: preserve evidence produced by build_note() (avoid downstream overwrite)
    __CC_ORIG_EVIDENCE = list(getattr(note, 'evidence', None) or [])
    """
    Finalize a note into a ReviewPacket and write it to logs/finalized/<session_id>.json.

    Key behavior:
    - Pull #1 seeding happens BEFORE any evidence attachment.
    - If Pull #1 produced evidence (>=3 chunks), we prefer it for note.evidence.
    - Only if still missing do we fall back to generic retrieval.
    """
    # Fail-closed: ReviewPacket requires NoteDraft; never allow note=None.
    if note is None:
        note = _fallback_note_from_state(state)

    # Pull structured state early
    sx = {}
    try:
        if state is not None:
            sx = getattr(state, "symptoms", None) or {}
    except Exception:
        sx = {}
    if not isinstance(sx, dict):
        sx = {}

    # -------------------------------
    # RAG Pull #1: post-intake seeding (chief complaint + intake facts + anchors)
    # -------------------------------
    try:
        if False:
            rag = sx.get("_rag")
            if not isinstance(rag, dict):
                rag = {}

            have_ev = isinstance(rag.get("evidence"), list) and len(rag.get("evidence") or []) > 0
            if not have_ev:
                cc = ""
                try:
                    cc = (getattr(state, "chief_complaint", "") or getattr(state, "chief", "") or "").strip()
                except Exception:
                    cc = ""

                llm_sum = str(sx.get("_llm_intake_summary") or "").strip()
                llm_ext = sx.get("_llm_intake_extract")
                if not isinstance(llm_ext, dict):
                    llm_ext = {}

                anchors = []
                def _add(k, v):
                    v = (str(v or "").strip())
                    if v:
                        anchors.append(f"{k}:{v}")

                _add("age", sx.get("age_years") or sx.get("age") or getattr(state, "age_years", None) or getattr(state, "age", None))
                _add("sex_at_birth", sx.get("sex_at_birth") or getattr(state, "sex_at_birth", None))
                _add("pregnancy_possible", sx.get("pregnancy_possible") or getattr(state, "pregnancy_possible", None))
                _add("renal_disease", sx.get("renal_disease") or getattr(state, "renal_disease", None))
                _add("liver_disease", sx.get("liver_disease") or getattr(state, "liver_disease", None))
                _add("allergies", sx.get("allergies") or sx.get("med_allergies") or getattr(state, "allergies", None))

                fact_bits = []
                for k in ("duration", "onset", "location", "severity", "quality", "associated_symptoms", "red_flags", "context"):
                    v = llm_ext.get(k)
                    if v:
                        fact_bits.append(f"{k}:{str(v).strip()}")

                parts = [p for p in [cc, llm_sum, " ".join(fact_bits), " ".join(anchors)] if p and str(p).strip()]
                query = " | ".join(parts).strip()
                if query:
                    try:
