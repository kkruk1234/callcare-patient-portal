def _postprocess_soap_global(note, state) -> None:
    """
    Global deterministic cleanup of SOAP text:
    - Inject actual numeric age into the S: line (e.g., "35-year-old patient ...")
    - Rewrite awkward pregnancy phrasing ("Pregnancy is not possible" -> "Patient is not pregnant")
    This is intentionally conservative: only rewrites when patterns are clearly present.
    """
    try:
        soap = getattr(note, "soap", None)
        if not soap or not isinstance(soap, str):
            return

        sx = getattr(state, "symptoms", None) or {}

        def _as_int(v):
            try:
                if v is None:
                    return None
                s = str(v).strip()
                if not s:
                    return None
                n = float(s)
                if n <= 0 or n > 120:
                    return None
                return int(round(n))
            except Exception:
                return None

        # --- AGE: try multiple locations, then scan symptoms for any plausible 'age' value ---
        age_val = None
        for k in ("age_years", "age", "age_in_years", "patient_age", "age_years_int"):
            if k in sx:
                iv = _as_int(sx.get(k))
                if iv is not None:
                    age_val = iv
                    break
        if age_val is None:
            for k in ("age_years", "age", "age_in_years", "patient_age", "age_years_int"):
                iv = _as_int(getattr(state, k, None))
                if iv is not None:
                    age_val = iv
                    break
        if age_val is None:
            for k, v in sx.items():
                if "age" not in str(k).lower():
                    continue
                iv = _as_int(v)
                if iv is not None:
                    age_val = iv
                    break

        # --- PREGNANCY phrasing cleanup (global) ---
        soap2 = soap
        soap2 = re.sub(r"\bPregnancy\s+is\s+not\s+possible\b\.?", "Patient is not pregnant.", soap2, flags=re.IGNORECASE)
        soap2 = re.sub(r"\bPregnancy\s+not\s+possible\b\.?", "Patient is not pregnant.", soap2, flags=re.IGNORECASE)

        # --- TICK ATTACHMENT narrative correction (avoid "37 hours ago" when user meant attachment duration) ---
        # If the user answered tick_attachment_timeframe (e.g., "37 hours"), some generators mistakenly write
        # "tick bite ... 37 hours ago". Convert that to "Tick was attached for ~37 hours" (on S: line only).
        tf_raw = (
            sx.get("tick_attachment_timeframe")
            or sx.get("tick_attached_timeframe")
            or sx.get("tick_attachment_hours")
            or ""
        )
        tf_raw_s = str(tf_raw).strip().lower()
        tf_hours = None
        if "hour" in tf_raw_s:
            mm = re.search(r"(\d{1,3})\s*hour", tf_raw_s)
            if mm:
                try:
                    tf_hours = int(mm.group(1))
                except Exception:
                    tf_hours = None

        # --- AGE injection only on S: line, only if it's missing any 'year-old' already ---
        if age_val is not None:
            lines = soap2.splitlines()
            for i, ln in enumerate(lines):
                if ln.lstrip().startswith("S:"):
                    # If tick attachment duration was provided, fix the common mis-phrasing "... <N> hours ago ..."
                    if tf_hours is not None:
                        # Most specific pattern
                        ln2 = re.sub(
                            r"\btick bite sustained\s+(?:approximately|about)?\s*"
                            + str(tf_hours)
                            + r"\s*hours?\s*ago\s+while\s+in\s+([A-Za-z][A-Za-z \-]{0,40})\b\.?",
                            r"tick bite in \1. Tick was attached for approximately "
                            + str(tf_hours)
                            + r" hours.",
                            ln,
                            flags=re.IGNORECASE,
                        )
                        # More general fallback
                        if ln2 == ln:
                            ln2 = re.sub(
                                r"\btick bite\b([^.\n]{0,120})\b"
                                + str(tf_hours)
                                + r"\s*hours?\s*ago\b",
                                r"tick bite\1Tick was attached for approximately "
                                + str(tf_hours)
                                + r" hours",
                                ln,
                                flags=re.IGNORECASE,
                            )
                        ln = ln2

                    # If the S line already contains "year-old", don't touch it.
                    if re.search(r"\byear[- ]old\b", ln, flags=re.IGNORECASE):
                        break

                    # Common format: "S: Patient ..."
                    if re.search(r"^\s*S:\s*Patient\b", ln):
                        lines[i] = re.sub(
                            r"^\s*S:\s*Patient\b",
                            f"S: {age_val}-year-old patient",
                            ln,
                            count=1,
                        )
                        break

                    # If S line exists but doesn't start with Patient, insert prefix conservatively
                    if re.match(r"^\s*S:\s*\S", ln):
                        lines[i] = re.sub(
                            r"^\s*S:\s*",
                            f"S: {age_val}-year-old patient. ",
                            ln,
                            count=1,
                        )
                        break
            soap2 = "\n".join(lines)

        if soap2 != soap:
            setattr(note, "soap", soap2)
    except Exception:
        return


