def _strip_llm_med_regimen_from_plan_line(plan_line: str, med_names: List[str]) -> str:
    """
    If the LLM already wrote a med regimen in the same Plan line, strip it so the protocol block is the single source of truth.
    Keeps the prefix "- Plan:" (and any whitespace).
    """
    try:
        if not plan_line:
            return plan_line
        lower = plan_line.lower()
        if not any((m or "").lower() in lower for m in med_names):
            return plan_line

        m = re.match(r"^(\s*-\s*Plan\s*:)\s*(.*)$", plan_line)
        if m:
            return m.group(1)
        m2 = re.match(r"^(\s*Plan\s*:)\s*(.*)$", plan_line)
        if m2:
            return m2.group(1)
        return plan_line
    except Exception:
        return plan_line


def _inject_med_protocol_into_plan(soap_text: str, state: CallState) -> str:
    try:
        if not soap_text:
            return soap_text

        protocol, _reason = load_med_protocol_for_state(state)
        if not isinstance(protocol, dict) or not protocol:
            return soap_text

        # ---- Display-order preferences for a few known patterns (does not change med_suggestions ordering) ----
        sx = getattr(state, "symptoms", None) or {}
        if not isinstance(sx, dict):
            sx = {}

        renal_raw = str(sx.get("renal_disease", "") or "").strip().lower()
        renal_yes = renal_raw in ("yes", "y", "true")

        preg_raw = str(sx.get("pregnancy_possible", "") or "").strip().lower()
        preg_yes = preg_raw in ("yes", "y", "true", "pregnant")
        preg_unknown = ("unknown" in preg_raw) or ("not sure" in preg_raw) or ("unsure" in preg_raw) or ("maybe" in preg_raw) or ("possible" in preg_raw) or (preg_raw == "")

        pref = []
        if renal_yes:
            pref = ["fosfomycin", "nitrofurantoin", "trimethoprim-sulfamethoxazole"]
        elif preg_yes or preg_unknown:
            pref = ["cephalexin", "amoxicillin-clavulanate"]

        rx = protocol.get("rx_options") or []
        if isinstance(rx, list) and rx and pref:
            def rank(r):
                try:
                    med = (r.get("med") or "").strip().lower()
                except Exception:
                    med = ""
                for i, p in enumerate(pref):
                    if med.startswith(p):
                        return (0, i)
                return (1, 999)

            rx2 = []
            for idx, r in enumerate(rx):
                if isinstance(r, dict):
                    rx2.append((rank(r), idx, r))
            rx2.sort(key=lambda t: (t[0], t[1]))

            protocol = dict(protocol)
            protocol["rx_options"] = [t[2] for t in rx2]

        def _render_protocol_lines(p: dict) -> list:
            out = []
            out.append("Medication recommendations (Tier 1):")
            out.append("Reviewing physician will confirm appropriateness and prescribe if indicated.")

            rx2 = p.get("rx_options") or []
            if isinstance(rx2, list):
                for r in rx2:
                    if not isinstance(r, dict):
                        continue
                    med = (r.get("med") or "").strip()
                    dosing = (r.get("dosing") or "").strip()
                    if not med:
                        continue
                    line = med + (f" — {dosing}" if dosing else "")
                    out.append(line)
                    notes = (r.get("notes") or "").strip()
                    excl = (r.get("exclusions") or "").strip()
                    if notes:
                        out.append("Notes: " + notes)
                    if excl:
                        out.append("Exclusions: " + excl)

            sc = p.get("supportive_care") or []
            if isinstance(sc, list) and sc:
                out.append("Supportive care:")
                for it in sc:
                    if isinstance(it, dict):
                        item = (it.get("item") or "").strip()
                        det = (it.get("details") or "").strip()
                        if item and det:
                            out.append(f"{item}: {det}")
                        elif item:
                            out.append(item)
                    elif isinstance(it, str) and it.strip():
                        out.append(it.strip())

            fu = p.get("followup_and_safety") or []
            if isinstance(fu, list) and fu:
                out.append("Follow-up and safety:")
                for it in fu:
                    if isinstance(it, dict):
                        item = (it.get("item") or "").strip()
                        det = (it.get("details") or "").strip()
                        if item and det:
                            out.append(f"{item}: {det}")
                        elif item:
                            out.append(item)
                    elif isinstance(it, str) and it.strip():
                        out.append(it.strip())

            return out

        block = _render_protocol_lines(protocol)
        if not block:
            return soap_text

        med_names = protocol_med_names(protocol)

        lines = soap_text.splitlines()

        plan_idx = None
        for i, ln in enumerate(lines):
            if re.match(r"^\s*-\s*Plan\s*:", ln):
                plan_idx = i
                break
            if re.match(r"^\s*Plan\s*:", ln):
                plan_idx = i
                break

        if plan_idx is None:
            return soap_text

        # If already injected, don't do it again
        for j in range(plan_idx + 1, min(plan_idx + 80, len(lines))):
            if "Medication protocol (from data/protocols/meds):" in lines[j]:
                return soap_text

        if med_names:
            lines[plan_idx] = _strip_llm_med_regimen_from_plan_line(lines[plan_idx], med_names)

        base_indent = re.match(r"^(\s*)", lines[plan_idx]).group(1)  # type: ignore
        child = base_indent + "  "
        grand = child + "  "

        injected: List[str] = []
        injected.append(child + "Medication protocol (from data/protocols/meds):")

        for item in block:
            s = (item or "").strip()
            if not s:
                continue
            if s.endswith(":"):
                injected.append(child + f"- {s}")
            elif s.startswith(("Notes:", "Exclusions:")):
                injected.append(grand + f"- {s}")
            else:
                injected.append(child + f"- {s}")

        new_lines = lines[: plan_idx + 1] + injected + lines[plan_idx + 1 :]

        # Targeted cleanup near Plan when protocol exists
        boiler = ("local resistance", "empiric antibiotic", "urine analysis", "urinalysis", "culture if possible", "guided by local")
        start = plan_idx + 1 + len(injected)
        end = min(plan_idx + 140, len(new_lines))
        cleaned = []
        for k, ln in enumerate(new_lines):
            if k >= start and k < end:
                s2 = ln.strip().lower()
                # remove certain non-bullet boilerplate lines
                if s2 and (not s2.startswith("-")) and any(b in s2 for b in boiler):
                    continue
            cleaned.append(ln)

        return "\n".join(cleaned)
    except Exception:
        return soap_text


def _rewrite_plan_with_primary_protocol_rx(soap_text: str, state: CallState) -> str:
    """Insert a single primary Rx option (exclusion-aware) above the protocol block in Plan.

    Important: state.pathway_id is often None; fall back to state.symptoms['_pathway']['id'] for protocol loading.
    """
    import re as _re
    from pathlib import Path

    txt = soap_text or ""

    # Determine pathway id robustly
    pid = getattr(state, "pathway_id", "") or ""
    if not pid:
        try:
            pid = ((getattr(state, "symptoms", {}) or {}).get("_pathway") or {}).get("id") or ""
        except Exception:
            pid = ""

    # Load protocol robustly (don't rely only on load_med_protocol_for_state)
    protocol = None
    try:
        from app.clinical.med_protocols import load_med_protocol_for_state
        protocol = load_med_protocol_for_state(state)
    except Exception:
        protocol = None

    if not isinstance(protocol, dict):
        # Fallback: load directly from file by pid
        if pid:
            fp = Path("data/protocols/meds") / f"{pid}.yaml"
            if fp.exists():
                try:
                    import yaml as _yaml
                    protocol = _yaml.safe_load(fp.read_text(encoding="utf-8"))
                except Exception:
                    protocol = None

    if not isinstance(protocol, dict):
        return txt

    rx_options = protocol.get("rx_options") or []
    if not isinstance(rx_options, list) or not rx_options:
        return txt

    symptoms = getattr(state, "symptoms", {}) or {}
    answers = symptoms.get("_answers") or {}

    def _get_any(*keys):
        for k in keys:
            if k in answers and answers.get(k) is not None:
                return answers.get(k)
            if k in symptoms and symptoms.get(k) is not None:
                return symptoms.get(k)
        return None

    def _as_list(v):
        if v is None:
            return []
        if isinstance(v, list):
            return [str(x) for x in v if str(x).strip()]
        if isinstance(v, str):
            v2 = v.strip()
            return [v2] if v2 else []
        return [str(v)]

    med_excl = _as_list(_get_any("med_exclusions", "medication_exclusions", "analgesic_exclusions"))
    preg_possible = _as_list(_get_any("pregnancy_possible", "pregnant_possible", "preg_possible"))
    preg_flag = any(x.strip().lower() in ("yes", "y") for x in preg_possible)

    excl_text = " | ".join([x.lower() for x in med_excl])

    renal_flag = any(w in excl_text for w in ["kidney", "renal", "gfr", "creatinine", "dialysis"])
    ulcer_gi_flag = any(w in excl_text for w in ["ulcer", "gi bleed", "gastrointestinal bleed", "stomach bleed"])
    anticoag_flag = any(w in excl_text for w in ["blood thinner", "anticoagul", "warfarin", "apixaban", "rivaroxaban", "heparin", "eliquis", "xarelto"])
    liver_alcohol_flag = any(w in excl_text for w in ["liver", "heavy alcohol", "alcohol use", "cirrhosis", "hepatitis"])

    def _is_nsaid(med_name: str) -> bool:
        m2 = (med_name or "").lower()
        nsaids = ["ibuprofen", "naproxen", "diclofenac", "ketorolac", "indomethacin", "meloxicam", "celecoxib", "nsaid"]
        return any(x in m2 for x in nsaids)

    def _excluded_for_patient(opt: dict) -> bool:
        exc_l = str(opt.get("exclusions") or "").lower()
        med_name = str(opt.get("med") or "").lower()

        if renal_flag and (_is_nsaid(med_name) or "renal" in exc_l or "kidney" in exc_l):
            return True
        if ulcer_gi_flag and (_is_nsaid(med_name) or "ulcer" in exc_l or "gi bleed" in exc_l or "bleed" in exc_l):
            return True
        if anticoag_flag and (_is_nsaid(med_name) or "anticoag" in exc_l or "blood thinner" in exc_l):
            return True
        if preg_flag and ("pregnan" in exc_l or "trimester" in exc_l):
            return True
        if liver_alcohol_flag and (("acetaminophen" in med_name) or ("liver" in exc_l) or ("heavy alcohol" in exc_l)):
            return True

        return False

    chosen = None
    for opt in rx_options:
        if not isinstance(opt, dict):
            continue
        med = (opt.get("med") or "").strip()
        dosing = (opt.get("dosing") or "").strip()
        if not (med and dosing):
            continue
        if _excluded_for_patient(opt):
            continue
        chosen = opt
        break

    if not chosen:
        return txt

    primary_line = f"Primary medication option (based on your answers): {chosen.get('med').strip()} — {chosen.get('dosing').strip()}"

    # Insert above protocol header (case-insensitive contains match)
    lines = txt.splitlines()
    out = []
    inserted = False
    for ln in lines:
        if (not inserted) and ("medication protocol (from data/protocols/meds)" in ln.lower()):
            # avoid duplicates
            if not any("Primary medication option (based on your answers):" in x for x in out[-10:]):
                out.append("  - " + primary_line)
            inserted = True
        out.append(ln)

    return "\n".join(out)

def _build_query(state: CallState) -> str:
    parts: List[str] = []
    cc = (getattr(state, "chief_complaint", None) or "").strip()
    if cc:
        parts.append(cc)

    pid = _pathway_id(state)
    if pid:
        parts.append(pid)

    sx = _symptoms(state)
    for k, v in sx.items():
        if str(k).startswith("_"):
            continue
        if v is None or v == "":
            continue
        parts.append(f"{k}:{v}")

    age_years = getattr(state, "age_years", None)
    if age_years is not None and str(age_years).strip() != "":
        parts.append(f"age:{age_years}")

    return " ".join(parts).strip() or "general safety guidance"


def _try_rag_search(query: str, k: int = 5):
    candidates = [
        ("app.rag.retriever", "search"),
        ("app.rag.retriever", "retrieve"),
        ("app.rag.search", "search"),
        ("app.rag.search", "search_snippets"),
        ("app.rag.index", "search"),
        ("app.rag.query", "query"),
        ("app.rag.rag", "query"),
    ]
    for mod_name, fn_name in candidates:
        try:
            mod = importlib.import_module(mod_name)
            fn = getattr(mod, fn_name, None)
            if not callable(fn):
                continue
            try:
                res = fn(query, k=k)
            except TypeError:
                try:
                    res = fn(query, top_k=k)
                except TypeError:
                    res = fn(query)

            if res is None:
                return []
            if isinstance(res, dict) and "results" in res:
                res = res["results"]
            if isinstance(res, list):
                out = []
                for item in res:
                    if isinstance(item, dict):
                        out.append(item)
                    else:
                        out.append({
                            "title": getattr(item, "title", "") or "",
                            "source": getattr(item, "source", "") or "",
                            "url": getattr(item, "url", "") or "",
                            "snippet": getattr(item, "snippet", "") or getattr(item, "text", "") or "",
                        })
                return out
        except Exception:
            continue
    return []


def _evidence_from_decision(state: CallState) -> List[EvidenceRef]:
    decision = getattr(state, "decision", None)
    if not decision:
        return []
    dev = getattr(decision, "evidence", None)
    if not dev:
        return []

    out: List[EvidenceRef] = []
    for e in list(dev):
        if isinstance(e, EvidenceRef):
            out.append(e)
            continue

        if isinstance(e, dict):
            title = (e.get("title") or "").strip()
            source = (e.get("source") or "").strip()
            url = (e.get("url") or "").strip()
            snippet = (e.get("snippet") or e.get("text") or "").strip()
        else:
            title = (getattr(e, "title", "") or "").strip()
            source = (getattr(e, "source", "") or "").strip()
            url = (getattr(e, "url", "") or "").strip()
            snippet = (getattr(e, "snippet", "") or getattr(e, "text", "") or "").strip()

        if not (title or source or snippet):
            continue

        out.append(_mk_evidence_ref({
            "title": title or source or "Evidence",
            "source": source or title or "Source",
            "url": url,
            "snippet": snippet[:1200],
        }))
    return out


def _evidence_from_rag(state: CallState, max_snips: int = 6) -> List[EvidenceRef]:
    hits = _try_rag_search(_build_query(state), k=max_snips)
    out: List[EvidenceRef] = []
    for h in hits:
        title = (h.get("title") or "").strip()
        source = (h.get("source") or "").strip()
        url = (h.get("url") or "").strip()
        snippet = (h.get("snippet") or h.get("text") or "").strip()
        if not (title or source or snippet):
            continue
        out.append(_mk_evidence_ref({
            "title": title or source or "Evidence",
            "source": source or title or "Source",
            "url": url,
            "snippet": snippet[:1200],
        }))
    return out


def _merge_evidence(primary: List[EvidenceRef], secondary: List[EvidenceRef], max_total: int = 5) -> List[EvidenceRef]:
    seen = set()
    merged: List[EvidenceRef] = []
    for ev in primary + secondary:
        key = (
            (getattr(ev, "title", "") or ""),
            (getattr(ev, "source", "") or ""),
            (getattr(ev, "url", "") or ""),
            ((getattr(ev, "snippet", "") or "")[:120] if hasattr(ev, "snippet") else ""),
        )
        if key in seen:
            continue
        seen.add(key)
        merged.append(ev)
        if len(merged) >= max_total:
            break
    return merged



# --- CALLCARE_PROTOCOL_PI_V1 ---
def _patient_instructions_from_protocol_state(state: CallState) -> List[str]:
    """If a meds protocol exists for this pathway, convert supportive_care + followup_and_safety into patient-facing bullets."""
    try:
        from app.clinical.med_protocols import load_med_protocol_for_state
    except Exception:
        return []

    try:
        protocol = load_med_protocol_for_state(state) if state is not None else None
    except Exception:
        protocol = None

    if not isinstance(protocol, dict):
        return []

    bullets: List[str] = []

    for section_name in ("supportive_care", "followup_and_safety"):
        section = protocol.get(section_name) or []
        if not isinstance(section, list):
            continue

        for item in section:
            if not isinstance(item, dict):
                continue
            title = (item.get("item") or "").strip()
            details = (item.get("details") or "").strip()
            if title and details:
                bullets.append(title + ": " + details)
            elif title:
                bullets.append(title)
            elif details:
                bullets.append(details)

    # Deduplicate while preserving order
    seen = set()
    out: List[str] = []
    for b in bullets:
        b2 = " ".join(str(b).split()).strip()
        if b2 and b2 not in seen:
            out.append(b2)
            seen.add(b2)
    return out


def _build_patient_instructions(disposition: str, safety_net: List[str], allow_otc: bool) -> List[str]:
    """
    Build patient-facing instructions.

    DVT / urgent-eval rules:
    - Never rely solely on LLM SOAP phrasing.
    - If disposition OR safety-net content implies urgency, do NOT use 'if worsening' boilerplate.
    - Telephone-only wording: use 'go to the emergency department / call 911' rather than 'call or return'.
    """
    out: List[str] = []

    disp = (disposition or "").strip()
    disp_l = disp.lower()

    def _ireplace(text: str, old: str, new: str) -> str:
        t = text
        old_l = old.lower()
        while True:
            i = t.lower().find(old_l)
            if i == -1:
                return t
            t = t[:i] + new + t[i+len(old):]

    def _urgent_from_disposition(d: str) -> bool:
        markers = [
            "urgent", "same-day", "emergency", "emergency department", "ed",
            "immediate", "go now", "in-person evaluation", "in person evaluation"
        ]
        return any(x in d for x in markers)

    def _urgent_from_safety(sn: List[str]) -> bool:
        hay = " ".join([str(x) for x in (sn or [])]).lower()
        # If we're talking PE red flags / ED language, treat as urgent.
        markers = ["chest pain", "shortness of breath", "difficulty breathing", "call 911", "emergency department", "ed"]
        return any(x in hay for x in markers)

    urgent = _urgent_from_disposition(disp_l) or _urgent_from_safety(safety_net)

    if urgent:
        out.append("This needs urgent in-person evaluation today.")
    else:
        out.append("If you are not improving as expected, or if symptoms worsen, seek in-person medical care.")

    normalized: List[str] = []
    for s in (safety_net or [])[:10]:
        s2 = str(s).strip()
        if not s2:
            continue

        # Convert telephone-only phrasing.
        s2 = _ireplace(s2, "call or return", "go immediately to your local emergency department")
        s2 = _ireplace(s2, "return immediately", "go immediately to your local emergency department")
        s2 = _ireplace(s2, "call immediately", "go immediately to your local emergency department")

        if urgent:
            s2_l = s2.lower()
            already = ("emergency department" in s2_l) or ("call 911" in s2_l) or ("go immediately" in s2_l)
            if not already:
                s2 = "Go immediately to your local emergency department (or call 911) if " + s2.rstrip(".") + "."

        normalized.append(s2)

    if urgent:
        out.append("Emergency warning signs (go to the emergency department immediately / call 911):")

    out.extend(normalized)
    return out
def _generate_llm_soap_with_retry(state: CallState, evidence: List[EvidenceRef]) -> Tuple[str, str]:
    if os.environ.get("CALLCARE_NO_LLM", "").strip() in ("1", "true", "yes", "on"):
        return ("", "CALLCARE_NO_LLM enabled")

    try:
        llm = importlib.import_module("app.clinical.llm_note_writer")
        build_prompt = getattr(llm, "build_prompt", None)
        generate_note_text = getattr(llm, "generate_note_text", None)
        if not callable(build_prompt) or not callable(generate_note_text):
            return ("", "llm_note_writer missing required functions")

        prompt = build_prompt(state=state, evidence=evidence)

        for attempt in range(3):
            try:
                txt = generate_note_text(prompt) or ""
                if txt.strip():
                    return (txt, "")
                return ("", "empty LLM output")
            except Exception as e:
                msg = str(e)
                if ("RateLimitError" in type(e).__name__) or ("rate_limit" in msg.lower()) or ("429" in msg):
                    if attempt < 2:
                        time.sleep(2.5 * (attempt + 1))
                        continue
                    return ("", "rate limit (429)")
                return ("", f"{type(e).__name__}: {msg[:160]}")
        return ("", "rate limit (429)")
    except Exception as e:
        return ("", f"{type(e).__name__}: {str(e)[:160]}")



def _postprocess_dvt_possible_soap(soap_text: str) -> str:
    """Deterministic cleanup for dvt_possible. Keeps the LLM narrative but removes unsafe/incorrect phrasing."""
    txt = soap_text or ""

    # Laterality/calf hallucination -> keep it general
    txt = txt.replace("left or right calf", "leg")
    txt = txt.replace("Left or right calf", "Leg")

    # Plan contradiction: replace 'if worse' language with 'urgent today'
    txt = txt.replace(
        "Advise patient to seek emergency care if symptoms worsen",
        "Advise patient to seek urgent in-person evaluation today"
    )

    # Phone-only safety-net phrasing
    txt = txt.replace("call or return immediately", "go immediately to their local emergency department (or call 911)")
    txt = txt.replace("call or return", "go immediately to their local emergency department")
    txt = txt.replace("return immediately", "go immediately to their local emergency department (or call 911)")

    return txt



# --- CALLCARE_PREG_DUPLICATE_STRIP_V1 ---
def _strip_redundant_no_preg_pos_sentence(soap_text: str, preg_sentence: str) -> str:
    """Remove redundant phrases like 'There is no pregnancy possibility.' while keeping canonical 'Patient is not pregnant.'"""
    import re as _re

    txt = soap_text or ""
    ps = (preg_sentence or "").strip().lower()

    # Only apply when explicitly stating not pregnant.
    if "not pregnant" not in ps:
        return txt

    patterns = [
        r'\bThere is no pregnancy possibility\.?\s*',
        r'\bThere is no possibility of pregnancy\.?\s*',
        r'\bNo pregnancy possibility\.?\s*',
        r'\bNo possibility of pregnancy\.?\s*',
    ]
    for pat in patterns:
        txt = _re.sub(pat, "", txt, flags=_re.IGNORECASE)

    txt = _re.sub(r' +', ' ', txt)
    txt = _re.sub(r'\n\n\n+', '\n\n', txt)
    return txt


def build_note(state: CallState) -> NoteDraft:
    disposition, plan, safety = _decision_bits(state)

    ev_dec = _evidence_from_decision(state)
    ev_rag = _evidence_from_rag(state, max_snips=6) if len(ev_dec) < 3 else []
    evidence = _merge_evidence(ev_dec, ev_rag, max_total=5)

    preg_norm = _sync_pregnancy_from_answers(state)
    preg_sentence = _preg_sentence_from_norm(preg_norm)

    soap_text, err = _generate_llm_soap_with_retry(state, evidence)
    if not soap_text.strip():
        soap_text = f"(NOTE: LLM note generation unavailable: {err})\n"

    # Pregnancy: single canonical placement (last sentence of Subjective) + cleanup elsewhere
    soap_text = _insert_preg_sentence_as_last_subjective_sentence(soap_text, preg_sentence)

    soap_text = _strip_redundant_no_preg_pos_sentence(soap_text, preg_sentence)

    soap_text = _fix_tick_attachment_wording_in_subjective(soap_text)

    # Deterministic meds injection (and strip duplicate LLM dosing in Plan if present)
    soap_text = _inject_med_protocol_into_plan(soap_text, state)
    soap_text = _rewrite_plan_with_primary_protocol_rx(soap_text, state)

    if getattr(state, "pathway_id", "") == "dvt_possible":
        soap_text = _postprocess_dvt_possible_soap(soap_text)

    allow_otc = (not _is_emergent_disposition(disposition)) and (not _avoid_otc_from_text(plan, soap_text))
    if getattr(state, "pathway_id", "") == "dvt_possible":
        allow_otc = False
    
    # Prefer protocol-driven patient instructions when a meds protocol exists for this pathway.
    patient_instructions = _patient_instructions_from_protocol_state(state)
    if not patient_instructions:
        patient_instructions = _build_patient_instructions(disposition, safety, allow_otc)
    # DVT_PATIENT_INSTRUCTIONS_OVERRIDE
    # For dvt_possible: instructions must be urgent-now (not contingent on worsening), ED/911-forward, and never mention meds.
    if getattr(state, "pathway_id", "") == "dvt_possible":
        patient_instructions = [
            "This needs urgent in-person evaluation today for possible deep vein thrombosis (DVT).",
            "Because this is a phone visit, please go in person today for an exam and testing (typically an ultrasound of the leg).",
            "Go immediately to your local emergency department (or call 911) if you develop chest pain, shortness of breath, coughing up blood, or fainting.",
            "Go immediately to your local emergency department (or call 911) if leg pain or swelling worsens significantly."
        ]


    clinician_questions: List[str] = []
    allergies = getattr(state, "allergies", None)
    if allergies:
        clinician_questions.append(f"Medication allergies: {allergies}")

    risk_flags: List[str] = []
    rf = getattr(state, "red_flags", None)
    if isinstance(rf, list):
        risk_flags = [str(x) for x in rf if str(x).strip()]

    return NoteDraft(
        soap=soap_text,
        patient_instructions=patient_instructions,
        clinician_questions=clinician_questions,
        risk_flags=risk_flags,
        evidence=evidence,
    )
