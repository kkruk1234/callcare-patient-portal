# ----------------------------
# DECIDE_WRAPPER_V1
# Ensures new-pathway disposition rules are actually applied.
# ----------------------------
def decide(state: CallState):

    # ==================================
    # FORCE_CAUDA_ED_V1 (cannot fail)
    # ==================================
    try:
        _pid = str((state.symptoms.get("_pathway") or {}).get("id") or "")
        _sx = state.symptoms or {}
        _ans = _sx.get("_answers") or {}
        if _pid == "acute_back_pain_redflags":
            if bool(_sx.get("bladder_issue")) or bool(_sx.get("saddle_numb")) or bool(_sx.get("leg_weakness")):
                # minimal Decision-like object (works with both dict and pydantic Decision)
                try:
                    state.decision = state.decision or None
                except Exception:
                    pass
                # If there is already a Decision object later, this will be overridden by wrapper;
                # so we hard-return a dict if necessary.
                return {"disposition": "ed_now", "plan": [], "safety_net": [], "evidence": []}
            if (str(_ans.get("bladder","")).lower() == "yes") or (str(_ans.get("saddle","")).lower() == "yes") or (str(_ans.get("weakness","")).lower() == "yes"):
                return {"disposition": "ed_now", "plan": [], "safety_net": [], "evidence": []}
    except Exception:
        pass
    """
    Wrapper around _decide_orig(state):
    - Preserves existing decision logic
    - Applies apply_new_pathway_rules() for newer pathways
    - Overrides disposition when new rules fire
    """
    decision = _decide_orig(state)

    # Build flags and apply deterministic new-pathway rules
    flags = {"ed_now": [], "urgent_today": [], "routine": [], "cannot_rule_out": []}
    # HOOK_BATCH5_V1
    try:
        apply_batch5_rules(pid, symptoms, flags)
    except Exception:
        pass
    pw = (state.symptoms.get("_pathway") or {})
    pathway_id = str(pw.get("id") or "").strip()

    try:
        apply_new_pathway_rules(pathway_id, state.symptoms, flags)
    except Exception:
        # If something goes wrong, don't crash decisioning
        return decision

    # Determine final disposition from flags (priority order)
    new_disp = None
    if flags["ed_now"]:
        new_disp = "ed_now"
    elif flags["urgent_today"]:
        new_disp = "urgent_today"
    elif flags["routine"]:
        new_disp = "routine"
    elif flags["cannot_rule_out"]:
        # Keep existing if set; otherwise use cannot_rule_out
        new_disp = getattr(decision, "disposition", None) or "cannot_rule_out"

    # Override if new rules produced a disposition
    if new_disp:
        try:
            decision.disposition = new_disp
        except Exception:
            pass

    return decision


# ----------------------------
# BATCH5_RULES_V1
# ----------------------------
def apply_batch5_rules(pid: str, symptoms: dict, flags: dict) -> None:
    ed_now = flags.setdefault("ed_now", [])
    urgent_today = flags.setdefault("urgent_today", [])
    routine = flags.setdefault("routine", [])
    cannot = flags.setdefault("cannot_rule_out", [])

    def ed(code): ed_now.append(code)
    def urgent(code): urgent_today.append(code)
    def rout(code): routine.append(code)
    def cant(code): cannot.append(code)

    if pid == "eye_floaters_flashes":
        curtain = _bool(symptoms.get("curtain"))
        vision = _bool(symptoms.get("vision_loss"))
        pain = _bool(symptoms.get("severe_pain_photophobia"))
        if curtain or vision:
            ed("retinal_detachment_possible")
        elif pain:
            urgent("eye_pain_or_photophobia")
        else:
            urgent("possible_retinal_tear_eval")

    if pid == "eye_foreign_body":
        chemical = _bool(symptoms.get("chemical"))
        vision = _bool(symptoms.get("vision_change"))
        pain = _bool(symptoms.get("severe_pain"))
        if chemical:
            ed("chemical_eye_exposure")
        elif vision or pain:
            urgent("eye_foreign_body_urgent_eval")
        else:
            urgent("eye_foreign_body_eval")

    if pid == "nosebleed_epistaxis":
        prolonged = _bool(symptoms.get("prolonged"))
        heavy = _bool(symptoms.get("heavy_or_symptoms"))
        anticoag = str(symptoms.get("anticoag","")).strip().lower() in ("yes","true","y")
        if heavy:
            ed("nosebleed_heavy_or_symptomatic")
        elif prolonged and anticoag:
            urgent("nosebleed_prolonged_on_anticoagulant")
        elif prolonged:
            urgent("nosebleed_prolonged")
        else:
            rout("nosebleed_stable")

