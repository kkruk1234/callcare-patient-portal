# ============================
# PRIMARY_CARE_POSTURE_V1
# Convert triage dispositions into urgent-care / primary-care style plans.
# This does NOT prescribe meds. It upgrades the plan language + follow-up posture.
# ============================

def _as_list(x):
    if x is None:
        return []
    if isinstance(x, list):
        return x
    return [str(x)]

def _get_attr(obj, name: str, default=None):
    try:
        if isinstance(obj, dict):
            return obj.get(name, default)
    except Exception:
        pass
    try:
        return getattr(obj, name, default)
    except Exception:
        return default

def _set_list_attr(obj, name: str, vals):
    try:
        setattr(obj, name, vals)
        return True
    except Exception:
        try:
            if isinstance(obj, dict):
                obj[name] = vals
                return True
        except Exception:
            pass
    return False

def _apply_primary_care_posture(decision, pid: str, sx: dict):
    """
    Mutates decision.plan / decision.safety_net to reflect urgent-care / primary-care behavior.
    - Keeps ED rules intact.
    - For urgent_today: same-day outpatient evaluation + clinician-directed treatment framing.
    - For routine/self_care: outpatient management framing + follow-up expectations.
    """
    disp = str(_get_attr(decision, "disposition", "") or "")
    disp_l = disp.lower()

    # Normalize common variants
    if disp in ("SELF_CARE",):
        disp_l = "self_care"

    # Never override ED plans
    if disp_l == "ed_now":
        return decision

    plan = _as_list(_get_attr(decision, "plan", []))
    safety = _as_list(_get_attr(decision, "safety_net", []))

    plan_text = " ".join([str(x) for x in plan]).lower()
    already_specific = any(k in plan_text for k in [
        "mg", "dose", "dosing", "start ", "prescrib", "antibiot", "steroid", "inhaler",
        "amoxic", "doxy", "azith", "cephal", "predni", "albuterol"
    ])

    # Posture framing
    header = []
    if disp_l == "urgent_today":
        header.append("Same-day outpatient evaluation is recommended (urgent care/clinic).")
        header.append("This is a phone-only assessment; the plan below is a working plan pending clinician approval.")
    else:
        header.append("Outpatient management is appropriate based on the phone history, with follow-up if not improving.")
        header.append("This is a phone-only assessment; the plan below is a working plan pending clinician approval.")

    # If plan is generic triage boilerplate, replace with outpatient framing + follow-up expectations
    if not already_specific:
        new_plan = header[:]
        # Keep any non-generic bullets that already exist
        for x in plan:
            xs = str(x).strip()
            if not xs:
                continue
            low = xs.lower()
            if "supportive care" in low and "guideline" in low:
                continue
            if "monitor symptoms" in low and "seek care" in low:
                continue
            new_plan.append(xs)

        # If nothing meaningful remains, add default outpatient steps
        if len(new_plan) <= len(header):
            new_plan += [
                "Provide condition-appropriate outpatient treatment recommendations when indicated (clinician to finalize).",
                "Follow up if not improving within 24–72 hours depending on condition severity.",
            ]
        _set_list_attr(decision, "plan", new_plan)

        # Add a minimal safety net if missing
        if not safety:
            safety = [
                "Seek urgent in-person care if symptoms worsen or do not improve as expected.",
                "Go to the ER now for severe symptoms, trouble breathing, chest pain, confusion, fainting, or rapidly worsening condition.",
            ]
            _set_list_attr(decision, "safety_net", safety)

    return decision

def _decide_orig(state: CallState) -> Decision:
    """
    Produce an evidence-grounded clinical decision.
    This version is deterministic + retrieval-based (no LLM yet).
    """

    # Build a simple clinical query
    query_parts: List[str] = []
    if state.chief_complaint:
        query_parts.append(state.chief_complaint)
    if "duration" in state.symptoms:
        query_parts.append(f"duration {state.symptoms['duration']}")
    if "fever" in state.symptoms:
        query_parts.append(f"fever {state.symptoms['fever']}")

    query = " ".join(query_parts).strip()

    results = retrieve(query, k=3)

    evidence = [
        EvidenceRef(
            source=r["source"],
            title="Guideline excerpt",
            snippet=r["text"][:300],
        )
        for r in results
    ]

    # UC_POSTURE_DEFAULT_V1
    # Baseline (non-red-flag) posture is outpatient urgent care / primary care, not nurse-triage.
    # Red-flag enforcement later may upgrade to urgent_today / ed_now.
    disposition = "routine"
    plan = [
        "Outpatient management is reasonable based on this phone history if no red flags are present.",
        "Provide specific treatment recommendations when indicated (medications are recommendations for async physician approval).",
        "If symptoms do not improve as expected, arrange in-person evaluation (same-day if worsening).",
    ]
    safety_net = [
        "Seek urgent in-person care today if symptoms worsen, new red flags develop, or you are not improving as expected.",
        "Go to the emergency department now for severe symptoms, trouble breathing, chest pain, fainting, confusion, severe dehydration, or rapidly worsening condition.",
    ]

    return Decision(
        disposition=disposition,
        differential=[state.chief_complaint or "undifferentiated complaint"],
        plan=plan,
        safety_net=safety_net,
        evidence=evidence,
        uncertainty="Prototype decision logic without clinician override",
    )



# ----------------------------
# NEW_PATHWAY_RULES_V1
# Deterministic disposition rules for newer pathways (phone-only triage)
# ----------------------------

def _bool(v):
    if isinstance(v, bool):
        return v
    if v is None:
        return False
    s = str(v).strip().lower()
    return s in ("yes", "true", "y", "1")

def apply_new_pathway_rules(pathway_id: str, symptoms: dict, flags: dict) -> None:
    """
    Mutates flags dict:
      flags["ed_now"], flags["urgent_today"], flags["routine"], flags["cannot_rule_out"]
    """
    pid = (pathway_id or "").strip()

    def ed(code): flags["ed_now"].append(code)
    def urgent(code): flags["urgent_today"].append(code)
    def routine(code): flags["routine"].append(code)

    # Chest pain
    if pid == "chest_pain":
        severe_breathing = _bool(symptoms.get("severe_breathing"))
        syncope = _bool(symptoms.get("syncope"))
        high_risk = _bool(symptoms.get("high_risk_associated"))
        radiation = _bool(symptoms.get("radiation"))
        exertional = _bool(symptoms.get("exertional"))
        if severe_breathing or syncope:
            ed("chest_pain_severe_breathing_or_syncope")
        elif high_risk and (radiation or exertional):
            ed("chest_pain_high_risk_features")
        else:
            urgent("chest_pain_needs_same_day_eval")

    # Stroke/neuro
    if pid == "stroke_neuro":
        face = _bool(symptoms.get("face_droop"))
        arm = _bool(symptoms.get("one_sided_weakness"))
        speech = _bool(symptoms.get("speech_change"))
        onset = _bool(symptoms.get("sudden_recent_onset"))
        if onset and (face or arm or speech):
            ed("possible_stroke_fast_positive")
        else:
            urgent("neuro_symptoms_need_eval")

    # Asthma/wheeze
    if pid == "asthma_wheeze":
        severe = _bool(symptoms.get("severe_work_of_breathing"))
        cyanosis = _bool(symptoms.get("cyanosis"))
        not_helping = str(symptoms.get("rescue_not_helping","")).strip().lower() in ("yes","true","y")
        prior_severe = str(symptoms.get("prior_severe_asthma","")).strip().lower() in ("yes","true","y")
        if severe or cyanosis or not_helping:
            ed("asthma_severe_or_not_responding")
        elif prior_severe:
            urgent("asthma_history_severe_needs_same_day")
        else:
            urgent("asthma_symptoms_need_eval")

    # Flu-like illness
    if pid == "flu_like_illness":
        severe = _bool(symptoms.get("severe_breathing_or_confusion"))
        dehydration = _bool(symptoms.get("dehydration_risk"))
        high_risk = str(symptoms.get("high_risk_group","")).strip().lower() in ("yes","true","y")
        if severe:
            ed("flu_like_severe_breathing_or_confusion")
        elif dehydration or high_risk:
            urgent("flu_like_high_risk_or_dehydration")
        else:
            routine("flu_like_home_care_ok_if_stable")

    # Vaginal discharge
    if pid == "vaginal_discharge":
        fever_pain = _bool(symptoms.get("fever_or_pelvic_pain"))
        if fever_pain:
            urgent("vaginal_discharge_fever_or_pelvic_pain")
        else:
            routine("vaginal_discharge_non_emergent")

    # Pelvic pain
    if pid == "pelvic_pain":
        preg = str(symptoms.get("pregnancy_possible","")).strip().lower() in ("yes","true","y","unknown")
        severe = _bool(symptoms.get("severe_pain"))
        bleed_syncope = _bool(symptoms.get("heavy_bleeding_or_syncope"))
        fever = _bool(symptoms.get("fever"))
        if (preg and (bleed_syncope or severe)) or bleed_syncope:
            ed("pelvic_pain_possible_ectopic_or_heavy_bleed")
        elif fever or severe or preg:
            urgent("pelvic_pain_needs_same_day_eval")
        else:
            urgent("pelvic_pain_needs_eval")

    # Hemorrhoids/rectal pain
    if pid == "hemorrhoids_rectal_pain":
        heavy = _bool(symptoms.get("heavy_bleed_or_melena"))
        fever = _bool(symptoms.get("fever_or_severe_swelling"))
