        fever = _bool(symptoms.get("fever"))
        flank = _bool(symptoms.get("flank_pain"))
        vomiting = _bool(symptoms.get("vomiting"))
        preg = str(symptoms.get("pregnancy_possible","")).strip().lower() in ("yes","true","y","unknown")
