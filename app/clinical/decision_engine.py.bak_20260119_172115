        elif low_urine or not can_keep:
            urgent("dehydration_needs_eval")
        else:
            routine("mild_dehydration_home_care")

    # Medication side effect
    if pid == "med_side_effect":
        anaph = _bool(symptoms.get("anaphylaxis_signs"))
        severe_rash = _bool(symptoms.get("severe_rash"))
        if anaph:
            ed("med_reaction_anaphylaxis")
        elif severe_rash:
            urgent("med_reaction_severe_rash")
        else:
            urgent("med_reaction_needs_review")

    # Tick bite
    if pid == "tick_bite":
        systemic = _bool(symptoms.get("systemic_symptoms"))
        rash = _bool(symptoms.get("expanding_rash"))
        if systemic and rash:
            urgent("tick_bite_systemic_plus_rash")
