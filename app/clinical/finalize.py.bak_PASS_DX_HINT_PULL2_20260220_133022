def _extract_differential_from_note(note):
    """
    Returns ordered list of differential items from the Assessment section.
    Accepts formats like:
      1. X
      2. Y
      - X
    """
    import re
    soap = str(getattr(note, "soap", "") or "")

    # Pull A: block if present
    m = re.search(r"(?ims)\nA:\s*\n(.*?)(?:\n\n|\nP:\s*\n)", soap)
    a = (m.group(1) if m else soap)

    lines = [ln.strip() for ln in a.splitlines() if ln.strip()]

    out = []
    for ln in lines:
        # numbered
        mm = re.match(r"^\s*\d+\.\s*(.+)$", ln)
        if mm:
            out.append(mm.group(1).strip())
            continue
        # bullets
        mm = re.match(r"^\s*[-*]\s*(.+)$", ln)
        if mm:
            out.append(mm.group(1).strip())
            continue

    # If no explicit list, fall back to first sentence (weak)
    if not out:
        first = " ".join(a.strip().split()[:12]).strip()
        if first:
            out = [first]

    # normalize: keep only first ~6 items
    return out[:6]


def _diff_item_to_queries(item: str, cc: str = ""):
    """
    Generic, scalable query builder:
    - No diagnosis-specific mappings.
    - Uses the differential item text + chief complaint context.
    - Produces a small, stable set of positive queries for treatment/management + dosing.
    """
    it = (item or "").strip()
    cc = (cc or "").strip()

    # Strip common prefixes (still generic; not condition-specific)
    it = re.sub(r"(?i)^\s*(less likely|unlikely|consider|rule out)\s*[:\-]?\s*", "", it).strip()
    it = re.sub(r"\s*\(.*?\)\s*", " ", it).strip()  # remove parenthetical aside
    it = re.sub(r"\s{2,}", " ", it).strip()

    base = it if it else cc
    if not base:
        return []

    # Keep few queries to avoid drift
    q1 = f"{base} treatment management guideline"
    q2 = f"{base} dosing contraindications pregnancy renal"
    if cc and cc.lower() not in base.lower():
        q3 = f"{base} | {cc} guideline"
        return [q1, q2, q3]
    return [q1, q2]


def _should_allow_dx_url(item: str, title: str, url: str, text: str = ""):
    """
    Generic, scalable allow/deny:
    - Allow only if the candidate content overlaps meaningfully with the differential item tokens.
    - No hard-coded diseases, no per-diagnosis exclusions.
    """
    it = (item or "").lower()
    blob = (str(title or "") + " " + str(url or "") + " " + str(text or "")).lower()

    # Normalize & tokenize
    it = re.sub(r"\s*\(.*?\)\s*", " ", it)
    it = re.sub(r"[^a-z0-9\s\-\/]", " ", it)
    it = re.sub(r"\s{2,}", " ", it).strip()

    # If item is too generic (e.g., "cardiac causes"), don't over-restrict
    generic_markers = ("cardiac", "pulmonary", "serious", "life-threatening", "causes", "etiology", "differential")
    if any(g in it for g in generic_markers) and len(it.split()) <= 4:
        return True

    stop = set(["likely","less","unlikely","possible","or","and","with","without","given","absence","history","risk","factors","minor","atypical","presentation","from","due","to","cause","causes"])
    toks = [t for t in re.split(r"[^a-z0-9]+", it) if len(t) >= 5 and t not in stop]

    # If we have no meaningful tokens, allow (avoid deleting everything)
    if not toks:
        return True

    hits = sum(1 for t in toks[:8] if t in blob)
    # Require at least 1 strong token match
    return hits >= 1

