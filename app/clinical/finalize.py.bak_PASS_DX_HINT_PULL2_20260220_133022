def _extract_dx_cue_from_note(note) -> str:
    import re
    soap = str(getattr(note, "soap", "") or "")
    # Prefer sectioned SOAP A:
    m = re.search(r"(?ims)\nA:\s*\n(.*?)(?:\n\n|\nP:\s*\n)", soap)
    if m:
        first = (m.group(1) or "").strip().splitlines()[0].strip()
        return " ".join(first.split()[:12]).strip()
    # Fallback: inline A:
    m2 = re.search(r"(?im)^\s*A:\s*(.+)$", soap)
    if m2:
        return " ".join((m2.group(1) or "").strip().split()[:12]).strip()
    return ""

def _run_rag_pull2_dx_refine(note, state):
    """
    Pull #2: diagnosis-anchored refinement using the NOTE assessment (not state.pathway_id).

    Scalable relevance rule:
      - Require BOTH dx cue alignment AND chief-complaint alignment.
      - Avoid full-text token sprawl by matching on title + leading snippet.
      - Never return worse-than-baseline: if dx cue missing or no good hits, do nothing.
    """
    try:
        if state is None:
            return note

        dx_cue = _extract_dx_cue_from_note(note)
        if not dx_cue:
            return note  # cannot refine without a working dx cue

        cc = (getattr(state, "chief_complaint", "") or "").strip()

        from app.rag.retrieve import retrieve
        from app.clinical.evidence_adapter import as_evidence_refs
        import re

        dx_l = str(dx_cue).lower().strip()
        cc_l = str(cc).lower().strip()

        # Focused query includes both signals
        q2 = f"{dx_cue} | {cc} | treatment management guideline dosing"
        try:
            chunks = retrieve(q2, k=40) or []
        except TypeError:
            chunks = retrieve(q2) or []

        # Tokenize dx cue (NO stoplist: keep diagnosis-defining words like 'musculoskeletal')
        dx_tokens = [t for t in re.split(r"[^a-z0-9]+", dx_l) if len(t) >= 5]
        dx_tokens = dx_tokens[:6]

        # Tokenize chief complaint:
        # Keep acuity terms like acute/chronic; drop only pain-words + trivial time filler.
        cc_raw = [t for t in re.split(r"[^a-z0-9]+", cc_l) if len(t) >= 4]
        cc_stop = {
            "pain", "ache", "aches", "aching", "hurt", "hurts", "hurting", "sore",
            "problem", "issue", "issues", "concern", "today", "now",
        }
        cc_tokens = [t for t in cc_raw if t not in cc_stop]
        cc_tokens = cc_tokens[:6]

        # Exclusions ONLY if not in dx cue (keep your existing safety logic)
        excludes = [
            "supraventricular", "svt", "tachycardia",
            "troponin", "myocardial", "heart attack", "infarction",
            "pulmonary hypertension", "pulmonary embol",
            "congenital heart", "turner syndrome",
            "heart disease in women",
        ]

        def ok_chunk(ch):
            if not isinstance(ch, dict):
                return False

            title = (ch.get("title") or "").lower()
            text  = (ch.get("text") or "").lower()

            # Use only a leading snippet to avoid incidental matches deep in the page
            snippet = text[:600] if isinstance(text, str) else ""
            blob = (title + " " + snippet).strip()

            # MUST match dx cue (phrase or tokens)
            if dx_l and dx_l in blob:
                pass
            elif dx_tokens and not any(t in blob for t in dx_tokens):
                return False

            # MUST also match chief complaint (phrase or meaningful tokens)
            if cc_l:
                if cc_l in blob:
                    pass
                elif cc_tokens and not any(t in blob for t in cc_tokens):
                    return False

            # Drop exclusion topics unless explicitly part of dx cue
            for ex in excludes:
                if ex in blob and ex not in dx_l:
                    return False

            return True

        kept = [ch for ch in chunks if ok_chunk(ch)]

        # Score kept: prefer condition/guideline pages + pages that match BOTH signals strongly
        def score(ch):
            title = (ch.get("title") or "").lower()
            url = (ch.get("url") or ch.get("source") or "").lower()
            text = (ch.get("text") or "").lower()
            snippet = text[:600] if isinstance(text, str) else ""
            blob = title + " " + snippet

            s = 0
            # dx strength
            if dx_l and dx_l in blob:
                s += 90
            if dx_tokens and any(t in blob for t in dx_tokens):
                s += 25

            # cc strength
            if cc_l and cc_l in blob:
                s += 35
            if cc_tokens and any(t in blob for t in cc_tokens):
                s += 15

            # guideline-ish boosts
            if "nhs.uk/conditions/" in url:
                s += 16
            if "guideline" in blob or "nice" in blob or "management" in blob:
                s += 10
            if "dosing" in blob or "dose" in blob:
                s += 6

            # Penalize generic hubs
            if url.endswith("/chestpain.html") or "chest pain" == title.strip():
                s -= 20
            if "lab-tests" in url:
                s -= 15

            return s

        kept.sort(key=score, reverse=True)

        pull2_refs = as_evidence_refs(kept[:5]) or []
        if not pull2_refs:
            return note

        # Merge: Pull #2 dominates, Pull #1 demoted (dedupe by url/source)
        existing = list(getattr(note, "evidence", []) or [])
        seen = set()
        merged = []

        def key(e):
            return (getattr(e, "url", None) or getattr(e, "source", None) or "").strip()

        for e in pull2_refs:
            k = key(e)
            if not k or k in seen:
                continue
            seen.add(k)
            merged.append(e)

        # Keep at most 2 demoted items (still apply exclude logic)
        for e in existing:
            k = key(e)
            if not k or k in seen:
                continue
            blob = ((getattr(e, "title", "") or "") + " " + (getattr(e, "source", "") or "")).lower()
            if any(ex in blob for ex in excludes) and not any(ex in dx_l for ex in excludes):
                continue
            seen.add(k)
            merged.append(e)
            if len(merged) >= 7:
                break

        note.evidence = merged[:6]
        return note

    except Exception:
        return note


