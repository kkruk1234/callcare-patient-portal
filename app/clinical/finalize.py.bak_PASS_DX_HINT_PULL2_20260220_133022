def _extract_drug_names(med_suggestions):
    out = []
    if isinstance(med_suggestions, list):
        for m in med_suggestions:
            if not isinstance(m, dict):
                continue
            name = (m.get("drug") or m.get("med") or m.get("name") or "").strip()
            if name:
                out.append(name)
    # de-dupe preserve order
    seen = set()
    final = []
    for n in out:
        k = n.lower()
        if k in seen:
            continue
        seen.add(k)
        final.append(n)
    return final[:4]  # cap to avoid noise

def _has_dosing_capable_source(evidence):
    """
    Heuristic: if evidence includes drug monograph sources likely to contain dosing.
    This is intentionally conservative: better to keep disclaimer than hallucinate dosing.
    """
    ev = evidence or []
    for e in ev:
        title = (getattr(e, "title", "") or "").lower()
        src = (getattr(e, "source", "") or "").lower()
        blob = title + " " + src
        if "medlineplus.gov/druginfo/meds/" in blob:
            return True
        if "nhs.uk/medicines/" in blob:
            return True
        if "accessdata.fda.gov" in blob or "fda" in blob and "label" in blob:
            return True
    return False

def _ensure_dosing_sources(note, state, med_suggestions):
    """
    If meds are suggested and no dosing-capable source is present,
    retrieve drug-monograph evidence and merge into note.evidence.
    """
    try:
        if state is None:
            return note

        drugs = _extract_drug_names(med_suggestions)
        if not drugs:
            return note

        existing = list(getattr(note, "evidence", []) or [])
        if _has_dosing_capable_source(existing):
            return note

        from app.rag.retrieve import retrieve
        from app.clinical.evidence_adapter import as_evidence_refs

        anchors = []
        try:
            preg = (getattr(state, "pregnancy_possible", "") or "").strip()
            if preg:
                anchors.append(f"pregnancy:{preg}")
        except Exception:
            pass
        try:
            sx = getattr(state, "symptoms", None) or {}
            if isinstance(sx, dict):
                ren = (sx.get("renal_disease") or "").strip()
                liv = (sx.get("liver_disease") or "").strip()
                if ren:
                    anchors.append(f"renal:{ren}")
                if liv:
                    anchors.append(f"liver:{liv}")
        except Exception:
            pass

        got = []
        for drug in drugs:
            q = f'{drug} adult dosing mg contraindications renal pregnancy | {" ".join(anchors)}'
            try:
                chunks = retrieve(q, k=30) or []
            except TypeError:
                chunks = retrieve(q) or []

            # Prefer true monograph-style URLs
            preferred = []
            for c in chunks:
                if not isinstance(c, dict):
                    continue
                url = (c.get("url") or c.get("source") or "").lower()
                title = (c.get("title") or "").lower()
                if "medlineplus.gov/druginfo/meds/" in url:
                    preferred.append(c)
                elif "nhs.uk/medicines/" in url:
                    preferred.append(c)
                elif "accessdata.fda.gov" in url and "label" in url:
                    preferred.append(c)
                elif "drug" in title and "information" in title:
                    preferred.append(c)

            pick = preferred[:2] if preferred else chunks[:1]
            got.extend(pick)

        refs = as_evidence_refs(got) or []
        if not refs:
            return note

        # Merge, dedupe by source/url
        seen = set()
        merged = []

        def key(e):
            return (getattr(e, "url", None) or getattr(e, "source", None) or "").strip()

        for e in existing + refs:
            k = key(e)
            if not k or k in seen:
                continue
            seen.add(k)
            merged.append(e)

        # Keep concise
        note.evidence = merged[:8]
        return note
    except Exception:
        return note

