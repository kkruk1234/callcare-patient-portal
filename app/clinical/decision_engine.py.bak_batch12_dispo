# DECIDE_WRAPPER_STRONG_V2
# ============================
# Re-installed strong wrapper: preserves original decide() but safely enforces dispositions
# using only state.symptoms + selected pathway_id. Avoids NameError issues permanently.

def _set_disposition(decision, value: str):
    """Set disposition on model-like objects or dicts; otherwise wrap."""
    try:
        setattr(decision, "disposition", value)
        return decision
    except Exception:
        pass
    try:
        if isinstance(decision, dict):
            decision["disposition"] = value
            return decision
    except Exception:
        pass
    return {"disposition": value, "decision": decision}

# Capture the decide() that existed before this wrapper (if any)
try:
    _decide_original = decide  # type: ignore[name-defined]
except Exception:
    _decide_original = None

def decide(state):  # type: ignore[override]
    """
    Wrapper around original decide().
    If original decide() exists, call it first, then enforce critical ED/urgent rules.
    If original decide() is missing/broken, return a minimal dict decision.
    """
    # Call original safely
    decision = None
    if _decide_original is not None:
        try:
            decision = _decide_original(state)
        except Exception:
            # If original decide breaks, fall back to minimal decision object
            decision = {"disposition": "SELF_CARE"}
    else:
        decision = {"disposition": "SELF_CARE"}

    # Pull pathway id + symptoms safely
    try:
        pid = str((state.symptoms.get("_pathway") or {}).get("id") or "")
    except Exception:
        pid = ""
    try:
        sx = state.symptoms or {}
    except Exception:
        sx = {}

    # ============================
    # BATCH 5 enforcement (critical)
    # ============================

    # Eye floaters/flashes: curtain or vision loss => ED now
    if pid == "eye_floaters_flashes":
        if bool(sx.get("curtain")) or bool(sx.get("vision_loss")):
            return _set_disposition(decision, "ed_now")

    # Eye foreign body: chemical splash => ED now
    if pid == "eye_foreign_body":
        if bool(sx.get("chemical")):
            return _set_disposition(decision, "ed_now")

    # Urinary retention: unable + severe/systemic => ED now
    if pid == "urinary_retention":
        unable = bool(sx.get("unable_6h"))
        severe = bool(sx.get("severe_suprapubic"))
        systemic = bool(sx.get("systemic"))
        if unable and (severe or systemic):
            return _set_disposition(decision, "ed_now")

    # Food poisoning: GI bleed or severe red flags => ED now
    if pid == "food_poisoning":
        if bool(sx.get("gi_bleed")) or bool(sx.get("severe_redflags")):
            return _set_disposition(decision, "ed_now")

    # Nosebleed: heavy bleeding or faintness => ED now
    if pid == "nosebleed_epistaxis":
        if bool(sx.get("heavy_bleeding")) or bool(sx.get("feels_faint")) or bool(sx.get("prolonged")):
            return _set_disposition(decision, "ed_now")

    # ============================
    # BATCH 6 enforcement
    # ============================

