from app.core.models import CallState, EvidenceRef, NoteDraft


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def _model_field_names(model_cls) -> set:
    if hasattr(model_cls, "model_fields"):  # pydantic v2
        return set(model_cls.model_fields.keys())
    if hasattr(model_cls, "__fields__"):  # pydantic v1
        return set(model_cls.__fields__.keys())
    return set()


_EVID_FIELDS = _model_field_names(EvidenceRef)


def _mk_evidence_ref(data: Dict[str, Any]) -> EvidenceRef:
    safe = {k: v for k, v in data.items() if k in _EVID_FIELDS}

    if "source" in _EVID_FIELDS and not safe.get("source"):
        safe["source"] = "Unknown source"
    if "snippet" in _EVID_FIELDS and safe.get("snippet") is None:
        safe["snippet"] = ""
    if "title" in _EVID_FIELDS and not safe.get("title"):
        safe["title"] = safe.get("source", "Evidence")

    return EvidenceRef(**safe)


def _decision_bits(state: CallState) -> Tuple[str, List[str], List[str]]:
    decision = getattr(state, "decision", None)
    if not decision:
        return ("", [], [])
    disposition = str(getattr(decision, "disposition", "") or "")
    plan = list(getattr(decision, "plan", []) or [])
    safety = list(getattr(decision, "safety_net", []) or [])
    plan = [str(x) for x in plan if str(x).strip()]
    safety = [str(x) for x in safety if str(x).strip()]
    return (disposition, plan, safety)


def _is_emergent_disposition(disposition: str) -> bool:
    d = (disposition or "").lower()
    return any(x in d for x in ["call 911", "ems", "emergency", "ed now", "go to the er", "go to er", "er now"])


def _avoid_otc_from_text(plan: List[str], soap_text: str) -> bool:
    haystack = " ".join(plan) + "\n" + (soap_text or "")
    h = haystack.lower()
    return (
        "avoid self-medicating" in h
        or ("avoid" in h and "nsaid" in h)
        or ("avoid" in h and "acetaminophen" in h)
        or ("avoid" in h and "tylenol" in h)
        or ("avoid" in h and "ibuprofen" in h)
    )


def _symptoms(state: CallState) -> Dict[str, Any]:
    sx = getattr(state, "symptoms", None) or {}
    return sx if isinstance(sx, dict) else {}


def _pathway_id(state: CallState) -> str:
    sx = _symptoms(state)
    p = sx.get("_pathway", {})
    if isinstance(p, dict) and p.get("id"):
        return str(p["id"]).strip()
    pid = getattr(state, "pathway_id", None) or getattr(state, "pathway", None)
    return str(pid).strip() if pid else ""


# ----------------------------
# Minimal pregnancy handling
# ----------------------------

def _normalize_preg_value(raw: Any) -> str:
    s = ("" if raw is None else str(raw)).strip().lower()
    if not s:
        return ""
    if s in ("no", "n", "false", "0", "not pregnant"):
        return "no"
    if s in ("yes", "y", "true", "1", "pregnant", "possible"):
        return "yes"
    if s in ("unknown", "unsure", "not sure", "maybe", "?"):
        return "unknown"
    if s in ("not_applicable", "not applicable", "na", "n/a", "male"):
        return "not_applicable"
    return "unknown"


def _sync_pregnancy_from_answers(state: CallState) -> str:
    try:
        cur = getattr(state, "pregnancy_possible", None)
        cur_norm = _normalize_preg_value(cur)
        if cur_norm:
            return cur_norm

        sx = getattr(state, "symptoms", None) or {}
        if not isinstance(sx, dict):
            return ""

        direct = _normalize_preg_value(sx.get("pregnancy_possible", None))
        if direct:
            state.pregnancy_possible = direct
            sx["pregnancy_possible"] = direct
            return direct

        ans = sx.get("_answers", {})
        if isinstance(ans, dict):
            if "pregnancy_possible" in ans:
                val = _normalize_preg_value(ans.get("pregnancy_possible"))
                if val:
                    state.pregnancy_possible = val
                    sx["pregnancy_possible"] = val
                    return val
            for k, v in ans.items():
                if "preg" in str(k).lower():
                    val = _normalize_preg_value(v)
                    if val:
                        state.pregnancy_possible = val
                        sx["pregnancy_possible"] = val
                        return val

        return ""
    except Exception:
        return ""


def _preg_sentence_from_norm(norm: str) -> str:
    if norm == "no":
        return "Patient is not pregnant."
    if norm == "yes":
        return "Pregnancy is possible or status is uncertain."
    if norm == "unknown":
        return "Pregnancy status is unknown."
    # Do NOT inject "not applicable" automatically.
    return ""


def _inject_preg_sentence_into_subjective(soap_text: str, preg_sentence: str) -> str:
    try:
        if not soap_text or not preg_sentence:
            return soap_text
        if "pregnan" in soap_text.lower():
            return soap_text

        lines = soap_text.splitlines()
        for i, line in enumerate(lines):
            if line.strip().startswith("S:"):
                # If S: is on its own line, put pregnancy on the first content line after it if possible
                if line.strip() == "S:":
                    j = i + 1
                    while j < len(lines) and lines[j].strip() == "":
                        j += 1
                    if j < len(lines):
                        lines[j] = lines[j].rstrip() + " " + preg_sentence
                        return "\n".join(lines)
                else:
                    lines[i] = line.rstrip() + " " + preg_sentence
                    return "\n".join(lines)
        return soap_text
    except Exception:
        return soap_text


# ----------------------------
# Deterministic tick-attachment wording fix (FIXED: handles S: on its own line)
# ----------------------------

def _fix_tick_attachment_wording_in_subjective(soap_text: str) -> str:
    """
    Corrects the specific LLM error:
      "tick bite sustained in Georgia approximately 37 hours ago"
    to:
      "tick bite after exposure in Georgia with the tick attached for approximately 37 hours"

    FIX: Many notes format Subjective as:
      S:
      <content line>
    So we rewrite the first content line(s) after S: until blank line or next heading.
    """
    try:
        if not soap_text:
            return soap_text

        lines = soap_text.splitlines()

        # find the Subjective block start
        s_idx = None
        for i, line in enumerate(lines):
            if line.strip() == "S:" or line.strip().startswith("S:"):
                s_idx = i
                break
        if s_idx is None:
            return soap_text

        # Determine where Subjective content starts
        start = s_idx
        if lines[s_idx].strip() == "S:":
            start = s_idx + 1
        else:
            # S: is on the same line as content; include that line
            start = s_idx

        # rewrite lines in the Subjective block until a blank line or next heading
        for j in range(start, len(lines)):
            txt = lines[j]

            # stop conditions (end of Subjective block)
            if j != s_idx and txt.strip() == "":
                break
            if txt.strip().startswith(("O:", "A:", "P:")):
                break

            # if already correct, stop early
            if re.search(r"\btick\b.*\battached\b.*\bhours?\b", txt, flags=re.IGNORECASE):
                continue

            m = re.search(
                r"(tick bite)\s+sustained(?:\s+in\s+([A-Za-z][A-Za-z .'-]{1,40}))?\s+approximately\s+(\d{1,3})\s*hours?\s+ago",
                txt,
                flags=re.IGNORECASE,
            )
            if not m:
                continue

            loc = (m.group(2) or "").strip()
            hours = int(m.group(3))

            if loc:
                replacement = f"tick bite after exposure in {loc} with the tick attached for approximately {hours} hours"
            else:
                replacement = f"tick bite with the tick attached for approximately {hours} hours"

            new_txt = re.sub(
                r"(tick bite)\s+sustained(?:\s+in\s+[A-Za-z][A-Za-z .'-]{1,40})?\s+approximately\s+\d{1,3}\s*hours?\s+ago",
                replacement,
                txt,
                flags=re.IGNORECASE,
            )
            lines[j] = new_txt

        return "\n".join(lines)
    except Exception:
        return soap_text


