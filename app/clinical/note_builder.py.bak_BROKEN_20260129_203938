def build_note_with_reason(state: CallState) -> Tuple[Optional[NoteDraft], str]:
    """
    Internal helper returning (NoteDraft|None, error_reason).
    """
    evidence = _best_snippets(state, max_snips=8)
    prompt = _build_prompt(state, evidence)

    try:
        llm = importlib.import_module("app.clinical.llm_note_writer")
        generate_note_text = getattr(llm, "generate_note_text", None)
        if not callable(generate_note_text):
            return None, "llm_note_writer.generate_note_text not callable"

        txt = generate_note_text(prompt) or ""
        txt = str(txt)

        # NoteDraft schema in your repo expects list[str] for patient_instructions
        patient_instructions: List[str] = []
        clinician_questions: List[str] = []
        risk_flags: List[str] = []

        draft = NoteDraft(
            soap=txt.strip() + ("\n" if txt and not txt.endswith("\n") else ""),
            patient_instructions=patient_instructions,
            clinician_questions=clinician_questions,
            risk_flags=risk_flags,
            evidence=evidence,
        )
        return draft, ""
    except Exception as e:
        return None, str(e)

def build_note(state: CallState) -> Optional[NoteDraft]:
    """
    Public API used by finalize.py. MUST return NoteDraft (or None), not a tuple.
    """
    draft, _reason = build_note_with_reason(state)
    return draft

