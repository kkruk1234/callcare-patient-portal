def _dedupe_evidence_refs_by_source(evidence_refs):
    """Deduplicate EvidenceRef items by .source (URL in this system), preserving order."""
    seen = set()
    out = []
    for ev in (evidence_refs or []):
        src = getattr(ev, "source", None)
        if not src:
            continue
        if src in seen:
            continue
        seen.add(src)
        out.append(ev)
    return out


def _ensure_min_unique_evidence_refs(
    *,
    query: str,
    retrieve_fn,
    as_refs_fn,
    min_unique: int = 3,
    k_steps=(8, 12, 18, 24, 36),
    extra_queries=None,
):
    """
    Try to attach >= min_unique unique evidence sources (EvidenceRef.source) during RAG intake.

    Strategy:
      - Retrieve with increasing k
      - If still short, try broadened queries
      - Deduplicate strictly by URL stored in EvidenceRef.source
      - Never fabricate sources
    """
    extra_queries = extra_queries or []
    tried = []
    best = []

    def attempt(q: str, k: int):
        nonlocal best
        chunks = retrieve_fn(q, k=k) or []
        refs = as_refs_fn(chunks) or []
        refs = _dedupe_evidence_refs_by_source(refs)
        if len(refs) > len(best):
            best = refs
        return refs

    base_query = (query or "").strip()
    if base_query:
        for k in k_steps:
            tried.append((base_query, k))
            refs = attempt(base_query, k)
            if len(refs) >= min_unique:
                return refs

    # Broadening: “guideline / treatment / patient info” tends to pull distinct sources
    broadened = []
    if base_query:
        broadened.extend([
            f"{base_query} treatment",
            f"{base_query} guideline",
            f"{base_query} management",
            f"{base_query} patient information",
        ])
    broadened.extend([q for q in extra_queries if q and q.strip()])

    for q in broadened:
        q = q.strip()
        if not q:
            continue
        for k in k_steps:
            tried.append((q, k))
            refs = attempt(q, k)
            if len(refs) >= min_unique:
                return refs

    # Best effort (may still be < min_unique if corpus/index truly lacks more)
    return best

def _build_prompt(state: CallState, evidence: List[EvidenceRef]) -> str:
    """
    If your llm_note_writer has build_prompt(state,evidence), use it.
    Otherwise, build a basic prompt here.
    """
    try:
        llm = importlib.import_module("app.clinical.llm_note_writer")
        build_prompt = getattr(llm, "build_prompt", None)
        if callable(build_prompt):
            return build_prompt(state=state, evidence=evidence)
    except Exception:
        pass

    # Minimal fallback prompt if build_prompt missing
    chief = _get_chief(state)
    sx = getattr(state, "symptoms", None) or {}
    ans = (sx.get("_answers") if isinstance(sx, dict) else {}) or {}
    if not isinstance(ans, dict):
        ans = {}

    lines = []
    lines.append("You are writing a clinician-grade SOAP note for a phone-only encounter.")
    lines.append("Use ONLY the structured answers provided. Do NOT invent symptoms or negatives.")
    lines.append("")
    lines.append(f"CHIEF_COMPLAINT: {chief}")
    lines.append("")
    lines.append("STRUCTURED_ANSWERS:")
    for k in sorted(ans.keys()):
        lines.append(f"- {k}: {ans.get(k)}")

    # Pregnancy status sentence (use patient's answer only; no inference)
    preg_raw = str(ans.get("pregnancy") or "").strip().lower()
    preg_sentence = ""
    if preg_raw:
        if preg_raw.startswith("n"):
            preg_sentence = "Patient is not pregnant."
        elif preg_raw.startswith("y"):
            preg_sentence = "Patient is pregnant."
        elif preg_raw in ("unknown", "not sure", "unsure", "?"):
            preg_sentence = "Patient is unsure of pregnancy status."
    if preg_sentence:
        lines.append("")
        lines.append("PREGNANCY_STATUS_SENTENCE:")
        lines.append(preg_sentence)
        lines.append("")
        lines.append("In the SOAP note Subjective, include the pregnancy status sentence verbatim if present.")
    lines.append("")
    lines.append("EVIDENCE:")
    if evidence:
        for i, e in enumerate(evidence, 1):
            key = getattr(e, "key", f"EVID_{i}")
            title = getattr(e, "title", "")
            url = getattr(e, "url", "")
            txt = getattr(e, "text", "")
            lines.append(f"{key}: {title}")
            if url:
                lines.append(url)
            if txt:
                t = (txt or "").strip().replace("\r", " ")
                if len(t) > 1200:
                    t = t[:1200] + "…"
                lines.append(t)
            lines.append("---")
    else:
        lines.append("(No evidence snippets retrieved.)")

    lines.append("")
    lines.append("Output format rules (VERY IMPORTANT):")

- The Working diagnosis line MUST include the word 'because' and at least one patient-reported feature; do not stop after the diagnosis name.
    lines.append("- Use headings exactly: S:, O:, A:, P: (each on its own line).")
    lines.append("- In A::")
    lines.append(
    '  - Working diagnosis (most likely): <diagnosis> is likely because <brief reason using only answered features> is likely because <1–2 sentences explaining why, using only the patient’s answered features>. '
    'Rationale: Immediately after the working diagnosis, add 1–2 sentences explaining WHY it is most likely, '
    'using ONLY the patient’s answered features and the EVIDENCE above. '
    'Do NOT infer negatives or add symptoms not stated; if not asked, omit or write "not assessed".'
)

    lines.append("  - Differential: a numbered list (1., 2., 3., ...). Keep items short.")
    lines.append("  - Red flags considered: 1 sentence.")
    lines.append("- In P:, do NOT use a numbered list. Use short paragraphs or bullet points.")
    lines.append("- Only the differential should be numbered.")
    return "\n".join(lines).strip() + "\n"


