def _pick_pathway(chief: str, state: Optional[CallState] = None) -> Dict[str, Any]:
    chief_l = _norm(chief)
    # --- CALLCARE_BATCH2_GUARDS_V1 ---
    # High-signal complaint guards so sticky pathways (headache/cough/GI) don't steal these.
    try:
        import re as _re
        chief_compact = _re.sub(r'[^a-z0-9]+', '', chief_l)
    except Exception:
        chief_compact = (chief_l or "")


    
    # --- CALLCARE_PNA_KEYWORD_GUARD_V1 ---
    # If the caller explicitly says 'pneumonia', route to pneumonia_possible immediately.
    if re.search(r"\bpneumonia\b", chief_l):
        return {"id": "pneumonia_possible", "score": 999}

# --- CALLCARE_PNA_GUARD_V1 ---
    # Pneumonia-suggestive complaints (pleuritic pain / hurts to breathe + fever/cough) should not route to generic cough_uri.
    if (("fever" in chief_l) or ("chills" in chief_l)) and (("cough" in chief_l) or ("phlegm" in chief_l) or ("sputum" in chief_l)) and (("hurts to breathe" in chief_l) or ("pain with breathing" in chief_l) or ("chest pain when breathing" in chief_l) or ("pleur" in chief_l) or ("shortness of breath" in chief_l) or ("sob" in chief_l)):
        return {"id": "pneumonia_possible", "score": 999}

    # Hypertension / very high BP complaints
    if ("blood pressure" in chief_l) or ("high bp" in chief_l) or ("bp is high" in chief_l) or ("hypertension" in chief_l) or ("bloodpressure" in chief_compact):
        return {"id": "hypertensive_urgency", "score": 999}

    # Alcohol withdrawal language
    if ("alcohol withdrawal" in chief_l) or ("stopped drinking" in chief_l) or ("quit drinking" in chief_l) or ("detox" in chief_l) or ("withdrawal" in chief_l and "drink" in chief_l):
        return {"id": "alcohol_withdrawal_mild", "score": 999}

    # Opioid withdrawal language
    if ("opioid withdrawal" in chief_l) or ("stopped oxycodone" in chief_l) or ("stopped hydrocodone" in chief_l) or ("dope sick" in chief_l) or ("withdrawal" in chief_l and ("oxycodone" in chief_l or "hydrocodone" in chief_l or "percocet" in chief_l or "vicodin" in chief_l)):
        return {"id": "opioid_withdrawal_mild", "score": 999}


    # --- CALLCARE_GUARD_BLOCK_V1: high-signal chief complaint routing guards ---
    # Prevents common wrong picks (menstrual -> cough_uri, chemical eye -> minor_burn, urinary freq -> UTI, insomnia -> work stress).
    chief_compact = re.sub(r'[^a-z0-9]+', '', chief_l)

    # Eye chemical exposure (bleach/chemical/cleaner in eye)
    if ("eye" in chief_l) and (("bleach" in chief_l) or ("chemical" in chief_l) or ("cleaner" in chief_l) or ("ammonia" in chief_l)):
        return {"id": "eye_chemical_exposure", "score": 999}
    if ("eye" in chief_l) and (("splash" in chief_l) or ("splashed" in chief_l) or ("spray" in chief_l) or ("sprayed" in chief_l)) and (("bleach" in chief_l) or ("chemical" in chief_l) or ("cleaner" in chief_l)):
        return {"id": "eye_chemical_exposure", "score": 999}

    # Menstrual pain / dysmenorrhea
    if ("period" in chief_l or "menstrual" in chief_l or "dysmenorrhea" in chief_l) and ("cramp" in chief_l or "pain" in chief_l):
        return {"id": "menstrual_pain_severe", "score": 999}

    # Insomnia / can't sleep
    if ("can't sleep" in chief_l or "cannot sleep" in chief_l or "cant sleep" in chief_l or "insomnia" in chief_l or "won't sleep" in chief_l or "wont sleep" in chief_l):
        return {"id": "insomnia", "score": 999}

    # Urinary frequency explicitly without burning/dysuria
    if (("pee" in chief_l) or ("urinate" in chief_l) or ("urination" in chief_l) or ("urinary" in chief_l) or ("frequency" in chief_l)) and (
        ("doesn't burn" in chief_l) or ("doesnt burn" in chief_l) or ("no burning" in chief_l) or ("not burning" in chief_l) or ("without burning" in chief_l)
    ):
        return {"id": "urinary_frequency_no_pain", "score": 999}

    # LEG RED/SWOLLEN SORTER (before cellulitis guards)
    leg_words = ["leg", "calf", "thigh", "ankle", "foot"]
    if any(w in chief_l for w in leg_words) and (("red" in chief_l) or ("redness" in chief_l)) and (("swollen" in chief_l) or ("swelling" in chief_l)):
        return {"id": "red_swollen_leg_sort", "score": 999}
    if "one leg" in chief_l and (("swollen" in chief_l) or ("swelling" in chief_l)):
        return {"id": "red_swollen_leg_sort", "score": 999}
    if "unilateral" in chief_l and "leg" in chief_l and (("swollen" in chief_l) or ("swelling" in chief_l)):
        return {"id": "red_swollen_leg_sort", "score": 999}

    # If user explicitly says cellulitis/infection, go cellulitis
    if any(k in chief_l for k in ["cellulitis", "skin infection", "infected", "spreading redness", "infected wound", "infected bite"]):
        return {"id": "cellulitis", "score": 999}

    # DVT suspicion direct phrasing
    if any(k in chief_l for k in ["one leg", "calf", "leg"]) and any(k in chief_l for k in ["swollen", "swelling", "warm", "tender"]):
        return {"id": "dvt_possible", "score": 999}

    # CAT/DOG BITE direct phrasing (ensure these never fall through to YAML scorer)
    if any(k in chief_l for k in ["cat bite", "cat bit", "bit by a cat", "bitten by a cat", "cat bit me", "bitten by cat"]):
        return {"id": "cat_bite_wound", "score": 999}
    if any(k in chief_l for k in ["dog bite", "dog bit", "bit by a dog", "bitten by a dog", "dog bit me", "bitten by dog"]):
        return {"id": "dog_bite_wound", "score": 999}

    # CAT/DOG BITE compact-text guard (handles inputs like 'catbitemyhand')
    chief_compact2 = re.sub(r'[^a-z0-9]+', '', chief_l)
    if 'catbite' in chief_compact2 or 'catbit' in chief_compact2:
        return {"id": "cat_bite_wound", "score": 999}
    if 'dogbite' in chief_compact2 or 'dogbit' in chief_compact2:
        return {"id": "dog_bite_wound", "score": 999}



    # Fallback keyword scoring from YAML
    # NOTE: chief text may be normalized without spaces/punctuation elsewhere.
    # We match keywords against BOTH a spaced-normalized and compact-normalized version,
    # so phrases like "cat bite" match "cat bite my hand" AND "catbitemyhand".
    chief_raw = (chief or "")
    chief_l_raw = chief_raw.lower()

    def _norm_spaces(s: str) -> str:
        s = (s or "").lower()
        # keep word boundaries by converting non-alphanum to spaces
        s = re.sub(r"[^a-z0-9]+", " ", s)
        s = re.sub(r"\s+", " ", s).strip()
        return s

    chief_spaced = _norm_spaces(chief_raw)
    chief_compact = chief_spaced.replace(" ", "")

    best = ("cough_uri", 0)
    for fp in PATHWAYS_DIR.glob("*.yaml"):
        try:
            s = fp.read_text(encoding="utf-8", errors="ignore")
        except Exception:
            continue

        pid = ""
        kws = []
        # super-light parse: id: and any_keywords: [...] must exist somewhere in file
        for line in s.splitlines():
            line_stripped = line.strip()
            if line_stripped.startswith("id:"):
                pid = line_stripped.split(":", 1)[1].strip()
            if "any_keywords:" in line_stripped and "[" in line_stripped and "]" in line_stripped:
                rhs = line_stripped.split("any_keywords:", 1)[1].strip()
                # rhs is YAML-ish list; it's also valid Python list in this project (double quotes)
                try:
                    kws = eval(rhs, {"__builtins__": {}})
                except Exception:
                    kws = []
                break

        if not pid or not isinstance(kws, list):
            continue

        score = 0
        for k in kws:
            if not k:
                continue
            k_raw = str(k)
            k_low = k_raw.lower()
            k_spaced = _norm_spaces(k_raw)
            k_compact = k_spaced.replace(" ", "")

            # Match against raw lower too (helps simple cases)
            if k_low and (k_low in chief_l_raw):
                score += 1
                continue

            # Match against normalized variants
            if k_spaced and (k_spaced in chief_spaced):
                score += 1
                continue
            if k_compact and (k_compact in chief_compact):
                score += 1
                continue

        if score > best[1]:
            best = (pid, score)

    return {"id": best[0], "score": best[1]}



