def _rag_intake_enabled() -> bool:
    return (os.getenv("CALLCARE_RAG_INTAKE_DEFAULT", "0") == "1") and (os.getenv("CALLCARE_RAG_DISABLED", "0") != "1")


def _call_llm_for_planner(prompt: str) -> str:
    """
    Very small adapter so we don't guess your exact LLM module.
    Tries several common call sites. If none exist, raise and RAG plan will fallback safely.
    """
    # Hard disable
    if os.getenv("CALLCARE_LLM_DISABLED", "0") == "1":
        raise RuntimeError("CALLCARE_LLM_DISABLED=1")

    # Try common internal modules (non-fatal if missing)
    try:
        from app.clinical.llm import call_llm  # type: ignore
        return call_llm(prompt)
    except Exception:
        pass

    try:
        from app.clinical.llm_client import call_llm  # type: ignore
        return call_llm(prompt)
    except Exception:
        pass

    try:
        from app.clinical.llm_utils import call_llm  # type: ignore
        return call_llm(prompt)
    except Exception:
        pass

    # Last resort: see if note_writer exposes something usable
    try:
        from app.clinical.llm_note_writer import call_llm  # type: ignore
        return call_llm(prompt)
    except Exception:
        pass

    raise RuntimeError("No LLM call function found (planner cannot run).")


def _build_rag_demographics(state: CallState) -> Demographics:
    age = int(state.symptoms.get("age_years") or 0)
    preg = (state.symptoms.get("pregnancy_possible") or "unknown")
    allergies = (state.symptoms.get("allergies") or state.symptoms.get("allergies_text") or "")
    return Demographics(age_years=age, pregnancy_possible=str(preg), allergies_text=str(allergies))


def _rag_questions_from_state(state: CallState) -> list:
    rag = state.symptoms.get("_rag") or {}
    plan = rag.get("plan") or {}
    qs = plan.get("questions") or []
    out = []
    for q in qs:
        if not isinstance(q, dict):
            continue
        qtype = q.get("type")
        item = {
            "prompt": q.get("prompt", ""),
            "type": qtype,
            "store_as": q.get("store_as", ""),
        }
        # Your YAML loader supports 'options' (multiselect) – use that for multiple_choice too.
        if qtype == "multiple_choice":
            item["options"] = q.get("choices") or []
        out.append(item)
    return out


RESP_PATHWAYS = ['asthma_wheeze', 'copd_exacerbation', 'cough_uri', 'flu_like_illness', 'sinusitis', 'uri_sinus_overlap']


