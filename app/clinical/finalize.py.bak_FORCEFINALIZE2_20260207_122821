def _filter_rag_chunks_for_query(query: str, chunks):
    """
    Deterministic relevance filter to reduce off-topic evidence.
    For 'genital warts' we prefer HPV/genital/STI/condyloma content and avoid plantar/verruca.
    If filtering would remove everything, return original chunks.
    """
    q = (query or "").lower()
    if not chunks:
        return chunks

    prefer_terms = ["genital", "hpv", "condyloma", "sti", "sexually transmitted"]
    avoid_terms = ["plantar", "verruca", "verrucas", "foot", "feet"]

    def score(ch):
        title = str(ch.get("title") or "").lower()
        text = str(ch.get("text") or "").lower()
        s = 0
        for t in prefer_terms:
            if t in title or t in text:
                s += 2
        for t in avoid_terms:
            if t in title:
                s -= 3
            elif t in text:
                s -= 1
        return s

    # Only apply strong filtering when query is in the genital/HPV/STI neighborhood
    if any(t in q for t in ["genital", "hpv", "sti"]):
        ranked = sorted(list(chunks), key=score, reverse=True)
        kept = [c for c in ranked if score(c) >= 0]
        return kept if kept else ranked
    return chunks


def _attach_rag_evidence_if_missing(note: "NoteDraft", state) -> "NoteDraft":
    """
    Last-chance evidence attachment:
    - If note.evidence is empty, run retrieval using chief complaint and attach EvidenceRef list.
    - Retrieves more chunks, dedupes by URL (in adapter), and keeps up to 6 unique sources.
    - Never raises (fail-silent); preserves current note if anything goes wrong.
    """
    try:
        existing = getattr(note, "evidence", None)
        if existing and len(existing) > 0:
            return note
    except Exception:
        pass

    import os
    if os.getenv("CALLCARE_RAG_DISABLED", "0") == "1":
        return note

    # Prefer pre-seeded RAG context (Pull #1/#2) if present; otherwise fall back to chief complaint.
    sx = {}
    try:
        sx = getattr(state, "symptoms", None) or {}
    except Exception:
        sx = {}
    if not isinstance(sx, dict):
        sx = {}

    rag = sx.get("_rag") or {}
    if not isinstance(rag, dict):
        rag = {}

    # If chunks were already seeded, attach them directly (best case).
    seeded = rag.get("evidence")
    if isinstance(seeded, list) and seeded:
        try:
            from app.clinical.evidence_adapter import as_evidence_refs
            refs = as_evidence_refs(seeded) or []
            refs = refs[:6]
            if refs:
                if hasattr(note, "model_copy"):
                    return note.model_copy(update={"evidence": refs})
                try:
                    note.evidence = refs
                except Exception:
                    pass
                return note
        except Exception:
            pass

    # Otherwise, prefer the more specific seeded queries (if any)
    query = ""
    try:
        query = str(rag.get("query_pull2") or rag.get("query_pull1") or "").strip()
    except Exception:
        query = ""

    if not query:
        try:
            query = getattr(state, "chief_complaint", "") or getattr(state, "chief", "") or ""
        except Exception:
            query = ""
        query = (query or "").strip()
    if not query:
        return note


    try:
        from app.rag.retrieve import retrieve
        from app.clinical.evidence_adapter import as_evidence_refs
    except Exception:
        return note

    try:
        # Pull more than we need; adapter dedupes by URL/source
        try:
            chunks = retrieve(query, k=18)
            chunks = _filter_rag_chunks_for_query(query, chunks)
        except TypeError:
            chunks = retrieve(query)
        refs = as_evidence_refs(chunks or [])

        # Keep up to 6 unique sources (aiming for >=3)
        if refs:
            refs = refs[:6]

        if not refs:
            return note

        if hasattr(note, "model_copy"):
            return note.model_copy(update={"evidence": refs})
        try:
            note.evidence = refs
        except Exception:
            pass
        return note
    except Exception:
        return note
def _fallback_note_from_state(state) -> "NoteDraft":
    """
    Deterministic minimal note.
    - Uses only already-captured structured info if present
    - No invented symptoms/negatives/tests
    """
    chief = ""
    age = ""
    sex = ""
    answers = {}

    try:
        chief = getattr(state, "chief_complaint", "") or getattr(state, "chief", "") or ""
    except Exception:
        chief = ""
    try:
        age = str(getattr(state, "age", "") or getattr(state, "age_years", "") or "")
    except Exception:
        age = ""
    try:
        sex = str(getattr(state, "sex_at_birth", "") or getattr(state, "sex", "") or "")
    except Exception:
        sex = ""
    try:
        answers = getattr(state, "answers", {}) or {}
        if not isinstance(answers, dict):
            answers = {}
    except Exception:
        answers = {}

    lines = []
    lines.append("SUBJECTIVE:")
    if chief:
        lines.append(f"- Chief concern: {chief}")
    if age or sex:
        demo = " ".join([x for x in [age + "y" if age else "", sex if sex else ""] if x]).strip()
        if demo:
            lines.append(f"- Demographics: {demo}")

    if answers:
        lines.append("- History/details (structured):")
        for k in sorted(answers.keys()):
            v = answers.get(k)
            if v is None:
                continue
            vs = str(v).strip()
            if not vs:
                continue
            lines.append(f"  - {k}: {vs}")

    lines.append("")
    lines.append("OBJECTIVE:")
    lines.append("- Phone encounter; no vitals or exam performed.")
    lines.append("")
    lines.append("ASSESSMENT:")
    if chief:
        lines.append(f"- {chief} (insufficient data for definitive diagnosis based on available answers).")
    else:
        lines.append("- Concern not specified (insufficient data).")
    lines.append("")
    lines.append("PLAN:")
    lines.append("- Provide supportive guidance and return precautions.")
    lines.append("- If symptoms worsen or red flags develop, seek urgent in-person evaluation.")
    lines.append("- If persistent, clinician review recommended for targeted testing and treatment plan.")

    return NoteDraft(
        soap="\n".join(lines),
        patient_instructions=[],
        clinician_questions=[],  # keep empty to avoid surfacing conceptually
        risk_flags=[],
        evidence=[],
    )


