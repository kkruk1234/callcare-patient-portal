    return ""


def _load_manifest_sources(pathway_id: str) -> List[dict]:
    if not pathway_id:
        return []
    manifest_path = MANIFESTS_DIR / pathway_id / "manifest.json"
    if not manifest_path.exists():
        return []

    try:
        data = json.loads(manifest_path.read_text(encoding="utf-8"))
    except Exception:
        return []

    sources = data.get("sources") or []
    if not isinstance(sources, list):
        return []

    out: List[dict] = []
    for s in sources:
        if isinstance(s, dict):
            out.append(s)
    return out


def _mk_evidence_ref(title: str, url: str, snippet: str, sid: str) -> EvidenceRef:
    payload = {}
    if hasattr(EvidenceRef, "model_fields"):  # pydantic v2
        fields = set(EvidenceRef.model_fields.keys())
    else:
        fields = set(getattr(EvidenceRef, "__fields__", {}).keys())

    if "title" in fields:
        payload["title"] = title
    if "url" in fields:
        payload["url"] = url
    if "source" in fields:
        payload["source"] = url or title
    if "snippet" in fields:
        payload["snippet"] = snippet
    if "source_id" in fields:
        payload["source_id"] = sid

    if "url" not in fields and url:
        if "source" in fields and not payload.get("source"):
            payload["source"] = url
        elif "snippet" in fields and url not in str(payload.get("snippet", "")):
            payload["snippet"] = (str(payload.get("snippet", "")) + " " + url).strip()

    return EvidenceRef(**payload)


def _set_note_evidence_from_manifest(note: NoteDraft, pathway_id: str) -> None:
    sources = _load_manifest_sources(pathway_id)
    if not sources:
        return

    ev: List[EvidenceRef] = []

    for s in sources:
        title = str(s.get("title") or s.get("id") or pathway_id).strip()
        url = str(s.get("url") or "").strip()
        sid = str(s.get("id") or "").strip()
        snippet = "Listed in pathway manifest"

        ev.append(_mk_evidence_ref(title=title, url=url, snippet=snippet, sid=sid))

    try:
        note.evidence = ev
    except Exception:
        pass


def _age_years_from_state(state: Optional[CallState]) -> Optional[int]:
    if state is None:
        return None
    sx = getattr(state, "symptoms", None) or {}
    for k in ("age_years", "age", "age_in_years"):
        v = sx.get(k) if isinstance(sx, dict) else None
        if v is not None and str(v).strip() != "":
            try:
                return int(float(v))
            except Exception:
                pass
    for attr in ("age_years", "age"):
        v = getattr(state, attr, None)
        if v is not None and str(v).strip() != "":
            try:
                return int(float(v))
            except Exception:
                pass
    return None


def _ensure_age_in_subjective(note: NoteDraft, state: Optional[CallState]) -> None:
    try:
        soap = getattr(note, "soap", "") or ""
    except Exception:
        return
    soap_s = str(soap)

    age = _age_years_from_state(state)
    if age is None:
        return

    if re.search(rf"\b{age}\s*-\s*year\s*-\s*old\b|\b{age}\s*year\s*old\b|\b{age}\s*-\s*year\s*old\b|\b{age}-year-old\b", soap_s, flags=re.IGNORECASE):
        return

    if re.search(r"\b\d{1,3}\s*-\s*year\s*-\s*old\b|\b\d{1,3}-year-old\b", soap_s, flags=re.IGNORECASE):
        return

    lines = soap_s.splitlines()
    out = []
    injected = False

    for ln in lines:
        if not injected and ln.lstrip().startswith("S:"):
            if ln.strip() == "S:" or ln.strip() == "S:":
                out.append(ln.rstrip())
                out.append(f"Patient is a {age}-year-old presenting by phone.")
            else:
                out.append(ln.rstrip() + f" Patient is a {age}-year-old.")
            injected = True
        else:
            out.append(ln.rstrip())

    new_soap = "\n".join(out).strip() + "\n"
    try:
        setattr(note, "soap", new_soap)
    except Exception:
        pass


def finalize(session_id: str, note: NoteDraft, state: Optional[CallState] = None) -> ReviewPacket:
    # Fail-closed: ReviewPacket requires NoteDraft; never allow note=None.
    if note is None:
        note = _fallback_note_from_state(state)
    # Attach RAG evidence if upstream plumbing failed to include it.
    # --- CALLCARE_FINALIZE_NOTE_FALLBACK_V3 ---
    _note_reason = ''

    # Pull structured state early
    sx = {}
    try:
        if state is not None:
            sx = getattr(state, "symptoms", None) or {}
    except Exception:
        sx = {}
    if not isinstance(sx, dict):
        sx = {}

    # -------------------------------
    # RAG Pull #1: post-intake seeding
    # Seed sx["_rag"]["evidence"] BEFORE note generation so downstream can use it.
    # -------------------------------
    try:
        import os
        if os.getenv("CALLCARE_RAG_DISABLED", "0") != "1" and state is not None:
            rag = sx.get("_rag")
            if not isinstance(rag, dict):
                rag = {}

            have_ev = isinstance(rag.get("evidence"), list) and len(rag.get("evidence") or []) > 0
            if not have_ev:
                cc = ""
                try:
                    cc = (getattr(state, "chief_complaint", "") or getattr(state, "chief", "") or "").strip()
                except Exception:
                    cc = ""

                llm_sum = str(sx.get("_llm_intake_summary") or "").strip()
                llm_ext = sx.get("_llm_intake_extract")
                if not isinstance(llm_ext, dict):
                    llm_ext = {}

                anchors = []
                def _add(k, v):
                    v = (str(v or "").strip())
                    if v:
                        anchors.append(f"{k}:{v}")

                _add("age", sx.get("age_years") or sx.get("age") or getattr(state, "age_years", None) or getattr(state, "age", None))
                _add("sex_at_birth", sx.get("sex_at_birth") or getattr(state, "sex_at_birth", None))
                _add("pregnancy_possible", sx.get("pregnancy_possible") or getattr(state, "pregnancy_possible", None))
                _add("renal_disease", sx.get("renal_disease") or getattr(state, "renal_disease", None))
                _add("liver_disease", sx.get("liver_disease") or getattr(state, "liver_disease", None))
                _add("allergies", sx.get("allergies") or sx.get("med_allergies") or getattr(state, "allergies", None))

                fact_bits = []
                for k in ("duration", "onset", "location", "severity", "quality", "associated_symptoms", "red_flags", "context"):
                    v = llm_ext.get(k)
                    if v:
                        fact_bits.append(f"{k}:{str(v).strip()}")

                parts = [p for p in [cc, llm_sum, " ".join(fact_bits), " ".join(anchors)] if p and str(p).strip()]
                query = " | ".join(parts).strip()
                if query:
                    from app.rag.retrieve import retrieve
                    try:
                        chunks = retrieve(query, k=24)
                    except TypeError:
                        chunks = retrieve(query)
                    chunks = _filter_rag_chunks_for_query(cc or query, chunks)
                    rag["query_pull1"] = query
                    rag["evidence"] = chunks or []
                    sx["_rag"] = rag
                    try:
                        state.symptoms = sx
                    except Exception:
                        pass
    except Exception:
        pass

    # True last-chance evidence attachment (only if still missing)
    note = _attach_rag_evidence_if_missing(note, state)

    # Accept legacy callers passing (NoteDraft, reason) or None
    if isinstance(note, tuple):
        try:
            _note_reason = '' if len(note) < 2 else str(note[1] or '')
            note = note[0] if len(note) >= 1 else None
        except Exception:
            note = None

    # If note is None, try building it here (preferred) using state
    if note is None and state is not None:
        try:
            note, _note_reason = build_note_with_reason(state)
        except Exception as _e:
            _note_reason = str(_e)
            note = None


    # -------------------------------
    # Use Pull #1 evidence if available (turn seeded chunks into note.evidence)
    # -------------------------------
    try:
        if state is not None:
            sx_tmp = getattr(state, "symptoms", None) or {}
            if isinstance(sx_tmp, dict):
                rag = sx_tmp.get("_rag")
                chunks = rag.get("evidence") if isinstance(rag, dict) else None
                cur = getattr(note, "evidence", None) or []
                # If note has no evidence (or only 1 generic item), prefer anchored Pull #1 evidence
                if isinstance(chunks, list) and len(chunks) >= 3 and (not isinstance(cur, list) or len(cur) <= 1):
                    from app.clinical.evidence_adapter import as_evidence_refs
                    refs = as_evidence_refs(chunks)
                    if refs:
                        # Keep up to 6 sources
                        note.evidence = refs[:6]
    except Exception:
        pass

    # Deterministic fallback NoteDraft (never invent symptoms/negatives)
    if note is None:
        sx2 = getattr(state, 'symptoms', None) or {}
        if not isinstance(sx2, dict):
            sx2 = {}
        ans = sx2.get('_answers') or {}
        if not isinstance(ans, dict):
            ans = {}
        chief = (getattr(state, 'chief_complaint', '') or '').strip() if state is not None else ''
        allergies = sx2.get('allergies') or sx2.get('med_allergies') or sx2.get('medication_allergies') or getattr(state, 'allergies', None) if state is not None else None
        preg = ans.get('pregnancy') or sx2.get('pregnancy_possible') or getattr(state, 'pregnancy_possible', None) if state is not None else None
        s_lines = []
        if chief:
            s_lines.append(f"Patient presents with: {chief}.")
        else:
            s_lines.append("Patient presents with a medical concern (chief complaint not recorded).")
        if allergies:
            s_lines.append(f"Medication allergies reported: {str(allergies).strip()}.")
        if preg:
            s_lines.append(f"Pregnancy status: {str(preg).strip()}.")
        if ans:
            s_lines.append("Structured history captured:")
            for k in sorted(ans.keys()):
                s_lines.append(f"- {k}: {ans.get(k)}")
        soap = []
        soap.append("S: " + " ".join(s_lines).strip())
        soap.append("O: Phone-only encounter; no vitals or physical exam available.")
        soap.append("A: Automated assessment unavailable (note generation failed).")
        soap.append("P: Proceed with asynchronous physician review; consider in-person evaluation/testing as clinically appropriate.")
        if _note_reason:
            soap.append(f"\n(NOTE: Automated note generation failed: {_note_reason})")
        note = NoteDraft(soap="\n".join(soap).strip() + "\n", patient_instructions=[], clinician_questions=[], risk_flags=[], evidence=[])

    # If RAG evidence exists in state, attach it deterministically
    try:
        if state is not None:
            sx3 = getattr(state, 'symptoms', None) or {}
            if isinstance(sx3, dict):
                rag = sx3.get('_rag') or {}
                ev = rag.get('evidence') if isinstance(rag, dict) else None
                if isinstance(ev, list) and ev and (not getattr(note, 'evidence', None)):
                    for i, d in enumerate(ev, start=1):
                        if isinstance(d, dict) and not d.get('key'):
                            d['key'] = f"EVID_{i}"
                    note.evidence = as_evidence_refs(ev)  # type: ignore
    except Exception:
        pass

    # True last-chance evidence attachment (only if still missing)
    note = _attach_rag_evidence_if_missing(note, state)
# --- END CALLCARE_FINALIZE_NOTE_FALLBACK_V3 ---


    """
    Finalize a note into a ReviewPacket and write it to logs/finalized/<session_id>.json.

    This MUST preserve clinical state into the finalized JSON (if schema supports fields):
      - chief_complaint
      - pathway_id
      - answers
      - pregnancy_possible
      - evidence
      - med_suggestions
    """
    import uuid

    FINAL_DIR.mkdir(parents=True, exist_ok=True)

    # Infer pathway id early
    pid = ""
    try:
        pid = _infer_pathway_id(note, state)
    except Exception:
        pid = ""

    # Try attaching manifest evidence into note.evidence (best-effort)
    try:
        if pid and not getattr(note, "evidence", None):
            _set_note_evidence_from_manifest(note, pid)
    except Exception:
        pass

    disposition, reasons = _extract_disposition_from_state(state)
    recommended = _map_disposition_to_recommendation(disposition)

    comments = "Tier-1 protocol auto-finalized"
    if disposition != "UNKNOWN":
        comments += f" | disposition={disposition}" + (f" reasons={reasons}" if reasons else "")
    if pid:
        comments += f" | pathway_id={pid}"

    # Detect ReviewPacket fields (pydantic v2/v1)
    if hasattr(ReviewPacket, "model_fields"):
        fields = set(ReviewPacket.model_fields.keys())
    elif hasattr(ReviewPacket, "__fields__"):
        fields = set(ReviewPacket.__fields__.keys())
    else:
        fields = set()

    now = now_iso()
    kwargs = {}

    # Required in newer schema
    if "packet_id" in fields:
        kwargs["packet_id"] = str(uuid.uuid4())
    if "created_at" in fields:
        kwargs["created_at"] = now

    # Pull structured state
    sx = {}
    ans = {}
    try:
        if state is not None:
            sx = getattr(state, "symptoms", None) or {}
    except Exception:
        sx = {}
    if not isinstance(sx, dict):
        sx = {}

    try:
        ans = sx.get("_answers", {}) or {}
    except Exception:
        ans = {}
    if not isinstance(ans, dict):
        ans = {}

    # Chief complaint with fallbacks
    cc = ""
    try:
        if state is not None:
            cc = (getattr(state, "chief_complaint", None) or "").strip()
    except Exception:
        cc = ""
    if not cc:
        for k in ("chief_complaint", "cc", "main_concern"):
            v = sx.get(k)
            if v:
                cc = str(v).strip()
                break
    if not cc:
        v = ans.get("chief_complaint") or ans.get("cc") or ans.get("main_concern")
        if v:
            cc = str(v).strip()

    # Pregnancy possible raw — MUST be a string for ReviewPacket schema
    preg = ""
    try:
        if state is not None and hasattr(state, "pregnancy_possible"):
            v = getattr(state, "pregnancy_possible", None)
            if v is not None and str(v).strip() != "":
                preg = str(v).strip()
    except Exception:
        preg = ""

    if not preg:
        v2 = sx.get("pregnancy_possible", None)
        if v2 is not None and str(v2).strip() != "":
            preg = str(v2).strip()

    if preg is None:
        preg = ""

    # Evidence list from note
    ev = []
    try:
        ev = getattr(note, "evidence", None) or []
    except Exception:
        ev = []
    if not isinstance(ev, list):
        ev = []

    # Med suggestions (deterministic, from data/protocols/meds/<pathway_id>.yaml)
    med_suggestions: List[dict] = []
    try:
        if state is not None and pid:
            protocol, _reason = load_med_protocol_for_state(state)
            if isinstance(protocol, dict):
                med_suggestions = protocol_to_med_suggestions(protocol, pathway_id=pid) or []
    except Exception:
        med_suggestions = []

    # Phase-1 RAG-first meds support: merge rx_candidates (structured) into med_suggestions
    try:
        from app.clinical.med_support import generate_med_support
        ms = generate_med_support(state=state, evidence=ev)
        rx = ms.get("rx_candidates") if isinstance(ms, dict) else None
        if isinstance(rx, list) and rx:
            # Merge + de-dupe by drug/med name (keep protocol suggestions first)
            seen = set()
            merged = []
            for item in (med_suggestions or []) + rx:
                if not isinstance(item, dict):
                    continue
                name = str(item.get("drug") or item.get("med") or "").strip().lower()
                key = name if name else str(item).strip().lower()
                if key in seen:
                    continue
                seen.add(key)
                merged.append(item)
            med_suggestions = merged
    except Exception:
        pass


    # Common fields
    if "session_id" in fields:
        kwargs["session_id"] = session_id
    if "timestamp_iso" in fields and "created_at" not in kwargs:
        kwargs["timestamp_iso"] = now
    if "timestamp" in fields and "timestamp_iso" not in kwargs and "created_at" not in kwargs:
        kwargs["timestamp"] = now

    if "note" in fields:
        kwargs["note"] = note
    if "recommended_disposition" in fields:
        kwargs["recommended_disposition"] = recommended
    if "status" in fields:
        kwargs["status"] = "APPROVED"
    if "reviewer_id" in fields:
        kwargs["reviewer_id"] = "SYSTEM"
    if "reviewer_comments" in fields:
        kwargs["reviewer_comments"] = comments

    # State-preservation fields (only if schema supports them)
    if "chief_complaint" in fields:
        kwargs["chief_complaint"] = cc
    if "pathway_id" in fields:
        kwargs["pathway_id"] = pid or (getattr(state, "pathway_id", "") if state is not None else "")
    if "answers" in fields:
        kwargs["answers"] = ans
    if "pregnancy_possible" in fields:
        kwargs["pregnancy_possible"] = preg
    if "evidence" in fields:
        kwargs["evidence"] = ev
    if "med_suggestions" in fields:
        kwargs["med_suggestions"] = med_suggestions

    # Deterministic cleanup (best effort)
    try:
        if state is not None:
            _postprocess_soap_global(note, state)
    except Exception:
        pass


    # CAT_BITE_OVERRIDES_V1

    try:

        sx = getattr(state, "symptoms", {}) or {}

        pid2 = (sx.get("_pathway") or {}).get("id") or (pid or "")

        if pid2 == "cat_bite_wound":

            # Strong, specific patient instructions

            try:

                note.patient_instructions = [

                    "Cat bites have a high risk of infection. Gently wash the area with soap and running water. Do not soak the wound.",

                    "If the bite is on the hand or wrist, get in-person care today (urgent care or emergency department), even if it seems mild.",

                    "Get urgent care immediately if redness is spreading, swelling worsens, pus develops, pain increases, fever or chills occur, red streaks appear, numbness develops, or finger/hand movement becomes difficult.",

                    "Go to the emergency department now or call 911 if you feel very ill, develop confusion, or symptoms are rapidly worsening.",

                    "If you are not up to date on tetanus (or unsure), you should get a tetanus booster in person."

                ]

            except Exception:

                pass

    

            # Evidence: if manifest is thin / starter-only, append authoritative references

            try:

                ev2 = getattr(note, "evidence", None) or []

                if not isinstance(ev2, list):

                    ev2 = []

                joined = " ".join([str(getattr(e, "title", "") or "") + " " + str(getattr(e, "source", "") or "") for e in ev2]).lower()

                if (len(ev2) < 2) or ("starter" in joined) or (joined.strip() == ""):

                    extra = [

                        {"title":"CDC — Rabies (when to seek care after animal bites)","source":"https://www.cdc.gov/rabies/exposure/index.html","snippet":"General post-exposure considerations; seek in-person evaluation for animal bites as indicated."},

                        {"title":"IDSA — Skin and Soft Tissue Infections guideline (bite wounds / wound infection management)","source":"https://www.idsociety.org/practice-guideline/skin-and-soft-tissue-infections/","snippet":"Guidance includes bite wounds and when broader coverage is needed."},

                        {"title":"Merck Manual Professional — Bites (cat bites; hand bites)","source":"https://www.merckmanuals.com/professional/infectious-diseases/bites-and-clenched-fist-injuries/bites","snippet":"Cat bites are high-risk; hand bites often need prompt evaluation."},

                    ]

                    ev2 = ev2 + extra

                    setattr(note, "evidence", ev2)

            except Exception:

                pass

    except Exception:

        pass


    packet = ReviewPacket(**kwargs)

    out_path = FINAL_DIR / f"{session_id}.json"
    try:
        out_path.write_text(packet.model_dump_json(indent=2), encoding="utf-8")
    except Exception:
        out_path.write_text(packet.json(indent=2), encoding="utf-8")

    return packet
