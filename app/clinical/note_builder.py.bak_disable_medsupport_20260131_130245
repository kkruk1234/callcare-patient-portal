def _strip_llm_med_regimen_from_plan_line(plan_line: str, med_names: List[str]) -> str:
    """
    If the LLM already wrote a med regimen in the same Plan line, strip it so the protocol block is the single source of truth.
    Keeps the prefix "- Plan:" (and any whitespace).
    """
    try:
        if not plan_line:
            return plan_line
        lower = plan_line.lower()
        if not any((m or "").lower() in lower for m in med_names):
            return plan_line

        m = re.match(r"^(\s*-\s*Plan\s*:)\s*(.*)$", plan_line)
        if m:
            return m.group(1)
        m2 = re.match(r"^(\s*Plan\s*:)\s*(.*)$", plan_line)
        if m2:
            return m2.group(1)
        return plan_line
    except Exception:
        return plan_line


def _inject_med_protocol_into_plan(soap_text: str, state: CallState) -> str:
    try:
        if not soap_text:
            return soap_text

        protocol, _reason = load_med_protocol_for_state(state)
        if not isinstance(protocol, dict) or not protocol:
            return soap_text

        # ---- Display-order preferences for a few known patterns (does not change med_suggestions ordering) ----
        sx = getattr(state, "symptoms", None) or {}
        if not isinstance(sx, dict):
            sx = {}

        renal_raw = str(sx.get("renal_disease", "") or "").strip().lower()
        renal_yes = renal_raw in ("yes", "y", "true")

        preg_raw = str(sx.get("pregnancy_possible", "") or "").strip().lower()
        preg_yes = preg_raw in ("yes", "y", "true", "pregnant")
        preg_unknown = ("unknown" in preg_raw) or ("not sure" in preg_raw) or ("unsure" in preg_raw) or ("maybe" in preg_raw) or ("possible" in preg_raw) or (preg_raw == "")

        pref = []
        if renal_yes:
            pref = ["fosfomycin", "nitrofurantoin", "trimethoprim-sulfamethoxazole"]
        elif preg_yes or preg_unknown:
            pref = ["cephalexin", "amoxicillin-clavulanate"]

        rx = protocol.get("rx_options") or []
        if isinstance(rx, list) and rx and pref:
            def rank(r):
                try:
                    med = (r.get("med") or "").strip().lower()
                except Exception:
                    med = ""
                for i, p in enumerate(pref):
                    if med.startswith(p):
                        return (0, i)
                return (1, 999)

            rx2 = []
            for idx, r in enumerate(rx):
                if isinstance(r, dict):
                    rx2.append((rank(r), idx, r))
            rx2.sort(key=lambda t: (t[0], t[1]))

            protocol = dict(protocol)
            protocol["rx_options"] = [t[2] for t in rx2]

        def _render_protocol_lines(p: dict) -> list:
            out = []
            out.append("Medication recommendations:")

            rx2 = p.get("rx_options") or []
            if isinstance(rx2, list):
                for r in rx2:
                    if not isinstance(r, dict):
                        continue
                    med = (r.get("med") or "").strip()
                    dosing = (r.get("dosing") or "").strip()
                    if not med:
                        continue
                    line = med + (f" — {dosing}" if dosing else "")
                    out.append(line)
                    notes = (r.get("notes") or "").strip()
                    excl = (r.get("exclusions") or "").strip()
                    if notes:
                        out.append("Notes: " + notes)
                    if excl:
                        out.append("Exclusions: " + excl)

            sc = p.get("supportive_care") or []
            if isinstance(sc, list) and sc:
                out.append("Supportive care:")
                for it in sc:
                    if isinstance(it, dict):
                        item = (it.get("item") or "").strip()
                        det = (it.get("details") or "").strip()
                        if item and det:
                            out.append(f"{item}: {det}")
                        elif item:
                            out.append(item)
                    elif isinstance(it, str) and it.strip():
                        out.append(it.strip())

            fu = p.get("followup_and_safety") or []
            if isinstance(fu, list) and fu:
                out.append("Follow-up and safety:")
                for it in fu:
                    if isinstance(it, dict):
                        item = (it.get("item") or "").strip()
                        det = (it.get("details") or "").strip()
                        if item and det:
                            out.append(f"{item}: {det}")
                        elif item:
                            out.append(item)
                    elif isinstance(it, str) and it.strip():
                        out.append(it.strip())

            return out

        block = _render_protocol_lines(protocol)
        if not block:
            return soap_text

        med_names = protocol_med_names(protocol)

        lines = soap_text.splitlines()

        plan_idx = None
        for i, ln in enumerate(lines):
            if re.match(r"^\s*-\s*Plan\s*:", ln):
                plan_idx = i
                break
            if re.match(r"^\s*Plan\s*:", ln):
                plan_idx = i
                break

        if plan_idx is None:
            return soap_text

        # If already injected, don't do it again
        for j in range(plan_idx + 1, min(plan_idx + 80, len(lines))):
            if "Medication protocol (from data/protocols/meds):" in lines[j]:
                return soap_text

        if med_names:
            lines[plan_idx] = _strip_llm_med_regimen_from_plan_line(lines[plan_idx], med_names)

        base_indent = re.match(r"^(\s*)", lines[plan_idx]).group(1)  # type: ignore
        child = base_indent + "  "
        grand = child + "  "

        injected: List[str] = []
        injected.append(child + "Medication protocol (from data/protocols/meds):")

        for item in block:
            s = (item or "").strip()
            if not s:
                continue
            if s.endswith(":"):
                injected.append(child + f"- {s}")
            elif s.startswith(("Notes:", "Exclusions:")):
                injected.append(grand + f"- {s}")
            else:
                injected.append(child + f"- {s}")

        new_lines = lines[: plan_idx + 1] + injected + lines[plan_idx + 1 :]

        # Targeted cleanup near Plan when protocol exists
        boiler = ("local resistance", "empiric antibiotic", "urine analysis", "urinalysis", "culture if possible", "guided by local")
        start = plan_idx + 1 + len(injected)
        end = min(plan_idx + 140, len(new_lines))
        cleaned = []
        for k, ln in enumerate(new_lines):
            if k >= start and k < end:
                s2 = ln.strip().lower()
                # remove certain non-bullet boilerplate lines
                if s2 and (not s2.startswith("-")) and any(b in s2 for b in boiler):
                    continue
            cleaned.append(ln)

        return "\n".join(cleaned)
    except Exception:
        return soap_text


def _rewrite_plan_with_primary_protocol_rx(soap_text: str, state: CallState) -> str:
    """Insert a single primary Rx option (exclusion-aware) above the protocol block in Plan.

    Important: state.pathway_id is often None; fall back to state.symptoms['_pathway']['id'] for protocol loading.
    """
    import re as _re
    from pathlib import Path

    txt = soap_text or ""

    # Determine pathway id robustly
    pid = getattr(state, "pathway_id", "") or ""
    if not pid:
        try:
            pid = ((getattr(state, "symptoms", {}) or {}).get("_pathway") or {}).get("id") or ""
        except Exception:
            pid = ""

    # Load protocol robustly (don't rely only on load_med_protocol_for_state)
    protocol = None
    try:
        from app.clinical.med_protocols import load_med_protocol_for_state
        protocol = load_med_protocol_for_state(state)
    except Exception:
        protocol = None

    if not isinstance(protocol, dict):
        # Fallback: load directly from file by pid
        if pid:
            fp = Path("data/protocols/meds") / f"{pid}.yaml"
            if fp.exists():
                try:
                    import yaml as _yaml
                    protocol = _yaml.safe_load(fp.read_text(encoding="utf-8"))
                except Exception:
                    protocol = None

    if not isinstance(protocol, dict):
        return txt

    rx_options = protocol.get("rx_options") or []
    if not isinstance(rx_options, list) or not rx_options:
        return txt

    symptoms = getattr(state, "symptoms", {}) or {}
    answers = symptoms.get("_answers") or {}

    def _get_any(*keys):
        for k in keys:
            if k in answers and answers.get(k) is not None:
                return answers.get(k)
            if k in symptoms and symptoms.get(k) is not None:
                return symptoms.get(k)
        return None

    def _as_list(v):
        if v is None:
            return []
        if isinstance(v, list):
            return [str(x) for x in v if str(x).strip()]
        if isinstance(v, str):
            v2 = v.strip()
            return [v2] if v2 else []
        return [str(v)]

    med_excl = _as_list(_get_any("med_exclusions", "medication_exclusions", "analgesic_exclusions"))
    preg_possible = _as_list(_get_any("pregnancy_possible", "pregnant_possible", "preg_possible"))
    preg_flag = any(x.strip().lower() in ("yes", "y") for x in preg_possible)

    excl_text = " | ".join([x.lower() for x in med_excl])

    renal_flag = any(w in excl_text for w in ["kidney", "renal", "gfr", "creatinine", "dialysis"])
    ulcer_gi_flag = any(w in excl_text for w in ["ulcer", "gi bleed", "gastrointestinal bleed", "stomach bleed"])
    anticoag_flag = any(w in excl_text for w in ["blood thinner", "anticoagul", "warfarin", "apixaban", "rivaroxaban", "heparin", "eliquis", "xarelto"])
    liver_alcohol_flag = any(w in excl_text for w in ["liver", "heavy alcohol", "alcohol use", "cirrhosis", "hepatitis"])

    def _is_nsaid(med_name: str) -> bool:
        m2 = (med_name or "").lower()
        nsaids = ["ibuprofen", "naproxen", "diclofenac", "ketorolac", "indomethacin", "meloxicam", "celecoxib", "nsaid"]
        return any(x in m2 for x in nsaids)

    def _excluded_for_patient(opt: dict) -> bool:
        exc_l = str(opt.get("exclusions") or "").lower()
        med_name = str(opt.get("med") or "").lower()

        if renal_flag and (_is_nsaid(med_name) or "renal" in exc_l or "kidney" in exc_l):
            return True
        if ulcer_gi_flag and (_is_nsaid(med_name) or "ulcer" in exc_l or "gi bleed" in exc_l or "bleed" in exc_l):
            return True
        if anticoag_flag and (_is_nsaid(med_name) or "anticoag" in exc_l or "blood thinner" in exc_l):
            return True
        if preg_flag and ("pregnan" in exc_l or "trimester" in exc_l):
            return True
        if liver_alcohol_flag and (("acetaminophen" in med_name) or ("liver" in exc_l) or ("heavy alcohol" in exc_l)):
            return True

        return False

    chosen = None
    for opt in rx_options:
        if not isinstance(opt, dict):
            continue
        med = (opt.get("med") or "").strip()
        dosing = (opt.get("dosing") or "").strip()
        if not (med and dosing):
            continue
        if _excluded_for_patient(opt):
            continue
        chosen = opt
        break

    if not chosen:
        return txt

    primary_line = f"Primary medication option (based on your answers): {chosen.get('med').strip()} — {chosen.get('dosing').strip()}"

    # Insert above protocol header (case-insensitive contains match)
    lines = txt.splitlines()
    out = []
    inserted = False
    for ln in lines:
        if (not inserted) and ("medication protocol (from data/protocols/meds)" in ln.lower()):
            # avoid duplicates
            if not any("Primary medication option (based on your answers):" in x for x in out[-10:]):
                out.append("  - " + primary_line)
            inserted = True
        out.append(ln)

    return "\n".join(out)


def _inject_med_support_into_plan(soap_text: str, state: CallState, evidence: List[EvidenceRef]) -> str:
    """
    Deterministic medication/treatment support insertion for RAG-first mode.

    Ordering (clinician requirement):
      1) plan_assessment
      2) rx_candidates
      3) gating_flags
      4) return_precautions
      5) testing_lines

    Notes:
      - No dosing in Phase 1 unless it already exists elsewhere (protocols).
      - No "physician approval" language is added to SOAP.
      - Safe no-op if headers not found or module unavailable.
    """
    try:
        if not soap_text:
            return soap_text
        # Avoid duplicate insertion
        if "Medication support:" in soap_text:
            return soap_text

        try:
            from app.clinical.med_support import generate_med_support
        except Exception:
            return soap_text

        support = generate_med_support(state=state, evidence=evidence)
        if not isinstance(support, dict):
            return soap_text

        plan_assessment = support.get("plan_assessment") or []
        rx_candidates = support.get("rx_candidates") or []
        gating_flags = support.get("gating_flags") or {}
        return_precautions = support.get("return_precautions") or []
        testing_lines = support.get("testing_lines") or []

        lines = soap_text.splitlines()

        # Find Plan header: prefer "P:"; fallback "Plan:"
        p_idx = None
        for i, ln in enumerate(lines):
            if ln.strip() == "P:":
                p_idx = i
                break
        if p_idx is None:
            for i, ln in enumerate(lines):
                if re.match(r"^\s*Plan\s*:\s*$", ln, flags=re.IGNORECASE):
                    p_idx = i
                    break
        if p_idx is None:
            return soap_text

        # Insert block immediately after Plan header line
        base = " - "
        sub = "   - "

        block = []
        block.append(base + "Medication support:")

        # 1) plan assessment
        block.append(sub + "Plan assessment:")
        for s in plan_assessment:
            s2 = str(s).strip()
            if s2:
                block.append("     - " + s2)

        # 2) rx candidates
        block.append(sub + "Rx candidates:")
        if isinstance(rx_candidates, list) and rx_candidates:
            for r in rx_candidates:
                if not isinstance(r, dict):
                    continue
                drug = str(r.get("drug") or r.get("med") or "").strip()
                intent = str(r.get("intent") or "").strip()
                blocked = bool(r.get("blocked", False))
                reasons = r.get("block_reasons") or []
                line = drug if drug else "Option"
                if intent:
                    line += " — " + intent
                if blocked:
                    line = "AVOID: " + line
                block.append("     - " + line)
                if reasons:
                    try:
                        for rr in reasons:
                            rr2 = str(rr).strip()
                            if rr2:
                                block.append("       - " + rr2)
                    except Exception:
                        pass
        else:
            block.append("     - (No specific medication candidates generated in Phase 1.)")

        # 3) gating flags
        block.append(sub + "Gating flags:")
        try:
            preg = str(gating_flags.get("pregnancy", "")).strip()
            renal = str(gating_flags.get("renal_disease", "")).strip()
            liver = str(gating_flags.get("liver_disease", "")).strip()
            alleg = str(gating_flags.get("allergies_text", "")).strip()
            if preg:
                block.append("     - Pregnancy: " + preg)
            if renal:
                block.append("     - Renal disease: " + renal)
            if liver:
                block.append("     - Liver disease: " + liver)
            if alleg:
                block.append("     - Allergies: " + alleg)
        except Exception:
            pass

        # 4) return precautions
        block.append(sub + "Return precautions:")
        for s in return_precautions:
            s2 = str(s).strip()
            if s2:
                block.append("     - " + s2)

        # 5) testing
        block.append(sub + "Testing:")
        for s in testing_lines:
            s2 = str(s).strip()
            if s2:
                block.append("     - " + s2)

        new_lines = lines[:p_idx+1] + block + lines[p_idx+1:]
        return "\n".join(new_lines)
    except Exception:
        return soap_text

def _build_query(state: CallState) -> str:
    parts: List[str] = []
    cc = (getattr(state, "chief_complaint", None) or "").strip()
    if cc:
        parts.append(cc)

    pid = _pathway_id(state)
    if pid:
        parts.append(pid)

    sx = _symptoms(state)
    for k, v in sx.items():
        if str(k).startswith("_"):
            continue
        if v is None or v == "":
            continue
        parts.append(f"{k}:{v}")

    age_years = getattr(state, "age_years", None)
    if age_years is not None and str(age_years).strip() != "":
        parts.append(f"age:{age_years}")

    return " ".join(parts).strip() or "general safety guidance"


def _try_rag_search(query: str, k: int = 5):
    candidates = [
        ("app.rag.retriever", "search"),
        ("app.rag.retriever", "retrieve"),
        ("app.rag.search", "search"),
        ("app.rag.search", "search_snippets"),
        ("app.rag.index", "search"),
        ("app.rag.query", "query"),
        ("app.rag.rag", "query"),
    ]
    for mod_name, fn_name in candidates:
        try:
            mod = importlib.import_module(mod_name)
            fn = getattr(mod, fn_name, None)
            if not callable(fn):
                continue
            try:
                res = fn(query, k=k)
            except TypeError:
                try:
                    res = fn(query, top_k=k)
                except TypeError:
                    res = fn(query)

            if res is None:
                return []
            if isinstance(res, dict) and "results" in res:
                res = res["results"]
            if isinstance(res, list):
                out = []
                for item in res:
                    if isinstance(item, dict):
                        out.append(item)
                    else:
                        out.append({
                            "title": getattr(item, "title", "") or "",
                            "source": getattr(item, "source", "") or "",
                            "url": getattr(item, "url", "") or "",
                            "snippet": getattr(item, "snippet", "") or getattr(item, "text", "") or "",
                        })
                return out
        except Exception:
            continue
    return []


