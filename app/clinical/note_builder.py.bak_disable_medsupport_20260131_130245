# CallCare: pregnancy sentence dedupe clamp
def _cc_dedupe_preg(text):
    if not text:
        return text
    # common doublets
    reps = [
        (r'(She is not pregnant\.)\s*(Patient is not pregnant\.)', r'\\1'),
        (r'(Patient is not pregnant\.)\s*(She is not pregnant\.)', r'\\1'),
        (r'(She is pregnant\.)\s*(Patient is pregnant\.)', r'\\1'),
        (r'(Patient is pregnant\.)\s*(She is pregnant\.)', r'\\1'),
    ]
    out = text
    for pat, rep in reps:
        out = re.sub(pat, rep, out, flags=re.IGNORECASE)
    return out
# --- End clamp ---


