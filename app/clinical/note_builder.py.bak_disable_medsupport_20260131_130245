def _evidence_from_rag(state: CallState, max_snips: int = 6) -> List[EvidenceRef]:
    # CallCare: dedupe hits by unique url/source
    def _cc_unique_by_url(hits):
        seen = set()
        out = []
        if not isinstance(hits, list):
            return []
        for h in hits:
            if not isinstance(h, dict):
                continue
            u = (h.get('url') or h.get('source') or '').strip()
            if not u:
                continue
            if u in seen:
                continue
            seen.add(u)
            out.append(h)
        return out

    from app.rag.retrieve import retrieve
    hits = retrieve(_build_query(state), k=max_snips)
    # CallCare: overfetch until we have max_snips unique urls
    hits = _cc_unique_by_url(hits)
    if len(hits) < max_snips:
        # overfetch and re-dedupe to reach max_snips unique sources
        more = retrieve(_build_query(state), k=max(max_snips * 6, 24))
        more = _cc_unique_by_url(more)
        # merge preserving order
        seen = set()
        merged = []
        for h in hits + more:
            u = (h.get('url') or h.get('source') or '').strip()
            if not u or u in seen:
                continue
            seen.add(u)
            merged.append(h)
        hits = merged
    hits = hits[:max_snips]

    out: List[EvidenceRef] = []
    for h in hits:
        title = (h.get("title") or "").strip()
        source = (h.get("source") or "").strip()
        url = (h.get("url") or "").strip()
        snippet = (h.get("snippet") or h.get("text") or "").strip()
        if not (title or source or snippet):
            continue
        out.append(_mk_evidence_ref({
            "title": title or source or "Evidence",
            "source": source or title or "Source",
            "url": url,
            "snippet": snippet[:1200],
        }))
    return out


def _merge_evidence(primary: List[EvidenceRef], secondary: List[EvidenceRef], max_total: int = 5) -> List[EvidenceRef]:
    seen = set()
    merged: List[EvidenceRef] = []
    for ev in primary + secondary:
        url = (getattr(ev, "url", "") or "").strip().lower()
        title = (getattr(ev, "title", "") or "").strip().lower()
        source = (getattr(ev, "source", "") or "").strip().lower()
        # Deduplicate primarily by URL (best), otherwise by (title, source)
        key = (url if url else None, title, source)
        if key in seen:

            continue
        seen.add(key)
        merged.append(ev)
        if len(merged) >= max_total:
            break
    return merged



