def _cc_filter_evidence_urinary(state, evidence):
    if not evidence or not _cc_is_urinary(state):
        return evidence
    cc = _cc_cc_text(state)
    # If the chief complaint is explicitly about incontinence or stones, don't filter those.
    allow_incontinence = 'incontinence' in cc or 'leaking' in cc
    allow_stones = 'stone' in cc or 'stones' in cc

    keep_hints = ('cystitis','uti','urinary-tract','urinary tract','nitrites','leukocyte','kidney infection','pyelonephritis','chlamydia','gonorr','urethritis','dysuria')
    drop_hints = ('oedema','swollen ankles','swollen feet','leg swelling','edema')

    kept = []
    maybe = []
    for ev in evidence:
        src = ''
        title = ''
        try:
            src = str(getattr(ev, 'source', '') or '').lower()
        except Exception:
            src = ''
        try:
            title = str(getattr(ev, 'title', '') or '').lower()
        except Exception:
            title = ''
        blob = src + ' ' + title

        # Always drop obvious unrelated edema pages in urinary context
        if any(h in blob for h in drop_hints):
            continue

        # Drop incontinence pages unless complaint is incontinence
        if (('incontinence' in blob) or ('urinaryincontinence' in blob) or ('urinary-incontinence' in blob)) and not allow_incontinence:
            continue

        # Drop bladder stones unless complaint suggests stones
        if ('bladder-stones' in blob or 'bladder stones' in blob) and not allow_stones:
            continue

        if any(h in blob for h in keep_hints):
            kept.append(ev)
        else:
            maybe.append(ev)

    # Prefer urinary-relevant evidence; only keep maybes if we have too few
    if len(kept) >= 3:
        return kept[:5]
    return (kept + maybe)[:5]
# --- End CallCare urinary relevance filter ---

    if not isinstance(protocol, dict):
        return []

    out = []

    # Supportive care
    sc = protocol.get("supportive_care") or []
    if isinstance(sc, list):
        for item in sc[:8]:
            if isinstance(item, dict):
                it = (item.get("item") or "").strip()
                det = (item.get("details") or "").strip()
                if it and det:
                    out.append("{}: {}".format(it, det))
                elif det:
                    out.append(det)
            elif isinstance(item, str) and item.strip():
                out.append(item.strip())

    # Follow-up and safety
    fs = protocol.get("followup_and_safety") or []
    if isinstance(fs, list):
        for item in fs[:8]:
            if isinstance(item, dict):
                it = (item.get("item") or "").strip()
                det = (item.get("details") or "").strip()
                if it and det:
                    out.append("{}: {}".format(it, det))
                elif det:
                    out.append(det)
            elif isinstance(item, str) and item.strip():
                out.append(item.strip())

    # Deduplicate, preserve order
    seen = set()
    cleaned = []
    for x in out:
        x2 = (x or "").strip()
        if not x2:
            continue
        k = x2.lower()
        if k in seen:
            continue
        seen.add(k)
        cleaned.append(x2)

    return cleaned

def build_note(state: CallState) -> NoteDraft:
    disposition, plan, safety = _decision_bits(state)
    ev_mf = _evidence_from_manifest(state)
    ev_dec = _evidence_from_decision(state)

    # Prefer manifest evidence (pathway-specific). Only use RAG to top up if we still have <3 unique items.
    evidence = _merge_evidence(ev_mf, ev_dec, max_total=5)
    # CallCare: apply urinary relevance filter to final evidence
    evidence = _cc_filter_evidence_urinary(state, evidence)

    if len(evidence) < 3:
        ev_rag = _evidence_from_rag(state, max_snips=6)
        evidence = _merge_evidence(evidence, ev_rag, max_total=5)
        # CallCare: apply urinary evidence clamp
        evidence = _cc_filter_urinary_evidence(state, evidence)
        # CallCare: enforce min 3 unique sources
        evidence = _cc_topup_evidence_min3(state, evidence, min_unique=3, max_total=5)

    preg_norm = _sync_pregnancy_from_answers(state)
    preg_sentence = _preg_sentence_from_norm(preg_norm)

    soap_text, err = _generate_llm_soap_with_retry(state, evidence)
    if not soap_text.strip():
        soap_text = f"(NOTE: LLM note generation unavailable: {err})\n"

    # Pregnancy: single canonical placement (last sentence of Subjective) + cleanup elsewhere
    soap_text = _insert_preg_sentence_as_last_subjective_sentence(soap_text, preg_sentence)

    soap_text = _strip_redundant_no_preg_pos_sentence(soap_text, preg_sentence)

    soap_text = _fix_tick_attachment_wording_in_subjective(soap_text)
    # (CallCare) Med protocol injection disabled (RAG/LLM-only)
# Deterministic meds support insertion (RAG-first, clinician-ordered)
    soap_text = _inject_med_support_into_plan(soap_text, state, evidence)

    if getattr(state, "pathway_id", "") == "dvt_possible":
        soap_text = _postprocess_dvt_possible_soap(soap_text)

    allow_otc = (not _is_emergent_disposition(disposition)) and (not _avoid_otc_from_text(plan, soap_text))
    if getattr(state, "pathway_id", "") == "dvt_possible":
        allow_otc = False
    # Patient instructions: derived from decision/safety-net (non-protocol)
    patient_instructions = _build_patient_instructions(disposition, safety, allow_otc)
    # (CallCare) Protocol-derived patient instructions disabled
# --- CALLCARE_STRIP_PREG_SAFETY_PI_V2 ---
    # If pregnancy is explicitly "not pregnant" (or patient answered pregnancy_possible = no), remove generic pregnancy-safety bullet.
    try:
        ps_l = (preg_sentence or "").lower()
        answers = (getattr(state, "symptoms", {}) or {}).get("_answers") or {}
        preg_ans = answers.get("pregnancy_possible")
        preg_no = False
        if isinstance(preg_ans, list):
            preg_no = any(str(x).strip().lower() in ("no", "n") for x in preg_ans)
        elif isinstance(preg_ans, str):
            preg_no = (preg_ans.strip().lower() in ("no", "n"))

        if ("not pregnant" in ps_l) or preg_no:
            patient_instructions = [
                x for x in patient_instructions
                if not str(x).strip().lower().startswith("pregnancy safety:")
            ]
    except Exception:
        pass

    # DVT_PATIENT_INSTRUCTIONS_OVERRIDE
    # For dvt_possible: instructions must be urgent-now (not contingent on worsening), ED/911-forward, and never mention meds.
    if getattr(state, "pathway_id", "") == "dvt_possible":
        patient_instructions = [
            "This needs urgent in-person evaluation today for possible deep vein thrombosis (DVT).",
            "Because this is a phone visit, please go in person today for an exam and testing (typically an ultrasound of the leg).",
            "Go immediately to your local emergency department (or call 911) if you develop chest pain, shortness of breath, coughing up blood, or fainting.",
            "Go immediately to your local emergency department (or call 911) if leg pain or swelling worsens significantly."
        ]


    clinician_questions: List[str] = []
    allergies = getattr(state, "allergies", None)
    if allergies:
        clinician_questions.append(f"Medication allergies: {allergies}")

    risk_flags: List[str] = []
    rf = getattr(state, "red_flags", None)
    if isinstance(rf, list):
        risk_flags = [str(x) for x in rf if str(x).strip()]

    return NoteDraft(
        soap=soap_text,
        patient_instructions=patient_instructions,
        clinician_questions=clinician_questions,
        risk_flags=risk_flags,
        evidence=evidence,
    )


# --- CallCare API shim: finalize.py expects build_note_with_reason ---
def build_note_with_reason(state, *args, **kwargs):
    # Return (note, reason). reason may be None.
    for name in (
        'build_note',
        'build_note_draft',
        'build_note_from_state',
        'build_note_for_state',
    ):
        fn = globals().get(name)
        if callable(fn):
            out = fn(state, *args, **kwargs)
            if isinstance(out, tuple) and len(out) == 2:
                return out
            return out, None
    raise ImportError('No compatible build_note* function found in note_builder.py')
# --- End shim ---

