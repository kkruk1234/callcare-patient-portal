def generate_evidence_queries(state, max_queries: int = 4, trace_fn=None):
    existing = getattr(state, "evidence_search_queries", None)
    if isinstance(existing, list) and len(existing) >= 2:
        return existing[:max_queries]

    def _llm(prompt, model=None, max_output_tokens=200, temperature=0.2, trace_fn=None):
        return _generate_from_prompt(
            prompt,
            model=model,
            max_output_tokens=max_output_tokens,
            temperature=temperature,
            trace_fn=trace_fn,
        )

    qs = _queryonly_generate_evidence_queries(
        state=state,
        llm_generate_fn=_llm,
        model=os.getenv("CALLCARE_QUERY_MODEL", "").strip() or None,
        max_queries=max_queries,
        max_output_tokens=200,
        temperature=0.2,
        trace_fn=trace_fn,
    )

    try:
        setattr(state, "evidence_search_queries", qs)
    except Exception:
        pass

    try:
        if isinstance(getattr(state, "answers", None), dict):
            state.answers["evidence_search_queries"] = qs
    except Exception:
        pass

    try:
        sx = getattr(state, "symptoms", None)
        if isinstance(sx, dict):
            sx["evidence_search_queries"] = qs
            if isinstance(sx.get("_answers"), dict):
                sx["_answers"]["evidence_search_queries"] = qs
    except Exception:
        pass

    return qs


