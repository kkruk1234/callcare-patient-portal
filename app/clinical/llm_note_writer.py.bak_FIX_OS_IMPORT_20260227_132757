def _client_and_model() -> Tuple[OpenAI, str]:
    api_key = os.getenv("OPENAI_API_KEY", "").strip()
    if not api_key:
        raise RuntimeError("OPENAI_API_KEY is not set.")
    client = OpenAI(api_key=api_key)

    model = os.getenv("CALLCARE_LLM_MODEL", "").strip()
    if not model:
        model = "gpt-4.1-mini"
    return client, model


def _generate_from_prompt(prompt: str, system_voice: str, max_output_tokens: int) -> str:
    client, model = _client_and_model()
    resp = client.responses.create(
        model=model,
        input=[
            {"role": "system", "content": system_voice},
            {"role": "user", "content": prompt},
        ],
        temperature=0.2,
        max_output_tokens=max_output_tokens,
    )

    text = getattr(resp, "output_text", None)
    if not text:
        try:
            parts = []
            for o in resp.output:
                for c in getattr(o, "content", []) or []:
                    if getattr(c, "type", "") == "output_text":
                        parts.append(getattr(c, "text", ""))
            text = "\\n".join([p for p in parts if p])
        except Exception:
            text = ""
    return (text or "").strip()


_NUM_RE = re.compile(r"\\d")
_EVID_RE = re.compile(r"^EVID_\\d+$")


def _has_number(s: Any) -> bool:
    if s is None:
        return False
    return bool(_NUM_RE.search(str(s)))


def _normalize_evid_ids(ids: Any) -> List[str]:
    if not ids:
        return []
    out: List[str] = []
    if isinstance(ids, list):
        items = ids
    else:
        items = [ids]
    for x in items:
        s = str(x).strip()
        if _EVID_RE.match(s):
            out.append(s)
    return sorted(list(dict.fromkeys(out)))


def _contains_banned_vague_phrases(text: str) -> bool:
    t = (text or "").lower()
    banned = [
        "as directed",
        "per label",
        "per the label",
        "use cautiously",
        "consider",
        "may help",
        "if appropriate",
        "talk to your doctor",
    ]
    return any(b in t for b in banned)


def _validate_med_object(m: Dict[str, Any]) -> Tuple[bool, List[str]]:
    problems = []
    name = str(m.get("name", "") or "").strip()
    dose = str(m.get("dose", "") or "").strip()
    route = str(m.get("route", "") or "").strip()
    freq = str(m.get("frequency", "") or "").strip()
    dur = str(m.get("duration", "") or "").strip()
    evid = _normalize_evid_ids(m.get("evidence_ids", []))

    if not name:
        problems.append("missing name")
    if not dose or not _has_number(dose):
        problems.append("missing numeric dose")
    if not route:
        problems.append("missing route")
    if not freq:
        problems.append("missing frequency")
    if not dur:
        problems.append("missing duration")
    if not evid:
        problems.append("missing evidence_ids")

    combined = " ".join([
        name, dose, route, freq, dur,
        str(m.get("max_per_day", "") or ""),
        " ".join(m.get("exclusions", []) if isinstance(m.get("exclusions"), list) else [])
    ])
    if _contains_banned_vague_phrases(combined):
        problems.append("contains banned vague phrase")

    return (len(problems) == 0), problems


def _try_parse_json(s: str) -> Optional[Dict[str, Any]]:
    if not s:
        return None
    txt = s.strip()
    start = txt.find("{")
    end = txt.rfind("}")
    if start != -1 and end != -1 and end > start:
        txt = txt[start:end + 1]
    try:
        obj = json.loads(txt)
        return obj if isinstance(obj, dict) else None
    except Exception:
        return None


def _extract_plan_json(guarded_prompt: str) -> Dict[str, Any]:
    out = _generate_from_prompt(
        guarded_prompt,
        system_voice=CALLCARE_PLAN_EXTRACTOR_VOICE,
        max_output_tokens=900,
    )
    obj = _try_parse_json(out)
    if obj is None:
        retry = "RETURN ONLY VALID JSON. NO TEXT.\n\n" + guarded_prompt
        out2 = _generate_from_prompt(
            retry,
            system_voice=CALLCARE_PLAN_EXTRACTOR_VOICE,
            max_output_tokens=900,
        )
        obj = _try_parse_json(out2)

    if obj is None:
        return {
            "first_line_medication": None,
            "alternatives": [],
            "medication_safety_considerations": [],
            "return_precautions": [],
            "testing": [],
            "dosing_not_found": True,
            "notes": "Dosing not found in retrieved evidence (extractor JSON parse failed)."
        }

    obj.setdefault("first_line_medication", None)
    obj.setdefault("alternatives", [])
    obj.setdefault("medication_safety_considerations", [])
    obj.setdefault("return_precautions", [])
    obj.setdefault("testing", [])
    obj.setdefault("dosing_not_found", False)
    obj.setdefault("notes", "")
    return obj


def _validate_and_sanitize_plan(plan: Dict[str, Any]) -> Dict[str, Any]:
    dosing_not_found = bool(plan.get("dosing_not_found", False))
    notes = str(plan.get("notes", "") or "").strip()

    fl = plan.get("first_line_medication", None)
    if isinstance(fl, dict):
        fl["evidence_ids"] = _normalize_evid_ids(fl.get("evidence_ids", []))
        ok, probs = _validate_med_object(fl)
        if not ok:
            dosing_not_found = True
            notes = (notes + " " if notes else "") + f"First-line omitted: {', '.join(probs)}."
            fl = None
    else:
        fl = None

    alts_out: List[Dict[str, Any]] = []
    alts_in = plan.get("alternatives", [])
    if isinstance(alts_in, list):
        for a in alts_in:
            if not isinstance(a, dict):
                continue
            a["evidence_ids"] = _normalize_evid_ids(a.get("evidence_ids", []))
            ok, probs = _validate_med_object(a)
            if ok:
                alts_out.append(a)
            else:
                dosing_not_found = True
                notes = (notes + " " if notes else "") + f"Alternative omitted: {', '.join(probs)}."

    if fl is None and not alts_out:
        dosing_not_found = True
        if not notes:
            notes = "Dosing not found in retrieved evidence."

    def clean_list(items: Any) -> List[Dict[str, Any]]:
        out: List[Dict[str, Any]] = []
        if not isinstance(items, list):
            return out
        seen = set()
        for it in items:
            if not isinstance(it, dict):
                continue
            text = str(it.get("text", "") or "").strip()
            if not text or text in seen:
                continue
            if _contains_banned_vague_phrases(text):
                continue
            seen.add(text)
            out.append({"text": text, "evidence_ids": _normalize_evid_ids(it.get("evidence_ids", []))})
        return out

    msc = clean_list(plan.get("medication_safety_considerations", []))
    rp = clean_list(plan.get("return_precautions", []))
    testing = clean_list(plan.get("testing", []))

    return {
        "first_line_medication": fl,
        "alternatives": alts_out,
        "medication_safety_considerations": msc,
        "return_precautions": rp,
        "testing": testing,
        "dosing_not_found": dosing_not_found,
        "notes": notes,
    }


def _format_plan_for_renderer(plan: Dict[str, Any]) -> str:
    lines: List[str] = []
    if plan.get("dosing_not_found"):
        lines.append("DOSING_NOT_FOUND: true")
        lines.append(f"NOTES: {plan.get('notes') or 'Dosing not found in retrieved evidence.'}")
        return "\\n".join(lines)

    lines.append("DOSING_NOT_FOUND: false")

    fl = plan.get("first_line_medication")
    if isinstance(fl, dict):
        lines.append("FIRST_LINE:")
        lines.append(f"- name: {fl.get('name','')}")
        lines.append(f"  dose: {fl.get('dose','')}")
        lines.append(f"  route: {fl.get('route','')}")
        lines.append(f"  frequency: {fl.get('frequency','')}")
        lines.append(f"  duration: {fl.get('duration','')}")
        if fl.get("max_per_day"):
            lines.append(f"  max_per_day: {fl.get('max_per_day')}")
        exc = fl.get("exclusions", [])
        if isinstance(exc, list) and exc:
            lines.append(f"  exclusions: {exc}")
        lines.append(f"  evidence_ids: {fl.get('evidence_ids',[])}")
    else:
        lines.append("FIRST_LINE: null")

    lines.append("ALTERNATIVES:")
    alts = plan.get("alternatives", [])
    if isinstance(alts, list) and alts:
        for a in alts:
            lines.append(f"- name: {a.get('name','')}")
            lines.append(f"  dose: {a.get('dose','')}")
            lines.append(f"  route: {a.get('route','')}")
            lines.append(f"  frequency: {a.get('frequency','')}")
            lines.append(f"  duration: {a.get('duration','')}")
            if a.get("max_per_day"):
                lines.append(f"  max_per_day: {a.get('max_per_day')}")
            exc = a.get("exclusions", [])
            if isinstance(exc, list) and exc:
                lines.append(f"  exclusions: {exc}")
            lines.append(f"  evidence_ids: {a.get('evidence_ids',[])}")
    else:
        lines.append("- (none)")

    def block(title: str, items: List[Dict[str, Any]]):
        lines.append(title)
        if items:
            for it in items:
                lines.append(f"- {it.get('text','')} (evidence: {it.get('evidence_ids',[])})")
        else:
            lines.append("- (none)")

    block("MEDICATION_SAFETY_CONSIDERATIONS:", plan.get("medication_safety_considerations", []))
    block("RETURN_PRECAUTIONS:", plan.get("return_precautions", []))
    block("TESTING:", plan.get("testing", []))

    return "\\n".join(lines).strip()



def _render_soap(guarded_prompt: str, plan_directives: str) -> str:
    renderer_rules = """
RENDERING RULES (DO NOT VIOLATE):
- Write the SOAP note now.
- SOAP headers exactly: S:, O:, A:, P:
- Subjective narrative prose.
- Objective phone-only; no invented vitals/exam.
- Assessment: working dx + Differential list per prompt.

PLAN RENDERING RULES:
- Render P: using PLAN_DIRECTIVES (authoritative).
- If DOSING_NOT_FOUND is true:
  - State dosing not found in retrieved evidence and defer medication dosing.
  - Do NOT invent dosing.
- If DOSING_NOT_FOUND is false:
  - First-line: ONE option with explicit dose/route/frequency/duration + evidence ids.
  - Alternatives: bullets with explicit dose/route/frequency/duration + evidence ids.

OUTPUT FORMAT (JSON ONLY):
{
  "soap_text": "S: ... O: ... A: ... P: ...",
  "evidence_search_queries": ["query 1", "query 2"]
}
""".strip()

    full_prompt = (
        renderer_rules
        + "\n\nPLAN_DIRECTIVES:\n"
        + (plan_directives or "")
        + "\n\n---\n\n"
        + (guarded_prompt or "")
    )

    enforce = "RETURN ONLY VALID JSON. NO TEXT.\n\n" + full_prompt

    out = _generate_from_prompt(
        enforce,
        system_voice=CALLCARE_NOTE_SYSTEM_VOICE,
        max_output_tokens=1100,
    )

    obj = _try_parse_json(out)
    if obj is None:
        out2 = _generate_from_prompt(
            enforce,
            system_voice=CALLCARE_NOTE_SYSTEM_VOICE,
            max_output_tokens=1100,
        )
        obj = _try_parse_json(out2)
        if obj is None:
            try:
                import json as _json
                return _json.dumps({"soap_text": (out2 or out or "").strip(), "evidence_search_queries": []})
            except Exception:
                return out2 or out

    obj.setdefault("soap_text", "")
    obj.setdefault("evidence_search_queries", [])
    try:
        import json as _json
        return _json.dumps(obj)
    except Exception:
        return out


def generate_note(state: CallState, evidence: List[EvidenceRef]) -> str:
    base_prompt = build_prompt(state, evidence)

    sx = getattr(state, "symptoms", None) or {}
    ans = {}
    if isinstance(sx, dict):
        a = sx.get("_answers", {})
        if isinstance(a, dict):
            ans = dict(a)

    allergies_val = ""
    if isinstance(ans.get("allergies"), str):
        allergies_val = ans.get("allergies")
    elif getattr(state, "allergies", None) is not None:
        allergies_val = str(getattr(state, "allergies"))
    allergies_norm = allergies_val.strip().lower()
    if allergies_norm in ("no", "none", "nope", "n"):
        allergies_norm = "none"
    if allergies_norm:
        ans["allergies"] = allergies_norm

    answered_lines = []
    for key in sorted(ans.keys()):
        answered_lines.append("- " + str(key) + ": " + str(ans.get(key)))
    answered_block = "\\n".join(answered_lines) if answered_lines else "(none)"

    guard = (
        "CRITICAL RULES (DO NOT VIOLATE):\\n"
        "- You may ONLY state symptoms, negatives, history, or treatments that are explicitly present in the structured answers provided below.\\n"
        "- If something was not asked, you MUST NOT state or imply it.\\n"
        "- Do NOT infer typical findings. Do NOT invent negatives.\\n"
        "- Allergy phrasing rule:\\n"
        "  - If allergies == 'none' or empty: you may say 'No known drug allergies.'\\n"
        "  - If allergies is non-empty: list the allergy(ies) plainly and DO NOT say 'no known allergies.'\\n"
    )

    guarded_prompt = guard + "\\n\\nANSWERED_FIELDS (anything not listed here was NOT ASKED):\\n" + answered_block + "\\n\\n" + base_prompt

    extracted = _extract_plan_json(guarded_prompt)
    validated = _validate_and_sanitize_plan(extracted)
    directives = _format_plan_for_renderer(validated)
    
    # CALLCARE_NOTE_QUERY_WIRING
    raw = _render_soap(guarded_prompt, directives)

    def _coerce_to_dict(x):
        if x is None:
            return None
        if isinstance(x, dict):
            return x
        try:
            if hasattr(x, "model_dump"):
                d = x.model_dump()
                return d if isinstance(d, dict) else None
        except Exception:
            pass
        try:
            d = dict(x)
            return d if isinstance(d, dict) else None
        except Exception:
            return None

    try:
        obj = _try_parse_json(raw)
        if isinstance(obj, dict):
            qs = obj.get("evidence_search_queries")
            qs2 = []
            if isinstance(qs, list):
                for q in qs:
                    q = str(q).strip()
                    if q:
                        qs2.append(q)
            qs2 = qs2[:4]

            if qs2:
                try:
                    setattr(state, "evidence_search_queries", qs2)
                except Exception:
                    pass

                try:
                    st_ans = getattr(state, "answers", None)
                    if isinstance(st_ans, dict):
                        st_ans["evidence_search_queries"] = qs2
                except Exception:
                    pass

                try:
                    sx0 = getattr(state, "symptoms", None)
                    sx = _coerce_to_dict(sx0)
                    if isinstance(sx, dict):
                        sx["evidence_search_queries"] = qs2
                        a = sx.get("_answers")
                        if isinstance(a, dict):
                            a["evidence_search_queries"] = qs2
                            sx["_answers"] = a
                        try:
                            setattr(state, "symptoms", sx)
                        except Exception:
                            pass
                except Exception:
                    pass

            st = obj.get("soap_text")
            if isinstance(st, str) and st.strip():
                return st.strip()
    except Exception:
        pass

    return raw
# Back-compat exports
def generate_llm_note(state: CallState, evidence: Optional[List[EvidenceRef]] = None) -> str:
    return generate_note(state, evidence or [])

def write_llm_note(state: CallState, evidence: Optional[List[EvidenceRef]] = None) -> str:
    return generate_note(state, evidence or [])

def create_llm_note(state: CallState, evidence: Optional[List[EvidenceRef]] = None) -> str:
    return generate_note(state, evidence or [])

def create_note_text(state: CallState, evidence: Optional[List[EvidenceRef]] = None) -> str:
    return generate_note(state, evidence or [])

def generate_note_text(prompt_or_state: Union[str, CallState], evidence: Optional[List[EvidenceRef]] = None) -> str:
    if isinstance(prompt_or_state, str):
        # Keep compatibility: prompt-only free text generation uses physician voice
        return _generate_from_prompt(prompt_or_state, system_voice=CALLCARE_NOTE_SYSTEM_VOICE, max_output_tokens=900)
    return generate_note(prompt_or_state, evidence or [])
