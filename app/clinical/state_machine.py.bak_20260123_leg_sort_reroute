def _pick_pathway(chief: str, state: Optional[CallState] = None) -> Dict[str, Any]:
    """
    Deterministic routing first, then fallback keyword scoring from YAML (very minimal).
    """
    chief_l = _norm(chief)

    # ---------------------------------------------------------
    # RED_SWOLLEN_LEG_SORT_ROUTING_V1
    # If the chief complaint sounds like unilateral red/swollen leg/calf/foot,
    # route to the sorter pathway FIRST (do NOT auto-label cellulitis).
    # ---------------------------------------------------------
    leg_words = ["leg", "calf", "shin", "ankle", "foot", "toe", "one leg", "unilateral"]
    inflam_words = ["red", "redness", "swollen", "swelling", "warm", "hot", "tender", "pain", "painful"]

    # Strong leg signal + inflammation signal
    if (any(w in chief_l for w in leg_words)
        and (("red" in chief_l) or ("redness" in chief_l))
        and (("swollen" in chief_l) or ("swelling" in chief_l) or ("warm" in chief_l) or ("tender" in chief_l) or ("pain" in chief_l))):
        return {"id": "red_swollen_leg_sort", "score": 999}

    # If they literally say DVT/clot with leg swelling, go straight to DVT pathway
    if any(k in chief_l for k in ["dvt", "blood clot", "clot in my leg", "deep vein thrombosis"]):
        return {"id": "dvt_possible", "score": 999}

    # ---------------------------------------------------------
    # Existing guards (kept) — but we must NOT steal leg cases
    # ---------------------------------------------------------

    # CELLULITIS_ROUTING_GUARD_V4_RED_SWOLLEN_LIMB
    # Catch classic SSTI/cellulitis patient phrasing that omits the word "infection":
    # e.g., "red and swollen hand", "red swollen finger", "arm is red and swollen"
    limb_words = [
        "hand","finger","thumb","wrist","arm","forearm","elbow",
        # NOTE: leg/calf/foot/etc intentionally removed so those go to the sorter
    ]
    pain_warm_words = ["warm","hot","tender","pain","painful","sore","aching","throbbing"]

    if "cellulitis" in chief_l:
        return {"id": "cellulitis", "score": 999}

    # Strong signal: upper-limb + red + swollen
    if any(w in chief_l for w in limb_words) and all(w in chief_l for w in ["red","swollen"]):
        return {"id": "cellulitis", "score": 999}

    # Slightly looser: upper-limb + (redness) + (swelling)
    if any(w in chief_l for w in limb_words) and (("redness" in chief_l) or ("red" in chief_l)) and (("swelling" in chief_l) or ("swollen" in chief_l)):
        return {"id": "cellulitis", "score": 999}

    # Also allow: upper-limb + (red) + (warm/hot/tender/painful)
    if any(w in chief_l for w in limb_words) and (("red" in chief_l) or ("redness" in chief_l)) and any(w in chief_l for w in pain_warm_words):
        return {"id": "cellulitis", "score": 999}

    # CELLULITIS_ROUTING_GUARD_V2
    if any(k in chief_l for k in [
        "cellulitis", "skin infection", "infected skin", "infected cut", "infected wound",
        "spreading redness", "redness spreading", "red and warm", "warm and swollen",
        "hot and swollen", "red swollen painful", "infected bite"
    ]):
        return {"id": "cellulitis", "score": 999}

    # DYSURIA_TOP_GUARD_V1
    if (("burn" in chief_l or "burning" in chief_l or "burns" in chief_l)
        and any(k in chief_l for k in ["pee", "peeing", "urinate", "urinating", "urination", "when i pee", "when i urinate"])):
        return {"id": "dysuria_uti", "score": 999}

    # --- (rest of your existing routing file stays the same) ---

    # [SNIP: everything below is unchanged from your pasted file except we removed the old
    # generic DVT suspicion line because sorter handles leg complaints early.]

    # Rib pain after fall
    if (any(k in chief_l for k in ["rib", "ribs"])
        and any(k in chief_l for k in ["hurt when i breathe", "hurts when i breathe", "deep breath", "take a deep breath", "breathing"])
        and any(k in chief_l for k in ["fell", "fall", "tripped", "hit", "injury"])):
        return {"id": "rib_pain_after_fall", "score": 999}

    # Contact-lens red eye
    if any(k in chief_l for k in ["contact lens", "contact lenses", "contacts"]) and any(k in chief_l for k in ["red eye", "red", "painful", "eye pain"]):
        return {"id": "contact_lens_red_eye", "score": 999}

    # Splinter/foreign body in skin
    if any(k in chief_l for k in ["splinter", "thorn", "glass", "foreign body"]) and any(k in chief_l for k in ["foot", "hand", "finger", "skin"]):
        return {"id": "skin_splinter_foreign_body", "score": 999}

    # New medication causing nausea
    if (any(k in chief_l for k in ["started a new", "new pill", "new medicine", "new medication"])
        and any(k in chief_l for k in ["nausea", "nauseated", "feel sick", "vomit", "vomiting"])):
        return {"id": "nausea_after_new_med", "score": 999}

    # Relationship distress
    if any(k in chief_l for k in ["partner", "husband", "wife", "boyfriend", "girlfriend", "marriage", "relationship"]) and any(k in chief_l for k in ["fighting", "argument", "breakup", "divorce", "conflict"]):
        return {"id": "relationship_distress_noncrisis", "score": 999}

    # Caregiver stress
    if any(k in chief_l for k in ["caregiver", "caregiving", "taking care of", "caring for"]) or any(k in chief_l for k in ["dementia", "alzheim"]):
        return {"id": "caregiver_stress_noncrisis", "score": 999}

    # Work stress / burnout
    if any(k in chief_l for k in ["burnout", "burned out", "overwhelmed at work", "work stress", "job stress", "stressed at work", "can't cope at work", "exhausted from work"]):
        return {"id": "work_stress_burnout_noncrisis", "score": 999}

    # ... keep your direct map list exactly as-is ...
    direct = [
        (["palpitations", "irregular heartbeat", "heart flutter", "heart racing", "skipping beats"], "atrial_fibrillation_possible"),
        (["blood pressure is high", "bp is high", "high blood pressure", "hypertension crisis"], "hypertensive_urgency"),
        (["sudden shortness of breath", "pain with breathing", "pleuritic", "coughing up blood", "coughing blood"], "pulmonary_embolism_possible"),
        (["heart failure", "worse when lying flat", "waking up gasping", "swelling legs", "leg swelling"], "heart_failure_exacerbation"),
        (["low blood sugar", "hypoglycemia", "shaky and sweaty", "sweaty and shaky"], "hypoglycemia_possible"),
        (["missed dialysis", "high potassium", "kidney failure", "dialysis missed"], "hyperkalemia_possible"),
        (["alcohol withdrawal", "stopping drinking", "quit drinking", "cut down alcohol", "shaky after stopping alcohol"], "alcohol_withdrawal_mild"),
        (["opioid withdrawal", "stopping opioids", "stopped opioids", "withdrawal from fentanyl", "withdrawal from oxycodone", "stopping pain pills"], "opioid_withdrawal_mild"),
        (["can't hold urine", "cant hold urine", "leaking urine", "urine leakage", "wetting myself", "new incontinence"], "urinary_incontinence_new"),
        (["itching all over", "itchy all over", "itching without rash", "itching everywhere", "generalized itching"], "pruritus_generalized_no_rash"),
        (["grief", "bereavement", "mourning", "can't cope after loss", "cant cope after loss"], "grief_adjustment_noncrisis"),
        (["ptsd", "flashbacks", "nightmares", "hypervigilant", "triggered by trauma"], "ptsd_symptoms_noncrisis"),
        (["can't stop using", "cant stop using", "drug use", "drinking too much", "substance problem", "alcohol problem"], "substance_use_concern_noncrisis"),
        (["dysuria", "uti", "burning urination", "burning when i pee", "painful urination", "urinary urgency", "urinary frequency"], "dysuria_uti"),
        (["vomit", "vomiting", "nausea", "throwing up", "emesis"], "nausea_vomiting"),
        (["diarrhea", "loose stool", "watery stool", "gastroenteritis"], "diarrhea"),
        (["ear pain", "earache", "otitis", "swimmer's ear"], "ear_pain"),
        (["pink eye", "conjunctivitis", "red eye", "eye discharge"], "red_eye"),
        (["back pain", "low back", "sciatica", "lumbar"], "low_back_pain"),
        (["sore throat", "throat pain", "strep"], "sore_throat"),
        (["cough", "runny nose", "congestion", "cold", ], "cough_uri"),
        (["rash", "skin infection", "cellulitis", "impetigo"], "rash_skin_infection"),
        (["abdominal pain", "belly pain", "stomach pain"], "abdominal_pain"),
        (["headache", "migraine", "worst headache", "thunderclap"], "headache"),
        (["med refill", "refill", "renew medication", "prescription renewal"], "med_refill"),
    ]

    for keys, pid in direct:
        if any(k in chief_l for k in keys):
            return {"id": pid, "score": 999}

    # Fallback: minimal keyword scoring from YAML `match:any_keywords: [...]`
    best = ("cough_uri", 0)
    if PATHWAYS_DIR.exists():
        for fp in PATHWAYS_DIR.glob("*.yaml"):
            raw = fp.read_text(encoding="utf-8", errors="ignore")
            pid = ""
            kws: List[str] = []
            for line in raw.splitlines():
                s = line.strip()
                if s.startswith("id:"):
                    pid = s.split(":", 1)[1].strip()
                if "any_keywords:" in s and "[" in s and "]" in s:
                    inside = s.split("[", 1)[1].rsplit("]", 1)[0]
                    parts = [p.strip().strip('"').strip("'") for p in inside.split(",") if p.strip()]
                    kws.extend([p.lower() for p in parts if p])
            if not pid:
                continue
            score = sum(1 for k in kws if k and k in chief_l)
            if score > best[1]:
                best = (pid, score)

    return {"id": best[0], "score": best[1]}


